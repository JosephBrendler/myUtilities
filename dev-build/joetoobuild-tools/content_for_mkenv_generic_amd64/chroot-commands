# note: it is essential to clear the environment when chrooting,
# else the chroot inherits livecd's and fails to set it up properly,
# so that (for example) /usr/sbin will be in the PATH
env -i chroot /mnt/gentoo /bin/bash
source /etc/profile
export PS1="(chroot) $PS1"


# consider adopting a more explicit chroot command:
## construct an explicit chroot command to tightly control the environtment
## fresh environment for the chroot (zero out the livecd's environment)
#chroot_cmd=( env -i )
## set up root user for new environment
chroot_cmd+=( USER=root HOME=/root LOGNAME=root SHELL=/bin/bash )
chroot_cmd+=( TERM="$TERM" )       # ensure the terminal will function
chroot_cmd+=( PATH=/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin ) # minimal complete pa>
chroot_cmd+=( chroot "${newroot_mountpoint%/}" /bin/bash --login )
"${chroot_cmd[@]}"

source /etc/profile
export PS1="(chroot) $PS1"
