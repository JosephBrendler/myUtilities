    right_status $? "$notice" || FLAGGED=$TRUE

    [ $FLAGGED ] && return 1
    return 0
}

maybe-activate-swap() {
    local result=0 msg="" swap_dev_or_file=""
    local -a swap_devices=()
    # if the system does not have it, then set up swap - again most important for resource constrained systems
    # check if /proc/swaps has more than 1 line (the header row)
    d_do 'echo "running swapon --show"; swapon --show' "$debug"
#    if [ "$(wc -l < /proc/swaps)" -gt 1 ]; then
    if swapon --noheadings --show | read ; then
        j_msg "-${notice}" -p "System already has swap set up; continuing"
    else
        # if the build target has swap set up - use it now
        j_msg "-${notice}" -p "Discovering swap device ..."
        # read id of all swap block devs from blkid
        readarray -t swap_devices < <(blkid -t TYPE=swap -o device)
        # guard against activating the wrong one if multiple
        j_msg "-${debug}" -p "\${#swap_devices[@]}: ${#swap_devices[@]}"
        d_do 'printf "%s\n" "${swap_devices[@]}"' "$debug"
        case "${#swap_devices[@]}" in
            0 ) j_msg "-${info}" -p "no swap lv found" ;; # ok - make swapfile
            1 ) swap_dev_or_file="${swap_devices[0]}"
                j_msg "-${info}" -p "assigned swap device: [$swap_dev_or_file]" ;;
            * ) j_msg "-${err}" -p "ambiguous swap state"
                blkid -t TYPE=swap -o export | sed 's|^|    |'
                j_msg "-${warn}" -p "${BYon}Note: ${Boff}you will need to choose a device and manually run ${BGon}swapon ${BMon}<device>${Boff}."
                msg="${BGon}lsblk -f${Boff} or ${BGon}lsblk ${BMon}-p --inverse ${BCon}<device>${Boff} may be helpful."
                j_msg "-${warn}" -p "$msg"
                msg="Then resume ${BGon}${PN}${Boff} wtth the ${BMon}-r${Boff} flag (choose skip this step),"
                msg+=" or use the ${BMon}-<stepnumber>${Boff} flag, to continue"
                j_msg "-${warn}" -p -n "$msg"; j_msg "-${warn}" -mp ""
                die "could not determine swap device to activate" ;;
        esac
        # check if block above did not pick a device to activate
        if [ -z "$swap_dev_or_file" ]; then
            # create swap directory
            local newswap_dir="${newroot_mountpoint%/}/var/cache/swap"
            mkdir -p "${newswap_dir}"
            # create swap file
            local newswapfile="${newswap_dir%/}/swap1"
            j_msg "-${notice}" -p "creating swap file"
            dd if=/dev/zero of="${newswapfile}" bs=4M count=1024 status=progress
            swapsize=$(stat -c '%s' "${newswapfile}")
            [[ "$swapsize" -ge $((4 * 1024 * 1024 * 1024 )) ]] ; result=$?
            j_msg "-${notice}" -p "done creating swap file; result:"
            handle_result $result "${newswapfile##*/} $swapsize" "" "$notice" || \
                j_msg "-${warn}" -p "${BYon}warning:${Boff} failed to create swap file"
            if [ $result -eq 0 ] ; then
                j_msg "-${notice}" -p "formatting swap file"
                chmod 600 "${newswapfile}" && mkswap "${newswapfile}" ; result=$?
                handle_result $result "" "" "$notice" || \
                    j_msg "-${warn}" -p "${BYon}warning:${Boff} failed to format swap file"
            fi
            [ $result -eq 0 ] && swap_dev_or_file="$newswapfile"
        fi
        # now activate the swap device or file if there is one
        if [ -n "$swap_dev_or_file" ]; then
            j_msg "-${notice}" -p -n "activating swap device or file"
            swapon "$swap_dev_or_file"
            handle_result $? "activated swap on [$swap_dev_or_file]" "" "$notice" || \
                j_msg "-${warn}" -p "failed to activate swap on [$swap_dev_or_file]"
        else
            j_msg "-${warn}" -p "no usable swap device or swap file available"
        fi
    fi   # swap on yet?
}

# removed sync-repo in this non-crossbuilding scenario.  Run it in chroot
populate_repo() {
    local result=0
    # (re)populate a sync-type = git repository in the ${newroot_mountpoint}
    # remove it if it already exists and recreate
    local REPO="$1"
    local git_target="${newroot_mountpoint%/}/var/db/repos/${REPO}"
    local -a git_cmd=( git  clone )
    local sync_uri=""

    j_msg "-${debug}" -p "REPO: [$REPO]"
    j_msg "-${notice}" -p -n "checking for pre-existing repo"
    [[ ! -d "${newroot_mountpoint%/}/var/db/repos/${REPO}" ]]
    handle_result $? "will create" "will remove and re-create" "$notice"
    local propagated_result=$?
    if [ ! $propagated_result -eq 0 ]; then
        j_msg "-${notice}" -p -n "sanitizing previous content"
        rm -rf "${newroot_mountpoint%/}/var/db/repos/${REPO}"
        handle_result $? "removed" "" "$notice" || die "failed to remove pre-existing repo [$REPO]"
    fi
    j_msg "-${notice}" -p -n "creating directory for repository [$REPO]"
    mkdir -p "${newroot_mountpoint%/}/var/db/repos/${REPO}"
    handle_result $? "created" "" "$notice" || die "failed to mkdir -p ${newroot_mountpoint%/}/var/db/repos/${REPO}"
    case "$REPO" in
        gentoo) sync_uri="https://github.com/gentoo-mirror/gentoo.git" ;;
        joetoo) sync_uri="https://github.com/JosephBrendler/joetoo.git" ;;
        *     ) die "invalid REPO in ${FUNCNAME[0]}" ;;
    esac

    # for resource constrained systems, the following optimizations are very important
    git_cmd+=( --depth 1 )          # limit depth to just the most recent commit
    git_cmd+=( --single-branch )    # get only default branch (ignore e.g. experimental or development)
    git_cmd+=( --config pack.windowMemory=100m )     # limit memory used by delta compression
    git_cmd+=( --config pack.packSizeLimit=100m )
    git_cmd+=( --config core.bigFileThreshold=100m ) # dont bother wasting RAM compressing if this big - write to disk

    # for powerful systems, use -j for some parallelism
#    git_cmd+=( -j "$(nproc)" )

    # complete the command; use --progress to force progress output (goes to stderr). redirect on actual cmdline, to stdout
    git_cmd+=( --progress "${sync_uri}" "${git_target}" )

    # execute command to clone repository
    j_msg "-${notice}" -p "cloning repository [$REPO]"
    if [ $DEBUG ] || [[ "$verbosity" -gt "$info" ]]; then
        "${git_cmd[@]}" 2>&1
    else
        # tr CR LF to just CR to compress output to just one line (ugly - dont do this)
        "${git_cmd[@]}" 2>&1
    fi; result=$?
    echo
    j_msg "-${notice}" -p "done cloning repository [$REPO]; result"
    handle_result $result '' '' "$notice" || return 1
    return 0
}

