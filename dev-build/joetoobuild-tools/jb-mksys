# This script needs you to provide this header and its _compat and _unicode helpers
#   in the /usr/sbin/ directory of your build system (likely a livecd, wherein your newroot_mountpoint=/mnt/gentoo)
# This script itself will install these in the target system -- in ${newroot_mountpoint%/}/usr/sbin/
#   as part of install_files (mkenv) phase, so the finalize-chroot-sys script can find them after chroot
# IMPORTANT: to get this working, copy all three to the livecd's /usr/sbin/ --
#   script_header_joetoo
#   script_header_joetoo_compat
#   script_header_joetoo_unicode
# IMPORTANT: also copy script_header_joetoo_extended to /usr/sbin to enable its run_array() functionality
# to /usr/sbin (where the script expects the header, and where the header expects its helpers to be)

#-----[ pre-requisite function ]------------------------------------------------------------------------------------

install_script_headers() {
    # script headers are needed in the livecd and target filesystems PATH
    local target="${1%/}"   # normalize w/o trailing /
    # guard - refuse to proceed if target dir (or link to dir) does not exist
    # (should be present on livecd and on target system after stage3 is extracted)
    echo "checking if target dir [$target] exists"
    [ -d "$target" ] || return 1
    # cover all four headers in comments above
    local -a headers=(
        "script_header_joetoo"
        "script_header_joetoo_compat"
        "script_header_joetoo_unicode"
        "script_header_joetoo_extended"
    )
    local header_url="https://raw.githubusercontent.com/JosephBrendler/myUtilities/master/dev-util/script_header_joetoo"
    local dest perms
    # iterate in nested for loops each suffix for each tartet
    for header in "${headers[@]}"; do
        dest="${target}/${header}"
        # skip this header (continue) if it is already downloaded and sourceable in this target and has proper syntax
        echo -n "Is $header already installed w proper syntax?"
        if [[ "$header" == "script_header_joetoo" ]] ; then
            # check script_header_joetoo for POSIX syntax compliance
            if [ -r "${dest}" ] && sh -n "${dest}" ; then
                echo " (yes; ok to continue)"
                continue
            else
                echo " (no: will install)"
            fi
        else
            # check other headers for bash syntax
            if [ -r "${dest}" ] && bash -n "${dest}" ; then
                echo " (yes; ok to continue)"
                continue
            else
                echo " (no: will install)"
            fi
        fi
        # no form of download to temp file and do safe write works with cp -f, mv, nor install
        # (livecd overlayfs + tmpfs layers complains about all with "cannot remove"  and "stale file handle" errors
        # (so download directly and verify)
        # wget flags for one line progress bar and output to file:
        #   --progress=bar:force - when the output is not a TTY, the progress bar always falls back to "dot"
        #   --show-progress - force wget to display the progress bar in any verbosity
        #   -O - output to file'  --timeout and --tries limitted to prevent hangs
        echo "downloading ${header} ->  ${dest}"
        wget -q --progress=bar:force --show-progress --timeout=20 --tries=3 \
            "${header_url}/${header}" \
            -O "${dest}" || return 2
        # confirm the download apears valid
        echo -n "validating shell syntax in $dest"
        if [[ "$header" == "script_header_joetoo" ]] ; then
            # check script_header_joetoo for POSIX syntax compliance
            sh -n "$dest"
            if [ $? -eq 0 ]; then echo " (ok)"; else echo " (fail)"; return 3; fi
        else
            # check script_header_joetoo for Bash syntax compliance
            bash -n "$dest"
            if [ $? -eq 0 ]; then echo " (ok)"; else echo " (fail)"; return 3; fi
        fi
        # ensure proper permissions are set (644 is good for sourced files; dont need x)
        echo -n "checking permissions on $dest"
        perms=$(stat -c '%a' "$dest" 2>/dev/null)
        if [[ "$perms" == "644" ]] ; then
            echo " (ok: $perms)"
        else
            echo -n "(wrong: $perms; resetting)"
            chmod 644 "$dest"
            if [ $? -eq 0 ]; then echo " (ok)"; else echo " (fail)"; return 4; fi
        fi
        done
}

report_script_header_install_results() {
    local result="$1"
    case $result in
        0) echo "install_script_headers completed successfully" ;;
        1) echo "install_script_headers failed because target dir does not exist" ;;
        2) echo "install_script_headers failed to wget header for target as shown" ;;
        3) echo "install_script_headers failed to validate syntax of downloaded header as shown" ;;
        4) echo "install_script_headers failed to set permissions on header in target as shown" ;;
        *) echo "install_script_headers failed for unknown reason [$result]" ;;
    esac
    # propagate the script header function exit status
    return $result
}

# Note: legacy version wrote to /usr/sbin and stuggled with overlayfs issues
#   put ${JOETOO_HEADER_DIR} in the PATH instead, and install there
install_script_headers "${JOETOO_HEADER_DIR}"; result=$?
