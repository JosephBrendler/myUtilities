    fi
    j_msg "-${notice}" -p -n "done downloading .DIGESTS file; result:"
    handle_result $result '' '' "$notice" || FLAGGED=$TRUE
    if [ "$DEBUG" ] || [ "$verbosity" -ge "$info" ] ; then
        j_msg "-${notice}" -p "running wget ${target_url}.asc ..."
        wget --progress=bar:force --show-progress "${target_url}.asc"; result=$?
    else
        j_msg "-${notice}" -p "running wget to download pgp signature file from target_url ..."
        wget -q --progress=bar:force --show-progress "${target_url}.asc"; result=$?
    fi
    j_msg "-${notice}" -p -n "done downloading pgp signature file; result:"
    handle_result $result '' '' "$notice" || FLAGGED=$TRUE
    [ $FLAGGED ] && return 1
    return 0
}

check-date-time() {
    # if no input was provided, show and check the current time
    if [ -z "$1" ]; then
        j_msg "-${notice}" -p "${BWon}Check current UTC system date/time shown below${Boff}"
        j_msg "-${notice}" -mp -n "${BCon}"; date -u | sed 's|^|    |' ; j_msg "-${notice}" -mp "${Boff}"
    else
        j_msg "-${notice}" -p "${BWon}Check proposed UTC system date/time shown below${Boff}"
        j_msg "-${notice}" -mp -n "${BCon}"; date -u -d "$1" | sed 's|^|    |' ; j_msg "-${notice}" -mp "${Boff}"
    fi
    j_msg "-${notice}" -p "${BWon}(${BMon}Hint:${Boff} verify with ${BGon}date -u${BWon})${Boff} on another system"
    answer="" # global
    yn_prompt "${BWon}Is this correct? ${Boff}"
    case "$answer" in
        y) return 0 ;;
        n) return 1 ;;
    esac
}

set-date-time() {
    local input="" msg="" placeholder=""
    local APPROVED=$FALSE
    # first ask user if the *current time is already valid
    if check-date-time; then APPROVED=$TRUE; fi
    while [ ! $APPROVED ]; do
        msg="    ${BWon}Enter a valid date/time; (format: '${BCon}YYYY-MM-DD HH:MM:SS [AM|PM] [TZ]${BWon}'):${Boff} "
        j_msg -u -mp -n "$msg"
        # generate a valid placeholder based on the current machine's current time
        placeholder="$(date -u +'%Y-%m-%d %H:%M:%S UTC')"

        # -e enables arrow keys, -i pre-fills the line with editable placeholder
        read -e -i "$placeholder" -r input

        # quick guard against malformed input
        if [ ${#input} -lt 8 ]; then
            j_msg "-${err}" -m "${BRon}Error${Boff}Input [$input] is too short (malformed)${Boff}"
            continue  # skip validation and loop to get new input
        fi
        # more thorough input validation
        if ! date -d "$input" +"%Y-%m-%d %H:%M:%S" &>/dev/null; then
            j_msg "-${err}" -m "${BRon}Error${Boff}Improperly formatted input [$input]${Boff}"
            continue  # skip validation and loop to get new input
        fi
        # force the input to start with exactly 4 digits followed by a dash (e.g., 2026-)
        # yes, I know it is a Y3K bug... sorry; given 974 years to fix it, I prefer it to ^[0-9]{4}
        if [[ ! "$input" =~ ^2[0-9]{3}- ]]; then
            j_msg "-${err}" -m "${BRon}Error${Boff} Year must be exactly 4 digits (e.g., YYYY-MM-DD)${Boff}"
            continue
        fi
        if check-date-time "$input"; then APPROVED=$TRUE; fi
    done
    # if there is input; then having passed validation and user-acceptance, set the time; else accept current time
    if [ -n "$input" ]; then
        j_msg "-${notice}" -p -n "Setting datetime ..."
        date -s "$input" &>/dev/null
        handle_result $? "$(date -u +'%Y-%m-%d %H:%M:%S UTC')" '' "$notice" || die "failed to set date"
    fi
}

# to_do: migrate this to script_header_joetoo_extended
# (it should enable bash array/run_array scripts to continue using the POSIX process_cmdline functions
#  because it should override the definition of this function in script_header_joetoo by being loaded AFTER)
_get_entry() # (BASH) get human readable description for command sequence step number
{ ge_ret=0; if ! isint "$1"; then j_msg -${err} "error: zero args; _get_desc requires $1 step number"; return 1; fi
  _ge_raw_cmd="${command_sequence[${1}]}"  # the actual command
  _ge_desc="${msg1_sequence[${1}]}"  # human readable description
  _ge_clean_cmd=$(printf -- '%b' "$_pa_cmd" | strip_ansi | _translate_escapes)
#  j_msg -${debug} "_ge_entry: $_ge_entry"
#  j_msg -${debug} "_ge_desc: $_ge_desc"
  case $2 in
    1 ) printf '%s' "$_ge_desc" ;;
    2 ) printf '%s' "$_ge_clean_cmd" ;;
    3 ) printf '%s' "$_ge_raw_cmd" ;;
    * ) j_msg -${err} "invalid format [$2]"; ge_ret=1
  esac
  unset -v _ge_entry _ge_desc _ge_raw_cmd _ge_clean_cmd
  return $ge_ret
}
# @usage _get_entry <step_number> <format_type>
# @args $1 (int) the 0-indexed step number to retrieve from the command sequence
# @args $2 (int) format type: 1=description, 2=cleaned command, 3=raw command
# @vars cmd_seq_file (global) path to the temporary command sequence file
# @vars US (global) Unit Separator character used as the delimiter
# @vars ret (global) initialized to 0 for exit status tracking
# @deps isint, j_msg -${err}, sed, printf, strip_ansi, _translate_escapes
# @rule extracts specific lines from the command sequence file and parses by $US delimiter
# @ret 0 on success (prints requested string to stdout); 1 on invalid arguments
# @note uses _ge_ prefix for local variables; unsets all before returning
# @note format 2 uses strip_ansi and _translate_escapes for log-safe output

parse_commandline() {
  j_msg "-${debug}" -p "in ${FUNCNAME[0]}"
  local args=()
  local msg
  local _pc_arg=""
  # early-exit guard max cmdline is - jping <tgtlst> -c d -p 1 -P -j 2 -W 1 -t 1 -f
  if [ $# -gt 3 ] ; then j_msg "-${err}" "too many [$#] args [$*]"; my_usage; exit 1; fi
  # guard - early return no action if no args
  if [ $# -eq 0 ] ; then j_msg "-${info}" "zero [$#] args [$*] (ok)"; return 0; fi
  # guard - null arg $1 is invalid
  if [ -z "$1" ] ; then j_msg "-${err}" "\$1 is null [$1]"; my_usage; exit 1; fi

  # pre-define a dynamic macro for adjusting verbosity (used by script_header_joetoo's _pc_action_verbosity
  # usage example: _pc_operator="+"; eval "$_pc_adjust_verbosity"
  _pc_adjust_verbosity="verbosity=\$(( verbosity \${_pc_operator} 1 ))"

  j_msg "-${debug}" -p "${BYon}top of ${FUNCNAME[0]}; cmdline${Boff}: [$*]"
  j_msg "-${debug}" -p "\$#: [$#]"
  j_msg "-${debug}" -p "\$1: [$1]"
  # parse command line (validate any $2 arg requested by $1 before assigning
  # ($2 must exist, which is not the case if $1 was the last arg,
  #  and $2 must not be an option - must not start with '-' )
  while [ $# -gt 0 ] ; do
    j_msg "-${debug}" -p "top of while loop: \$1: [$1]"
    if [[ "$1" == "--" ]]; then
        # '--' indicates "end of options; all else is arguments"
        args+=("$@"); break;
    fi
    # strip first char(s) if leading - or --, and process the rest
    # (recursively if needed for compound art in * case below)
    _pc_arg="$1"
    if [ "${_pc_arg:0:1}" = "-" ] ; then
       _pc_arg="${_pc_arg#?}"   # strip shortest match for ? (any single char) from prefix
       j_msg "-${debug}" -p "stripped - so new _pc_arg: $_pc_arg"
    fi
    if [ "${_pc_arg:0:1}" = "-" ] ; then
       _pc_arg="${_pc_arg#?}"   # strip shortest match for ? (any single char) from prefix
       j_msg "-${debug}" -p "stripped another - so new _pc_arg: $_pc_arg"
    fi
    j_msg "-${debug}" -p "${BYon}parsing parameter${Boff}: [$_pc_arg] of ${BYon}existing cmdline${Boff} [$*]"
    case "$_pc_arg" in
      r|resume )   # .............................. # resume script at saved next step
            j_msg -${debug} "pa -[rR]): [running _pc_action_resume], shifting 2";
            _pc_action_resume;     # use bash equiv ov script_header_joetoo's _pc_action_resume helper
            shift
        ;;
      *[0-9]*)
            j_msg -${debug} "pa 0-9)  with $_pc_arg";
            if isint "$_pc_arg"; then
                _pc_action_number "$_pc_arg";  # use bash equiv of script_header_joetoo _pc_action_number helper
            else
                j_msg -${err} "invalid cmdline arg [$_pc_arg] in pa case -*[0-9]* (ignoring)" ;
            fi
        ;;
      I|interactive )  # .......................... # number of parallel jobs
        INTERACTIVE="$TRUE"
        j_msg "-${debug}" -p "${BYon}set${Boff} INTERACTIVE: [$(TrueFalse "$INTERACTIVE")], shifting 1"
        ;;

      N|noninteractive )  # ....................... # number of parallel jobs
        INTERACTIVE="$FALSE"
        j_msg "-${debug}" -p "${BYon}set${Boff} INTERACTIVE: [$(TrueFalse "$INTERACTIVE")], shifting 1"
        ;;

      Q|quiet)  # ................................. # (silence) using using script_header_joetoo _pc_action_quiet
        _pc_action_quiet
        j_msg -${debug} -p "(pc)(Q) ran _pc_action_quiet; shifting 1"
        ;;

      D|debug)  # ,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,, # (debug)
        export DEBUG=$TRUE; j_msg -${debug} -p "(pc)(D) set DEBUG=\$TRUE; shifting 1" ;;

      v|louder)  # ................................ # (increase verbosity) using script_header_joetoo _pc_action>
        _pc_operator="+"; _pc_action_verbosity
        j_msg -${debug} -p "(pc)(v) ran _pc_action_verbosity (op: +); shifting 1"
        ;;

      q|quieter)  # ............................... # (decrease verbosity) using script_header_joetoo _pc_action>
        _pc_operator="-"; _pc_action_verbosity
        j_msg -${debug} -p "(pc)(q) ran _pc_action_verbosity (op: -); shifting 1"
        ;;

      h|help     ) my_usage; exit 1 ;;

      *             )  # ............................. # fall-through (either arg, compound flags, or bad flag)
        j_msg -${debug} -p "(pc)(*) _pc_arg not recognized, falling through to * case"
        # if there is only 1 char in $1, it must have recursed and failed to match above (return 1: failed)
        if [ ${#_pc_arg} -eq 1 ] ; then j_msg "-${err}" "failed to match _pc_char_flag [$_pc_char_flag]"; return 1; fi
        # process as potential compound flag (e.g. originally -Nvv)
        local _pc_flags="$_pc_arg" _pc_char_flag="" result=0
        while [ ${#_pc_flags} -gt 0 ]; do
          # strip first character and process it recursively
          _pc_char_flag="${_pc_flags:0:1}"
          j_msg -${debug} -p "current _pc_flags: [$_pc_flags]; about to recurse to examine _pc_char_flag [$_pc_char_flag]"
          parse_commandline "$_pc_char_flag"
          result=$?
          j_msg "-${debug}" -p -n "done checking single char [$_pc_char_flag]; result:"
          handle_result $result "[$_pc_char_flag] is ok" "[$_pc_char_flag] is not valid" || return 1
          _pc_flags="${_pc_flags#?}"
        done
        ;;
    esac
    shift
  done
  j_msg "-${debug}" -p "remaining argument(s): [${args[*]}]"
}

#-----[ main script ]------------------------------------------------------------------------------------
checkroot
separator "$(hostname)" "${PN}"

j_msg "-${debug}" -p "DEBUG: $(TrueFalse $DEBUG)"
j_msg "-${debug}" -p "verbosity: $verbosity"

parse_commandline "$@" || die "failed to parse_commandline"

show_config || die "failed to show_config"

old_dir="$(pwd)"
j_msg "-${notice}" -p -n "moving from ${old_dir} to newroot_mountpoint: [${newroot_mountpoint}] ..."
cd "${newroot_mountpoint}" ; right_status $? "$notice"

run_array "$status_file" "$starting_step" "$stopping_step" || die "failed to complete command sequence with run_array"

j_msg "-${notice}" -p -n "moving from $(pwd) back to ${old_dir} ..."
cd "${old_dir}" ; right_status $? "$notice"

exit 0

