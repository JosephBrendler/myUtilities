    local -a targets=(
        "/usr/sbin"
        "${newroot_mountpoint%/}/usr/sbin"
        "${JOETOO_HEADER_DIR}"
    )
    # cover all four headers in comments above
    local -a files=(
        "bashrc_aliases_include_joe_brendler"
    )
    local file_url="https://raw.githubusercontent.com/JosephBrendler/myUtilities/master/dev-util/joetoolkit/joetoolkit"
    local dest
    # iterate in nested for loops each suffix for each tartet
    for target in "${targets[@]}"; do
        for file in "${filess[@]}"; do
            # create target directory if needed (should only be needed for newroot_mountpoint target)
            # CAREFUL - dont create split-usr layout by accident on merged-usr system
            # so do not mkdir for targets - let stage3 extraction take cara of that
###            mkdir -p "${target}" || return 1
            # skip this header (continue) if it is already downloaded and executable in this target and has proper syntax
            [ -x "${target}/${file}" ] && sh -n "${target}/${file}" && continue
            # download directly and verify
            dest="${target}/${file}"
            # wget flags for one line progress bar and output to file:
            #   --progress=bar:force - when the output is not a TTY, the progress bar always falls back to "dot"
            #   --show-progress - force wget to display the progress bar in any verbosity
            #   -O - output to file'  --timeout and --tries limitted to prevent hangs
            j_msg "-${notice}" -p "downloading ${file} ->  ${dest}"
            wget -q --progress=bar:force --show-progress --timeout=20 --tries=3 \
                "${file_url}/${file}" \
                -O "${dest}" || return 2
            # confirm the download apears valid
            sh -n "$dest"   || return 3   # check bashrc_aliases_include_joe_brendler for POSIX syntax compliance
            # set permission on file file (executable)
            chmod 644 "${dest}" || return 4
        done
    done
}

