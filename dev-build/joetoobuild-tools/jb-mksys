#-----[ functions ]------------------------------------------------------------------------------------

my_usage() {
  j_msg "-${debug}" -p "in ${FUNCNAME[0]}"
  local msg="${BRon}usage${Boff}: ${_func_color}$PN${Boff} [options]"
  j_msg "-${notice}" -p "$msg"

  msg="${BYon}Options --${Boff}"
  j_msg "-${notice}" -p "$msg"
  msg="${BMon}  -I|--interactive${Boff}${Con} .....: show config and confirm before executing command${Boff} (default)"
  j_msg "-${notice}" -m "$msg"
  msg="${BMon}  -N|--noninteractive${Boff}${Con} ..: execute immediately${Boff}"
  j_msg "-${notice}" -m "$msg"
  msg="${BMon}  -v|--louder${Boff}${Con} ..........: Increase verbosity (may repeat)${Boff}"
  j_msg "-${notice}" -m "$msg"
  msg="${BMon}  -q|--quieter${Boff}${Con} .........: Fecrease verbosity (may repeat)${Boff}"
  j_msg "-${notice}" -m "$msg"
  msg="${BMon}  -Q|--quiet${Boff}${Con} ...........: Silence most output (script_header_joetoo quiet mode)${Boff}"
  j_msg "-${notice}" -m "$msg"
  msg="${BMon}  -D|--debug${Boff}${Con} ...........: Enable debug output${Boff}"
  j_msg "-${notice}" -m "$msg"
  msg="${BMon}  -h|--help${Boff}${Con} ............: print this message${Boff}"
  j_msg "-${notice}" -m "$msg"
  # enumerate command sequence
  msg="${BYon}Command Sequence --${Boff}"
  j_msg "-${notice}" -p "$msg"
  for ((i=0; i<${#command_sequence[@]}; i++)); do
      msg="     ${BBon}[${BMon}${i}${BBon}]${Boff}${Con} ${msg1_sequence[$i]}${Boff}"
      j_msg "-${notice}" -mp "$msg"
  done
}

print_next_steps() {
    separator "${PN}" "(${FUNCNAME[0]})"
    local msg="" outfile="${newroot_mountpoint%/}/_joetoo-system-install_next_steps"

    local -a messages=(
        "${BCon}(${BMon}1${BCon})${Boff} edit .bashrc, make.conf"
        "${BCon}(${BMon}2${BCon})${Boff} run jb-chroot-sys [or manually run chroot-prep ; cat chroot-commands (copy/paste)]"
        "${BCon}(${BMon}3${BCon})${Boff} this should auto-run finalize-chroot-sys script on first root login"
        "${BCon}(${BMon}4${BCon})${Boff} after finalize-chroot-sys script finishes, run chown -R root:root /root"
        "    and chown -R \${user}:\${user} /home/\${user}"
        "${BCon}(${BMon}5${BCon})${Boff} if not already complete, emerge @system; emerge @world"
        "${BCon}(${BMon}6${BCon})${Boff} *** build kernel, initramfs, and update /etc/fstab and bootloader --"
        "    ${BMon}Hint:${Boff} blkid | grep \${filter} >> /etc/fstab ; nano /etc/fstab"
        "    bootloader files could include --"
        "        /boot/cmdline.txt, /boot/config.txt (raspi)"
        "        /boot/joetooEnv.txt (rockchip)"
        "        /etc/default/grub (amd64)"
        "${BCon}(${BMon}7${BCon})${Boff} validate apache ssl, vpn keys, etc. reboot ..."
    )
    msg="${BYon}Next Steps should include the following --${Boff}"
    # first tee write resets outfole; subsequent tee writes append
    j_msg "-${notice}" -p "$msg" | tee "$outfile"
    for msg in "${messages[@]}"; do
        j_msg "-${notice}" -mp "    $msg" | tee -a "$outfile"
    done
    j_msg "-${notice}" -mp ""
    msg="${BYon}Note${Boff}: to reprint these next_steps instructions, run --"
    j_msg "-${notice}" -p "$msg" | tee -a "$outfile"
    msg="    ${BBon}cat ${BMon}${outfile}${Boff}"
    j_msg "-${notice}" -mp "$msg" | tee -a "$outfile"
    j_msg "-${notice}" -mp ""
    return 0
}

prepare-to-finalize-chroot() {
    separator "${PN}" "(${FUNCNAME[0]})"
    local finalize_chroot_joetoo_file="${JOETOO_HEADER_DIR%/}/finalize-chroot-sys"
    local finalize_chroot_joetoo_destination="${newroot_mountpoint%/}/usr/sbin/"
    # install /usr/sbin/finalize-chroot (should have been installed install_files (mkenv) above
    j_msg "-${notice}" -p "validating availability of /usr/sbin/finalize-chroot-sys ..."
    if [[ ! -x "${newroot_mountpoint%/}/usr/sbin/finalize-chroot-sys" ]] ; then
        j_msg "-${err}" "executable ${newroot_mountpoint%/}/usr/sbin/finalize-chroot-sys not found - copying"
        j_msg "-${notice}" -p -n "looking for \$finalize_chroot_joetoo_file [$finalize_chroot_joetoo_file]"
        [[ -f "$finalize_chroot_joetoo_file" ]]
        handle_result $? "found it" "not found" "$notice" || return 1
        j_msg "-${notice}" -p -n "copying \$finalize_chroot_joetoo_file to destination [$finalize_chroot_joetoo_destination]"
        cp -a "$finalize_chroot_joetoo_file" "${finalize_chroot_joetoo_destination %/}/"
        handle_result $? "" "" "$notice" || return 1
        j_msg "-${notice}" -p -n "setting permissions"
        # set permissions by appending basenamed sourcefile to dest dir/
        chmod +x "${finalize_chroot_joetoo_destination%/}/${finalize_chroot_joetoo_file##*/}"
        handle_result $? "" "" "$notice" || return 1
    else
        j_msg "-${notice}" -p "${BGon}Confirmed${Boff}"
    fi
    d_do 'ls -al "${finalize_chroot_joetoo_destination%/}/${finalize_chroot_joetoo_file##*/}"' "$info"

    # mod /root/.bashrc (likely installed already by content_for_mkenv_generic_amd64)
    #  to run /usr/sbin/finalize-chroot if /root/firstlogin exists
    #  so check and only append lines not already posted
    local -a lines=(
        '/usr/sbin/install_my_local_ca_certificates'
        'rerunmsg="first-run chroot configuration not requested by presense of marker"'
        'if cat /root/firstlogin 2>/dev/null ; then /usr/sbin/finalize-chroot-sys; else j_msg -5 "$rerunmsg"; fi'
        'j_msg "-${warn}" -p "edit /root/.bashrc after first boot of new system, to modify prompt, etc."'
        'export PS1="(chroot) ${PS1}"'
    )
    for line in "${lines[@]}"; do
        j_msg "-${notice}" -p -n "checking for line [${line:0:10} ...]"
        if grep -q "^${line}" "${newroot_mountpoint%/}/root/.bashrc"; then
            j_msg "-${notice}" -mp " (${BGon}confirmed${Boff})"
        else
            j_msg "-${notice}" -mp " (${BYon}appending${Boff})"
            echo "${line}" >> "${newroot_mountpoint%/}/root/.bashrc"
        fi
    done

    # create /root/firstlogin
    j_msg "-${notice}" -p -n "creating firstrunmarker /root/firstlogin"
    echo "true" > "${newroot_mountpoint%/}/root/firstlogin"
    handle_result $? "" "" "$notice" || return 1
    return 0
}

