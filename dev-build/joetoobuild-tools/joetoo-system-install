#!/bin/bash
# wget-stage3-amd64   (c) joe brendler 2025-2055
# based on the author's work in the dev-sbc/crossbuild-tools::joetoo package
# but tuned for use installing a new or rebuilt system on hardware running a liveCD/liveUSB
# so unlike cb-mkenv (which sets up repos and selects a profile), those steps must
# be handled after chroot (as per gentoo handbook install sequence)

newroot_mountpoint="/mnt/gentoo"

# This script needs you to provide this header and its _compat and _unicode helpers
#   in the /usr/sbin/ directory of your build system (likely a livecd, wherein your newroot_mountpoint=/mnt/gentoo)
# This script itself will install these in the target system -- in ${newroot_mountpoint%/}/usr/sbin/
#   as part of install_files (mkenv) phase, so the finalize-chroot-joetoo script can find them after chroot
# IMPORTANT: to get this working, copy all three to the livecd's /usr/sbin/ --
#   script_header_joetoo
#   script_header_joetoo_compat
#   script_header_joetoo_unicode
# IMPORTANT: also copy script_header_joetoo_extended to /usr/sbin to enable its run_array() functionality
# to /usr/sbin (where the script expects the header, and where the header expects its helpers to be)
source /usr/sbin/script_header_joetoo
source /usr/sbin/script_header_joetoo_extended

#-----[ variables ]------------------------------------------------------------------------------------
INTERACTIVE=$TRUE  # force this true
[ -z "$verbosity" ] && verbosity=5
verbosity_str=$(get_severity "$verbosity")

mkenv_files="${newroot_mountpoint%/}/joetoobuild-tools/content_for_mkenv_gmki91"
mkimg_files="${newroot_mountpoint%/}/joetoobuild-tools/content_for_mkimg_retro"

PN=${0##*/}

# set these static here for $PN; they would be set by validate_target() in crossbuild-tools
BOARD=generic_amd64
TARGET=x86_64-pc-linux-gnu
TARGET_ARCH=amd64
QEMU_ARCH=x86_64
#STAGE3_SELECTOR="stage3-amd64-openrc-[0-9]"   # go with hardened below and change to hardened desktop in joetoo profile
#default_profile="default/linux/amd64/23.0"
LLVM_TARGET="X86-64"
target_url=""
stage3_tarball=""

# amd64 hardened openrc link looks like this
# https://...amd64/autobuilds/current-stage3-amd64-hardened-openrc/
#STAGE3_SELECTOR=stage3-amd64-openrc-[0-9]
STAGE3_SELECTOR='stage3-amd64-hardened-openrc-[0-9]'
#profile_number=48
#profile_number=21     # hardened ## /// no - they change the numbers
default_profile="default/linux/amd64/23.0/hardened"

status_file="${newroot_mountpoint%/}/${PN}-status"
# make sure it is writable
if [ ! -w "$status_file" ]; then
  rm -f "$status_file"
  touch "$status_file"
  chmod 644 "$status_file"
fi

varlist="bool.INTERACTIVE boot.DEBUG bool.RESUME verbosity verbosity_str"
varlist+=" TARGET_ARCH STAGE3_SELECTOR newroot_mountpoint default_profile"
varlist+=" mkenv_files mkimg_files status_file starting_step stopping_step"

command_sequence=(
'wget-stage3'
'verify-stage3-hashes'
'verify_stage3_signature'
'untar-stage3'
"install_files_from_source ${mkenv_files}"
"install_files_from_source ${mkimg_files}"
'copy-resolve-conf'
'make-repo-dirs'
'prepare-to-finalize-chroot'
'print_next_steps | tee "${newroot_mountpoint%/}/joetoobuild-tools/_joetoo-system-install_next_steps"'
)

msg1_sequence=(
'wget stage3'
'verify stage3 hashes'
'verify_stage3_signature'
'untar stage3'
"install ${mkenv_files} files"
"install ${mkimg_files} files"
'copy resolve.conf'
'make repo directories'
'prepare to finalize chroot'
'print next steps'
)

# set globals required by script_header_joetoo_extended run_array function
starting_step=0
stopping_step=$(( ${#command_sequence[@]} - 1 ))
# set global num_cmds required by script_header_joetoo process argument helpers _pc_action_resume and _number
num_cmds="${#command_sequence[@]}"

#-----[ functions ]------------------------------------------------------------------------------------

my_usage() {
  j_msg "-${debug}" -p "in ${FUNCNAME[0]}"
  local msg="${BRon}usage${Boff}: ${_func_color}$PN${Boff} [options]"
  j_msg "-${notice}" -p "$msg"

  msg="${BYon}Options --${Boff}"
  j_msg "-${notice}" -p "$msg"
  msg="${BMon}  -I|--interactive${Boff}${Con} .....: show config and confirm before executing command${Boff} (default)"
  j_msg "-${notice}" -m "$msg"
  msg="${BMon}  -N|--noninteractive${Boff}${Con} ..: execute immediately${Boff}"
  j_msg "-${notice}" -m "$msg"
  msg="${BMon}  -v|--louder${Boff}${Con} ..........: Increase verbosity (may repeat)${Boff}"
  j_msg "-${notice}" -m "$msg"
  msg="${BMon}  -q|--quieter${Boff}${Con} .........: Fecrease verbosity (may repeat)${Boff}"
  j_msg "-${notice}" -m "$msg"
  msg="${BMon}  -Q|--quiet${Boff}${Con} ...........: Silence most output (script_header_joetoo quiet mode)${Boff}"
  j_msg "-${notice}" -m "$msg"
  msg="${BMon}  -D|--debug${Boff}${Con} ...........: Enable debug output${Boff}"
  j_msg "-${notice}" -m "$msg"
  msg="${BMon}  -h|--help${Boff}${Con} ............: print this message${Boff}"
  j_msg "-${notice}" -m "$msg"
  # enumerate command sequence
  msg="${BYon}Command Sequence --${Boff}"
  j_msg "-${notice}" -p "$msg"
  for ((i=0; i<${#command_sequence[@]}; i++)); do
      msg="     ${BBon}[${BMon}${i}${BBon}]${Boff}${Con} ${msg1_sequence[$i]}${Boff}"
      j_msg "-${notice}" -mp "$msg"
  done
}

print_next_steps() {
    separator "${PN}" "(${FUNCNAME[0]})"
    j_msg "-${notice}" -p "${BYon}Next Steps should include the following --${Boff}"
    j_msg "-${notice}" -p "${BCon}(${BMon}1${BCon})${Boff} edit .bashrc, make.conf (follow handbook; below at a minimum)"
    j_msg "-${notice}" -p "${BCon}(${BMon}2${BCon})${Boff} chroot [run chroot-prep ; cat chroot-commands (copy/paste)]"
    j_msg "-${notice}" -p "${BCon}(${BMon}3${BCon})${Boff} run finalize-chroot-joetoo script (should auto-run on first chroot)"
    j_msg "-${notice}" -p "${BCon}(${BMon}4${BCon})${Boff} after script finishes, run chown -R root:root /root"
    j_msg "-${notice}" -p "${BCon}(${BMon}5${BCon})${Boff} after script finishes, run chown -R \${user}:\${user} /home/\${user}"
    j_msg "-${notice}" -p "${BCon}(${BMon}6${BCon})${Boff} if not already complete, emerge @system; emerge @world"
    j_msg "-${notice}" -p "${BCon}(${BMon}7${BCon})${Boff} *** build kernel, initramfs, and update /etc/fstab and bootloader --"
    j_msg "-${notice}" -p "    ${BMon}Hint:${Boff} blkid | grep \${filter} >> /etc/fstab ; nano /etc/fstab"
    j_msg "-${notice}" -p "    bootloader files could include --"
    j_msg "-${notice}" -p "        /boot/cmdline.txt, /boot/config.txt (raspi)"
    j_msg "-${notice}" -p "        /boot/joetooEnv.txt (rockchip)"
    j_msg "-${notice}" -p "        /etc/default/grub (amd64)"
    j_msg "-${notice}" -p "${BCon}(${BMon}8${BCon})${Boff} validate apache ssl, vpn keys, etc. reboot ..."
    j_msg "-${notice}" -p "${BCon}(${BMon}9${BCon})${Boff} validate apache ssl, vpn keys, etc. reboot ..."
    j_msg "-${notice}" -mp ""
    j_msg "-${notice}" -p "${BYon}Note${Boff}: to reprint these next_steps instructions, run --"
    j_msg "-${notice}" -mp "    ${BBon}cat ${BMon}${newroot_mountpoint%/}/joetoobuild-tools/_joetoo-system-install_next_steps${Boff}"
    return 0
}

prepare-to-finalize-chroot() {
    separator "${PN}" "(${FUNCNAME[0]})"
    local finalize_chroot_joetoo_file="${newroot_mountpoint%/}/joetoobuild-tools/finalize-chroot-joetoo"
    local finalize_chroot_joetoo_destination="${newroot_mountpoint%/}/usr/sbin/"
    # install /usr/sbin/finalize-chroot (should have been installed install_files (mkenv) above
    j_msg "-${notice}" -p "validating availability of /usr/sbin/finalize-chroot-joetoo ..."
    if [[ ! -x "${newroot_mountpoint%/}/usr/sbin/finalize-chroot-joetoo" ]] ; then
        j_msg "-${err}" "executable ${newroot_mountpoint%/}/usr/sbin/finalize-chroot-joetoo not found - copying"
        j_msg "-${notice}" -p -n "looking for \$finalize_chroot_joetoo_file [$finalize_chroot_joetoo_file]"
        [[ -f "$finalize_chroot_joetoo_file" ]]
        handle_result $? "found it" "not found" "$notice" || return 1
        j_msg "-${notice}" -p -n "copying \$finalize_chroot_joetoo_file to destination [$finalize_chroot_joetoo_destination]"
        cp -a "$finalize_chroot_joetoo_file" "${finalize_chroot_joetoo_destination %/}/"
        handle_result $? "" "" "$notice" || return 1
        j_msg "-${notice}" -p -n "setting permissions"
        # set permissions by appending basenamed sourcefile to dest dir/
        chmod +x "${finalize_chroot_joetoo_destination%/}/${finalize_chroot_joetoo_file##*/}"
        handle_result $? "" "" "$notice" || return 1
    else
        j_msg "-${notice}" -p "${BGon}Confirmed${Boff}"
    fi
    d_do 'ls -al "${finalize_chroot_joetoo_destination%/}/${finalize_chroot_joetoo_file##*/}"' "$info"

    # mod /root/.bashrc (likely installed already by content_for_mkenv_generic_amd64)
    #  to run /usr/sbin/finalize-chroot if /root/firstlogin exists
    echo "" >> "${newroot_mountpoint%/}/root/.bashrc"
    echo "install_my_local_ca_certificates"  >> "${newroot_mountpoint%/}/root/.bashrc"
    echo "" >> "${newroot_mountpoint%/}/root/.bashrc"
    echo "rerunmsg=\"first-run chroot configuration not requested by presense of marker\"" >> "${newroot_mountpoint%/}/root/.bashrc"
    # finalize-chroot-joetoo is in /usr/sbin which should be in PATH
    echo -n "[ -e /root/firstlogin ] && finalize-chroot-joetoo ||"  >> "${newroot_mountpoint%/}/root/.bashrc"
    echo " \\"  >> "${newroot_mountpoint%/}/root/.bashrc"
    echo 'echo -e "${rerunmsg} /root/firstlogin;\nre-run if needed with /usr/sbin/finalize-chroot-joetoo"'  >> "${newroot_mountpoint%/}/root/.bashrc"
    echo "" >> "${newroot_mountpoint%/}/root/.bashrc"
    echo "" >> "${newroot_mountpoint%/}/root/.bashrc"
    echo "j_msg \"-${err}\" \"edit /root/.bashrc after first boot of real image, to modify prompt, etc.\""  >> "${newroot_mountpoint%/}/root/.bashrc"
    echo  "" >> "${newroot_mountpoint%/}/root/.bashrc"
    echo "export PS1=\"(chroot) \${PS1}\""  >> "${newroot_mountpoint%/}/root/.bashrc"

    # create /root/firstlogin
    j_msg "-${notice}" -p -n "creating firstrunmarker /root/firstlogin"
    echo "true" >> "${newroot_mountpoint%/}/root/firstlogin"
    handle_result $? "" "" "$notice" || return 1
    return 0
}

# removed sync-repo in this non-crossbuilding scenario.  Run it in chroot

make-repo-dirs() {
    separator "${PN}" "(${FUNCNAME[0]})"
    for x in gentoo joetoo crossdev; do
        j_msg "-${notice}" -p -n "examining repo [$x]"
        if [ ! -d "${newroot_mountpoint%/}/var/db/repos/${x}" ] ; then
            j_msg "-${notice}" -mp -n " (${BRon}missing${Boff}) creating"
            mkdir -p "${newroot_mountpoint%/}/var/db/repos/${x}"
            handle_result $? '' '' "$notice" || return 1
        else
            j_msg "-${notice}" -mp -n " (${BGon}exists${Boff})"
            handle_result 0 '' '' "$notice"
        fi
    done
    return 0
}

copy-resolve-conf() {
    separator "${PN}" "(${FUNCNAME[0]})"
    # to-do make this a choice - static or dynamic; for now set up for dynamic
    j_msg "-${notice}" -p "copying /etc/resolve.conf to newroot_mountpoint ..."
    j_msg "-${notice}" -p -n "creating ${newroot_mountpoint%/}/run/resolvconf ..."
    mkdir -p "${newroot_mountpoint%/}/run/resolvconf"
    handle_result $? '' '' "$notice" || return 1
    j_msg "-${notice}" -p -n "copying to /run/resolvconf/resolv.conf ..."
    cp -a /etc/resolv.conf "${newroot_mountpoint%/}/run/resolvconf/"
    handle_result $? '' '' "$notice" || return 1
    j_msg "-${notice}" -p -n "linking /etc/resolv.conf ..."
    ln -sf ../run/resolvconf/resolv.conf "${newroot_mountpoint%/}/etc/resolv.conf"
    handle_result $? '' '' "$notice" || return 1
    d_do 'ls -al ${newroot_mountpoint%/}/etc/resolv.conf | sed "s|^|    |"' "$info"
    return 0
}

rsync_verbosity_flags() {
    loudness="$verbosity"
    [ "$DEBUG" ] && loudness=7
    [ "$QUIET" ] && loudness=0
    # set and return via stdout the appropriate info flags for rsync
    case "$loudness" in
        [0-4]) printf '%s\n' "--info=none" ;;  #................. # emerg, alert, crit, err, warn (errors only)
        5) printf '%s\n' "--info=progress2" ;; #................. # notice
        6) printf '%s\n' "--info=progress1,stats1" ;; #.......... # info
        7) printf '%s\n' "-vv --info=progress1,stats2,flist2" ;;  # debug
        *) printf '%s\n' "--info=progress2" ;; #................. # fall-through catch-all
    esac
}

install_files_from_source() {
    separator "${PN}" "(install_files_from_source)"
    local result=0
    # SOURCE = (in this context) staged data already collected to enable
    #           joetoo system image generation for this platform)
    # strip any trailing / for assurance to safely append / in rsync command
    SOURCE="${1%/}"
    DESTROOT="${newroot_mountpoint%/}"
    j_msg "-${notice}" -p "SOURCE: $SOURCE"
    # use rsync to copy the entire source tree into the destination root, preserving structure
    # flags: -a: archive; -H: hardlinks; -A: acls; -X: xattrs
    #   for --info=  progress2 is signle line running %; 0 is silent; 1 is individual files
    j_msg "-${notice}" -p "populating destination [$DESTROOT] with content from source [$SOURCE] ..."
    rsync -aHAX $(rsync_verbosity_flags) --numeric-ids --exclude='lost+found' "$SOURCE/" "$DESTROOT/"
    j_msg "-${notice}" -p -n "Done populating; result:"
    handle_result $result '' "error; rsync exited with status [$result]" "$notice" || return 1
    return 0
}

old_get-max-profile-number() {
#    validate_target ${BOARD} # set TARGET, TARGET_ARCH just in case not already set
## for joetoo-system-install, set these static at the top
