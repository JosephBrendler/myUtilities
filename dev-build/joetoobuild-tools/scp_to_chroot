#!/bin/bash
payload="${1:-finalize-chroot-sys}"
ip_address="${2:-192.168.62.164}"

source /usr/sbin/script_header_joetoo
checknotroot

PN=${0##/}
separator "$(hostname)" "$PN"

pw=$(ask_pass "Enter chroot system passwd: ")
j_msg "-${notice}" -p -n "copying payload [$payload] to local content directory"
cp -a "${payload}" "content_for_mkenv_generic_amd64/usr/sbin/${payload}" 2>/dev/null
handle_result $? '' '' "$notice"
list=(
  "/usr/bin/${payload}"
  "/joetoobuild-tools/${payload}"
  "/joetoobuild-tools/content_for_mkenv_generic_amd64/usr/sbin/${payload}"
)
for x in "${list[@]}"; do
  j_msg "-${notice}" -p -n "copying payload [$payload] to dir [${x:0:8}...]"
  sshpass -p "$pw" scp "${payload}" "root@${ip_address}":"/mnt/gentoo/${x#/}"
  handle_result $? '' '' "$notice"
done
