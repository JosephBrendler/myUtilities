#!/bin/bash
#payload="${1:-finalize-chroot-sys}"
payload="${1:-"jb-mksys"}"
#destination="${2:-192.168.62.164}"
destination="${2:-192.168.62.181}"

source /usr/sbin/script_header_joetoo
checknotroot

PN=${0##*/}
separator "$(hostname)" "$PN"

answer=""
yn_prompt "${BYon}About to scp payload [$payload] to destination [$destination] ${Boff}"
[[ "${answer:0:1}" != [yY] ]] && die "aborted by user"
pw=$(ask_pass "    Enter chroot system passwd: ")
#j_msg "-${notice}" -m -n " copying payload [$payload] to local content directory"
#cp -a "${payload}" "content_for_mkenv_generic_amd64/usr/sbin/${payload}" 2>/dev/null
handle_result $? '' '' "$notice"
list=(
  "/usr/bin/${payload}"
  "/joetoobuild-tools/${payload}"
)
#  "/joetoobuild-tools/content_for_mkenv_generic_amd64/usr/sbin/${payload}"
#)
for x in "${list[@]}"; do
  j_msg "-${notice}" -m -n " copying payload [$payload] to dir [${x:0:8}...]"
  sshpass -p "$pw" scp "${payload}" "root@${destination}":"/mnt/gentoo/${x#/}" 2>/dev/null
  handle_result $? '' '' "$notice"
done
