# note: it is essential to clear the environment when chrooting,
# else the chroot inherits livecd's and fails to set it up properly,
# so that (for example) /usr/sbin will be in the PATH and
# /root/.bashrc can run properly
env -i chroot /mnt/gentoo /bin/bash
source /etc/profile
export PS1="(chroot) $PS1"
