#!/bin/sh

repeat() { printf "%0${2}d\n" 0 | tr '0' "${1%${1#?}}" ; }

remote_list="iota01 g5nuc01 g3nuc01 elrond x401 x402 gmki91 gmki92 sandbox nueuler nugauss"
set -- $remote_list

for x in "$@"; do
    echo ;
    echo "$x" ;
    echo $(repeat '=' ${#x}) ;
    if scp -q /home/joe/myUtilities/dev-build/joetoobuild-tools/resolve_board_x86 $x:/home/joe/ ; then
        echo "scp ok"
    else
        echo "scp fail"
    fi
    ssh -t -q "$x" sh -c 'echo -n "" ;
        repeat() { printf "%0${2}d\n" 0 | tr "0" "${1%${1#?}}" ; } ;
        y=resolve_board_x86 ;
        echo; echo "$y" ; echo $(repeat "-" ${#y}) ;
        /home/joe/resolve_board_x86
        y=cpuid2cpuflags
        echo; echo "$y" ; echo $(repeat "-" ${#y}) ;
        if command -v "$y" &>/dev/null; then
            "$y"
        else
            echo "$y not found"
            if sudo emerge -v1 "$y" ; then
                echo "running $y"
                "$y"
            else
                echo "failed to emerge $y"
            fi
        fi
        y=make.conf ;
        echo ; echo "$y" ; echo $(repeat "-" ${#y}) ;
        grep ^COMMON_FLAGS /etc/portage/make.conf ;
        y=resolve-march-native
        echo; echo "$y" ; echo $(repeat "-" ${#y}) ;
        if command -v "$y" &>/dev/null; then
            "$y"
        else
            echo "$y not found"
            if sudo emerge -v1 "$y" ; then
                echo "running $y"
                "$y"
            else
                echo "failed to emerge $y"
            fi
        fi
        y=/etc/portage/package.use/00cpu-flags ;
        echo ; echo "$y" ; echo $(repeat "-" ${#y}) ;
        cat "$y"
    '

done
