exit
cd
# umount possibly-nested mounts
for d in dev proc sys run; do
   umount -R /mnt/gentoo/${d}
done
# umount/detach loop devices
umount -l /mnt/gentoo/dev{/shm,/pts,}
# final recursive umount
umount -R /mnt/gentoo

