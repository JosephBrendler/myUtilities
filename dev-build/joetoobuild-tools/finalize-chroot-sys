add-default-runlevel-services() {
    local -a list=()
    # add all services to default runlevel (should have merged with world)
    SOFARSOGOOD=$TRUE
    # add prerequisite networking links in /etc/init.d
    j_msg "-${notice}" -p "Adding prerequisite network interface links in /etc/init.d ..."
    list=( eth0 wlan0 )
    for x in "${list[@]}" ; do
        j_msg "-${notice}" -p -n "interface ${x}"
        if [ ! -L "/etc/init.d/net.${x}" ] ; then
            j_msg "-${notice}" -p -n " (linking)"
            ln -s /etc/init.d/net.lo "/etc/init.d/net.${x}"
            handle_result $? "" "" "$notice" || SOFARSOGOOD=$FALSE
        else
            handle_result 0 "already linked" "" "$notice"
        fi
    done
    # add links for services in default runlevel
    j_msg "-${notice}" -p "Adding services to the default runlevel ..."
    list=( apache2 chronyd cronie dbus ddns distccd gpm mysql net.eth0 net.wlan0 php-fpm rsyncd sshd sysklogd )
    for x in "${list[@]}" ; do
        j_msg "-${notice}" -p -n "examining ${x}"
        if [ ! -L "/etc/runlevels/default/${x}" ] ; then
            j_msg "-${notice}" -p -n " (linking)"
            ln -s "/etc/init.d/${x}" "/etc/runlevels/default/${x}"
            handle_result $? "" "" "$notice" || SOFARSOGOOD=$FALSE
        else
            handle_result 0 "already linked" "" "$notice" || SOFARSOGOOD=$FALSE
        fi
    done
    if [[ ! $SOFARSOGOOD ]] ; then
        j_msg "-${err}" "add-default-runlevel-services ${BRon}completed with errors${Boff}"
        FLAGGED=$TRUE
        return 1
    else
        j_msg "-${notice}" -p "add-default-runlevel-services ${BGon}succeeded${Boff}"
        return 0
    fi
}

setup-clock() {
    # determine what is presently set up, query user to fix
    currentclock=$(find /etc/runlevels/boot/ -iname "*clock" -exec basename {} \;)
    case "${currentclock}" in
        [sh]"wclock" )
            j_msg "-${notice}" -p "boot runlevel current clock: ${currentclock}" ;
            case "${currentclock:0:1}" in
                "h" ) otherclock="swclock" ;;
                "s" ) otherclock="hwclock" ;;
                * ) j_msg "-${err}" "invalid currentclock" ; return 1 ;;
            esac
            response="" ;
            msg="would you like to change to ${otherclock} ?\n"
            msg+="  y = yes; change | [s|n] = no; keep"
            new_prompt "${msg}"
            case "${response:0:1}" in
                [yY] )
                    j_msg "-${notice}" -p -n "removing current boot runlevel clock service ..." ;
                    rm "/etc/runlevels/boot/${currentclock}"
                    right_status $? "$notice" || FLAGGED=$TRUE
                    j_msg "-${notice}" -p -n "adding new boot runlevel clock service [${otherclock}] ..."
                    ln -s "/etc/init.d/${otherclock}" "/etc/runlevels/boot/${otherclock}"
                    right_status $? "$notice" || FLAGGED=$TRUE
                    currentclock="${otherclock}"
                    ;;
                [nNsS] ) ;;
                * ) j_msg "-${err}" "invalid response" ; return 1 ;;
            esac
            ;;
        * ) j_msg "-${err}" "invalid clock for boot runlevel: [{currentclock}]" ; return 1 ;;
    esac
    case "${currentclock:0:1}" in
        # write the temporary system clock time directly down into the hardware CMOS
        h) if ! hwclock --systohc ; then
               j_msg "-${err}" -m "failed to set rtc with hwclock --systohc";
               FLAGGED=$TRUE;
           fi ;;
        # ensure the shutdowntime file exists for use by swclock
        s) if ! mkdir -p /var/lib/misc && touch /var/lib/misc/openrc-shutdowntime ; then
               j_msg "-${err}" -m "failed to create /var/lib/misc/openrc-shutdowntime or its directory";
               FLAGGED=$TRUE;
           fi ;;
    esac
    # shellcheck disable=SC2086
    [ $FLAGGED ] && return 1
    return 0
}

install-grub() {
    local result=0
    local efi_part="" boot_part="" efi_dir="" boot_disk=""
    local -a esp
    local esp_guid_part_type_str="c12a7328-f81f-11d2-ba4b-00a0c93ec93b"
    local GRUB_EFI=$FALSE GRUB_BIOS=$FALSE
    local ig_arch="$cb_QEMU_ARCH"  # probably x86_64 for finalize-chroot-sys
    # first determine if there is one efi system partition mounted, to install to
    readarray -t esp < <(findmnt -rn -t vfat -o SOURCE,TARGET  | grep efi | awk '{print $1}')
    [ ${#esp[@]} -gt 1 ] && die "multiple efi partitions; pick, install grub manually, and resume at next step"
    # possible to-do: offer selection let user pick instead
    [ ${#esp[@]} -eq 1 ] && efi_part="${esp[0]}"
    # verify or branch to possible bios boot
    if [ -n "$efi_part" ] ; then
        # likely efi - verify
        if [[ "$(lsblk -no PARTTYPE "$efi_part")" == "$esp_guid_part_type_str" ]] ; then
            efi_dir=$(findmnt -rn -t vfat -o TARGET,SOURCE  | grep efi | awk '{print $1}')
            if [ -d "$efi_dir" ] ; then
                GRUB_EFI=$TRUE
            else
                die "failed to identify efi directory for grub-install"
            fi
        else
            die "failed to identify efi partition for grub-install"
        fi
    else
        # NOT efi - verify for legacy bios boot
        boot_part=$(findmnt -rn -o SOURCE /boot)
        if [ -n "$boot_part" ] ; then
            boot_disk=/dev/$(lsblk -no PKNAME "$boot_part")
            if [ -b "$boot_disk" ]; then
                GRUB_BIOS=$TRUE
            else
                die "failed to identify boot disk for grub-install"
            fi
        else
            die "failed to identify boot partition for grub-install"
        fi
    fi
    # now install grub accordingly (above should make GRUB_EFI and GRUB_BIOS orthogonal
    if [ $GRUB_EFI ] ; then
        # (copied from joetoolkit's grub_install_both_ways)
        # insall iaw news grub2 article - recommends install both with and w/o --removable
        # syntax here taken from https://wiki.gentoo.org/wiki/Handbook:AMD64/Installation/Bootloader
        j_msg "-${notice}" -p "Installing grub for efi system ..."
        grub-install --efi-directory="${efi_dir}" --target="${ig_arch}-efi" && \
        grub-install --efi-directory="${efi_dir}" --target="${ig_arch}-efi" --removable
        result=$?
        j_msg "-${notice}" -p "Done installing grub; result:"
        handle_result $result "" "" "$notice" || die "failed to install grub for efi system"
    elif [ $GRUB_BIOS ] ; then
        j_msg "-${notice}" -p "Installing grub for bios boot ..."
        grub-install "$boot_disk"; result=$?
        j_msg "-${notice}" -p "Done installing grub for bios boot; result:"
        handle_result $result "" "" "$notice" || die "failed to install grub for bios boot"
    fi

    j_msg "-${notice}" -p "Setting permissions on grub files ..."
    chmod +x /etc/grub.d/10_linux && \
    chmod +x /etc/grub.d/20_linux_xen; result=$?
    j_msg "-${notice}" -p "Done setting permissions on grub files; result:"
    handle_result $result "" "" || FLAGGED=$TRUE
    j_msg "-${notice}" -p "Running grub-mkconfig ..."
    grub-mkconfig -o /boot/grub/grub.cfg
    j_msg "-${notice}" -p "Done running grub-mkconfig; result:"
    handle_result $result "" "" || FLAGGED=$TRUE
    # shellcheck disable=SC2086
    [ $FLAGGED ] && return 1
    return 0
}


