emerge-world() {
    # re-run chroot_emerge -uavDN @world --keep-going
    # use an array to construct the emerge command
    local -a emerge_command=( "${chroot_emerge}" -uavDN )
    emerge_command+=( @world )
    j_msg "-${notice}" -p "emerging @world (-uavDN) ..."
    "${emerge_command[@]" ; result=$?
    j_msg "-${notice}" -p -n "Done emerging @world; result:"
    handle_result $? "" "" "$notice" || return 1
    j_msg "-${notice}" -p "about to run chroot_emerge -uavDN @world --keep-going"
    [[ $INTERACTIVE ]] && emerge_opts="-uavDNg" || emerge_opts="-uvDNg"
    eval "${chroot_emerge} ${emerge_opts} @world --keep-going" ; result=$?
    [ $result -eq 0 ] && j_msg "-${notice}" -p "emerge-world ${BGon}succeeded${Boff}" || \
        j_msg "-${err}" "emerge-world ${BRon}failed${Boff}"
    return $result
}

run-dispatch-conf() {
    j_msg "-${notice}" -p "about to run dispatch-conf"
    ROOT=/ dispatch-conf ; result=$?
    [ $result -eq 0 ] && j_msg "-${notice}" -p "run-dispatch-conf ${BGon}succeeded${Boff}" || \
        j_msg "-${err}" "run-dispatch-conf ${BRon}failed${Boff}"
    return $result
}

add-default-runlevel-services() {
    # add all services to default runlevel (should have merged with world)
    SOFARSOGOOD=$TRUE
    # add prerequisite networking links in /etc/init.d
    j_msg "-${notice}" -p "Adding prerequisite network interface links in /etc/init.d ..."
    list="eth0 wlan0"
    for x in $list ; do
        j_msg "-${notice}" -p -n "interface ${x}"
        if [ ! -L "/etc/init.d/net.${x}" ] ; then
            j_msg "-${notice}" -p -n " (linking)"
            ln -s /etc/init.d/net.lo "/etc/init.d/net.${x}"
            handle_result $? "" "" "$notice" || SOFARSOGOOD=$FALSE
        else
            handle_result 0 "already linked" "" "$notice"
        fi
    done
    # add links for services in default runlevel
    j_msg "-${notice}" -p "Adding services to the default runlevel ..."
    list="apache2 chronyd cronie dbus ddns distccd gpm mysql net.eth0 net.wlan0 php-fpm rsyncd sshd sysklogd"
    for x in $list ; do
        j_msg "-${notice}" -p -n "examining ${x}"
        if [ ! -L "/etc/runlevels/default/${x}" ] ; then
            j_msg "-${notice}" -p -n " (linking)"
            ln -s /etc/init.d/${x} /etc/runlevels/default/${x}
            handle_result $? "" "" "$notice" || SOFARSOGOOD=$FALSE
        else
            handle_result $? "already linked" "" "$notice" || SOFARSOGOOD=$FALSE
        fi
    done
    if [[ ! $SOFARSOGOOD ]] ; then
        j_msg "-${err}" "add-default-runlevel-services ${BRon}completed with errors${Boff}"
        FLAGGED=$TRUE
        return 1
    else
        j_msg "-${notice}" -p "add-default-runlevel-services ${BGon}succeeded${Boff}"
        return 0
    fi
}

setup-clock() {
    # determine what is presently set up, query user to fix
    currentclock=$(find /etc/runlevels/boot/ -iname "*clock" -exec basename {} \;)
    case "${currentclock}" in
        [sh]"wclock" )
            j_msg "-${notice}" -p "boot runlevel current clock: ${currentclock}" ;
            case "${currentclock:0:1}" in
                "h" ) otherclock="swclock" ;;
                "s" ) otherclock="hwclock" ;;
                * ) j_msg "-${err}" "invalid currentclock" ; return 1 ;;
            esac
            response="" ;
            msg="would you like to change to ${otherclock} ?\n"
            msg+="  y = yes; change | [s|n] = no; keep"
            new_prompt "${msg}"
            case "${response:0:1}" in
                [yY] )
                    j_msg "-${notice}" -p -n "removing current boot runlevel clock service ..." ;
                    rm /etc/runlevels/boot/${currentclock}
                    right_status $? "$notice" || FLAGGED=$TRUE
                    j_msg "-${notice}" -p -n "adding new boot runlevel clock service [${otherclock}] ..."
                    ln -s /etc/init.d/${otherclock} /etc/runlevels/boot/${otherclock}
                    right_status $? "$notice" || FLAGGED=$TRUE
                    ;;
                [nNsS] ) ;;
                * ) j_msg "-${err}" "invalid response" ; return 1 ;;
            esac
            ;;
        * ) j_msg "-${err}" "invalid clock for boot runlevel: [{currentclock}]" ; return 1 ;;
    esac
    [ $FLAGGED ] && return 1
    return 0
}

install-grub() {
    local result=0
    # this should have been installed in /usr/sbin/ (in PATH) by joetoolkit
    # ( maybe add step to edit make.conf and remind user to look at this)
    j_msg "-${notice}" -p "Installing grub ..."
    grub_install_both_ways; result=$?
    j_msg "-${notice}" -p "Done installing grub; result:"
    handle_result $result "" "" || FLAGGED=$TRUE
    j_msg "-${notice}" -p "Setting permissions on grub files ..."
    chmod +x /etc/grub.d/10_linux && \
    chmod +x /etc/grub.d/20_linux_xen; result=$?
    j_msg "-${notice}" -p "Done setting permissions on grub files; result:"
    handle_result $result "" "" || FLAGGED=$TRUE
    j_msg "-${notice}" -p "Running grub-mkconfig ..."
    grub-mkconfig -o /boot/grub/grub.cfg
    j_msg "-${notice}" -p "Done running grub-mkconfig; result:"
    handle_result $result "" "" || FLAGGED=$TRUE
    [ $FLAGGED ] && return 1
    return 0
}


