build-chroot_emerge-command() {
    # in a chroot, the emerge command is a native operation (no special environment modification)
    export chroot_emerge="emerge"
}

emerge-me() {
    # guard - reject invalid arg (payload required)
    if [ $# -lt 1 ] || [ $# -gt 2 ] ; then
        j_msg "-${err}" "one arg (payload) required by ${FUNCNAME[0]}"
        return 1
    fi
    local payload="$1"          # quote here to assemble, but not below, to split into args
    local extra_opts="${2:-}"   # default null
    # use an array to construct the emerge command - dont quote cmd, payload, opts - need to split
    local -a emerge_command=(
        ${chroot_emerge} ${emerge_opts} ${extra_opts} ${payload} ${emerge_trail_opts}
    )
    j_msg "-${notice}" -p "emerging payload with command [${emerge_command[@]}] ..."
    FEATURES="${emerge_features}" "${emerge_command[@]}" ; result=$?
    j_msg "-${notice}" -p -n "Done emerging $payload; result:"
    handle_result $? "" "" "$notice" || return 1
    return 0

}
