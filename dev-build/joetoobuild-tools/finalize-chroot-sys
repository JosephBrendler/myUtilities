build-chroot_emerge-command() {
    # in a chroot, the emerge command is a native operation (no special environment modification)
    export chroot_emerge="emerge"
}

emerge-me() {
    # guard - reject invalid arg (payload required)
    if [ $# -lt 1 ] || [ $# -gt 2 ] ; then
        j_msg "-${err}" "one arg (payload) required by ${FUNCNAME[0]}"
        return 1
    fi
    local payload="$1"          # quote here to assemble, but not below, to split into args
    local extra_opts="${2:-}"   # default null
    # use an array to construct the emerge command - dont quote cmd, payload, opts - need to split
    # shellcheck disable=SC2206
    local -a emerge_command=( ${chroot_emerge} ${emerge_opts} ${extra_opts} ${payload} ${emerge_trail_opts} )
    j_msg "-${notice}" -p "emerging payload with command [${emerge_command[*]}] ..."
    FEATURES="${emerge_features}" "${emerge_command[@]}" ; result=$?
    j_msg "-${notice}" -p -n "Done emerging $payload; result:"
    handle_result $? "" "" "$notice" || return 1
    return 0

}

get-git-and-eselect-repository() {
    # emerge dev-vcs/git and eselect-repository so sync-type = git will work for sync-repo
    # Note: use FEATURES="-buildpkg -getbinpkg" because neither binpkg signing nor verification
    # is set up yet
    local result=0
    local real_features="$emerge_features"  #save global features
    emerge_features="-buildpkg -getbinpkg"  # set temp_features in global variable

    # if they are not already installed, emerge git and eselect-repoasitory
    local my_payload=""
    if ! command -v git &>/dev/null; then
        j_msg "-${notice}" -p "dev-vcs/git is not installed; adding to payload"
        my_payload="dev-vcs/git"
    fi
    if ! eselect repository list &>/dev/null; then
        j_msg "-${notice}" -p "app-eselect/eselect-repository is not installed; adding to payload"
        # add space only if there is already some payload value
        my_payload+="${my_payload:+ }app-eselect/eselect-repository"
    fi
    # format: emerge-me "quoted payload" "quoted extra args"
    if [ ! -z "$my_payload" ]; then
        j_msg "-${notice}" -p "emerging [$my_payload] as a pre-requisite"
        emerge-me "$my_payload" "-1"; result=$?
    fi

    # restore global features
    emerge_features="$real_features"

    return 0
}

validate-prerequisites() {
    # Validate prerequisite expectations -
    ### we should be running inside a chroot
    j_msg "-${notice}" -p -n "Verifying we are inside a chroot ..."
    # Get device and inode numbers for the current root (/)
    current_root_dev_inode=$(stat -c "%d:%i" /)
    # Get device and inode numbers for the root of the init process (/proc/1/root)
    init_root_dev_inode=$(stat -c "%d:%i" /proc/1/root/.)
    # of these do not differ, assume we are NOT in a chroot
    [[ "${current_root_dev_inode}" == "${init_root_dev_inode}" ]] && die "looks like we are NOT in a chroot"
    right_status 0 "$notice"

    ### make.conf should be built for chroot/liveOS rather than crossbuilding
    # but for initial steps, stock stage3 make.conf is ok - fix up after emerging
    # joetoo-platform-meta
#    j_msg "-${notice}" -p -n "Verifying make.conf is built for chroot/liveOS ..."
#    validate_make_conf || die "failed to validate_make_conf"
#    right_status 0 "$notice"
    return 0
}

check-date-time() {
    # if no input was provided, show and check the current time
    if [ -z "$1" ]; then
        j_msg "-${notice}" -p "${BWon}Check current UTC system date/time shown below${Boff}"
        j_msg "-${notice}" -mp -n "${BCon}"; date -u | sed 's|^|    |' ; j_msg "-${notice}" -mp "${Boff}"
    else
        j_msg "-${notice}" -p "${BWon}Check proposed UTC system date/time shown below${Boff}"
        j_msg "-${notice}" -mp -n "${BCon}"; date -u -d "$1" | sed 's|^|    |' ; j_msg "-${notice}" -mp "${Boff}"
    fi
    j_msg "-${notice}" -p "${BWon}(${BMon}Hint:${Boff} verify with ${BGon}date -u${BWon})${Boff} on another system"
    answer="" # global
    yn_prompt "${BWon}Is this correct? ${Boff}"
    case "$answer" in
        y) return 0 ;;
        n) return 1 ;;
    esac
}

set-date-time() {
    local input="" msg="" placeholder=""
    local APPROVED=$FALSE
    # first ask user if the *current time is already valid
    if check-date-time; then APPROVED=$TRUE; fi
    while [ ! $APPROVED ]; do
        msg="    ${BWon}Enter a valid date/time; (format: '${BCon}YYYY-MM-DD HH:MM:SS [AM|PM] [TZ]${BWon}'):${Boff} "
        j_msg -u -mp -n "$msg"
        # generate a valid placeholder based on the current machine's current time
        placeholder="$(date -u +'%Y-%m-%d %H:%M:%S UTC')"

        # -e enables arrow keys, -i pre-fills the line with editable placeholder
        read -e -i "$placeholder" -r input

        # quick guard against malformed input
        if [ ${#input} -lt 8 ]; then
            j_msg "-${err}" -m "${BRon}Error${Boff}Input [$input] is too short (malformed)${Boff}"
            continue  # skip validation and loop to get new input
        fi
        # more thorough input validation
        if ! date -d "$input" +"%Y-%m-%d %H:%M:%S" &>/dev/null; then
            j_msg "-${err}" -m "${BRon}Error${Boff}Improperly formatted input [$input]${Boff}"
            continue  # skip validation and loop to get new input
        fi
        # force the input to start with exactly 4 digits followed by a dash (e.g., 2026-)
        # yes, I know it is a Y3K bug... sorry; given 974 years to fix it, I prefer it to ^[0-9]{4}
        if [[ ! "$input" =~ ^2[0-9]{3}- ]]; then
            j_msg "-${err}" -m "${BRon}Error${Boff} Year must be exactly 4 digits (e.g., YYYY-MM-DD)${Boff}"
            continue
        fi
        if check-date-time "$input"; then APPROVED=$TRUE; fi
    done
    # if there is input; then having passed validation and user-acceptance, set the time; else accept current time
    if [ -n "$input" ]; then
        j_msg "-${notice}" -p -n "Setting datetime ..."
        date -s "$input" &>/dev/null
        handle_result $? "$(date -u +'%Y-%m-%d %H:%M:%S UTC')" '' "$notice" || die "failed to set date"
    fi
}

