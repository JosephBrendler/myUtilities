validate-prerequisites() {
    # Validate prerequisite expectations -
    ### we should be running inside a chroot
    j_msg "-${notice}" -p -n "Verifying we are inside a chroot ..."
    # Get device and inode numbers for the current root (/)
    current_root_dev_inode=$(stat -c "%d:%i" /)
    # Get device and inode numbers for the root of the init process (/proc/1/root)
    init_root_dev_inode=$(stat -c "%d:%i" /proc/1/root/.)
    # of these do not differ, assume we are NOT in a chroot
    [[ "${current_root_dev_inode}" == "${init_root_dev_inode}" ]] && die "looks like we are NOT in a chroot"
    right_status 0 "$notice"

    ### make.conf should be built for chroot/liveOS rather than crossbuilding
    j_msg "-${notice}" -p -n "Verifying make.conf is built for chroot/liveOS ..."
    validate_make_conf || die "failed to validate_make_conf"
    right_status 0 "$notice"
    return 0
}

validate_make_conf() {
    source /etc/portage/make.conf
    j_msg "-${debug}" -p "ROOT: ${ROOT}"
#    [[ "${ROOT}" == "/" ]] && j_msg "-${debug}" -p "ROOT [${ROOT}] == \"/\""
    case "${ROOT}" in
        "/"      ) j_msg "-${notice}" -p -n " (${BGon}Ok${Boff})" ; return 0 ;;
        "/usr/"* ) j_msg "-${notice}" -p " (${BRon}for crossbuilding${Boff})" ; return 1 ;;
        *        ) j_msg "-${notice}" -p " (${BRon}invalid ROOT [${ROOT}]${Boff})" ;  return 1 ;;
    esac
}

run-locale-gen() {
    local result=0
    # /etc/locale.gen and /etc/env.d/02locale were updated by populate-target script
    j_msg "-${notice}" -p "running locale-gen ..."
    locale-gen; result=$?
    right_status $result "$notice" || COMPLETE=$FALSE
    return $result
}

check-reload-config() {
    local result=0
    # check/reload config
    j_msg "-${notice}" -p "checking/reloading config ..."
    gcc-config -l && \
    ldconfig -v && \
    ROOT=/ env-update && \
    source /etc/profile ; result=$?
    right_status $result "$notice" || COMPLETE=$FALSE
    return $result
}

set-password() {
    local result=0
    # set passwd for user $1
    [ $# -ne 1 ] && j_msg "-${err}" "invalid argument for set-password()" && return 1
    user="$1"
    j_msg "-${notice}" -p "please set the password for user [${user}] on this image"
    passwd "${user}" ; result=$?
    handle_result $result "success" "failed to set passwd for user [${user}]" "$notice" || FLAGGED=$TRUE
    return $result
}

set-timezone() {
    local result=0
    #  set timezone
    j_msg "-${notice}" -p -n "setting local timezone (America/New_York) for joetoo ..."
    ln -sf "../usr/share/zoneinfo/${timezone}" /etc/localtime && \
    handle_result $result "success" "fail" "$notice" || FLAGGED=$TRUE
    return $result
}

set-hostname() {
    local result=0
    #  set hostname
    response=""
    j_msg "-${notice}" -p "${BYon}Please identify the hostname for this system${Boff}"
    j_msg "-${notice}" -p "${BMon}Note:${Boff} If you are providing apache ssl or openvpn keys"
    j_msg "-${notice}" -p "via the /etc/joetoobuild-tools/mkimg-files/ structure of this build,"
    j_msg "-${notice}" -p "then they must correspond to this hostname"
    j_msg "-${notice}" -mp ""
    while [[ ! "${response}" == [yYsS] ]] ; do
        j_msg "-${notice}" -p -n "${BGon}*${Boff} set hostname for this image: "
        read -r candidate
        j_msg "-${notice}" -p "you responded [ ${candidate} ]"
        new_prompt "is this correct?"
    done
    if [[ "${response}" == [yY] ]] ; then
        j_msg "-${notice}" -p -n "setting hostname: ${candidate}"
        echo "${candidate}" > /etc/hostname
        # shellcheck disable=SC2320
        handle_result $? "success" "fail" "$notice" || FLAGGED=$TRUE
    else
        j_msg "-${err}" "candidate hostname provided, then rejected"
        j_msg "-${notice}" -p "please make a note to manually run the following command when you have time --"
        j_msg "-${notice}" -p "    ${BBon}echo ${BYon}<hostname> ${BGon}> ${Boff}/etc/hostname"
        return 2
    fi
    return $result
}

remove-kernelsources-mountpoint() {
    local result=0
    j_msg "-${notice}" -p -n "maybe removing kernel sources mountpoint"
    if [ -d /usr/src/linux ] ; then
        rm -r /usr/src/linux ; result=$?
        handle_result $result "success" "fail" "$notice" || FLAGGED=$TRUE
    else
        handle_result 0 "un-necessary" "" "$notice"
    fi
    return $result
}

prep-eix-db-dir() {
    local result=0
    SOFARSOGOOD=$TRUE
    # prepare the directory that will hold the eix database
    j_msg "-${notice}" -p "preparing the eix database directory ..."
    j_msg "-${notice}" -p -n "looking for /var/cache/eix"
    if [ -d /var/cache/eix ] ; then
        handle_result 0 "found" "" "$notice"
    else
        j_msg "-${notice}" -p -n " (creating)"
        mkdir -p /var/cache/eix/ ; result=$?
        handle_result $result "success" "fail" "$notice" || SOFARSOGOOD=$FALSE
    fi
    j_msg "-${notice}" -p -n "setting permissions for /var/cache/eix"
    chown portage:portage /var/cache/eix ; result=$?
    handle_result $result "success" "fail" "$notice" || SOFARSOGOOD=$FALSE
    if [[ ! $SOFARSOGOOD ]] ; then
        FLAGGED=$TRUE
        return 1
    fi
    return 0
}

sync-repo() {
    # use emerge to sync this repository
    local result=0
    local REPO="$1"
    local -a emerge_command=( "${chroot_emerge}" -av --sync "$REPO" )
    # if the eix database directory does not exist, create it and give portage permission to use it
    if [ ! -d /var/cache/eix ] ; then
        j_msg "-${notice}" -p -n "eix database directory does not exist; creating ..."
        mkdir -p /var/cache/eix
        handle_result $? '' '' "$notice" || die "failed to mkdir -p /var/cache/eix"
        j_msg "-${notice}" -p -n "setting permissions on eix database directory ..."
        chown -R portage:portage /var/cache/eix
        handle_result $? '' '' "$notice" || die "failed to chown -R portage:portage /var/cache/eix"
    else
        j_msg "-${notice}" -p "eix database /var/cache/eix already exists"
        j_msg "-${notice}" -p -n "setting permissions on eix database directory ..."
        chown -R portage:portage /var/cache/eix ; right_status $?
    fi
    # just notify which case we have - empty or existing repo
    if [[ -z $(find "/var/db/repos/${REPO}/" -mindepth 1) ]] ; then
        j_msg "-${err}" "Repository ${REPO} is empty"
    else
        j_msg "-${notice}" -p "Repository ${REPO} exists"
    fi
    # run ${chroot_emerge} --sync (explicitly rather than with alias) for this repo
    j_msg "-${notice}" -p "synchronizing portage tree with ${chroot_emerge} -av --sync ${REPO} ..."
    j_msg "-${debug}" -p "chroot_emerge = ${chroot_emerge}"

    "${emerge_command[@]}" ; result=$?
    j_msg "-${notice}" -p -n "Done syncing repo [$REPO]; result:"
    handle_result $result "" "failed: exit status [$result]" || return 1
    return 0
}

add-user() {
    local result=0 au_result=0
    # populate-user -- cb-populate-image should have loaded whatever structure
    #    was found in /etc/joetoobuild-tools/mkimg-files ...
    #    including .bashrc, .ssh/keys...
    #    as long as user populated that structure after emerging joetoobuild-tools
    response=""
    while [[ ! "${response}" == [yYsS] ]] ; do
        j_msg "-${notice}" -mp ""
        j_msg "-${notice}" -p -n "${BGon}*${Boff} set username for routine daily user: "
        read -r candidate
        j_msg "-${notice}" -p "you responded [ ${candidate} ]"
        new_prompt "is this correct?"
    done
    if [[ "${response}" == [yY] ]] ; then
        j_msg "-${notice}" -p -n "setting up user ${candidate}"
        useradd -m -G wheel,console,audio,cdrom,video,cdrw,usb,users,portage -s /bin/bash "${candidate}"
        result=$?
        handle_result $result "" "" "$notice" || { FLAGGED=$TRUE; au_result=1 ; }
    else
        j_msg "-${err}" "candidate username provided, then rejected"
        j_msg "-${notice}" -p "please make a note to manually run the following command when you have time --"
        j_msg "-${notice}" -p "    useradd ${BMon}-m -G${Boff} wheel,console,audio,cdrom,video,cdrw,usb,users,portage ${BMon}-s${Boff} /bin/bash ${BRon}\${username}${Boff}"
        au_result=$(( au_result | 2 ))
    fi

    if [ "$au_result" -eq 0 ] ; then
        # set password for this user
        set-password "${candidate}" ; result=$?
        j_msg "-${notice}" -p -n "Done setting password; result:"
        handle_result $result "" "" "$notice" || { FLAGGED=$TRUE; au_result=$(( au_result | 4 )); }
    fi
    return $au_result
}

fix-inittab() {
    local result=0 fi_result=0
    j_msg "-${notice}" -p -n "fixing /etc/inittab s0..."
    sed -i 's|^s0:|#s0:|' /etc/inittab ; result=$?
    handle_result $result "" "" "$notice" || { FLAGGED=$TRUE; fi_result=1 ; }

    j_msg "-${notice}" -p -n "fixing /etc/inittab f0..."
    sed -i 's|^f0:|#f0:|' /etc/inittab ; result=$?
    handle_result $result "" "" "$notice" || { FLAGGED=$TRUE; fi_result=$(( fi_result | 2 )) ; }
    return 0
}

write-fstab() {
    local result=0 temp_str=""
    # get root_dev (-P produces assignable var/val pairs; grep mountpoint ensures output TARGET matches mountpoint)
    j_msg "-${notice}" -p -n "determining root_dev ..."
    local root_mountpoint="/" SOURCE="" TARGET=""
    # use read with process substitution to get the SOURCE volume for root_mountpoint
    read -r SOURCE TARGET < <(findmnt -no SOURCE,TARGET --target "${root_mountpoint}")
    [ ! -z "$SOURCE" ] && root_dev="${SOURCE}"
    handle_result $? "$root_dev" "" "$notice" || die "failed to assign root_dev"
    # get boot_dev (-P produces assignable var/val pairs; grep mountpoint ensures output TARGET matches mountpoint)

    j_msg "-${notice}" -p -n "determining boot_dev ..."
    local boot_mountpoint="/boot"
    SOURCE=""; TARGET=""
    read -r SOURCE TARGET < <(findmnt -no SOURCE,TARGET --target "${boot_mountpoint}")
    [ ! -z "$SOURCE" ] && boot_dev="${SOURCE}"
    handle_result $? "$boot_dev" "" "$notice" || die "failed to assign boot_dev"

    # get blkid data for root_dev
    j_msg "-${notice}" -p -n "getting blkid data for root_dev"
    # use blkid directly on the device and parse the key=value pairs safely
    while IFS='=' read -r key value; do
        case "$key" in
            TYPE)     root_fstype="$value" ;;
            UUID)     root_uuid="$value" ;;
            PARTUUID) root_partuuid="$value" ;;
        esac
    done < <(blkid -o export "${root_dev}")
    handle_result $? "" "" "$notice" || die "failed to get blkid data for root_dev"
    j_msg "-${notice}" -p "    fstype: ...: [${root_fstype}]"
    j_msg "-${notice}" -p "    uuid: .....: [${root_uuid}]"
    j_msg "-${notice}" -p "    partuuid ..: [${root_partuuid}]"
    # set fstab opts and dump-pass strings for root
    root_opts="noatime"
    root_dp="0 1"

    # get blkid data for boot_dev
    while IFS='=' read -r key value; do
        case "$key" in
            TYPE)     boot_fstype="$value" ;;
            UUID)     boot_uuid="$value" ;;
            PARTUUID) boot_partuuid="$value" ;;
        esac
    done < <(blkid -o export "${boot_dev}")
    handle_result $? "" "" "$notice" || die "failed to get blkid data for boot_dev"
    j_msg "-${notice}" -p "    fstype: ...: [${boot_fstype}]"
    j_msg "-${notice}" -p "    uuid: .....: [${boot_uuid}]"
    j_msg "-${notice}" -p "    partuuid ..: [${boot_partuuid}]"
    # set fstab opts and dump-pass strings for boot
    boot_opts="noatime,noauto,nodev,nosuid,noexec"
    boot_dp="1 2"

    # write (append) fstab line for /boot
    # (for img or upd chroots, PARTUUIDs will have to be changed wen image is written to new media, e.g. sd card)
    if [ ! -z "${boot_dev}" ] ; then
        # prefer PARTUUID if available
        if [ ! -z "$boot_partuuid" ] ; then
            temp_str="PARTUUID=${boot_partuuid}"
        elif [ ! -z "$boot_uuid" ] ; then
            temp_str="PARTUUID=${boot_uuid}"
        else
            die "no valid boot device id found for fstab construction"
        fi
        j_msg "-${notice}" -p -n "writing (appending) fstab line for /boot ..."
        printf '%s\t%s\t\t%s\t\t%s\t\t%s' "${temp_str}" "${boot_mountpoint}" "${boot_fstype}" "${boot_opts}" "${boot_dp}" >> /etc/fstab
        handle_result $? "" "" "$notice" || { FLAGGED=$TRUE ; j_msg "-${err}" "failed to write boot line of fstab" ; }
    fi

    # write (append) fstab line for /
    # (for img or upd chroots, PARTUUIDs will have to be changed wen image is written to new media, e.g. sd card)
    if [ ! -z "${root_dev}" ] ; then
        # prefer PARTUUID if available
        if [ ! -z "$root_partuuid" ] ; then
            temp_str="PARTUUID=${root_partuuid}"
        elif [ ! -z "$root_uuid" ] ; then
            temp_str="PARTUUID=${root_uuid}"
        else
            die "no valid root device id found for fstab construction"
        fi
        j_msg "-${notice}" -p -n "writing (appending) fstab line for / ..."
        printf '%s\t%s\t\t%s\t\t%s\t\t%s' "${temp_str}" "${root_mountpoint}" "${root_fstype}" "${root_opts}" "${root_dp}" >> /etc/fstab
        handle_rtemp_stresult $? "" "" "$notice" || { FLAGGED=$TRUE ; j_msg "-${err}" "failed to write root line of fstab" ; }
    fi

    # write (append) a placeholder fstab line for swap
    j_msg "-${notice}" -p -n "writing (appending) fstab placeholder line for /var/cache/swap/swap1 ..."
    printf '%s\t%s\t\t%s\t\t%s\t\t%s' "/var/cache/swap/swap1" "none" "swap" "sw" "0 0" >> /etc/fstab
    handle_result $? "" "" "$notice" || { FLAGGED=$TRUE ; j_msg "-${err}" "failed to write swap line of fstab" ; }
    # shellcheck disable=SC2086
    [ $FLAGGED ] && return 1
    return 0
}

