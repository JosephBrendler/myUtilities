get-run-resolve-march-native-and-cpuid2cpuflags() {
    # emerge resolve-march-native and cpuid2cpuflags if not installed
    local result=0
    local my_payload=""
    local INSTALLED=$TRUE # assuming they may already be installed
    local output=""
    local _temp_file="" _target_file=""
    if ! command -v resolve-march-native &>/dev/null; then
        j_msg "-${notice}" -p "resolve-march-native is not installed; adding to payload"
        my_payload="app-misc/resolve-march-native"
    fi
    if ! command -v cpuid2cpuflags &>/dev/null; then
        j_msg "-${notice}" -p "cpuid2cpuflags is not installed; adding to payload"
        # add space only if there is already some payload value
        my_payload+="${my_payload:+ }app-portage/cpuid2cpuflags"
    fi
    # format: emerge-me "quoted payload" "quoted extra args"
    if [ ! -z "$my_payload" ]; then
        j_msg "-${notice}" -p "emerging [$my_payload] as non-world-selected"
        emerge-me "$my_payload" "-1" ; result=$?
        j_msg "-${notice}" -p -n "Done emerging [$my_payload]; result:"
        handle_result $result "" "" || INSTALLED=$FALSE
    fi
    # if these commands are installed, then offer to use them
    if [ $INSTALLED ] ; then
        # compute resolve-march-native output and offer to prepend
        if command -v resolve-march-native &>/dev/null; then
            output=$(resolve-march-native)
        else
            die "resolve-march-native requested, but it is not installed"
        fi
        j_msg "-${notice}" -p "resolve-march-native returned --"
        j_msg "-${notice}" -m "[$output]"
        response=""
        yns_prompt "${BYon}Prepend to make.conf? ${BWon}(y:yes; s:skip this step; n:abort and exit) "
        case "${response:0:1}" in
            [sS]) : ;;  # do nothing; just skip
            [nN]) die "Aborting as instructed" ;;
            [yY])
                _target_file="/etc/portage/make.conf"
                mkdir -p "${_target_file%/*}"             # make sure the directory exists
                # build prepend content in tempfile (remove with atomic write)
                _temp_file=$(mktemp /etc/portage/make.conf.XXXXXX)
                # assemble content with command grouping and then replace target file with atomic write
                {
                    printf '##COMMON_FLAGS staged by joetoo using resolve-march-native\n'
                    printf 'COMMON_FLAGS="%s"\n\n' "-O2 -pipe ${output}"
                    # preserve existing content; do not strip active COMMON_FLAGS, offer new one
                    # (use || true to prevent set -e failure if cat cannot find $_target_file)
                    cat "$_target_file" 2>/dev/null || true
                } > "$_temp_file"
                # set permissions and do atomic write to target file
                chmod 0644 "$_temp_file" && mv "$_temp_file" "$_target_file"; result=$?
                j_msg "Done; result:"
                handle_result $result '' '' "$notice" || die "failed to chmod or mv [$_target_file]"
                ;;
            *   ) die "Invalid prepend make.conf case in ${FUNCNAME[0]}" ;;
        esac

        # compute cpuid2cpuflags output and offer to append
        if command -v cpuid2cpuflags &>/dev/null; then
            output=$(cpuid2cpuflags)
        else
            die "cpuid2cpuflags requested, but it is not installed"
        fi
        j_msg "-${notice}" -p "cpuid2cpuflags returned --"
        j_msg "-${notice}" -m "[$output]"
        response=""
        yns_prompt "${BYon}Append to package.use/00cpu-flags? ${BWon}(y:yes; s:skip this step; n:abort and exit) "
        case "${response:0:1}" in
            [sS]) : ;;  # do nothing; just skip
            [nN]) die "Aborting as instructed" ;;
            [yY])
                _target_file="/etc/portage/package.use/00cpu-flags"
                mkdir -p "${_target_file%/*}"             # make sure the directory exists
                # build append content in tempfile (remove with atomic write)
                _temp_file=$(mktemp /etc/portage/package.use/00cpu-flags.XXXXXX)
                # assemble content with command grouping and then replace target file with atomic write
                {
                    # preserve existing content but strip old/active CPU_FLAGS entries
                    # (use || true to prevent set -e failure if grep matches nothing, which is ok)
                    grep -v "^${W0}\*/\* CPU_FLAGS_X86=" "$_target_file" 2>/dev/null || true
                    # append a comment and the new line if there is one
                    printf '##cpu-flags staged by joetoo using cpuid2cpuflags\n'
                    [ -n "$output" ] && printf '*/* %s\n' "$output"
                } > "$_temp_file"
                # set permissions and do atomic write to target file
                chmod 0644 "$_temp_file" && mv "$_temp_file" "$_target_file"; result=$?
                j_msg "Done; result:"
                handle_result $result '' '' "$notice" || die "failed to chmod or mv [$_target_file]"
                ;;
            *   ) die "Invalid prepend make.conf case in ${FUNCNAME[0]}" ;;
        esac
    else
        j_msg "failed to emerge and use resolve-march-native and/or cpuid2cpuflags"
        return 1
    fi
    return 0
}

