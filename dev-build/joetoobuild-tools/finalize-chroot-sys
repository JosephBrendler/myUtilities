# to_do: migrate this to script_header_joetoo_extended
# (it should enable bash array/run_array scripts to continue using the POSIX process_cmdline functions
#  because it should override the definition of this function in script_header_joetoo by being loaded AFTER)
_get_entry() # (BASH) get human readable description for command sequence step number
{ ge_ret=0; if ! isint "$1"; then j_msg -${err} "error: zero args; _get_desc requires $1 step number"; return 1; fi
  _ge_raw_cmd="${command_sequence[${1}]}"  # the actual command
  _ge_desc="${msg1_sequence[${1}]}"  # human readable description
  _ge_clean_cmd=$(printf -- '%b' "$_pa_cmd" | strip_ansi | _translate_escapes)
#  j_msg -${debug} "_ge_entry: $_ge_entry"
#  j_msg -${debug} "_ge_desc: $_ge_desc"
  case $2 in
    1 ) printf '%s' "$_ge_desc" ;;
    2 ) printf '%s' "$_ge_clean_cmd" ;;
    3 ) printf '%s' "$_ge_raw_cmd" ;;
    * ) j_msg -${err} "invalid format [$2]"; ge_ret=1
  esac
  unset -v _ge_entry _ge_desc _ge_raw_cmd _ge_clean_cmd
  return $ge_ret
}
# @usage _get_entry <step_number> <format_type>
# @args $1 (int) the 0-indexed step number to retrieve from the command sequence
# @args $2 (int) format type: 1=description, 2=cleaned command, 3=raw command
# @vars cmd_seq_file (global) path to the temporary command sequence file
# @vars US (global) Unit Separator character used as the delimiter
# @vars ret (global) initialized to 0 for exit status tracking
# @deps isint, j_msg -${err}, sed, printf, strip_ansi, _translate_escapes
# @rule extracts specific lines from the command sequence file and parses by $US delimiter
# @ret 0 on success (prints requested string to stdout); 1 on invalid arguments
# @note uses _ge_ prefix for local variables; unsets all before returning
# @note format 2 uses strip_ansi and _translate_escapes for log-safe output


initialize_variables() {
    j_msg "-${notice}" -p "initializing ..."

    # newer versions of initialize_vars protect standard joetoo variables like verbosity and INTERACTIVE
    initialize_vars "${varlist}"

    # set default values
    FLAGGED=$FALSE
    j_msg "-${info}" -p -n "sourcing BUILD ..."
    source /etc/joetoobuild-tools/BUILD
    right_status $? "$info" || FLAGGED=$TRUE

    j_msg "-${info}" -p -n "sourcing BPN ..."
    source /etc/joetoobuild-tools/BPN
    right_status $? "$info" || FLAGGED=$TRUE

    j_msg "-${info}" -p -n "initializing default starting_step = 0"
    export starting_step=0
    right_status $? "$info" || FLAGGED=$TRUE

    j_msg "-${info}" -p -n "initializing default stopping_step = $(( ${#command_sequence[@]} - 1 ))"
    export stopping_step=$(( ${#command_sequence[@]} - 1 ))
    right_status $? "$info" || FLAGGED=$TRUE

    j_msg "-${info}" -p -n "initializing num_cmds ${#command_sequence[@]}"
    export num_cmds="${#command_sequence[@]}"
    right_status $? "$info" || FLAGGED=$TRUE

    j_msg "-${info}" -p -n "initializing default status_file = /root/bin/finalizechrootjoetoo_status"
    export status_file="/root/bin/finalizechrootjoetoo_status"
    right_status $? "$info" || FLAGGED=$TRUE

    j_msg "-${info}" -p -n "setting PN = ${0##*/}"
    PN=${0##*/}
    right_status $? "$info" || FLAGGED=$TRUE

    j_msg "-${info}" -p -n "setting timezone"
    timezone=America/New_York
    handle_result $? "$timezone" "" "$info" || FLAGGED=$TRUE

    j_msg "-${info}" -p -n "setting emerge_features"
    emerge_features="buildpkg"
    handle_result $? "$timezone" "" "$info" || FLAGGED=$TRUE

    j_msg "-${info}" -p -n "setting emerge_opts"
    if [ $INTERACTIVE ] ; then emerge_opts="-uavDNg"; else emerge_opts="-uvDNg"; fi
    handle_result $? "$emerge_opts" "" "$info" || FLAGGED=$TRUE

    j_msg "-${info}" -p -n "setting emerge_trail_opts"
    emerge_trail_opts="--keep-going --verbose-conflicts --with-bdeps=y"
    return 0
    handle_result $? "$emerge_opts" "" "$info" || FLAGGED=$TRUE

    if [[ $FLAGGED ]] ; then
        j_msg "-${err}" "failed clean exit; note red flags above"
        return 1
    else
        j_msg "-${notice}" -p "initialization complete"
        return 0
    fi
}

