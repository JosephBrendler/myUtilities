# (it should enable bash array/run_array scripts to continue using the POSIX process_cmdline functions
#  because it should override the definition of this function in script_header_joetoo by being loaded AFTER)
usage() # (BASH) explain default usage; redo for command_sequence array use (NOT extensible with local usage module)
{
  local N="${num_cmds}"
  local _u_step=0 _u_entry="" _u_desc=""

  separator "${PN}-${BUILD}" "(usage)"
  j_msg -${err} "${BRon}Usage: ${BGon}${PN} [-[options]] ${Boff}"
  j_msg -${notice} -m "${BYon}valid commandline options --${Boff}"
  j_msg -${notice} -m "${BMon}  -h | --help${Boff}${Con} ...............:${Boff} print this usage message"
  j_msg -${notice} -m "${BMon}  -I | --interactive${Boff}${Con} ........:${Boff} run supervised; confirm execution of each step"
  j_msg -${notice} -m "${BMon}  -N | --noninteractive${Boff}${Con} .....:${Boff} run un-supervised; automatically do each step"
  j_msg -${notice} -m "${BMon}  -s | --status${Boff}${Con} .............:${Boff} return status (next step, step_number)"
  j_msg -${notice} -m "${BMon}  -r | --resume${Boff}${Con} .............:${Boff} resume at next step in status_file"
  j_msg -${notice} -m "${BMon}  -l | --logging${Boff}${Con} ............:${Boff} turn on logging to logFile"
  j_msg -${notice} -m "${BMon}  -v | --verbose${Boff}${Con} ............:${Boff} increase verbosity"
  j_msg -${notice} -m "${BMon}  -q | --quiet${Boff}${Con} ..............:${Boff} decrease verbosity"
  j_msg -${notice} -m "${BMon}  -V | --VERBOSE | --DEBUG${Boff}${Con} ..:${Boff} force DEBUG output, ignoring verbosity, unless silenced"
  j_msg -${notice} -m "${BMon}  -Q | --QUIET | --SILENCE${Boff}${Con} ..:${Boff} set QUIET (silent) output, ignoring verbosity and DEBUG"
  j_msg -${notice} -m "${BMon}  -[1-${N}]${Boff}${Con}..................:${Boff} save N to status file and resume at step N"
  j_msg -${notice} -m "  ${BYon}*${Boff} Single-character options may be combined."
  j_msg -${notice} -m "    e.g. ${BGon}${PN} --verbose -nqr8${Boff} would resume non-interactively"
  j_msg -${notice} -m "    (automatic, unsupervised) at step 8 with normal verbosity"
  j_msg -${notice} -m "${BYon}Caveat:${Boff}"
  j_msg -${notice} -m "${BMon}   -I${Boff}${Con}. (interactive/supervised) is on by default${Boff}"
  j_msg -${notice} -m "${BMon}   -r${Boff}${Con}. (resume) sets starting_step to # in [ $status_file ]${Boff}"
  j_msg -${notice} -m "${BMon}   -[1-${N}]${Boff}${Con}. sets starting_step (default 1 otherwise)${Boff}"
  # source user-script specific usage-module which should be built in the same format
  j_msg -${notice} -m "${BMon}additional ${app_customization_root} - commandline options:${Boff}"

  if [ ${#command_sequence[@]} -gt 0 ] ; then
    j_msg -${notice} -M "$idx_hammer_and_wrench" "${BYon}${PN} workflow sequence (steps):${Boff}"
    for ((_u_step=0; _u_step<${#command_sequence[@]}; _u_step++ )); do
      _u_entry="${command_sequence[${_u_step}]}"   # extract the specific line corresponding to the current step counter
      _u_desc="${msg1_sequence[${_u_step}]}"       # human readable description
      j_msg -${notice} -M "$idx_wrench"  "${BBon}[${Boff}${Yon}${_u_step}${BBon}]${Boff} ${Con}${_u_desc}${Boff}"
    done
  fi
  leave "normal exit from usage"
}
