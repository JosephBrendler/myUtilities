#!/bin/bash
#
# Automate production of a kbuild output sed filter
#
# e.g. run once with no arg redir output to file1
#      then run again with $1 = /home/joe/raspi-sources/linux, and
#      * append to file1 with >>, then sort -u file1 > file2
#      then edit/use the contents of file2 to populate a block
#      in kernelupdate, like -
#      export make_work_filter="
#      s|...|...|;
#      ...
#      "
#      (semicolon delimited substitution clauses)
#      and use in the script like -
#      "${make_me[@]}" mrproper | sed "$make_work_filter"
#
sources_dir="${1:-/usr/src/linux/}"

readarray -t kbuild_verbs < <(
    grep -iR quiet_cmd "$sources_dir" | \
    cut -d'=' -f2 | awk '{print $1}' | \
    sort -u | grep -vE '^\$|^/|^$' | grep -v 'echo'
)

echo "ingested [${#kbuild_verbs[@]}] kbuild verbs"
echo; echo

make_work_filter=""

for verb in "${kbuild_verbs[@]}"; do
    case "$verb" in
        AR|ARCHIVE|FIT|ITB|ITS|TAR) metaphor="\$bin_package" ;;
        AS|AS32|PASYMS|SPU_AS) metaphor="\$bin_wrench" ;;
        ASN.1|LDS) metaphor="\$bin_scroll" ;;
        BINDGEN|OBJCOPY|COPY|CPUSTR|STUBCPY|UIMAGE|UIMAGE.O|X32)
            metaphor="\$bin_dna" ;;
        BISON) metaphor="\$bin_bison" ;;
        BLDFW|DUMPSYMS|HDRTEST|TEST)
            metaphor="\$bin_test_tube" ;;
        BOOTAR) metaphor="\${bin_uBOOT}\${bin_package}" ;;
        BOOTAS) metaphor="\${bin_uBOOT}\${bin_wrench}" ;;
        BOOTCC) metaphor="\${bin_uBOOT}\${bin_hammer}" ;;
        BTF|SCHEMA) metaphor="\$bin_triangular_ruler" ;;
        BUILD|CC|CC32|CXX|SPU_CC)
            metaphor="\$bin_hammer" ;;
        BZIP2|GZIP|LZ4|LZMA|LZO|XIPZ|XZ|XZKERN|XZMISC|ZSTD|ZSTD22)
            metaphor="\$bin_clamp" ;;
        CALL|SYSCALL) metaphor="\$bin_telephone" ;;
        CAT) metaphor="\$bin_cat" ;;
        CERT|GENKEY) metaphor="\$bin_key" ;;
        CHECK|CHKDT|CHKFTRC|CHKHEAD|CHKREL|LLSCCHK|PROMCHK)
            metaphor="\$bin_magnifying_glass_left" ;;
        CHKSHA1) metaphor="\$bin_lock" ;;
        CLEAN|LINT) metaphor="\$bin_broom" ;;
        CPP|OBJSTRIP|RSCPP|SO2S|STRIP)
            metaphor="\$bin_scissors" ;;
        CONMK|YACC|MODPOST) metaphor="\$bin_puzzle" ;;
        DEPMOD) metaphor="\$bin_spider_web" ;;
        DESCEND) metaphor="\$bin_ladder" ;;
        DEVLIST) metaphor="\$bin_catalog" ;;
        DTC) metaphor="\$bin_tree_deciduous" ;;
        DTEX) metaphor="\$bin_magnet" ;;
        ECOFF) metaphor="\$bin_relic" ;;
        ELFTOAOUT|MKELF|M68KAS|M68KLD|MKCAP|MKDIR|MKELF|MKLST|MKMAP|MKPIGGY|MKREG)
            metaphor="\$bin_bricks" ;;
        EXPORTS) metaphor="\$bin_outbox" ;;
        FLEX) metaphor="\$bin_toolbox" ;;
        GEN|GENHDR|GENIMAGE|GENKDB|GENMAP|GENVDSO)
            metaphor="\$bin_seedling" ;;
        GENSEED) metaphor="\$bin_dice" ;;
        HDRINST) metaphor="\$bin_inbox" ;;
        HEXDUMP) metaphor="\$bin_hex_digits" ;;
        HOSTCC|HOSTCXX|HOSTRUSTC) metaphor="\$bin_pickaxe" ;;
        HOSTLD) metaphor="\${bin_house}\${bin_chain}" ;;
        HYPCOPY|HYPERCALLS|HYPREL) metaphor="\${bin_uCLOUD}" ;;
        INSTALL) metaphor="\$bin_hammer_and_wrench" ;;
        IPE_POL|POLICY) metaphor="\$bin_shield" ;;
        LD|LD32|SPU_LD|SYMLINK) metaphor="\$bin_chain" ;;
        LEX) metaphor="\$bin_open_book" ;;
        LOGO) metaphor="\$bin_palette" ;;
        MOC) metaphor="\$bin_mask" ;;
        MUNGE) metaphor="\$bin_cyclone" ;;
        OVL) metaphor="\$bin_onion" ;;
        PAD|VOFFSET|ZOFFSET) metaphor="\$bin_ruler" ;;
        PERL|PERLASM) metaphor="\$bin_camel" ;;
        PIGGY) metaphor="\$bin_piggy" ;;
        QUOTE) metaphor="\$bin_speech_bubble" ;;
        REMOVE) metaphor="\$bin_trash_can" ;;
        RELOCS) metaphor="\$bin_paper_clip" ;;
        RUSTDOC) metaphor="\$bin_books" ;;
        SECTCMP) metaphor="\$bin_bar_chart" ;;
        SEEDHDR) metaphor="\$bin_chestnut" ;;
        SYSHDR) metaphor="\$bin_bookmarks" ;;
        SIGN) metaphor="\$bin_lock_pen" ;;
        SPHINX|SYSHDR|SYSNR|SYSTBL) metaphor="\$bin_blue_book" ;;
        STUB_EXE) metaphor="\$bin_rocket" ;;
        TABLE) metaphor="\$bin_clipboard" ;;
        TOUCH) metaphor="\$bin_touch" ;;
        UNROLL) metaphor="\$bin_paper_roll" ;;
        VDSO*) metaphor="\$bin_compass" ;;
        WRAP) metaphor="\$bin_giftwrap" ;;
        UPD) metaphor="\$bin_refresh" ;;
    esac

    make_work_filter+="s|^\${W0}${verb} |   $metaphor $verb |;\n"

done

echo -e "$make_work_filter"


