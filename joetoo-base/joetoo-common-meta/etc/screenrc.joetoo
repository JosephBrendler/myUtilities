# /etc/screenrc.joetoo
# Gentoo baseline is set in /etc/screenrc
# /etc/screenrc.joetoo establishes fleet-wide template
# user can override in ~/.screenrc

# enable UTF‑8 (when safe)
defutf8 on
utf8 on
# dsable C1 control code interpretation
# (prevents UTF‑8 continuation bytes from being misinterpreted as C1 control codes)
defc1 off
# enable background color erase (BCE)
# (required for $BGon, $BOon, $Boff to behave correctly)
defbce on
# advertise 256‑color capability
term screen-256color



