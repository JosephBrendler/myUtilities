#INPUT_DEVICES="evdev"     # (deprecated) Linux kernel's generic input event interface
#INPUT_DEVICES="libinput"  # originally developed as Synaptics driver for touchpads
# old guides recommended using both but it's not necessary
# (X11 prefers libinput, Wayland ignores evdev, evdev can cause duplicate device enumeration,
#  evdev can break touchpad gestures or touchscreen calibration, and evdev has been deprecated)
# use libinput - the modern unified input stack for mice, kbds, touchpads, touchscreens
INPUT_DEVICES="libinput"
