ARCH="arm"
# use these for cross-building (otherwise, CHOST is now set in the profile)
CHOST="armv6j-unknown-linux-gnueabihf"
CBUILD=x86_64-pc-linux-gnu
ROOT=/usr/${CHOST}/
CTARGET="${CHOST}"
SYSROOT="/usr/${CHOST}/"
# comment-out lines above, and use this (below) for chroot
# (or carefully use alias emerge-chroot to specify ROOT, CBUILD, CHOST)
#ROOT=/
#CTARGET="${CHOST}"
#SYSROOT="/"
