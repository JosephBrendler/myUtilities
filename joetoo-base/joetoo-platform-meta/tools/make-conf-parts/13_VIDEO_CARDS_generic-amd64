# Intel GPUs (mapping: 
#  Kernel driver (KMS / DRM)......: i915 -------- the only kernel driver for Intel GPUs Gen 3 → 12 [ CONFIG_DRM_I915=y ]
#
#  Mesa driver (3D acceleration)..: iris -------- gen 8-12 (broadwell skylake, alderlake)
#                                   i965 -------- gen 4-7  (ivybridge, haswell, arrandale, sandybridge, broadwell)(fallback for gen 8) 
#                                   i915 -------- gen 3    (ivybridge)
#
#  Xorg driver (if you have X)....: intel ------- this is a wrapper (deprecated)
#                                   modesetting - this is preferred (auto‑selected)
# Note on form below: VIDEO_CARDS="mesa mesa xorg"
# (the default below leaves xorg blank to force x to pick modesetting)
VIDEO_CARDS="iris i965"

# AMD GPUs 
# Note on form: VIDEO_CARDS="[kms-driver] [mesa-driver]"
#VIDEO_CARDS="amdgpu radeonsi"
# NVIDIA (open source) GPUs
# Note on form: VIDEO_CARDS="[kms-driver]"
#VIDEO_CARDS="nouveau"
# NVIDIA (proprietary) GPUs
# Note on form: VIDEO_CARDS="[proprietary-driver]"
#VIDEO_CARDS="nvidia"
