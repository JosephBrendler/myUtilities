# explicitly opt in on Gentoo's new standard binary package format
BINPKG_FORMAT="gpkg"

# standard FEATURES set for joetoo --
FEATURES=""
FEATURES="${FEATURES} -pid-sandbox"           # off: breaks too many packages
FEATURES="${FEATURES} -user-sandbox"          # off: prevent breakage in cross-arch and distcc builds (esp. for SBCs)
FEATURES="${FEATURES} -userpriv"              # off: prevent breakage in cross-arch and distcc builds (esp. for SBCs)
FEATURES="${FEATURES} -collision-protect"     # (obsolete) turn off b/c it breaks binpkg upgrades, multi-slot install

FEATURES="${FEATURES} sandbox"                # prevents ebuilds from doing stupid things in the production system
FEATURES="${FEATURES} parallel-fetch"         # fetch while building; saves time on slow SBCs
FEATURES="${FEATURES} merge-sync"             # prevents portage from blowing away metadata during sync
FEATURES="${FEATURES} fixlafiles"             # keeps .la files from breaking linking on mixed‑arch systems
#FEATURES="${FEATURES} deterministic"         # reproducible builds across architectures (slows down builds)

FEATURES="${FEATURES} buildpkg"               # build binpkgs for everything (serve to others)
FEATURES="${FEATURES} getbinpkg"              # use external binhost when available
FEATURES="${FEATURES} binpkg-multi-instance"  # required for multi-slot pkgs and gpkg, cluster consistency

#FEATURES="${FEATURES} noman"                 # save space on sbcs
FEATURES="${FEATURES} noinfo"                 # save space on sbcs
FEATURES="${FEATURES} nodoc"                  # save space on sbcs

#FEATURES="${FEATURES} ccache"                # cache compiled results (off until ABI/distcc problems get fixed)
FEATURES="${FEATURES} distcc"                 # participate in distributed compile cluster

# FUTURE: add binpkg signing
#FEATURES="${FEATURES} sign"                  # sign binpkgs
#PORTAGE_GPG_KEY="<binpkg-sign-key"           # sign binpkgs

# Maintainer Notes:
# (1) normally, one box might be best to use "userpriv" but this joetoo template is tuned to support
#     a cross-arch distcc cluster, cross-builds for entire systems, binpkgs for multiple arch's,
#     and SBCs with toolchain quirks
# (2) per-package env overrides are available and should also be curated
# (3) precedence: lowest to highest: make.conf, per-package env, command line...
#   *** so app-portage/jus needs to be corrected to NOT override per-package env choices
#       by adding FEATURES= on the command line ***
