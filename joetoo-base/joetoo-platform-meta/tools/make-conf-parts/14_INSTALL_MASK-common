# INSTALL_MASK is a post‑build, pre‑merge filter that tells portage -
# “After building the package, but before merging it into ROOT, delete these paths”
# It is used to strip unwanted locales, documentation, examples, manpages,
#   bundled unwanted libraries, and files that would conflict with the live system layout
#INSTALL_MASK="/usr/share/dev-perl/DBD-mysqllocale \
#  -/usr/share/locale/en \
#  -/usr/share/locale/en_US \
#  -/usr/share/locale/kf5_all_languages \
#  -/usr/share/locale/locale.alias"
# The above was used to mask all and selectively unmask english - not needed any more, since
#   L10N and LINGUAS in /etc/portage/package.use/02localization

# UNINSTALL_IGNORE is also a post-build filter but in the other direction; it tells portage -
# "When uninstalling a package, do NOT delete these paths"
# It is used to protect symlinks, directories, files owned/installed by mutiple packages,
#   and files that must persist across upgrades
# otherwise apache2 uninstalls my symlink /var/www --> /srv/www
UNINSTALL_IGNORE="
  /lib/modules/*
  /var/www
  /boot/*.dtb
"

# CONFIG_PROTECT_MASK tells portage -
# "Do NOT treat these paths as config files;overwrite them without ._cfg0000 files.
# It is used for generated/ephemeral files that should never be preserved
#   across upgrades
CONFIG_PROTECT_MASK="/etc/crossbuild-tools"
