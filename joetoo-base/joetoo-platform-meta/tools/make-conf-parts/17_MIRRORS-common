# KERNEL= setting no longer required in modern Gentoo - removal scheduled for 1 August 2026
#KERNEL="linux"

QEMU_SOFTMMU_TARGETS="aarch64 arm x86_64"
QEMU_USER_TARGETS="aarch64 arm x86_64"

LLVM_TARGETS="AArch64 ARM X86"

# GENTOO_MIRRORS - optimized choices for support to Northern Virginia
#   LeaseWeb runs an Anycast CDN for Gentoo, with US East node in Washington, DC (fastest mirror for Northern VA)
#     peering with Equinix Ashburn - biggest IX on east coast, Verizon, Comcast, Cox, CentruryLink
#     20260407 - ipv4: 5.82 ms, no AAAA record for ipv6
#   OSUOSL (Oregon State University Open Source Lab) is Gentoo’s primary upstream mirror provider,
#     nodes in Oregon, Chicago, NY (latter 2 supporting east coast)
#     (high reliability, excellent uptime, and strong bandwidth)
#     20260407 - ipv4:  81.7 ms, ipv6: 80.7 ms
#   Virginia Tech (Blacksburg, VA) - good regional mirror Ashburn -> Blackburg low latency, well maintained academic mirror
#     20260407 - ipv4: 10.4 ms, ipv6: 10.9 ms
#   Rochester Institute of Technology (RIT) (Rochester, NY) - solid, well‑maintained academic mirror
#     20260407 - ipv4: 26.5 ms, ipv6: 190.ms
GENTOO_MIRRORS="
  https://mirror.leaseweb.com/gentoo/
  http://gentoo.osuosl.org/
  http://mirror.cc.vt.edu/pub/gentoo/
  http://mirrors.rit.edu/gentoo/
"
