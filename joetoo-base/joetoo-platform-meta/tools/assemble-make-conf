#source /usr/sbin/cb-common-functions ; right_status $? ${notice}
#TARGET=""

# override usage in script_header_joetoo and local.usage in crossbuild-tools
usage() {
    j_msg -${notice} -p "${BRon}usage: ${BGon}${PN} <BOARD> <CONFIG>${Boff}"
    j_msg -${notice} -mp ""
    j_msg -${notice} -p "${BYon}  BOARD must be one of the following --${Boff}"
    d_do 'joetoo-sbc-list | sed "s|^|    |"' ${notice}
    j_msg -${notice} -mp ""
    j_msg -${notice} -p "${BYon}  CONFIG must be one of the following --${Boff}"
    for conf in $(find ${config_dir%/}/ -name 'assemble-make-conf*.conf' -printf '%f\n'); do
        j_msg -${notice} -mp "    ${conf}"
    done
    j_msg -${notice} -mp ""
    j_msg -${notice} -p "${BMon}  which can be found/edited in ${LBon}${config_dir}${Boff}"
    exit 1
}

initialize_variables() {
    # use script_header_joetoo functions
    initialize_vars ${varlist}
    initialize_vars ${hidden_varlist}

    FLAGGED=$FALSE
    # assign initial values
    j_msg -${notice} -p -n "Re-assigning PN = \$(basename $0) ..."
    PN=${0##*/} ; result=$? ; right_status $result ${notice}
    [ ! $result -eq 0 ] && FLAGGED=$TRUE

    j_msg -${notice} -p -n "Re-assigning package_source_dir = /home/joe/myUtilities/joetoo-base/joetoo-platform-meta ..."
    export package_source_dir=/home/joe/myUtilities/joetoo-base/joetoo-platform-meta
    right_status $? ${notice} || FLAGGED=$TRUE

    j_msg -${notice} -p -n "Re-assigning tool_dir = ${package_source_dir%/}/tools ..."
    export tool_dir=${package_source_dir%/}/tools
    right_status $? ${notice} || FLAGGED=$TRUE

    j_msg -${notice} -p -n "sourcing BUILD ..."
    source ${package_source_dir%/}/BUILD
    right_status $? ${notice} || FLAGGED=$TRUE

    j_msg -${notice} -p -n "sourcing BPN ..."
    source ${package_source_dir%/}/BPN
    right_status $? ${notice} || FLAGGED=$TRUE

    # note: ordered this way, config file can override verbosity
    j_msg -${notice} -p -n "maybe re-assigning verbosity = 5 ..."
    if [ -z "$verbosity" ] ; then export verbosity=5; fi
    right_status $? ${notice} || FLAGGED=$TRUE

    j_msg -${notice} -p -n "Assigning config_file"
    [ -f "${config_dir%/}/${myCONFIG}" ] && \
        config_file="${config_dir%/}/${myCONFIG}" || \
        die "config_file [${config_dir%/}/${myCONFIG}] does not exist"
    handle_result 0 "${myCONFIG}" "" ${notice} || FLAGGED=$TRUE

    j_msg -${notice} -p -n "sourcing ${config_file} ..."
    source "${config_file}"
    right_status $? ${notice} || FLAGGED=$TRUE

    j_msg -${notice} -p -n "Re-assigning BOARD = ${myBOARD} ..."
    export BOARD=${myBOARD}
    right_status $? ${notice} || FLAGGED=$TRUE

    j_msg -${notice} -p -n "Re-assigning user = joe ..."
    export user="joe"
    right_status $? ${notice} || FLAGGED=$TRUE

    j_msg -${notice} -p -n "Assigning MAKE_CONF_PARTS_DIR = ${tool_dir%/}/make-conf-parts ..."
    export MAKE_CONF_PARTS_DIR="${tool_dir%/}/make-conf-parts"
    right_status $? ${notice} || FLAGGED=$TRUE

    j_msg -${notice} -p -n "Assigning DRAFT_FILE = /tmp/draft-make-conf/make.conf.draft_${BOARD} ..."
    export DRAFT_FILE="/tmp/draft-make-conf/make.conf.draft_${BOARD}"
    right_status $? ${notice} || FLAGGED=$TRUE

    j_msg -${notice} -p -n "Assigning OUT_FILE = ${package_source_dir%/}/make_conf/make.conf.\${SYS_TYPE}.\${ENV_TYPE}.\${BOARD}"
    export OUT_FILE="${package_source_dir%/}/make_conf/make.conf.${SYS_TYPE}.${ENV_TYPE}.${BOARD}"
    right_status $? ${notice} || FLAGGED=$TRUE

    [ $FLAGGED ] && return 1 || return 0
}

display_configuration() {
    separator "${PN}" "(display configuration)"
    # use script_header_joetoo functions
    longest=$(get_longest ${varlist})
    display_vars $longest ${varlist} || return 1
    return 0
}

validate_board() {
    # look for a match in joetoo-sbc-list
    candidates=( $(joetoo-sbc-list | grep "${BOARD}" | awk '{print $1}') )
    if [ ${#candidates[@]} -gt 0 ] ; then
        # make sure it's an exact match, not just a subsring similarity (maybe multiple candidates)
        for ((i=0; i<${#candidates[@]}; i++)) ; do
            [[ "${BOARD}" == "${candidates[$i]}" ]] && return 0  # exact match
        done
    else
        # empty string means no match at all
        j_msg -${err} "BOARD [$BOARD] is not currently supported"
    fi
    # return failure if it exhausted the list of candidates, no match, and got here
    return 1
}

