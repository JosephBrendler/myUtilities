    right_status $? ${notice} ; return $?
}

add-MIRRORS() {
    j_msg -${debug} -p "inside ${FUNCNAME[0]}"
    j_msg -${notice} -p -n "adding MIRRORS ..."
    add-part "${MAKE_CONF_PARTS_DIR%/}/00_BLANK_LINE" && \
    add-part "${MAKE_CONF_PARTS_DIR%/}/17_MIRRORS-common"
    right_status $? ${notice} ; return $?
}

post-file() {
    j_msg -${debug} -p "inside ${FUNCNAME[0]}"
    PROCEED=$TRUE
    j_msg -${notice} -p -n "copying draft"
    if [ -e "${OUT_FILE}" ] && [ ! ${OVER_WRITE} ] ; then
        # same-named file already exists, and OVER_WRITE=$FALSE, so confirm with user before writing
        j_msg -${notice} -mp   # severity-aware newline; was otherwise waiting from j_msg -${notice} -p -n above
        j_msg -${notice} -p "${OUT_FILE}"
        yns_prompt "already exists; overwrite?"
        [[ "${response:0:1}" != [yY] ]] && PROCEED=$FALSE
    fi
    if [ ${PROCEED} ] ; then
        z=$(dirname "${OUT_FILE}")
        # create directory if needed
        if [ -d "${z}" ] ; then
            j_msg -${notice} -mp -n " (dir ${BGon}exists${Boff})"
        else
            mkdir -p "${z}" && chown -f -R "${user}:${user}" "${z}"; result=$?
            if [ "$result" -eq 0 ] ; then
                j_msg -${notice} -mp -n " (dir ${BMon}created for ${user}${Boff})"
            else
                die "failed to mkdir -p ${z}"
           fi  # mkdir result
        fi
        # copy file to final
        cp -a "${DRAFT_FILE}" "${OUT_FILE}"
        handle_result $? "copied" "" ${notice} || die "failed to copy draft to final"
    fi
    right_status $? ${notice} ; return $?
}

set-ownership() {
    j_msg -${debug} -p "inside ${FUNCNAME[0]}"
    j_msg -${notice} -p -n "setting ownership of \${OUT_FILE}"
    chown -f "${user}:${user}"  "${OUT_FILE}"
    handle_result $? "" "" ${notice}
    return $?
}

