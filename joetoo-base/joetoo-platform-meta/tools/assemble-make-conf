tool_dir="${package_source_dir%/}/tools"

j_msg -${notice} -p -n "sourcing BUILD ..."
source "${package_source_dir%/}/BUILD" ; right_status $? ${notice}
j_msg -${notice} -p -n "sourcing BPN ..."
source "${package_source_dir%/}/BPN" ; right_status $? ${notice}
