#!/bin/bash
#
# This script performs a secure DDNS update using ssh
#
# 20260424 - refactored to support dual-stack ipv4/ipv6 and both dnsmasq/radvd SLAAC and openvpn clients
#
PN=${0##*/}   # like =$(basename $0) but w/o sub-shell and function call

# initialze pseudo-boolean reference
# (because this script does not source script_header_joetoo)
TRUE=0; FALSE=""; NEED_UPDATE="$FALSE"

#-----[ user configured variables ]---------------------------------------------------

# source /etc/conf.d/ddns if it exists; exit if missing
_conf="/etc/conf.d/ddns"
if [ -f "$_conf" ]; then
    . "$_conf"
else
    logger -p "user.err" -t "${PN}" "Configuration file $_conf missing. Exiting."
    exit 1
fi

# map the sourced config variables to internal script variables if names differ

# BUILD: package build variable generated by the ebuild producing this file
BUILD="${BUILD:-0.0.0}"
# logging tag
TAG="${PN}-${BUILD}"

# dns to query with dig to validate cached address info
joetoo_dns="${JOETOO_DNS_SERVER:-elrond}"

# now sourced from /etc/conf.d/ddns --
LOG_FACILITY="${LOG_FACILITY:-local5}"
DDNS_REVERIFY_INTERVAL="${DDNS_REVERIFY_INTERVAL:-600}"  # seconds (reverify dns if cache info is older than 10 min)
DDNS_CACHE_DIR="${DDNS_CACHE_DIR:-/run/ddns-daemon.cache}"

# assign and apply sensible defaults in case /etc/conf.d/ddns is missing or de-populated
# user: identify the local user who will run ssh (sudo -u $user ssh ...)
user="${DDNS_USER:-joe}"
# ddns_server: identify the alias established in ~/.ssh/config and /etc/ssh/ssh_confg.d/01_joetoo_ssh_config.conf
#   this will be used to set the remote User, shh key id, adn performance/resilience policy options
ddns_server="${DDNS_SSH_ALIAS:-elrond-ddns-46}"
# joetoo_ULA_prefix: first part of local stable SLAAC addresses in joetoo domain
joetoo_ULA_prefix="${JOETOO_ULA_PREFIX:-fd62}"
# joetoo_ip4_prefix: first part of local private ipv4 addresses in joetoo domain
joetoo_ip4_prefix="${JOETOO_IP4_PREFIX:-192.168.6}"
# joetoo_domain: identify the local domain (currently for joetoo this is "brendler")
joetoo_domain="${JOETOO_DOMAIN:-brendler}"

#-----[ derived variables ]----------------------------------------------

# DDNS_SSH_TARGET form from server and domain names (don't use $user from above as this could differ from remote User
DDNS_SSH_TARGET="${ddns_server}.${joetoo_domain}"
# FQDN: form from local hostname and domain mname
FQDN="$(hostname).${joetoo_domain}"

# Get parameters passed as arguments by ddns_watcher script
#    for this script to get hooked if these events fire
EVENT="$1"
ADDR="$2"
INTERFACE="$3"
SOURCE="${4:-$TBD}"  # for log entries (who sent this to us); also send to server

#-----[ functions ]-----------------------------------------------------------

timestamp() { printf '%s\n' "$(date '+%Y-%m-%d_%H:%M:%S')" ; }

TrueFalse() {
    case "$1" in
        [yY]*|[tT]*|[uU]*|[hH]*|"$TRUE"|"0")
            printf '%s' "True"; return 0 ;;
        [nN]*|[fF]*|[dD]*|[lL]|"$FALSE")
            printf '%s' "False"; return 1 ;;
        *) printf '%s' "unset"; return 2 ;;
    esac
}

#-----[ main script ]---------------------------------------------------------

# Log the Initial State
msg="(debug) - invoked - EVENT: [$EVENT] INTERFACE: [$INTERFACE] ADDR: [$ADDR] SOURCE: [$SOURCE]"
logger -p "${LOG_FACILITY}.debug" -t "${TAG}" "${msg}"
msg="(debug) - other variables: TRUE: [$(TrueFalse $TRUE)] FALSE: [$(TrueFalse $FALSE)] NEED_UPDATE: [$NEED_UPDATE]"
msg+=" TAG: [$TAG] LOG_FACILITY: [$LOG_FACILITY] DDNS_CACHE_DIR [$DDNS_CACHE_DIR]"
logger -p "${LOG_FACILITY}.debug" -t "${TAG}" "${msg}"

# summary-validate INTERFACE and EVENT
if [ -z "$EVENT" ] || ! printf '%s\n' "$EVENT" | grep -Eq '^(add|del)$'; then
    # EVENT is invalid if null or not one of add|del
    msg="(warn) Filtered: Event [$EVENT] is null"
    logger -p "${LOG_FACILITY}.warn" -t "${TAG}" "${msg}"
    # Exit with success (0) because the script did its job by filtering
    exit 0
elif [ -z "$INTERFACE" ]; then
    # INTERFACE is invalid if null
    msg="(warn) Filtered: Interface [$INTERFACE] is null"
    logger -p "${LOG_FACILITY}.warn" -t "${TAG}" "${msg}"
    # Exit with success (0) because the script did its job by filtering
    exit 0
fi
msg="(debug) progress: checking ADDR: [$ADDR]"
logger -p "${LOG_FACILITY}.debug" -t "${TAG}" "${msg}"

# validate ADDR and detect address family (ipv4/ipv6) and thus TYPE (A|AAAA)
# (removed guard to reject empty address (some del events might not have one - try to get from cache))
case "$ADDR" in
    "$joetoo_ULA_prefix"*) TYPE="AAAA" ;;      # fd62:6262:6260::/44
    "$joetoo_ip4_prefix"*) TYPE="A" ;;         # 192.168.60/22
                       "")                     # empty; Ok; infer type from SOURCE
                           case "$SOURCE" in   #(use ipv4/6 to future-proof modular dhcpcd-hook(s) and daemon(s))
                               *ipv4*|*dhcpcd*) TYPE="A" ;;
                               *ipv6*|*daemon*) TYPE="AAAA" ;;
                               *)               TYPE="AAAA" ;; # Safest default for Joetoo
                           esac
                           ;;
                        *) msg="(warn) Filtered: Address [$ADDR] outside authorized"
                           msg+=" 192.168.60/22 or fd62:6262:6260::/44 ranges"
                           logger -p "${LOG_FACILITY}.warn" -t "${TAG}" "${msg}"
                           # Exit with success (0) because the script did its job by filtering
                           exit 0 ;;
esac
# ADDR is now either valid for A|AAAA or empty (validate latter with del event below)

# complete the identification of the cache file for this interface
# (cannot be done prior to determining TYPE (above), and
#  must be done prior to assessing empty address for del event (below)
CACHE_FILE="${DDNS_CACHE_DIR}.${INTERFACE}.${TYPE}"
msg="(debug) progress: EVENT, INTERFACE, ADDR validation complete. TYPE: [$TYPE]; Checking cache file: [$CACHE_FILE]"
logger -p "${LOG_FACILITY}.debug" -t "${TAG}" "${msg}"
# check the cache, if it exists
if [ -f "$CACHE_FILE" ]; then
    CACHE_INFO=$(cut -d '|' -f1,2 "$CACHE_FILE")
    CACHE_TS=$(cut -d '|' -f3 "$CACHE_FILE")
else
    CACHE_INFO=""
    CACHE_TS=""
fi

msg="(debug) progress: assigned cache file: [$CACHE_FILE]"
logger -p "${LOG_FACILITY}.debug" -t "${TAG}" "${msg}"

if [ -z "$ADDR" ]; then
    # if event is del, try to get addr from cache; keep going if successful or exit
    case "$EVENT" in
        "add")
            msg="(warn) Filtered: Event [$EVENT], but ADDR [$ADDR] from SOURCE: [$SOURCE] is null"
            logger -p "${LOG_FACILITY}.warn" -t "${TAG}" "${msg}"
            # Exit with success (0) because the script did its job by filtering
            exit 0
            ;;
        "del")
            if [ -n "$CACHE_INFO" ]; then
                # strip longest match for '|*' from the right - leaving addr
                ADDR="${CACHE_INFO%%|*}"
                if [ -z "$ADDR" ]; then
                    msg="(warn) Filtered: Event [$EVENT], but failed to read ADDR from cache"
                    logger -p "${LOG_FACILITY}.warn" -t "${TAG}" "${msg}"
                    # Exit with success (0) because the script did its job by filtering
                    exit 0
                else
                    NEED_UPDATE=$TRUE  # call for update for del event
                fi
                # ADDR should now contain the last cached address for this interface
            else
                msg="(warn) Filtered: Event [$EVENT], but cannot get ADDR; cache is empty"
                logger -p "${LOG_FACILITY}.warn" -t "${TAG}" "${msg}"
                # Exit with success (0) because the script did its job by filtering
                exit 0
            fi
            ;;
        *)
            msg="(warn) Filtered: Invalid Event [$EVENT] from SOURCE: [$SOURCE]"
            logger -p "${LOG_FACILITY}.warn" -t "${TAG}" "${msg}"
            # Exit with success (0) because the script did its job by filtering
            exit 0
            ;;
    esac
fi
TIMESTAMP="$(timestamp)"

msg="(debug) progress: Done ADDR check; Event: [$EVENT]. Expect: timestamp: [$TIMESTAMP] populated;"
msg+=" for add, addr [$ADDR] populated, for del NEED_UPDATE [$(TrueFalse $NEED_UPDATE)] true"
logger -p "${LOG_FACILITY}.debug" -t "${TAG}" "${msg}"


# if you are here w/o getting shunted out, all input now "validated"
# now determine is cache is fresh/valid or if update required
# (only relevant if event is add)
case "$EVENT" in
        "del")
            # action is del, so remove the cache
            rm -f "$CACHE_FILE"
            if [ $? -ne 0 ]; then
                msg="(warn) Warning: Failed to delete cache file"
                logger -p "${LOG_FACILITY}.warn" -t "${TAG}" "${msg}"
                # Exit with success (0) because the script did its job by filtering
                exit 0
            fi
            ;;
        "add")
            msg="(notice) EVENT: [$EVENT]; CACHE_INFO: [$CACHE_INFO];  ADDR|INTERFACE: [$ADDR|$INTERFACE] SOURCE: [$SOURCE]"
            logger -p "${LOG_FACILITY}.notice" -t "${TAG}" "${msg}"
            if [ "$CACHE_INFO" = "$ADDR|$INTERFACE" ]; then
                # if CACHE_TS is unset, treat it as stale
                [ -z "$CACHE_TS" ] && CACHE_TS="1985-01-01_00:00:00"
                # guard vs unset or malformed CACHE_TS
                if ! CACHE_TS_SECONDS=$(date -d "${CACHE_TS/_/ }" +%s 2>/dev/null); then
                    # treat as stale
                    CACHE_TS_SECONDS=0
                fi
                NOW_SECONDS=$(date +%s)
                # reverify dns if cache info is older than 10 min
                if (( NOW_SECONDS - CACHE_TS_SECONDS > DDNS_REVERIFY_INTERVAL )); then
                    # STALE CACHE
                    # domain information groper (dig) +short means just get the final answer;
                    #   TYPE means the command digs for ipv4|6 (A|AAAA) records automatically
                    DNS_INFO=$(dig +short "${TYPE}" "$FQDN" "@${joetoo_dns}")
                    if [ -z "$DNS_INFO" ]; then
                        # DNS unreachable → do NOT update cache, do NOT update DNS
                        # let cache remain stale; retry later
                        exit 0   # i.e. skip directly to next iteration of while loop
                    fi
                    # look for ADDR in DNS_INFO -F (fixed string) -x (whole line) -q (quiet)
                    if printf '%s\n' "$DNS_INFO" | grep -Fxq "$ADDR"; then
                        # dns has the correct address - just update the cache
                        printf '%s\n' "${ADDR}|${INTERFACE}|${TIMESTAMP}" > "$CACHE_FILE"
                        msg="(notice) DNS verified; updated cache timestamp for $ADDR $INTERFACE"
                        logger -p "${LOG_FACILITY}.notice" -t "${TAG}" "${msg}"
                    else
                        # dns does not have the right address - update it
                        msg="(notice) DNS not verified; setting NEED_UPDATE to TRUE"
                        msg="${msg} to send update for $ADDR $INTERFACE"
                        logger -p "${LOG_FACILITY}.notice" -t "${TAG}" "${msg}"
                        NEED_UPDATE=$TRUE   # call for update for add event
                        # write new info to cache
                        printf '%s\n' "${ADDR}|${INTERFACE}|${TIMESTAMP}" > "$CACHE_FILE"
                    fi  # addr in dns_info ?
                fi  # stale cache
            else
                # address is not the same ac cache - submit new update
                msg="(notice) address differs from cache; setting NEED_UPDATE to TRUE"
                msg="${msg} to send update for $ADDR $INTERFACE"
                logger -p "${LOG_FACILITY}.notice" -t "${TAG}" "${msg}"
                NEED_UPDATE=$TRUE   # call for update for add event
                # write new info to cache
                printf '%s\n' "${ADDR}|${INTERFACE}|${TIMESTAMP}" > "$CACHE_FILE"
            fi  # addr same as cache?
            ;;
        *)
            msg="(warn) Filtered: Invalid Event [$EVENT] from SOURCE: [$SOURCE]"
            logger -p "${LOG_FACILITY}.warn" -t "${TAG}" "${msg}"
            # Exit with success (0) because the script did its job by filtering
            exit 0
            ;;
esac

msg="(debug) progress: validation complete. NEED_UPDATE: [$NEED_UPDATE)] Event [$EVENT] from SOURCE: [$SOURCE]"
logger -p "${LOG_FACILITY}.debug" -t "${TAG}" "${msg}"

if [ "$NEED_UPDATE" ]; then
    # Final command arguments: ADDRESS, FQDN, INTERFACE, and timestamp
    # (INTERFACE to be used in NS hosts file '#' comment field
    #  in oder to distinguish between multiple addresses for a fqdn
    #  when that host has multiple interfaces with ipv6 addresses)
    # (timestamp in same comment field for visibly obvious confirmation)
    COMMAND_ARGS="${ADDR} ${FQDN} ${INTERFACE} ${TIMESTAMP} ${EVENT} ${TYPE} ${SOURCE}"

    msg="(info) Executing SSH as ${user} with args: [$COMMAND_ARGS]..."
    logger -p "${LOG_FACILITY}.info" -t "${TAG}" "${msg}"

    # Execute the secure SSH command as ${user}
        # note: to prevent redundancy, confusion, and config conflicts, and to enforce apprpriate policy,
        #   (1) fleet-wide performance/resiliency policy (ssh -o options) previously in user ssh config
        #       and the ddns-update script are now consolidated in /etc/ssh/ssh_config.d/01_joetoo_ssh_config.conf
        #   (2) the ddns-update script and root-owned policy file are now free of "sensitive" info and policy settings
        #   (3) sensitive info should remain in the client/user config, for security
        #       (sensitive info should not be stored in files curated in public repositories)
    # CRITICAL: pass the content of ${COMMAND_ARGS} as a single, quoted argument string
    #           so ssh (upon connection) can pass it "here are your args" to the command named in authorized_keys
    SSH_OUTPUT=$( \
        /usr/bin/sudo -u "${user}" /usr/bin/ssh -q \
        "$DDNS_SSH_TARGET" \
        "${COMMAND_ARGS}" 2>&1 \
    )
    EXIT_CODE=$?
    # Log the action taken
    if [ "$EXIT_CODE" -eq 0 ]; then
        msg="(info) SSH exit code: [$EXIT_CODE] RESULT: SUCCESS. ${EVENT} ${TYPE} record for ${FQDN} on $INTERFACE."
        logger -p "${LOG_FACILITY}.info" -t "${TAG}" "${msg}"
        logger -p "${LOG_FACILITY}.debug" -t "${TAG}" "SSH_OUTPUT: $SSH_OUTPUT"
    else
        msg="(info) SSH exit code: [$EXIT_CODE] RESULT: FAILED. failed to update ${TYPE} record for ${FQDN}."
        logger -p "${LOG_FACILITY}.err" -t "${TAG}" "${msg}"
        logger -p "${LOG_FACILITY}.debug" -t "${TAG}" "SSH_OUTPUT: $SSH_OUTPUT"
    fi
else
    # update not needed; log and leave
    msg="(info) update transmission to dns not required; exiting without further action on input from SOURCE: [$SOURCE]"
    logger -p "${LOG_FACILITY}.info" -t "${TAG}" "${msg}"
fi
exit 0
