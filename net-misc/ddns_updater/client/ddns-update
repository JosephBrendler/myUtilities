#!/bin/bash
#
# This script performs a secure DDNS update using ssh
#
# 20260424 - refactored to support dual-stack ipv4/ipv6 and both dnsmasq/radvd SLAAC and openvpn clients
#
PN=${0##*/}   # like =$(basename $0) but w/o sub-shell and function call

#-----[ user configured variables ]---------------------------------------------------
user="joe"
#ddns_server="elrond"
ddns_server="elrond-ddns"   # use the alias established in ~/.ssh/config
domain="brendler"

# tp-do: transition to pairwise-unique (or client-qunique keys) for greater security
# (with a shared key [status quo] compromise of any client enables actor to impersonate
#  any remote hostname in spoofed dns updates - sending false ip addr for the impersonated host)
ssh_key_id="id_ddns_update_46"

debugging_log="/tmp/ddns-update.debug.log"
LOG_FACILITY="local5"

#-----[ derived variables ]----------------------------------------------------------
# The key is owned by '${user}' and used via 'sudo -u ${user}'
SSH_KEY_PATH="/home/${user}/.ssh/${ssh_key_id}"
DDNS_SSH_TARGET="${user}@${ddns_server}.${domain}"
# The Fully Qualified Domain Name
FQDN="$(hostname).${domain}"

# Get parameters passed as arguments by ddns_watcher script
#    for this script to get hooked if these events fire
EVENT="$1"
ADDR="$2"
INTERFACE="$3"

#-----[ functions ]-----------------------------------------------------------
timestamp() { printf '%s\n' "$(date '+%Y-%m-%d_%H:%M:%S')" ; }

#-----[ main script ]---------------------------------------------------------

# Log the Initial State
{
    printf '%s\n' "-----[ ${PN} started at $(timestamp) ]----------------"
    printf '%s\n' "    EVENT: .....: [$EVENT]"
    printf '%s\n' "    ADDR .......: [$ADDR]"
    printf '%s\n' "    INTERFACE ..: [$INTERFACE]"
} >> "$debugging_log"

msg="[$(timestamp)] DEBUG: DDNS_UPDATE Script Invoked. EVENT: [$EVENT] INTERFACE: [$INTERFACE]"
logger -p "${LOG_FACILITY}.debug" -t "${PN}" "${msg}"
msg="[$(timestamp)] DEBUG: ADDR: [$ADDR]"
logger -p "${LOG_FACILITY}.debug" -t "${PN}" "${msg}"

# address validation and dns record type A/AAAA detction (from ip family)

# reject empty address but return 0 (log as error, but dont error-out; just take no action)
if [ -z "$ADDR" ]; then
    # the variable is an "empty" string
    msg="[$(timestamp)] INVALID: Empty address provided by caller ddns-daemon(SLAAC) or joetoo-up/down.sh(openvpn) for EVENT: [$EVENT]"
    logger -p "${LOG_FACILITY}.err" -t "${PN}" "${msg}"
    printf '%s\n' "${msg}" >> "${debugging_log}"
    exit 0
fi

# detect address family (ipv4/ipv6)
if [[ "$ADDR" =~ ^192\.168\.6[0-3]\. ]]; then
    # matches 192.168.60.x through 192.168.63.x (/22 range)
    # this covers dnamasq (62.0/24) and VPN (63.0/24) clients
    TYPE="A"
elif [[ "$ADDR" =~ ^fd62:6262:626[0-9a-fA-F]: ]]; then
    # matches fd62:6262:6260:: through fd62:6262:626f:: (/44 range)
    # this covers stable SLAAAC (62::/64) and VPN (63::/64) clients
    TYPE="AAAA"
else
    # This is not a Brendler-internal address (LL, GUA, or foreign subnet)
    msg="[$(timestamp)] FILTERED: Address [$ADDR] outside authorized 192.168.60/22 or fd62:6262:6260::/44 ranges"
    logger -p "${LOG_FACILITY}.warn" -t "${PN}" "${msg}"
    printf '%s\n' "${msg}" >> "${debugging_log}"
    # Exit with success (0) because the script did its job by filtering
    exit 0
fi

# Final command arguments: ADDRESS, FQDN, INTERFACE, and timestamp
# (INTERFACE to be used in NS hosts file '#' comment field
#  in oder to distinguish between multiple addresses for a fqdn
#  when that host has multiple interfaces with ipv6 addresses)
# (timestamp in same comment field for visibly obvious confirmation)
TIMESTAMP="$(timestamp)"
COMMAND_ARGS="${ADDR} ${FQDN} ${INTERFACE} ${TIMESTAMP} ${EVENT} ${TYPE}"

msg="[$(timestamp)] Executing SSH as ${user} with args: [$COMMAND_ARGS]..."
logger -p "${LOG_FACILITY}.info" -t "${PN}" "${msg}"
printf '%s\n' "${msg}" >> "$debugging_log"

# Execute the secure SSH command as ${user}
# CRITICAL: We pass the FQDN and IPV6_ADDRESS as a single, quoted argument string
SSH_OUTPUT=$( \
    /usr/bin/sudo -u "${user}" /usr/bin/ssh \
    -i "$SSH_KEY_PATH" \
    -o StrictHostKeyChecking=yes \
    -o BatchMode=yes \
    -o ControlMaster=no \
    "$DDNS_SSH_TARGET" \
    "${COMMAND_ARGS}" 2>&1 \
)
EXIT_CODE=$?
# Log the action taken
{
    printf '%s\n' "SSH Exit Code: $EXIT_CODE"
    printf '%s\n' "SSH Output (Stdout/Stderr):"
    if [ "$EXIT_CODE" -eq 0 ]; then
        msg="SSH exit code: [$EXIT_CODE] RESULT: SUCCESS. ${EVENT} ${TYPE} record for ${FQDN} on $INTERFACE."
        logger -p "${LOG_FACILITY}.info" -t "${PN}" "${msg}"
        logger -p "${LOG_FACILITY}.debug" -t "${PN}" "SSH_OUTPUT: $SSH_OUTPUT"
        printf '%s\n' "${msg}"
    else
        msg="[$(timestamp)] SSH exit code: [$EXIT_CODE] RESULT: FAILED. failed to update ${TYPE} record for ${FQDN}."
        logger -p "${LOG_FACILITY}.err" -t "${PN}" "${msg}"
        logger -p "${LOG_FACILITY}.debug" -t "${PN}" "SSH_OUTPUT: $SSH_OUTPUT"
        printf '%s\n' "${msg}"
    fi
    printf '%s\n' "-----[ ${PN} fnished at $(timestamp) ]----------------"
} >> "${debugging_log}"
exit 0
