#!/bin/sh
#
# dynamic dns update service daemon (c) joe brendler 2026-8765
#
# use "ip -6 monitor all" as a background service - to detect and act on
# events requiring a ddns update be sent to the dns (call /usr/sbin/ddns-update)
# format:
#   /usr/sbin/ddns-update "$EVENT" "$ADDR" "$INTERFACE" "$SOURCE"
# Event Add: only when it is not “Deleted”, “temporary”, or “tentative”
# note: ignore lifetime refresh messages, link flapping, and route changes
#  ** act only on [ADDR]Deleted or [ADDR] with a stable ULA

# make the daemon tell the shell - “When I exit, kill every process in my process group”
trap 'kill 0' EXIT

#-----[ variables ]-----------------------------------------------------

PN=${0##*/}

# source /etc/conf.d/ddns if it exists; exit if missing
_conf="/etc/conf.d/ddns"
if [ -f "$_conf" ]; then
    . "$_conf"
else
    logger -p "user.err" -t "${PN}" "(err) Configuration file $_conf missing. Exiting."
    exit 1
fi

# map the sourced config variables to internal script variables if names differ


# BUILD: package build variable generated by the ebuild producing this file
BUILD="${BUILD:-0.0.0}"
# logging tag
TAG="${PN}-${BUILD}" # for log entries
SOURCE="$TAG"        # for ddns-update submission

# dns to query with dig to validate cached address info
joetoo_dns="${JOETOO_DNS_SERVER:-elrond}"

# now sourced from /etc/conf.d/ddns --
LOG_FACILITY="${LOG_FACILITY:-local5}"
DDNS_REVERIFY_INTERVAL="${DDNS_REVERIFY_INTERVAL:-600}"  # seconds (reverify dns if cache info is older than 10 min)
DDNS_CACHE_DIR="${DDNS_CACHE_DIR:-/run/ddns-daemon.cache}"

# assign and apply sensible defaults in case /etc/conf.d/ddns is missing or de-populated
# user: identify the local user who will run ssh (sudo -u $user ssh ...)
user="${DDNS_USER:-joe}"
# ddns_server: identify the alias established in ~/.ssh/config and /etc/ssh/ssh_confg.d/01_joetoo_ssh_config.conf
#   this will be used to set the remote User, shh key id, adn performance/resilience policy options
ddns_server="${DDNS_SSH_ALIAS:-elrond-ddns-46}"
# joetoo_ULA_prefix: first part of local stable SLAAC addresses in joetoo domain
joetoo_ULA_prefix="${JOETOO_ULA_PREFIX:-fd62}"
# joetoo_ip4_prefix: first part of local private ipv4 addresses in joetoo domain
joetoo_ip4_prefix="${JOETOO_IP4_PREFIX:-192.168.6}"
# joetoo_domain: identify the local domain (currently for joetoo this is "brendler")
joetoo_domain="${JOETOO_DOMAIN:-brendler}"

#-----[ derived variables ]----------------------------------------------
FQDN="$(hostname).${joetoo_domain}"
# let ddns-update calculate timestamp and fqdn for itself

# create the cache directory if needed, and only if the prefix is valid (contains at least leading and one addl /)
slashes="${DDNS_CACHE_DIR//[^\/]}"  # parameter expansion to substitute '' for anything that is not a /
if [ ${#slashes} -ge 2 ]; then
  mkdir -p  "${DDNS_CACHE_DIR%/*}"   # like $(dirname "$DDNS_CACHE_DIR") w/w subshell and function call
else
  DDNS_CACHE_DIR="/run/ddns-daemon.cache"
fi

#-----[ functions ]-----------------------------------------------------

# timestamp (for comparison to cache) moved to ddns-update
# logger timestamps entries automatically

#-----[ main script ]-----------------------------------------------------
ip -6 monitor address | while read -r line; do

    case "$line" in
        *"Deleted"* )
            # format: Deleted <ifindex>: <iface> inet6 <addr>/<prefixlen>
            # extract interface and address
            INTERFACE=$(printf '%s\n' "$line" | awk '{print $3}')
            ADDR=$(printf '%s\n' "$line" | awk '{print $5}' | cut -d/ -f1)
            # filter to ignore link-local and multicast deletions
            case "$ADDR" in fe80:*|ff*) continue ;; esac
            # valid deletion: trigger event
            if [ -n "$INTERFACE" ] && [ -n "$ADDR" ]; then
                EVENT="del"
            else
                # malformed extraction - continue for clean avoidance of subsequent logic for a non-event
                continue
            fi
            ;;

        *"inet6 ${joetoo_ULA_prefix}"* )
            # format: <ifindex>: <iface> inet6 <addr>/<prefixlen>
            # extract interface and address
            INTERFACE=$(printf '%s\n' "$line" | awk '{print $2}')
            ADDR=$(printf '%s\n' "$line" | awk '{print $4}' | cut -d/ -f1)
            # skip temporary or tentative (noise)
            case "$line" in *temporary*|*tentative*) continue ;; esac

            # filter "no-change" events - check cache before setting EVENT
            if [ -n "$INTERFACE" ] && [ -n "$ADDR" ]; then
              _cache_file="${DDNS_CACHE_DIR}.${INTERFACE}.AAAA"
              if [ -f "$_cache_file" ]; then
                  _cache_info=$(cut -d '|' -f1,2 "$_cache_file")
                  if [ "$_cache_info" = "${ADDR}|${INTERFACE}" ]; then
                      # Silent drop: matches current state
                      continue
                  fi  # _cache_info
              fi  # _cache_file
            else
                # malformed extraction - continue for clean avoidance of subsequent logic for a non-event
                continue
            fi  # INTERFACE && ADDR

            EVENT="add"
            ;;

        * )
            continue
            ;;
    esac

    # when we have EVENT, ADDR, and INTERFACE, then act
    case "$EVENT" in
        # add|del). add | del ), "add"|"del"), "add" | "del" ) are functionally identical
        add | del )
          # moved cache/verify to ddns-update; dont need separate event cases here now
          msg="(notice) Event: [$EVENT] ADDR: [$ADDR] INTERFACE: [$INTERFACE]"
          logger -p "${LOG_FACILITY:-local5}.notice" -t "${TAG}" "${msg}"
          /usr/sbin/ddns-update "$EVENT" "$ADDR" "$INTERFACE" "$SOURCE"
          # explicitly reset for next line in monitor
          EVENT=""; ADDR=""; INTERFACE=""
          ;;
    esac
done
