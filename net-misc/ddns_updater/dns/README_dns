# dhcpcd.conf - install to /etc/ (this is dns/router version of the .conf)

# openvpn_dns_updater.sh - install to /usr/sbin/
# 20_openVPN_clients - gets built in /etc/hosts.d/ by openvpn_dns_updater.sh

# 30_ddns_clients - gets built in /etc/hosts.d/ by update-client-host.sh

# note ddns-update-server now posts ipv4 info in /etc/hosts.d/14_ddns_ipv4 and /etc/hosts.d/16_ddns_ipv6
# 99-ddns-update - install to /etc/sudoers.d/ (allows remote connect to run specified commands)(legacy)
# 99-ddns-update-server - install to /etc/sudoers.d/ (allows remote connect to run specified commands)

# update-client-host.sh - install to /etc/ddns_update/ (this is the script run by sudo when the ssh (legacy legacy)
#   user connects and sends "${COMMAND_ARGS} (="${ACTION_IPV6_ADDRESS} ${FQDN} ${INTERFACE} $(timestamp)")
# ddns-update-server - install to /usr/sbin/ (this is the new dual-stack updater)
#   user connects and sends "${COMMAND_ARGS} (="${ADDR} ${FQDN} ${INTERFACE} $(timestamp)" ${EVENT} ${TYPE})

# note: router must have (pub key) /home/joe/.ssh/id_ddns_update.pub (in /home/joe/.ssh/authorized_keys)
#   client->router uppdate enabled by /etc/ddns_update/update-client-host.sh,
#     authorized by /home/joe/.ssh/authorized_keys and /etc/sudoers.d/99-ddns-update
# note: client must have (priv key) /home/joe/.ssh/id_ddns_update and /home/joe/.ssh/id_ddns_update.pub 
#   client connects to submit update with /home/joe/.ssh/id_ddns_update (private key)

# note: same for new dual-stack system except the new keys are id_ddns_update_46/id_ddns_update_46.pub and the
#   single authorized command is to run /usr/sbin/ddns-update-server via ssh
#     authorized by /home/joe/.ssh/authorized_keys and /etc/sudoers.d/99-ddns-update-server
# note: client must have (priv key) /home/joe/.ssh/id_ddns_update_46 and /home/joe/.ssh/id_ddns_update_46.pub 
#   client connects to submit update with /home/joe/.ssh/id_ddns_update_46 (private key)

# note that /etc/ddns_update/update-client-host.sh is run by the remotely connected updater
#   and it uses LOCK_DIR="/run/lock/ddns_updater"
#   and keeps debug log in /tmp/dhcpcd.ddns-update.debug.log
#   script collects the arg sent by ssh args and writes to temp file and then sorts output
#   and prints fixed width cols to hosts file
# /etc/ddns_update/update-client-host.sh supports both the legacy-legacy inputs triggered by
#   client use of /lib/dhcpcd/dhcpcd-hooks/99-ddns-update-hoot -> /etc/dhcpcd.ddns-update.sh -> router via ssh
#      and the legacy /usr/sbin/ddns-daemon -> /usr/sbin/ddns-update -> router via ssh

