#!/bin/bash
#
# ddns-update-server  -- server side of client ddns update script executed by ssh command under authorized_keys
#   constraining user key id to just this one command
#
# responds to calls from client ddns-update which responds to calls from three sources --
#    (1) /usr/sbin/ddns openrc service and daemon SLAAC (ipv6 dnsmasq/radvd clients)
#    (2) /lib/dhcpcd/dhcpcd-hooks/99-dhcpcd-ddns-update (ipv4 dnsmasq clients)
#    (3) /etc/openvpn/openvpnremote-up.sh --> joetoo-up.sh
#
#    Note: use the full path of system commands because that is how they must be referenced by sudo
#      for the /etc/sudoers.d/99-ddns-update-server file entry that authorizes "$user"
#      passwordless sudo access to run this script
#
# 20260424 - refactored to integrate ipv4 and ipv6 for both dnsmasq/radvd and openvpn clients (add address type A or AAAA)
#
# *** 20260502 *** - new file parsing strategy - treat the file read and write from the dns perspective -
#      - each line contains col 1: ip, col 2: name, col 3: metadata beginning with # - everything else is a comment
#      - after extracting these three parts, use separate (internal) logic to dissassemble and use the metadata
#      - metadata will consist of # followed by interface then timestamp and as ver 0.1.15+ deploys,
#        some lines will also have source (where the update originated - useful for human auditing)
#

# Note: All file access operations must be run with sudo for read/write access.
# (depends on user running the script to have NOPASSWD access to the script
#  which is granted in /etc/sudoers.d/99-ddns-update

PN=${0##*/}

# source /etc/conf.d/ddns if it exists; exit if missing
_conf="/etc/conf.d/ddns"
if [ -f "$_conf" ]; then
    . "$_conf"
else
    logger -p "user.err" -t "${PN}" "(err) Configuration file $_conf missing. Exiting."
    exit 1
fi

# map the sourced config variables to internal script variables if names differ


# BUILD: package build variable generated by the ebuild producing this file
BUILD="${BUILD:-0.0.0}"
# logging tag
TAG="${PN}-${BUILD}" # for log entries
SOURCE="$TAG"        # for ddns-update submission

# dns to query with dig to validate cached address info
joetoo_dns="${JOETOO_DNS_SERVER:-elrond}"

# now sourced from /etc/conf.d/ddns --
LOG_FACILITY="${LOG_FACILITY:-local5}"
DDNS_REVERIFY_INTERVAL="${DDNS_REVERIFY_INTERVAL:-600}"  # seconds (reverify dns if cache info is older than 10 min)
DDNS_CACHE_DIR="${DDNS_CACHE_DIR:-/run/ddns-daemon.cache}"

# assign and apply sensible defaults in case /etc/conf.d/ddns is missing or de-populated
# user: identify the local user who will run ssh (sudo -u $user ssh ...)
user="${DDNS_USER:-joe}"
# ddns_server: identify the alias established in ~/.ssh/config and /etc/ssh/ssh_confg.d/01_joetoo_ssh_config.conf
#   this will be used to set the remote User, shh key id, adn performance/resilience policy options
ddns_server="${DDNS_SSH_ALIAS:-elrond-ddns-46}"
# joetoo_ULA_prefix: first part of local stable SLAAC addresses in joetoo domain
joetoo_ULA_prefix="${JOETOO_ULA_PREFIX:-fd62}"
# joetoo_ip4_prefix: first part of local private ipv4 addresses in joetoo domain
joetoo_ip4_prefix="${JOETOO_IP4_PREFIX:-192.168.6}"
# joetoo_domain: identify the local domain (currently for joetoo this is "brendler")
joetoo_domain="${JOETOO_DOMAIN:-brendler}"

# server-specific variables from /etc/conf.d/ddns --
# now sourced from /etc/conf.d/ddns --
LOCK_DIR="${LOCK_DIR:-/run/lock/ddns_updater}"

# IPV4_HOSTS_FILE: hosts file, e.g. --
#   192.168.62.137  gmki91.brendler      # eth0       2026-04-27_02:11:12
ipv4_hosts_file="${IPV4_HOSTS_FILE:-/etc/hosts.d/14_ddns_ipv4}"

# IPV6_HOSTS_FILE: hosts file, e.g. --
#   fd62:6262:6262:0:88ec:ce98:33f8:9d68   gmki91.brendler      # eth0       2026-04-27_13:30:59
ipv6_hosts_file="${IPV6_HOSTS_FILE:-/etc/hosts.d/16_ddns_ipv6}"

#-----[ variables ]----------------------------------------------------------------

if [ $# -eq 7 ]; then
    # Newest mode - integrated ipv4/6 for dnsmasq/radva and openvpn clients --
    # [ADDR] [FQDN] [INTERFACE] [TIMESTAMP] [EVENT] [TYPE]
    ADDR="$1"; FQDN="$2"; INTERFACE="$3"; TIMESTAMP="$4"; EVENT="$5"; TYPE="$6"; SOURCE="${7:-TBD}"
elif [ $# -eq 6 ]; then
    # Newest legacy mode - integrated ipv4/6 for dnsmasq/radva and openvpn clients --
    # [ADDR] [FQDN] [INTERFACE] [TIMESTAMP] [EVENT] [TYPE]
    ADDR="$1"; FQDN="$2"; INTERFACE="$3";TIMESTAMP="$4";EVENT="$5"; TYPE="$6"; SOURCE="legacy 6-arg ddns-daemon"
elif [ $# -eq 5 ]; then
    # legacy mode: client ddns openrc service via /usr/sbin/ddns-daemon (ip monitor) and /usr/sbin/ddns-update script
    # [ADDR] [FQDN] [INTERFACE] [TIMESTAMP] [EVENT] (does not support type, but handles only ipv6)
    ADDR="$1"; FQDN="$2"; INTERFACE="$3"; TIMESTAMP="$4"; EVENT="$5"; TYPE="AAAA"; SOURCE="legacy 5-arg ddns-daemon"
elif [ $# -eq 4 ]; then
    # fall back to legacy-legacy mode 4-arg dhcpcd-hook input (client /etc/dhcpcd.ddns_update.sh)
    # [ADDR] [FQDN] [INTERFACE] [TIMESTAMP] (does not support delete event or type; handles only ipv6 adds)
    ADDR="$1"; FQDN="$2"; INTERFACE="$3"; TIMESTAMP="$4"; EVENT="add"; TYPE="AAAA"; SOURCE="legacy 4-arg dhcpcd.ddns_update.sh"
else
    printf '%s\n' "Invalid argument count"
    exit 1
fi

# use a variable for the tab character to stay POSIX-friendly in awk, sort, printf below
TAB=$'\t'

W0="[[:space:]]*" # regex match for zero or more whitespaces
W1="[[:space:]]+" # regex match for one or more whitespaces
P0="[[:print:]]*" # regex match for zero or more printable characters (incl. whitespace)
P1="[[:print:]]+" # regex match for one or more printable characters (incl. whitespace)
G0="[[:graph:]]*" # regex match for zero or more printable characters (excl. whitespace)
G1="[[:graph:]]+" # regex match for one or more printable characters (excl. whitespace)

# ^^ parameter expansion operator - tells Bash to convert all characters in variable to uppercase
# Route to the appropriate file based on TYPE
if [ "${TYPE^^}" = "A" ]; then
    HOSTS_FILE="$ipv4_hosts_file"
    COL_WIDTH=15  # a="123.123.123.123"; echo ${#a} ==> 15
else
    # note: assume if not A it is AAAA; given elif blocks above making AAAA a default, this should be safe
    HOSTS_FILE="$ipv6_hosts_file"
    COL_WIDTH=38   # a="fd62:6262:6262:0:88ec:ce98:33f8:9d68"; echo ${#a} ==> 36
fi
TEMP_FILE=$(mktemp)
TEMP_FILE2=$(mktemp)

#-----[ functions ]----------------------------------------------------------------
timestamp () { printf '%s\n' "$(date +'%Y-%m-%d_%H:%M:%S')" ; }

#-----[ main script ]----------------------------------------------------------------
# initiate log entry
msg="(info) Recv: event: [$EVENT] type: [$TYPE] addr: [$ADDR] fqdn: [$FQDN] iface: [$INTERFACE] source: [$SOURCE]"
logger -p "${LOG_FACILITY}.info" -t "${TAG}" "${msg}"
msg="(info) Recv: user: [$user] hosts_file: [$HOSTS_FILE] temp_file: [$TEMP_FILE] lock_file: [$LOCK_FILE]"
logger -p "${LOG_FACILITY}.info" -t "${TAG}" "${msg}"

msg="(debug) confirming i am who i think i am: who am i|id -u: [$(whoami)|$(id -u)]"
logger -p "${LOG_FACILITY}.debug" -t "${TAG}" "${msg}"

# Ensure the lock file directory is created, owned by root, and persistent across reboots
/bin/mkdir -p "$LOCK_DIR"
# set the directory permissions (but not for shared access with a sticky bit)
#/bin/chmod 1777 "$LOCK_DIR"
/bin/chmod 0755 "$LOCK_DIR"


# Ensure the lock file exists and is owned by user
# Note: If $LOCK_FILE already exists, this does nothing but update the timestamp.
# I might want to change ownership if other users/services need to acquire the lock.
#LOCK_FILE="${LOCK_DIR}/${FQDN}-${INTERFACE}.lock"
# 20260306 - changed from per-interface to per-client lock to prevent client-initiated race between
#   its own multiple interface updates
# 20260306 #2 - changed from per-client to one single hosts file lock to prevent multi-client races
#LOCK_FILE="${LOCK_DIR}/${FQDN}.lock"
# use "basename" of hosts_file for the name of lock
LOCK_FILE="${LOCK_DIR}/${HOSTS_FILE##*/}.lock"

/usr/bin/touch "$LOCK_FILE"
/bin/chown "${user}" "$LOCK_FILE"
# set permission on lock file for user (but not 0606 restricted)
#/bin/chmod 0606 "$LOCK_FILE"
/bin/chmod 0644 "$LOCK_FILE"

# Acquire exclusive lock (non-sudo) with fd 200 b/c it is well above range used for normal shell ops
exec 200>"$LOCK_FILE"
# originally used flock -x 200 (exclusive lock; only one process can hold it)
# but the default behavior of processes encountering this is "blocking" (to freeze and wait)
# "like accepting a phone call, but replying 'sorry - too busy right now'"
####/usr/bin/flock -x 200 || { printf '%s\n' "Error: Updater is busy for ${FQDN}. Exiting." | tee -a "$debug_logfile" >&2; exit 1; }
# I would rather have clients approach this like,
#   "If the server is busy just skip this update and try again later"
# so - so they should gracefully decline to act, instead, this is enabled by using
# a non-blocking lock, and then rejecting the new process
if ! /usr/bin/flock -n 200; then
    msg="(notice): LOCK_FILE: [$LOCK_FILE] is locked. Exiting non-blocking; not updating for ${FQDN} ($SOURCE)"
    logger -p "${LOG_FACILITY}.notice" -t "${TAG}" "$msg"
    exit 0 # Exit successfully (code 0) to prevent the client from logging an error
fi

# if this is a delete action, just delete any line that has name and has interface in the metadata
# (process it and exit early; if it is not a del, then add - more complex)
if [ "$EVENT" = "del" ]; then
    # use nl to Write each file to standard output, with line numbers added.
    # remove lines that semantically match <something-ie-address><fqdn><space># followed by
    #   <something-and-or-space>interface followed by either <space><anything><EOL> OR
    #       interface followed by <EOL> -
    #   i.e. match/delete for interface=eth1: "<any-addr> <fqdn> #oops eth1 whatever"
    #   but do not match "<any-addr> <fqdn> #oops eth11" (there could be an actual eth11)

    logger -p "${LOG_FACILITY}.info" -t "${TAG}" "(info) Action: Deleting $TYPE record for $FQDN ($SOURCE) on $INTERFACE"

    # match the new fixed-width format:
    # BOL followed by the IP (G1)
    # whitespace (W1) followed by the FQDN
    # whitespace (W1), the comment marker '#', then whitespace (W1)
    # the INTERFACE name
    # EITHER more whitespace (W1) followed by the timestamp and source (P0) OR EOL ($)
#    /bin/grep -v -E "^${G1}${W1}${FQDN}${W1}#${W1}${INTERFACE}(${W1}${P0})?$" "$HOSTS_FILE" > "$TEMP_FILE"
    #   i.e. match/delete for interface=eth1: "<any-addr> <fqdn> #oops eth1 whatever"
    #   but do not match "<any-addr> <fqdn> #oops eth11"

    # use awk to print all but the line that matches the fqdn and iface to be deleted, intact, in their original form ($0)
    /usr/bin/awk -v T="${TAB}" -v w0="${W0}" -v target_fqdn="$FQDN" -v target_iface="$INTERFACE" '{
        addr = $1; fqdn = $2;
        metadata = $0; sub("^[^#]*#" w0, "", metadata);
        if (!(fqdn == target_fqdn && metadata ~ "^" target_iface)) { print $0 ; }
    }' "$HOSTS_FILE"  > "$TEMP_FILE"

    # atomic write - to ensure dnsmasq doesn't try to read a half-written file
    chmod 644 "$TEMP_FILE" ; result=$?
    mv "$TEMP_FILE" "$HOSTS_FILE" ; result=$(( result + $? ))
    if [ "$result" -eq 0 ] ; then
        msg="(info) successfully posted and set 644 permissions on $HOSTS_FILE for del"
        logger -p "${LOG_FACILITY}.info" -t "${TAG}" "$msg"
    else
        msg="(err) failed to post and/or set 644 permissions on $HOSTS_FILE for del"
        logger -p "${LOG_FACILITY}.err" -t "${TAG}" "$msg"
    fi

    msg="(debug) calling /etc/init.d/dnsmasq reload"
    logger -p "${LOG_FACILITY}.debug" -t "${TAG}" "$msg"

    /etc/init.d/dnsmasq reload
    exit 0
fi

# to get here, it must not be a del event - treat as add, but validate first
# validate from dns perspective - two values on the line are ip (ADDR) and name (FQDN)
if [ -z "$ADDR" ] || [ -z "$FQDN" ]; then
    msg="9err) Missing FQDN [$FQDN] or ADDR [$ADDR] in update from SOURCE [$SOURCE]"
    printf '%s\n' "$msg"
    logger -p "${LOG_FACILITY}.debug" -t "${TAG}" "$msg"
    exit 1
fi

# ingest the current hosts file (except for any line matching into ADDR, FQDN, METADATA
# Read all existing entries *EXCEPT* the line corresponding to the FQDN and INTERFACE
#    into the temporary file. This handles multi-homing by removing ONLY the old IP for this FQDN/Interface
# + assign addr and fqdn
# + assign a copy of the whole line to metadata, then
#   sub() - substitute (for everything from the left anchor (^)
#     of the line up to and including any whitespace trailing the #)
#     substitute "" - and assign that remainder back to metadata --
#   ( "^[^#]*#" : find everything from the start of the line until and including the first # )
#     w0 (assigned ${W0} in -v): include any trailing spaces (equiv [[:space:]]*) )
# + then only print if it does NOT match our target
#   ! : match logical negative of -
#   fqdn == target_fqdn (match the target_fqdn) && (and)
#   metadata ~ "^" target_iface (match a metadata field left-anchored with the target_iface value
/usr/bin/awk -v T="${TAB}" -v w0="${W0}" -v target_fqdn="$FQDN" -v target_iface="$INTERFACE" '{
    addr = $1; fqdn = $2;
    metadata = $0; sub("^[^#]*#" w0, "", metadata);
    if (!(fqdn == target_fqdn && metadata ~ "^" target_iface)) { print addr T fqdn T metadata ; }
}' "$HOSTS_FILE"  > "$TEMP_FILE"

# construct fixed width metadata field from INTERFACE TIMESTAMP and SOURCE
METADATA=$(printf "%-10s %-22s %s" "$INTERFACE" "$TIMESTAMP" "$SOURCE")
# Append the NEW record in tab-delimited format
printf "%s\t%s\t%s\t%s\n" "$ADDR" "$FQDN" "$METADATA" >> "$TEMP_FILE"

# Sort the final content of tab-delimited TEMP_FILE based on FQDN (field 2) and interface (start of field 3),
#   then format back to fixed-width (human-readable) and overwrite the privileged file
# output to TEMP_FILE2 and then mv to HOSTS_FILE for atomic write
LC_COLLATE="en_US.UTF-8" /usr/bin/sort -t"${TAB}" -k2,2 -k3,3 "$TEMP_FILE" | \
    /usr/bin/awk -F"${TAB}" -v ip_w="$COL_WIDTH" -v T="${TAB}" \
    '{ printf "%-"ip_w"s %-20s # %s\n", $1, $2, $3 }' | \
    /usr/bin/tee "$TEMP_FILE2" > /dev/null

# make sure the hosts file will be readable by dnsmasq
chmod 644 "$TEMP_FILE2" ; result=$?
mv "$TEMP_FILE2" "$HOSTS_FILE" ; result=$(( result + $? ))
if [ "$result" -eq 0 ] ; then
    msg="(info) successfully posted and set 644 permissions on $HOSTS_FILE for add"
    logger -p "${LOG_FACILITY}.info" -t "${TAG}" "$msg"
else
    msg="(err) failed to post and/or set 644 permissions on $HOSTS_FILE for add"
    logger -p "${LOG_FACILITY}.err" -t "${TAG}" "$msg"
fi

# Clean up the temporary file
rm -f "$TEMP_FILE"

# Trigger dnsmasq to reread the hosts file
/etc/init.d/dnsmasq reload
msg="(notice) SUCCESS: Updated ${FQDN} to ${ADDR} for ($SOURCE) and reloaded dnsmasq."
logger -p "${LOG_FACILITY}.notice" -t "${TAG}" "$msg"

# Note: lock file is automatically released when script completes
