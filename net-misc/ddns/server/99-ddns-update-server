# Allow DDNS_USER (joe) to execute the new ddns server script via SSH         
# on behalf of remote clients or directly on behalf of the server
#
joe ALL=(ALL) NOPASSWD: /usr/sbin/ddns-update-server *

# Allow DDNS_USER (joe) to run ddns server scripts and updates
# on behalf of the openvpn server which runs a user nobody
#joe ALL=(ALL) NOPASSWD: /etc/openvpn/openvpn-ddns-hook.down *
joe ALL=(ALL) NOPASSWD: /etc/openvpn/openvpn-ddns-hook.down
joe ALL=(ALL) NOPASSWD: /etc/openvpn/openvpn-ddns-hook-ipv4.down *
joe ALL=(ALL) NOPASSWD: /etc/openvpn/openvpn-ddns-hook-ipv6.down *
joe ALL=(ALL) NOPASSWD: /usr/sbin/openvpn_dns_updater.sh *

# Allow openvpn (running as nobody) to run the down hook as DDNS_USER (joe)
# note: SETENV: allows preservation of environment varaiables with -E (--preserve-env)
#nobody ALL=(joe) NOPASSWD: SETENV: /etc/openvpn/openvpn-ddns-hook.down *
nobody ALL=(joe) NOPASSWD: SETENV: /etc/openvpn/openvpn-ddns-hook.down
