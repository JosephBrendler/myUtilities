#!/bin/sh
# /usr/sbin/ddns-trigger-wsl-ipv4
# Logic to bridge Windows Host networking state to joetoo DDNS (for ipv4)

PN=${0##*/}   # like =$(basename $0) but w/o sub-shell and function call

# initialze pseudo-boolean reference
# (because this script does not source script_header_joetoo)
#TRUE=0; FALSE=""  # not presently using

#-----[ user configured variables ]---------------------------------------------------

# source /etc/conf.d/ddns if it exists; exit if missing
_conf="/etc/conf.d/ddns"
if [ -f "$_conf" ]; then
    . "$_conf"
    logger -p "local5.info" -t "${PN}" "(info) Configuration file [$_conf] sourced."
else
    logger -p "local5.err" -t "${PN}" "(err) Configuration file [$_conf] missing. Exiting."
    exit 1
fi

# map the sourced config variables to internal script variables if names differ

# BUILD: package build variable generated by the ebuild producing this file
BUILD="${BUILD:-0.0.0}"
# logging TAG
TAG="${PN}-${BUILD}"

# dns to query with dig to validate cached address info
joetoo_dns="${JOETOO_DNS_SERVER:-elrond}"

# now sourced from /etc/conf.d/ddns --
LOG_FACILITY="${LOG_FACILITY:-local5}"
DDNS_REVERIFY_INTERVAL="${DDNS_REVERIFY_INTERVAL:-600}"  # seconds (reverify dns if cache info is older than 10 min)
DDNS_CACHE_DIR="${DDNS_CACHE_DIR:-/run/ddns-daemon.cache}"

# assign and apply sensible defaults in case /etc/conf.d/ddns is missing or de-populated
# user: identify the local user who will run ssh (sudo -u $user ssh ...)
user="${DDNS_USER:-joe}"
# ddns_server: identify the alias established in ~/.ssh/config and /etc/ssh/ssh_confg.d/01_joetoo_ssh_config.conf
#   this will be used to set the remote User, shh key id, adn performance/resilience policy options
ddns_server="${DDNS_SSH_ALIAS:-elrond-ddns-46}"
# joetoo_ULA_prefix: first part of local stable SLAAC addresses in joetoo domain
joetoo_ULA_prefix="${JOETOO_ULA_PREFIX:-fd62}"
# joetoo_ip4_prefix: first part of local private ipv4 addresses in joetoo domain
joetoo_ip4_prefix="${JOETOO_IP4_PREFIX%.:-192.168.6}"
# joetoo_domain: identify the local domain (currently for joetoo this is "brendler")
joetoo_domain="${JOETOO_DOMAIN:-brendler}"

#-----[ derived variables ]----------------------------------------------

#ensure the prefixes dont end in punctuation (for powershell)
joetoo_ULA_prefix="${joetoo_ULA_prefix%%*(:|.)}"
joetoo_ip4_prefix="${joetoo_ip4_prefix%%*(:|.)}"

source="${TAG}_(${1:-UNK})"
# hard-code these for WSL
interface="eth0"
ipconfig_path="/mnt/c/Windows/System32/ipconfig.exe"
powershell_path="/mnt/c/Windows/System32/WindowsPowerShell/v1.0/powershell.exe"

logger -p "${LOG_FACILITY}.notice" -t "$TAG" "(notice) Pulling WSL ddns-update triggers for [$source] event"

# (1) Fetch the ipv4 and ULA ipv6 from the Windows host
# filter for the JOETOO_ULA_PREFIX (fd62) and exclude random/temporary suffixes
_win_ipv4=$(
    "$powershell_path" -Command "Get-NetIPAddress -AddressFamily IPv4  -IPAddress ${JOETOO_IP4_PREFIX}* | \
        Select-Object -ExpandProperty IPAddress -First 1" | tr -d '\r'
)
logger -p "${LOG_FACILITY}.debug" -t "$TAG" "(debug) got _win_ipv4: [${_win_ipv4}] from powershell"

# (3) Trigger the updates
# send a WSL boot event ddns-update, which handles the 'diff' check via its own cache
if [ -n "$_win_ipv4" ]; then
    logger -p "${LOG_FACILITY}.notice" -t "$TAG" "(notice) Triggering ddns-update for $_win_ipv4"
    /usr/sbin/ddns-update add "$_win_ipv4" "$interface" "$source"
fi

logger -p "${LOG_FACILITY}.notice" -t "$TAG" "(notice) WSL ddns-update triggers complete"

unset _win_ipv4 source TAG

