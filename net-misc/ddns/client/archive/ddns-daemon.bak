#!/bin/sh
#
# dynamic dns update service daemon (c) joe brendler 2026-8765
#
# use "ip -6 monitor all" as a background service - to detect and act on
# events requiring a ddns update be sent to the dns (call /usr/sbin/ddns-update)
# format:
# Deletion: [ADDR]Deleted <ifindex>: <iface> inet6 <addr>
#   action: ddns-update add <NEW_ADDR> <FQDN> <INTERFACE> <TIMESTAMP>
# Addition: [ADDR]<ifindex>: <iface> inet6 <addr> scope global ...
#   (but only when it is not “Deleted”, “temporary”, or “tentative”)
#  action: ddns-update del <OLD_ADDR> <FQDN> <INTERFACE> <TIMESTAMP>
# note: ignore lifetime refresh messages, link flapping, and route changes
#  ** act only on [ADDR]Deleted or [ADDR] with a stable ULA

# make the daemon tell the shell - “When I exit, kill every process in my process group”
trap 'kill 0' EXIT

#-----[ variables ]-----------------------------------------------------

PN=${0##*/}

# source /etc/conf.d/ddns if it exists; exit if missing
_conf="/etc/conf.d/ddns"
if [ -f "$_conf" ]; then
    . "$_conf"
else
    logger -p "user.err" -t "${PN}" "Configuration file $_conf missing. Exiting."
    exit 1
fi

# map the sourced config variables to internal script variables if names differ

# dns to query with dig to validate cached address info
joetoo_dns="${JOETOO_DNS_SERVER:-elrond}"
# debugging_log: file in which to write debugging info (to do: move to ordinary log when mature)
debugging_log="${DDNS_DEBUG_LOG:-/tmp/ddns-update.debug.log}"

# now sourced from /etc/conf.d/ddns --
#LOG_FACILITY="local5"
#DDNS_REVERIFY_INTERVAL=600  # seconds (reverify dns if cache info is older than 10 min)
#DDNS_CACHE_DIR=/run/ddns-daemon.cache

# assign and apply sensible defaults in case /etc/conf.d/ddns is missing or de-populated
# user: identify the local user who will run ssh (sudo -u $user ssh ...)
user="${DDNS_USER:-joe}"
# ddns_server: identify the alias established in ~/.ssh/config and /etc/ssh/ssh_confg.d/01_joetoo_ssh_config.conf
#   this will be used to set the remote User, shh key id, adn performance/resilience policy options
ddns_server="${DDNS_SSH_ALIAS:-elrond-ddns-46}"
# joetoo_ULA_prefix: first part of local stable SLAAC addresses in joetoo domain
joetoo_ULA_prefix="${JOETOO_ULA_PREFIX:-fd62}"
# joetoo_ip4_prefix: first part of local private ipv4 addresses in joetoo domain
joetoo_ip4_prefix="${JOETOO_IP4_PREFIX:-192.168.6"
# joetoo_domain: identify the local domain (currently for joetoo this is "brendler")
joetoo_domain="${JOETOO_DOMAIN:-brendler}"

#-----[ derived variables ]----------------------------------------------
FQDN="$(hostname).${joetoo_domain}"
# let ddns-update calculate timestamp and fqdn for itself

# create the cache directory if needed, and only if the prefix is valid (contains at least leading and one addl /)
slashes="${DDNS_CACHE_DIR//[^\/]}"  # parameter expansion to substitute '' for anything that is not a /
if [ ${#slashes} -ge 2 ]; then
  mkdir -p  "${DDNS_CACHE_DIR%/*}"   # like $(dirname "$DDNS_CACHE_DIR") w/w subshell and function call
else
  DDNS_CACHE_DIR="/run/ddns-daemon.cache"
fi

#-----[ functions ]-----------------------------------------------------

timestamp() {
    printf '%s\n' "$(date '+%Y-%m-%d_%H:%M:%S')"
}


#-----[ main script ]-----------------------------------------------------
ip -6 monitor address | while read -r line; do

    case "$line" in
        *"Deleted"* )
            # extract interface and address
            IFACE=$(printf '%s\n' "$line" | awk '{print $3}')
            ADDR=$(printf '%s\n' "$line" | awk '{print $5}' | cut -d/ -f1)
            # ignore link-local and multicast deletions
            printf '%s\n' "$ADDR" | grep -q "^fe80" && continue
            printf '%s\n' "$ADDR" | grep -q "^ff" && continue
            EVENT="del"
            ;;

        *"inet6 ${joetoo_ULA_prefix}"* )
            # extract interface and address
            IFACE=$(printf '%s\n' "$line" | awk '{print $2}')
            ADDR=$(printf '%s\n' "$line" | awk '{print $4}' | cut -d/ -f1)
            # skip temporary or tentative
            printf '%s\n' "$line" | grep -q "temporary" && continue
            printf '%s\n' "$line" | grep -q "tentative" && continue
            EVENT="add"
            ;;

        * )
            continue
            ;;
    esac

    # when we have EVENT, ADDR, and IFACE, then act
    if [ -n "$EVENT" ] && [ -n "$ADDR" ] && [ -n "$IFACE" ]; then

# move cache/verify to ddns-update
#        # first complete the identification of the cache file for this interface
#        CACHE_FILE="${DDNS_CACHE_DIR}.${IFACE}"
#        TIMESTAMP=$(timestamp)
#        # check the cache - if this info has not changed, then if it is stale reverify with dns
#        # (don't update the dns unless the dns is wrong)
#        if [ -f "$CACHE_FILE" ]; then
#            CACHE_INFO=$(cut -d '|' -f1,2 "$CACHE_FILE")
#            CACHE_TS=$(cut -d '|' -f3 "$CACHE_FILE")
#        else
#            CACHE_INFO=""
#            CACHE_TS=""
#        fi

        # for delete events - always submit to dns and always delete cache entry
        case "$EVENT" in
            "del")
                msg="[$TIMESTAMP] Deleting; sending update for $ADDR $IFACE"
                logger -p "${LOG_FACILITY}.notice" -t "${PN}" "${msg}"
                printf '%s\n' "${msg}" >> "${debugging_log}"
                /usr/sbin/ddns-update "$EVENT" "$ADDR" "$IFACE"
                # remove the cache
                rm -f "$CACHE_FILE"
                ;;
            "add")
                msg="[$TIMESTAMP] event: [$EVENT]; CACHE_INFO: [$CACHE_INFO];  ADDR|IFACE: [$ADDR|$IFACE]"
                logger -p "${LOG_FACILITY}.notice" -t "${PN}" "${msg}"
                printf '%s\n' "${msg}" >> "${debugging_log}"
                # call ddns_update (which will handle cache/verify now)
                /usr/sbin/ddns-update "$EVENT" "$ADDR" "$IFACE"


#                if [ "$CACHE_INFO" = "$ADDR|$IFACE" ]; then
#                    # if CACHE_TS is unset, treat it as stale
#                    [ -z "$CACHE_TS" ] && CACHE_TS="1985-01-01_00:00:00"
#                    # guard vs unset or malformed CACHE_TS
#                    if ! CACHE_TS_SECONDS=$(date -d "${CACHE_TS/_/ }" +%s 2>/dev/null); then
#                        # treat as stale
#                        CACHE_TS_SECONDS=0
#                    fi
#                    NOW_SECONDS=$(date +%s)
#                    # reverify dns if cache info is older than 10 min
#                    if (( NOW_SECONDS - CACHE_TS_SECONDS > DDNS_REVERIFY_INTERVAL )); then
#                        # STALE CACHE
#                        # domain information groper (dig) +short means just get the final answer; AAAA means ipv6
#                        DNS_INFO=$(dig +short AAAA "$FQDN" "@${joetoo_dns}")
#                        if [ -z "$DNS_INFO" ]; then
#                            # DNS unreachable → do NOT update cache, do NOT update DNS
#                            # let cache remain stale; retry later
#                            continue   # i.e. skip directly to next iteration of while loop
#                        fi
#                        # look for ADDR in DNS_INFO -F (fixed string) -x (whole line) -q (quiet)
#                        if printf '%s\n' "$DNS_INFO" | grep -Fxq "$ADDR"; then
#                            # dns has the correct address - just update the cache
#                            printf '%s\n' "${ADDR}|${IFACE}|${TIMESTAMP}" > "$CACHE_FILE"
#                            msg="[$TIMESTAMP] DNS verified; updated cache timestamp for $ADDR $IFACE"
#                            logger -p "${LOG_FACILITY}.notice" -t "${PN}" "${msg}"
#                            printf '%s\n' "${msg}" >> "${debugging_log}"
#                        else
#                            # dns does not have the right address - update it
#                            msg="[$TIMESTAMP] DNS not verified; sending update for $ADDR $IFACE"
#                            logger -p "${LOG_FACILITY}.notice" -t "${PN}" "${msg}"
#                            printf '%s\n' "${msg}" >> "${debugging_log}"
#                            /usr/sbin/ddns-update "$EVENT" "$ADDR" "$IFACE"
#                            # write new info to cache
#                            printf '%s\n' "${ADDR}|${IFACE}|${TIMESTAMP}" > "$CACHE_FILE"
#                        fi  # addr in dns_info ?
#                    fi  # stale cache
#                else
#                    # address is not the same ac cache - submit new update
#                    msg="[$TIMESTAMP] address differs from cache; sending update for $ADDR $IFACE"
#                    logger -p "${LOG_FACILITY}.notice" -t "${PN}" "${msg}"
#                    printf '%s\n' "${msg}" >> "${debugging_log}"
#                    /usr/sbin/ddns-update "$EVENT" "$ADDR" "$IFACE"
#                    # write new info to cache
#                    printf '%s\n' "${ADDR}|${IFACE}|${TIMESTAMP}" > "$CACHE_FILE"
#                fi  # addr same as cache?
                ;;
            *)
                msg="[$TIMESTAMP] INVALID event [$EVENT] for $ADDR $IFACE (skipping)"
                logger -p "${LOG_FACILITY}.err" -t "${PN}" "${msg}"
                printf '%s\n' "${msg}" >> "${debugging_log}"
                continue
        esac

        EVENT=""
        ADDR=""
        IFACE=""
    fi  # call for action

done
