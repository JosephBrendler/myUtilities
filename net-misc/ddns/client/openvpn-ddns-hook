#!/bin/sh
# /etc/openvpn/openvpnkeys_2024/openvpn-ddns-hook
# dual-stack DDNS integration for joetoo architecture
# (ebuild installs iaw USE openvpn_4 and openvpn_6 only what is needed)

PN=${0##*/}

# initialze pseudo-boolean reference
# (because this script does not source script_header_joetoo)
TRUE=0; FALSE=""; NEED_UPDATE="$FALSE"

#-----[ user configured variables ]---------------------------------------------------

# source /etc/conf.d/ddns if it exists; exit if missing
_conf="/etc/conf.d/ddns"
if [ -f "$_conf" ]; then
    . "$_conf"
else
    logger -p "user.err" -t "${PN}" "Configuration file $_conf missing. Exiting."
    exit 1
fi

# map the sourced config variables to internal script variables if names differ

# BUILD: package build variable generated by the ebuild producing this file
BUILD="${BUILD:-0.0.0}"
# logging tag
TAG="${PN}-${BUILD}"

# now sourced from /etc/conf.d/ddns --
LOG_FACILITY="${LOG_FACILITY:-local5}"

# JOETOO_OPENVPNKEYS_DIR - location of client openVPN configs, keys, and hook scripts
_odh_openvpn_dir="${JOETOO_OPENVPNKEYS_DIR:-"/etc/openvpn/openvpnkeys_2024/"}"

_log_prefix="[ddns-vpn-hook]"
_debug_log_file="/tmp/joetoo-updown.debug.log"
echo "(debug) running ${PN}" > "${_debug_log_file}"

# initialize (odh_-localized) variables for exit status and data
odh_status=0

#-----[ main script ]---------------------------------------------------------

# Log the Initial State
msg="(debug) - invoked - Capturing openVPN environent data for diagnotics"
logger -p "${LOG_FACILITY}.debug" -t "${TAG}" "${msg}"

# DIAGNOSTIC: capture openVPN environment
msg="(diagnostics) ------------------------------------------------------------"
logger -p "${LOG_FACILITY}.debug" -t "${TAG}" "${msg}"

msg=$( env | grep -E 'ifconfig|ip|remote|local|dev' | sort)
logger -p "${LOG_FACILITY}.debug" -t "${TAG}" "${msg}"

msg="(debug)(up) ifconfig_local: ${ifconfig_local}] should be populated by openvpn"
logger -p "${LOG_FACILITY}.debug" -t "${TAG}" "${msg}"
msg="(debug)(up) ifconfig_ipv6_local: ${ifconfig_ipv6_local}] should be populated by openvpn"
logger -p "${LOG_FACILITY}.debug" -t "${TAG}" "${msg}"

msg="(diagnostics) ------------------------------------------------------------"
logger -p "${LOG_FACILITY}.debug" -t "${TAG}" "${msg}"


# ddns registration hook - only attempt each if the script exists (ebuild installed it)
if [ -x "${_odh_openvpn_dir%/}/openvpn-ddns-hook-ipv4.up" ]; then
    "${_odh_openvpn_dir%/}/openvpn-ddns-hook-ipv4.up"
fi
if [ -x "${_odh_openvpn_dir%/}/openvpn-ddns-hook-ipv6.up" ]; then
    "${_odh_openvpn_dir%/}/openvpn-ddns-hook-ipv6.up"
fi

# Clean up localized variables
unset -v _log_prefix _debug_log_file _odh_openvpn_dir
logger -p "${LOG_FACILITY}.debug" -t "${TAG}" "Exiting with status [$odh_status]"

exit ${odh_status}

