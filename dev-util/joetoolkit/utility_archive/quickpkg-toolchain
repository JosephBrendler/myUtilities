#!/bin/bash

source /usr/sbin/script_header_joetoo

TARGET=""

toolchain=(
'gcc'
'glibc'
'binutils'
'linux-headers'
)

usage() {
    j_msg -${err} "${BRon}usage: ${BGon}quickpkg-toolchain <TARGET>${Boff}"
    j_msg -${notice} -p "${BYon}  Note: exactly one argument <TARGET> is required. Examples:${Boff}"
    j_msg -${notice} -p "    aarch64-unknown-linux-gnu"
    j_msg -${notice} -p "    armv6j-unknown-linux-gnueabihf"
    j_msg -${notice} -p "    armv7a-unknown-linux-gnueabihf"
    exit
}

validate_target() {
    case $TARGET in
        "aarch64-unknown-linux-gnu" )
            j_msg -${notice} -p "valid target: [${TARGET}]" 2 ;
            ;;
        "armv6j-unknown-linux-gnueabihf" )
            j_msg -${notice} -p "valid target: [${TARGET}]" 2 ;
            ;;
        "armv7a-unknown-linux-gnueabihf" )
            j_msg -${notice} -p "valid target: [${TARGET}]" 2 ;
            ;;
        * )
            E_j_msg -${notice} -p "invalid target: [${TARGET}]" ;
            usage ;;
    esac
}

#-----[ main script ]---------------------------------------------
checkroot
separator $(basename $0) $(hostname)
[ $# -ne 1 ] && usage
TARGET=$1
validate_target

old_dir="$(pwd)"
cd /usr/${TARGET}
j_msg -${notice} -p "now working in target sysroot directory: [${Mon}$(pwd)${Boff}]"

for tool in ${toolchain[@]}; do
    j_msg -${notice} -p "  building (quickpkg) binary package for ${LBon}cross-${TARGET}/${tool}${Boff}"
    quickpkg --include-unmodified-config=y cross-${TARGET}/${tool} >/dev/null 2>&1 ; right_status $? ${notice}
done

echo
cd $old_dir
j_msg -${notice} -p "now working in previous directory: [${Mon}$(pwd)${Boff}]"
