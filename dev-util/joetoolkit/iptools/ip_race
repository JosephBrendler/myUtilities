#!/bin/bash
selected_ip_list=()
tmp_ip_list=(fd62:6262:6262:0:6837:81cb:62fa:cc5e fd62:6262:6262:0:2bff:4078:2153:8ebe 192.168.62.129 192.168.62.193)
test() {
winner_file=$(mktemp -p /dev/shm)

for ip in "${tmp_ip_list[@]}"; do
  (timeout 0.5 bash -c "</dev/tcp/$ip/22" && echo "$ip" >> "$winner_file") &>/dev/null &
done
wait
best_ip=$(head -n1 "$winner_file")
[ -n "$best_ip" ] && selected_ip_list+=("$best_ip")
rm -f "$winner_file"
}

test
echo "${selected_ip_list[@]}"

