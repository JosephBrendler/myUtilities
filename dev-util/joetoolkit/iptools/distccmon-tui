stream_log_data() {
    # setup and messaging block goes to stderr so awk ignores it
    {
        j_msg -$notice -p "Starting log stream for: [$tui_DISTCC_LOG]"
        j_msg -$debug -p "grep_filter: [$grep_filter]"
        j_msg -$debug -p "tui_refresh_period: [$tui_refresh_period]"
        j_msg -$debug -p "mode: [$mode]"

    } >&2
    # data generation block must go to stdout so awk receives it
    {
        # first call stream_dns_hostfiles (once) if in server mode (not applicable to client mode
        # because client knows it is "localhost" and tui already knows who is in /etc/distcc/hosts
        # but server gets requests from ip addresses and tui has to look them up to be useful)
        [[ "$mode" == "server" ]] && stream_dns_hostfiles

        j_msg -$notice -p "First ingesting all of recorded history, please wait a few seconds ..." >&2
        # first dump and roll up all of recorded history - do not background this
        # ensure this massive dump is complete BEFORE backgrounding tail -F and interleaving the hearbeat
        for old_log in ${tui_DISTCC_OLDLOG_GLOB}; do [[ -f "$old_log" ]] && zcat "$old_log"; done
        cat "$tui_DISTCC_LOG"
        j_msg -$notice -p "Now backgrounding tail -F to stream all future lines" >&2
        sleep 0.5
        # now background the continued steaming of any future lines in this file
        tail -F "$tui_DISTCC_LOG" &

        # infinite loop, injecting hearbeat with dynamic formatting data (width)
        # (optionally also include "spoofed" log data to test error handling)
        while [ $TRUE ]; do
            printf "__HEARTBEAT__ %d\n" "$(tput cols)"
            # for testing diagnostic logic only (match both "distcc[" AND "compile from"
#            printf "distcc[000000] compile from spoofed client record for testing \n"
            # for testing diagnostic logic only (match both "distcc[" AND "compile from"
#            printf "distccd[000000] compile from spoofed server record for testing\n"
            # for testing diagnostic logic only (match  "__DNS_UPDATE__")
#            printf "__DNS_UPDATE__    1.1.1.1    spoofed_test_host\n"
            sleep "$tui_refresh_period"
        done
    } | grep --line-buffered --text -E "$grep_filter"
}

stream_dns_hostfiles() {
    local result=0 ssh_cmd=""

    # define a sed filter to transform raw lines of dns /etc/hosts.d/* files
    #   into the update input format expected by the awk's __DNS_UPDATE__ action block
    #   employ with LC_ALL=C sed "$SED_DNS_FILTER"
    # line format: 192.168.62.183  g3nuc01.brendler  # eth0  2026-06-12_07:40:38  ddns-update-hook-ipv4-0.3.1
    # strip blank lines and comments
    SED_DNS_FILTER="/^${W0}#/d; /^${W0}$/d; "
    # strip all right of including # and whitespace immediately preceding it (note: escape \#)
    SED_DNS_FILTER+="s/${W1}#${P1}$//; "
    # prepend "__DNS_UPDATE__" as awk action block expects
    SED_DNS_FILTER+="s/^/__DNS_UPDATE__ /; "
    # now sort the data on ip address
    SORT_DNS_FILTER+="sort -k2"

    # group setup commands and redirect stdout to stderr to protect the awk stream
    {
        start_ssh_agent "$local_user"
        source "$AGENT_ENV_FILE"
        load_key "$local_user"
        j_msg -$debug -p "local_user: $local_user"
        j_msg -$debug -p "dns: $dns"
        j_msg -$debug -p "SSH_KEY: $SSH_KEY"
        j_msg -$notice -p -n "Streaming dns hosts files directly to awk memory cache"
    } >&2

    # run the ssh command, outputting the raw file contents directly to stdout
    # note: -n prevents stdin hanging; BatchMode=yes prevents interactive prompts
    sudo_cmd=( sudo -u "$local_user" SSH_AUTH_SOCK="$SSH_AUTH_SOCK" )
    ssh_cmd=( ssh -n -q -i "$SSH_KEY" -o ConnectTimeout=2 -o BatchMode=yes "${remote_user}@${dns}" )
    payload_cmd=( cat '/etc/hosts.d/*' )
    sort_cmd=( sort -k2 )
    "${sudo_cmd[@]}" "${ssh_cmd[@]}" "${payload_cmd[@]}" | sed "$SED_DNS_FILTER" | "${sort_cmd[@]}"
    result=$?
    # group teardown commands and redirect stdout to stderr
    {
        handle_result $result "" "" $notice
        unload_key "$local_user" && \
        stop_ssh_agent "$local_user"
        result=$?
        j_msg -$notice -p "Done streaming dns host files; exiting with status code [$result]"
    } >&2
}

validate_tui_iput_logfile() {
    vti_ret=0
    # ensure mode-dependet log file exists and has proper ownership and permissions
    local file="" perms="" ownership=""
    case "$mode" in
        client)
            file="/var/log/distcc/distcc-client.log"
            perms="644"
            ownership="portage:portage"
            ;;
        server)
            file="/var/log/distcc/distccd.log"
            perms="644"
            ownership="distcc:daemon"
            ;;
        *) return 1 ;;
    esac
    # find or create the input logfile
    j_msg -$notice -p -n "Looking for input logfile [$file]"
    [ -f "$file" ]
    handle_result $? "found" "not found" $notice
    if [ ! $? -eq 0 ]; then
        j_msg -$notice -p -n "Creating input logfile [$file]"
        touch "$file"
        handle_result $? "created" "" $notice || vti_ret=1
    fi
    # set permissions on input logfile
    j_msg -$notice -p -n "Setting permissions on input logfile [$file]"
    chmod "$perms" "$file"
    handle_result $? "$(stat -c %a "$file")" "" $notice || vti_ret=$(( vti_ret | 2 ))
    # set ownership on input logfile
    j_msg -$notice -p -n "Setting ownership of input logfile [$file]"
    chown "$ownership" "$file"
    handle_result $? "$(stat -c %U:%G  "$file")" "" $notice || vti_ret=$(( vti_ret | 4 ))
    return $vti_ret
}

#-----[ main script ]--------------------------------------------------------------------------
checkroot
separator "${PN}-${BUILD}" "(initialization)"
validate_logfile
# status file is not used since there is no command sequence, but validate and store 0 to prevent errors
validate_root_file "$status_file"
echo 0 > "$status_file"

process_cmdline "$@" || die "failed to parse_cmdline"
configure_mode || die "failed to configure_mode"
# validate availability of input logfile (must configure mode first)
validate_tui_iput_logfile || die "failed to validate_tui_iput_logfile"

show_config || die "failed to show_config"
confirm_continue_or_exit

# run this "forever"
run_tui_engine || die "failed to run_tui_engine"

