# AWKs data structure will include these associative arrays (not visible to bash)
# active_peers           # list of distcc remote peer client/servers keyed on pid of jobs they are working
# active_starts          # recorded start-time when this keyed pid was first observed (job start)
# active_input_files     # list of files processed in this keyed pid job
# active_output_files    # list of files processed in this keyed pid job
# active_outcomes        # result of remote compile job ( success / failure )
# active_duration        # list of elapsed compile time keyed on pid
# active_ip_addrs        # list of ip addresses for server mode keyed on pid
# active_packages        # list of packages keyed on pid

# TBD if this will be a bash associative array for reading dns hostnames keyed to ip
declare -A host_names      # list of host names, keyed on ip addresses (read from dns)
declare -A bash_reg_locks  # tbd if needed (anti-avalanche guard -  dont spawn redundant network tasks for the same IP)

# identify client mode selector string patterns to capture important lifecycle events as shown above
c_file_selector="compile from"  #..............# input_file = $4 ;  output_file = $6
c_host_selector="\] exec on"  #.................#  --> host_name = $4
c_success_selector="completed ok"  #...........# && / compile / not / cpp /  -->  host_name = $5; outcome = success
c_failure_selector="ERROR:"  #.................# && /compile/ && /failed/ --> outcome = failure /// but pid may continue
c_elapsed_selector="elapsed compilation time"  # elapsed = $5
c_exit_selector="(dcc_exit)"  #................# record to history and delete from active records
# todo: identify package selector

# identify server mode selector string patterns to capture important lifecycle events as shown above
s_ip_selector="(dcc_check_client)"  #.....#  --> host_ip_address = $NF /// incl port#
