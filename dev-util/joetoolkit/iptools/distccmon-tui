run_tui_engine() {
    # create a background loop, grouped with tail using ( ... & ... ) and pipe this through
    # grep_filter to select relevant lines with --line-buffered immediately rendering then to output,
    # which is then piped to awk script to handle with associative arrays all keyed on pid
    # (HA! - but note that parallelism farms out preprocessing and compile with different pids,
    #  so the pid that competes the job may not be the one that "started" it)
    # (use tail -F rathern than -f so it will auto renew when log is rotated)

    # caution: the entire awk script must be single-quoted, so it cannot have ANY single-quites INSIDE it
    # (including contractions so do not put any apostraphe in dont; or just say do not instead)

    # 20260716 - instead of -
    #  (...) | awk '{...}' | while read signals ... /// chage to -
    #  awk '{...}' <(...#1) <(...#2) | while read signals ...
    #  (so we can feed two entire processes #1 being short-duration, and #2 being "infinite")
    # 20260718 - going back to (...) | grep | awk '{...}' | consumer to eliminate the first
    #  process substitution and the NR == NFR { ... } action block inside awk designed to consume
    #  dns updates, in favor of a single dns_cachu update block that can be called before and after
    #  the infinte hearbeat loop starts
    ( stream_log_data ) | awk "${awk_vars[@]}" '
    #-----[ awk functions ]---------------------------------------------------------------
    # Debug: dump every incoming line to stderr to verify the pipe is alive
#    { print "DEBUG [awk input]: " $0 > "/dev/stderr"; fflush("/dev/stderr") }
    # use this function to shift historical items down and append anew entry
    function rotate_history(new_record) {
        # shift existing records down by one index
        for (i = history_depth; i > 1; i--) {
            history[i] = history[i-1]
        }
        # insert the new record at the head of the array
        history[1] = new_record
    }
    # use this function to clean up record of pid when it is done
    function delete_active_records(p) {
        delete active_peers[p]
        delete active_starts[p]
        delete active_input_files[p]
        delete active_output_files[p]
        delete active_outcomes[p]
        delete active_duration[p]
        delete active_ip_addrs[p]
        delete last_contact[p]
    }
    # use this function to prune dead pids
    function prune_dead_pids(    pid, parts, ts, reason) {
        # consider aged-out and prune active records older than job_timeout
        for (pid in dead_pids) {
            # examine the reason the pid died, to determine wheter to do diagnostic message
            # format: dead_pid[pid] = systyme() "|" reason
            split(dead_pids[pid], parts, "|")
            ts = parts[1] + 0  # force awk to understand ts is a number
            reason = parts[2]
            # compare elapsed time against globally passed job_timeout
            if ((systime() - ts) > dead_pid_timeout) {
                # prune the dead pid
                delete dead_pids[pid]
                if (reason != "exit") {
                    # log to diagnostics
                    diagnostic_messages["dead_pid_pruned"][systime()] = \
                        "Pruned dead pid " pid " (reason: " reason ", timeout: " dead_pid_timeout "s)"
                }
            }
        }
    }
    # use this function to prune expired jobs
    function prune_expired_jobs(    pid) {
        # consider aged-out and prune active records older than job_timeout
        for (pid in last_contact) {
            # compare elapsed time against globally passed job_timeout
            if ((systime() - last_contact[pid]) > job_timeout) {
                # declare this pid dead for the anomalous reason "stale"
                dead_pids[pid] = systime() "|stale"
                # use existing cleanup function
                delete_active_records(pid)
                # log to diagnostics
                diagnostic_messages["expired_job_pruned"][systime()] = "Pruned expired job " pid " (timeout: " job_timeout "s)"
            }
        }
    }
    # use this function to prune expired packages
    function prune_expired_packages(    now, client_id, pkg) {
        now = systime()
        # consider aged-out and prune active packages older than pkg_timeout
        if (mode == "client") {
            client_id = "localhost"
            for (pkg in active_packages[client_id]) {
                if (now - active_packages[client_id][pkg] > pkg_timeout) {
                    delete active_packages[client_id][pkg]
                }
            }
        } else if (mode == "server") {
            for (client_id in active_packages) {
                for (pkg in active_packages[client_id]) {
                    if (now - active_packages[client_id][pkg] > pkg_timeout) {
                        delete active_packages[client_id][pkg]
                    }
                }
                # cleanup empty records
                if (length(active_packages[client_id]) == 0) {
                    delete active_packages[client_id]
                }
            }
        } else {
            diagnostic_messages["invalid_mode"][systime()] = "Invalid mode case in prune_expired_packages"
        }
    }
    # use this function to generate ui assets needed by the script
    function repeat(marker, reps,    i, out_str) {
        # trim marker to just its first character
        marker = substr(marker, 1, 1)
        # loop and concatenate
        i = 0; out_str = ""
        while (i++ < reps) out_str = out_str marker
        return out_str
    }
