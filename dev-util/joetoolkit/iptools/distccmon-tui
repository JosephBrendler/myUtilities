stream_dns_hostfiles() {
    local result=0 ssh_cmd=""
#    # not applicable to client mode
#    [[ "$mode" == "client" ]] && return 0    ### w/o dns first, current awk script NR == NFR block eats everything
    # group setup commands and redirect stdout to stderr to protect the awk stream
    {
        start_ssh_agent "$local_user"
        source "$AGENT_ENV_FILE"
        load_key "$local_user"
        j_msg -$debug -p "local_user: $local_user"
        j_msg -$debug -p "dns: $dns"
        j_msg -$debug -p "SSH_KEY: $SSH_KEY"
        j_msg -$notice -p -n "Streaming dns hosts files directly to awk memory cache"
    } >&2

    # run the ssh command, outputting the raw file contents directly to stdout
    # note: -n prevents stdin hanging; BatchMode=yes prevents interactive prompts
    ssh_cmd=( ssh -n -q -i "$SSH_KEY" -o ConnectTimeout=2 -o BatchMode=yes "${remote_user}@${dns}" )
    sudo -u "$local_user" SSH_AUTH_SOCK="$SSH_AUTH_SOCK" "${ssh_cmd[@]}" cat "/etc/hosts.d/*"
    result=$?
    # group teardown commands and redirect stdout to stderr
    {
        handle_result $result "" "" $notice
        unload_key "$local_user" && \
        stop_ssh_agent "$local_user"
        result=$?
        j_msg -$notice -p "Done streaming dns host files; exiting with status code [$result]"
    } >&2
}

ingest_dns_hosts_lists() {
    local -a hostfilelines=()
    local -a ssh_cmd=()
    local line="" ip="" host="" iface="" ts_rest=""

    # user script_header_joetoo_ssh tools to enable root use of user ssh_agent
    start_ssh_agent "$local_user"
    source "$AGENT_ENV_FILE"
    load_key "$local_user"

    j_msg -$debug -p "local_user: $local_user"
    j_msg -$debug -p "dns: $dns"
    j_msg -$debug -p "SSH_KEY: $SSH_KEY"

    # use an indexed array to ingest all of the dns hosts files at once
    j_msg -$notice -p -n "Reading dns hosts files into local indexed array"
    ssh_cmd=( ssh -q -i "$SSH_KEY" -o ConnectTimeout=2 -o BatchMode=yes "${remote_user}@${dns}" )
    readarray -t hostfilelines < <( sudo -u "$local_user" SSH_AUTH_SOCK="$SSH_AUTH_SOCK" "${ssh_cmd[@]}" cat "/etc/hosts.d/*" )
    handle_result $? "read [${#hostfilelines[@]}] lines" "" $notice

    unload_key "$local_user"
    stop_ssh_agent "$local_user"

    # iterate through all lines of the hosts files
    j_msg -$notice -p "Reading dns hosts files into global associative array of host_names keyed on unique ip addresses"
    for line in "${hostfilelines[@]}"; do
        # read the whole line, assign ip and host; _ is placeholder for #; ignore iface and timestamp
        read -r ip host _ iface ts_rest <<< "$line"
        j_msg -$debug -p "ip: [$ip] host: [$host] iface: [$iface] ts_rest: [$ts_rest]"
        [[ -z "$ip" || "$ip" == \#* ]] && continue # Skip empty/comments
        # record the likely duplicated host_hames for each unique ip address in the golbal host_names associative array
        host_names["$ip"]="$host"  # refactored to awk array dns_cache[$ip] when shifted into awk
    done
    right_status $? $notice

    j_msg "-${notice}" "ingested [${#host_names[@]}] host_names"

}

validate_tui_iput_logfile() {
