            file="/var/log/distcc/distcc-client.log"
            perms="644"
            ownership="portage:portage"
            ;;
        server)
            file="/var/log/distcc/distccd.log"
            perms="644"
            ownership="distcc:daemon"
            ;;
        *) return 1 ;;
    esac
    # find or create the input logfile
    j_msg -$notice -p -n "Looking for input logfile [$file]"
    [ -f "$file" ]
    handle_result $? "found" "not found" $notice
    if [ ! $? -eq 0 ]; then
        j_msg -$notice -p -n "Creating input logfile [$file]"
        touch "$file"
        handle_result $? "created" "" $notice || vti_ret=1
    fi
    # set permissions on input logfile
    j_msg -$notice -p -n "Setting permissions on input logfile [$file]"
    chmod "$perms" "$file"
    handle_result $? "$(stat -c %a "$file")" "" $notice || vti_ret=$(( vti_ret | 2 ))
    # set ownership on input logfile
    j_msg -$notice -p -n "Setting ownership of input logfile [$file]"
    chown "$ownership" "$file"
    handle_result $? "$(stat -c %U:%G  "$file")" "" $notice || vti_ret=$(( vti_ret | 4 ))
    return $vti_ret
}

