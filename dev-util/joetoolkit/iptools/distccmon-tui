s_success_selector="completed ok"  #...........# package = $3 (extractable);  outcome = success
s_failure_selector="ERROR:"  #.................# && /dcc_r/ --> outcome = all after ERROR:
s_summary_selector="(dcc_job_summary)"  #......# elapsed = $10; exit_code = $6 (set outcome)
#                                       #......# package = $12 (extract); infile = $12 (basename)
#                                       #......# also record to history and delete from active records

