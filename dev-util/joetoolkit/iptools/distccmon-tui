    -v cup="$(CUP)"
    -v line_clr="${line_color}"
    -v pid_clr="${BMon}"
    -v ts_clr="${BAon}"
    -v file_clr="${Gon}"
    -v mode_clr="${BYon}"
    -v host_clr="${Gon}"
    -v success_clr="${BGon}"
    -v failure_clr="${BRon}"
    -v title_clr="${BWon}"
    -v heading_clr="${BCon}"
    -v clr_off="${Boff}"
    -v placeholder_clr="${BOon}"
)

#-----[ functions ]----------------------------------------------------------------------------

# try just including local cli stuff here instead of getting app_configure to source it
# Convention for cmdline arg handling:
#   set result=0 for success with no operand
#   set result=6 for success with operand
#   set result=7 for file not found (to differentiate from error)
#   set result=1 for error

handle_local_arg() # (POSIX) local compound arg handler to extend cli in script_header_joetoo
{ local hla_ret=0 _hla_arg="$1" _hla_operand="$2"
  j_msg -${debug} -p "in handle_local_arg with _hla_arg: [$_hla_arg], _hla_operand: [$_hla_operand]"
  case "$_hla_arg" in
    "-"[S] | "--server" )
      mode="server" || hla_ret=1
      j_msg -${notice} -p "assigned mode = server"
      ;;
    "-"[C] | "--client" )
      mode="client" || hla_ret=1
      j_msg -${notice} -p "assigned mode = client"
      ;;
    * )
      # NOTICE: getting here does not mean error - it just means no single flag option matched,
      # but $1 could still be a compound argument (cluster of single-letter flags), so we have
      # to differentiate that (not found) status from "error", and fall back to the main script's logic
      hla_ret=7 # not found
      ;;
  esac
  j_msg -${debug} -p "handle_local_arg complete, returning [$hla_ret]"
  return $hla_ret
}
# @usage handle_local_arg (called from script_header_joetoo)
# @args $1=current arg, $2=potential operand
# @ret 0: successful action option for flag identified, 1: error
# @ret 6: consumed an operand, 7: file not found
# @note operates at INFO severity level
# @note examines string for match to known flags (e.g. -r|--resume)

handle_local_compound_arg() # (POSIX) local compound arg handler to extend cli in script_header_joetoo
{ local hlca_ret=0 _hlca_char="$1" # Get the first character of the parent's _pca_args directly as $1 now
  j_msg -${debug} -p "in handle_local_compound_arg with _pca_args: [$_pca_args], _hlca_char: [$_hlca_char]"
  case "$_hlca_char" in
    [S] )
      mode="server" || hlca_ret=1
      j_msg -${notice} -p "assigned mode = server"
      ;;
    [C] )
      mode="client" || hlca_ret=1
      j_msg -${notice} -p "assigned mode = client"
      ;;
    *    )
      # NOTICE: getting here does not mean error - it just means no single flag option matched,
      # but $1 could still be a compound argument (cluster of single-letter flags), so we have
      # to differentiate that (not found) status from "error", and fall back to the main script's logic
      hlca_ret=7 # not found
      ;;
  esac
  j_msg -${debug} -p "handle_local_compound_arg complete, returning [$hlca_ret]"
  return $hlca_ret
}
# @usage handle_local_compound_arg (called from script_header_joetoo)
# @ret 0: successful action option for flag identified, 1: error, 7: file not found
# @rule this function expects the parent script to have already stripped the leading '-'
# @note operates at INFO severity level
# @note examines the *first character* of the remaining _pca_args string

handle_local_usage() # (POSIX) local usage module to extend cli in script_header_joetoo
{
  j_msg -${notice} -m "  -[S] | --server ..........: operate ${PN} in server mode"
  j_msg -${notice} -m "  -[C] | --client ..........: operate ${PN} in server mode"
  j_msg -${notice} -pm ""  # severity-sensitive newline
  j_msg -${notice} -m "${BYon}Copy/create/set configuration (/etc/${PN}/${PN}.conf)${Boff}"
  j_msg -${notice} -m "${BYon}using ${BGon}eselect$ ${PN} ${BWon}list|set n${Boff}"
  j_msg -${notice} -pm ""  # severity-sensitive newline
}
# @usage handle_local_usage  (called from usage() in script_header_joetoo)
# @rule user-script specific usage-module which should be built in joetoo format
# @rule this file must contain legitimate bash assignments and commands
# @note operates at NOTICE severity level
# @note options h, i, n, s, r, v, q V, Q are already used by the joetoo cmdline processor


good_connectivity() {
    local ip_addr="$1"
    # first check connectivity, and then if possible use ssh to get hostname from server and tell it to register with dns
    # -c count; -W wait; -n nodns; note gnu timeout assurance
#    if timeout 1.5 ping -c 1 -W 1.5 -n "$ip_addr" &>/dev/null ; then
    # switch to devtcp to use port 22
    if timeout 1.5 bash -c "</dev/tcp/${ip_addr}/22" 2>/dev/null; then
        return 0
    else
        return 1
    fi
}

maybe_get_and_register_hostname() {
    # take over the screen to do this
    CLR; CUP 1 1
    j_msg -$notice -p "getent failed looking up ip_address [$ip_address], but it pings; trying ssh"
    # if ssh_agent isnt started start it and load keys (should only need to happen once)
    if [ -z "$AGENT_ENV" ] ; then
        j_msg -$notice -p "AGENT_ENV not set up; doing so now"
        j_msg -$notice -p -n "starting ssh agent ..."
        start_ssh_agent "$local_user" "$SSH_KEY"
        handle_result $? '' 'failed to start_ssh_agent' $notice || exit 1
        j_msg -$notice -p -n "loading local_user ssh key"
        load_key "$local_user"
        handle_result $? '' 'failed to load_key' $notice || exit 1
        sleep 3
        CLR; CUP 1 1
    fi
#    d_do 'echo "AGENT_ENV_FILE:"; cat $AGENT_ENV_FILE; echo "==========================="' $debug
    j_msg -$notice -p -n "sourcing AGENT_ENV_FILE [$AGENT_ENV_FILE]"
    source $AGENT_ENV_FILE  # source ssh_agent stuff incl auth sock
    handle_result $? '' 'failed to source AGENT_ENV_FILE' $notice || echo "maybe exit here"
    # set up a specific-identity, batchmode, timeout-sensitive ssh command to use in all four cases
    local -a ssh_cmd=( ssh -q -o ConnectTimeout=2 -o BatchMode=yes -i "$SSH_KEY" "${remote_user}@${ip_address}" )
    # use ssh to ask the remote ip_address to tell its hostname
    j_msg -$notice -p -n "looking up hostname"
    host_name=$(sudo -E -u "${local_user}" "${ssh_cmd[@]}" hostname)
    handle_result $? "$host_name" 'failed to look up host_name' $notice
    # if that did not work, then mark it unknown
    if [ -z "$host_name" ] ; then
        j_msg -$debug -p "failed to get hostname from ip_address, despite good ping"
        return 1
    else
        # get interface and ask remote machine to submit unregistered hostname to dns
        # Note: using -- /usr/sbin/ddns-update "$EVENT" "$ADDR" "$INTERFACE" "$SOURCE"
        j_msg -$notice -p -n "looking up interface"
        ssh_payload_command="ip -o addr show | grep '$ip_address'"
        iface=$(sudo -E -u "$local_user" "${ssh_cmd[@]}" "$ssh_payload_command" | awk '{print $2}')
        result=$?
        handle_result $result "$iface" '' $notice || return 1
        if [ -z "$iface" ] ; then
            j_msg -$debug -p "Note: host [$host_name] ip address [$ip_address] [unknown interface] is not registered with dns"
            sleep 3
            return 1
        else
#echo "in NOT -z (i.e. else) branch of if -z iface block"
            j_msg "-${notice}" -p "Note: host [$host_name] ip address [$ip_address] is not registered with dns"
            j_msg -$notice -p -n "Asking host [$host_name] via ssh to do that now"
            # now via ssh have the remote machine submit the update
            ssh_payload_command="rm -f /run/ddns-daemon.cache.*"
            sudo -E -u "$local_user" "${ssh_cmd[@]}" "$ssh_payload_command"
            result=$?
#echo "just ran sudo ... ssh ... status: [$result]"
            ssh_payload_command="/usr/sbin/ddns-update 'add' '$ip_address' '$iface' '${PN}-${BUILD}'"
            sudo -E -u "$local_user" "${ssh_cmd[@]}" "$ssh_payload_command"
            result=$?
#echo "just ran sudo ... ssh ... status: [$result]"
            handle_result $result '' "Host [$host_name] failed to reginster [$ip_address], [$iface] with dn" $notice || return 1
            sleep 3
        fi
#echo "now completely past if -z iface block"
    fi
    return 0
}

configure_mode() {
    local c_ret=0
    j_msg -$debug -p "running ${FUNCNAME[0]} for mode: [$mode]"
    case "$mode" in
        server)
            # identify server log file
            tui_DISTCC_LOG="/var/log/distcc/distccd.log"
            # set up a server grep_filter string with selectors to capture important lifecycle events as shown above
            grep_filter='HEARTBEAT'  #..................# ignore heartbeat - just update clock
            grep_filter+="|${s_ip_selector}"
            grep_filter+="|${s_file_selector}"
            grep_filter+="|${s_success_selector}"
            grep_filter+="|${s_summary_selector}"
            # append server selectors to awk_vars array for use in the awk script
            # (also include updates of vars that cmdline can modify (mode, verbosity, DEBUG)
            awk_vars+=(
                -v mode="$mode"
                -v verbosity="$verbosity"
                -v DEBUG=$(TrueFalse $DEBUG)
                -v ip_sel="$s_ip_selector"
                -v file_sel="$s_file_selector"
                -v success_sel="$s_success_selector"
                -v summary_sel="$s_summary_selector"
                -v logfile="$tui_DISTCC_LOG"
            )
            varlist+=" s_ip_selector s_file_selector s_success_selector s_summary_selector"
            ;;
        client)
            # identify client log file
            # Note: externally, client emerge must use DISTCC_VERBOSE=1
            #   and DISTCC_LOG= either on the emerge command line or in make.conf
            tui_DISTCC_LOG="/var/log/distcc/distcc-client.log"
            # set up a client grep_filter string with selectors to capture important lifecycle events as shown above
            grep_filter='HEARTBEAT'  #..................# ignore heartbeat - just update clock
            grep_filter+="|${c_file_selector}"
            grep_filter+="|${c_host_selector}"
            grep_filter+="|${c_success_selector}"
            grep_filter+="|${c_failure_selector}"
            grep_filter+="|${c_elapsed_selector}"
            grep_filter+="|${c_exit_selector}"
            # append client selectors to awk_vars array for use in the awk script
            # (also include updates of vars that cmdline can modify (mode, verbosity, DEBUG)
            awk_vars+=(
                -v mode="$mode"
                -v verbosity="$verbosity"
                -v DEBUG=$(TrueFalse $DEBUG)
                -v file_sel="$c_file_selector"
                -v host_sel="$c_host_selector"
                -v success_sel="$c_success_selector"
                -v failure_sel="$c_failure_selector"
                -v elapsed_sel="$c_elapsed_selector"
                -v exit_sel="$c_exit_selector"
                -v logfile="$tui_DISTCC_LOG"
            )
            varlist+=" c_file_selector c_host_selector c_success_selector c_failure_selector c_elapsed_selector c_exit_selector"
            ;;
        * ) c_ret=1 ;;
    esac
    j_msg -$debug -p "tui_DISTCC_LOG: [$tui_DISTCC_LOG]"
    # return non-zero bitmask on error or empty data structure(s)
    [ -z "$tui_DISTCC_LOG" ] && c_ret=$(( c_ret | 2 ))
    [ -z "$grep_filter" ] && c_ret=$(( c_ret | 4 ))
    [ ${#awk_vars[@]} -eq 0 ] && c_ret=$(( c_ret | 4 ))
    return $c_ret
}

run_tui_engine() {
    # create a background loop, grouped with tail using ( ... & ... ) and pipe this through
    # grep_filter to select relevant lines with --line-buffered immediately rendering then to output,
    # which is then piped to awk script to handle with associative arrays all keyed on pid
    # (HA! - but note that parallelism farms out preprocessing and compile with different pids,
    #  so the pid that competes the job may not be the one that "started" it)
    # (use tail -F rathern than -f so it will auto renew when log is rotated)

    # caution: the entire awk script must be single-quoted, so it cannot have ANY single-quites INSIDE it
    # (including contractions so do not put any apostraphe in dont; or just say do not instead)

    # 20260716 - instead of -
    #  (...) | awk '{...}' | while read signals ... /// chage to -
    #  awk '{...}' <(...#1) <(...#2) | while read signals ...
    #  (so we can feed two entire processes #1 being short-duration, and #2 being "infinite")

    awk "${awk_vars[@]}" '
    #-----[ awk functions ]---------------------------------------------------------------
    # use this function to shift historical items down and append anew entry
    function rotate_history(new_record) {
        # shift existing records down by one index
        for (i = history_depth; i > 1; i--) {
            history[i] = history[i-1]
        }
        # insert the new record at the head of the array
        history[1] = new_record
    }
    # use this function to clean up record of pid when it is done
    function delete_active_records(dead_pid) {
        delete active_peers[dead_pid]
        delete active_starts[dead_pid]
        delete active_input_files[dead_pid]
        delete active_output_files[dead_pid]
        delete active_outcomes[dead_pid]
        delete active_duration[dead_pid]
        delete active_ip_addrs[dead_pid]
        delete active_packages[dead_pid]
    }
    # use this function to generate ui assets needed by the script
    function repeat(marker, reps,    i, out_str) {
        # trim marker to just its first character
        marker = substr(marker, 1, 1)
        # loop and concatenate
        while (i++ < reps) out_str = out_str marker
        return out_str
    }
    # use this function to draw the heading panel at the top of each frame
    function draw_heading(mode) {
        # clear screen and print heading for client mode
        printf "%s%s", clr, cup ;
        printf "%s\n", dubdashline ;
        printf "  %sDISTCC_LOG%s = %s%-35.35s%s %sCurrent Time:%s %s%s%s\n",
            heading_clr, clr_off,
            file_clr, logfile, clr_off,
            heading_clr, clr_off, ts_clr, strftime("%H:%M:%S"), clr_off ;
        if (mode == "client") {
            printf "  %sDISTCC Mode: %sClient%s%  Current Package: %s%s%s\n",
                heading_clr, mode_clr, heading_clr, repeat(" ", 29), file_clr, active_packages[pid], clr_off ;
            printf "%s\n", dubdashline ;
            printf "  %sACTIVE REMOTE %sSERVER%s THREADS%s\n", title_clr, mode_clr, title_clr, clr_off ;
            COL3_TITLE = "SERVER"
        } else {
            printf "  %sDISTCC Mode: %sServer%s%s Current Package: %s%s%s\n",
                heading_clr, mode_clr, heading_clr, repeat(" ", 29), file_clr, active_packages[pid], clr_off ;
            printf "%s\n", dubdashline ;
            printf "  %sACTIVE REMOTE %sCLIENT%s THREADS%s\n", title_clr, mode_clr, title_clr, clr_off ;
            COL3_TITLE = "CLIENT"
        }
        printf "%s\n", dashline ;
        # drop output file; add precision
        printf "%s%-10.10s%s %s %s%-30.30s%s %s %s%-24.24s%s %s %s%-8.8s%s %s %s%-10.10s%s\n",
           title_clr, "PID", clr_off, separator,
           title_clr, "SOURCE FILE", clr_off, separator,
           title_clr, COL3_TITLE, clr_off, separator,
           title_clr, "ELAPSED", clr_off, separator,
           title_clr, "OUTCOME", clr_off
        printf "%s\n", dashline ;
    }
    # use this function to render the active panel within the frame
    function draw_active(mode) {
        # note: mode not currently used, but included for future-proofing
        # awk loop syntax assigns key to loop variable (so p is pid here)
        for (p in active_peers) {
            elapsed = now - active_starts[p]
            # update the active records
            printf "%s%-10.10s%s %s %s%-30.30s%s %s %s%-24.24s%s %s %s%-8.8s%s %s %-10.10s\n",
                pid_clr, p, clr_off, separator,
                file_clr, active_input_files[p], clr_off, separator,
                host_clr, active_peers[p], clr_off, separator,
                ts_clr, elapsed, clr_off, separator,
                active_outcomes[p]
            count++
        }
    }
    # use this function to render the recent history panel within the frame
    function draw_recent_history(mode) {
        # note: mode not currently used, but included for future-proofing
        # update recently completed jobs
        # if there are currently no active jobs, say so
        if (count == 0) {
