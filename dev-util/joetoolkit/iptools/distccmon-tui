    ### awk function for CLIENT mode ###-------------------------------------------------------------------------------------
    function parse_client_line(    pid, child_pid, client_id, parts, path, n, path_parts, final_time, log_str, clean_peer) {
        # if it is a real log line, parse the data
        # and ignore (dcc_increment_safeguard) lines that are sqawned child processes that generate only one line
        if ($0 !~ /__HEARTBEAT__/ && $0 !~ /dcc_increment_safeguard/) {
            # assign client_id so both client and server modes can use same data structure for active packages
            # (for client mode, it is trivial and by definition)
            client_id = "localhost"
            # extract pid (numeric part of first field; format: "distcc[1234567]"
            match($1, /[0-9]+/)
            pid = substr($1, RSTART, RLENGTH)   # RSTART, RLENGTH are awk built-in tracking regex matched pattern relative to full string
            # guard against a pid declared dead having a follow-on line revive it
            if (pid in dead_pids) { return 0 }
            # update last contact for every line received (enable prune if job dies with no exit_sel)
            last_contact[pid] = systime()
            # safe default initialization for fields required by piping and logging (do only on first observation of pid)
            if (!(pid in active_starts)) {
                active_input_files[pid]  = "(null)"
                active_peers[pid]        = "localhost"
                active_duration[pid]     = "0s"
                active_starts[pid]       = systime()

                # DIAGNOSTIC: Log the PID right before deletion to a temp file
                print systime() " PRE-PROCESS: First observance of PID " pid >> "/tmp/distcc_awk_debug.log"
            }
            # set start placeholder outcome only on the very first encounter (if empty)
            if (!(pid in active_outcomes)) {
                active_outcomes[pid] = sprintf("%s%-8.8s%s", placeholder_clr, "pending", clr_off) }

            # if line matches selector, save input and output file name and start time for this pid
            #   distcc[646584] "compile from" extensions.c to extensions.c.o
            if ($0 ~ file_sel) {
                active_input_files[pid] = $4
                active_output_files[pid] = $6
            }
            # if line matches selector, save distcc server host_name for this pid
            #   distcc[666568] (dcc_scan_args) found input file "/var/tmp/portage/dev-db/mysql-8.0.45/work/mysql/client/dump/database.cc"
            #   c_pkg_selector="found input file${P1}/work" #...# pkg is extracted from $6/$NF
            if ($0 ~ pkg_sel) {
                # for client mode, there is there can be a number of packages - one per ongoing emerge job in different sessions
                # to make the array self-deduplicating, key on the package name itself
                # (should be one package per emerge/make process tho ea session can have many concurrent jobs)
                # this split method is agnostic to which field the package name occupies
                split($0, parts, port_prefix)  # like cut, using port_prefix as delimiter - use parts[2]
                split(parts[2], path, "/")     # like cut, using "/" as delimiter - concat first two fields with another "/"
                pkg = path[2] "/" path[3]      # again like cut, so f1 is left of first / - take f2 f3
                # if pkg and client_id are both assigned, and if active_packages is not already assigned, do so
                if (pkg != "" && client_id != "") {
                    # key on client_id (assigned above) and package name to self-deduplicate, and store systime() so we can prune if aged-out
                    if (active_packages[client_id][pkg] == "") { active_packages[client_id][pkg] = systime() }
                } else {
                    diagnostic_messages["pkg_index_lacking"][systime()] = sprintf( \
                        "(client mode) missing index - client_id: [%s], pkg: [%s]", client_id, pkg)
                }
            }
            # if line matches selector, save distcc server host_name for this pid
            #   distcc[646584] "exec on" gmki92,lzo/4: x86_64-pc-linux-gnu-gcc ...
            #   distcc[646584] "(dcc_lock_host) got cpu lock on" gmki92,lzo/4 slot 0 as fd3 /// <-- alt if not localhost
            #   c_host_selector="\] exec on"  #................#  --> host_name = $4
            if ($0 ~ host_sel) {
                active_peers[pid] = $4              # like basename split
            }
            # if line matches selector, save outcome for this pid
            #   distcc[646584] "compile" ../accountsservice-23.13.9/src/extensions.c on gmki92,lzo/4 "completed ok"
            #   distcc[2463400] ERROR: compile /var/tmp/portage/dev-db/mysql...SymbolExists.c on nuthuvia,lzo/7 failed
            #   c_result_selector=" compile${P1} on" #.......# outcome = $NF; ok: infile=$3host_name=$5; failed; infile=$4/host_name=$6
            if (($0 ~ success_sel) && ($0 ~ / compile /) && ($0 !~ / cpp /)) {
                if ($0 ~ /completed ok/) {
                    split($0, parts, " compile ")
                    split(parts[2], path, " on ")
                    n = split(path[1], path_parts, "/")
                    if (!(pid in active_input_files)) { active_input_files[pid] = path_parts[n] }
                    split($0, parts, " completed ok")
                    n = split(parts[1], line_parts, " ")
                    if (!(pid in active_peers)) { active_peers[pid] = line_parts[n] }
                    active_outcomes[pid] = sprintf("%s%-8.8s%s", success_clr, "success", clr_off)
                } else if ($0 ~ /failed/) {
                    split($0, parts, " compile ")
                    split(parts[2], path, " on ")
                    n = split(path[1], path_parts, "/")
                    if (!(pid in active_input_files)) { active_input_files[pid] = parts[n] }
                    split($0, parts, " failed")
                    n = split(parts[1], line_parts, " ")
                    if (!(pid in active_peers)) { active_peers[pid] = line_parts[n] }
                    active_outcomes[pid] = sprintf("%s%-8.8s%s", failure_clr, "failure", clr_off)
                }
            }
            # if line matches selector, record the elapsed time for this pid
            #   distcc[646584] elapsed compilation time 3.136191s
            #   c_elapsed_selector="elapsed compilation time"  # elapsed = $5 ($NF)
            if ($0 ~ elapsed_sel) {
                active_duration[pid] = $NF
            }
            # if line matches selector, rotate history and delete active records for this pid
            #   distcc[646584] "(dcc_exit)" exit: code 0; self: 0.008061 user 0.016122 sys; children: 0.270012 user 0.214661 sys
            if ($0 ~ exit_sel) {

                # DIAGNOSTIC: Log the PID right before deletion to a temp file
                print systime() " PRE-DELETE: exit_sel matched for PID " pid >> "/tmp/distcc_awk_debug.log"

                # use exit code (awk sees "0;" as number 0 in this context) to set active_outcomes for this job
                if (($5 + 0) == 0) {
                    active_outcomes[pid] = sprintf("%s%-8.8s%s", success_clr, "success", clr_off)
                    # if we have a hostname, then sanitize it for use as a rollup array key
                    if (active_peers[pid] != "") {
                        clean_peer = active_peers[pid]
                        sub(/,.*/, "", clean_peer)    # strip distcc options (comma and all after, e.g., ,lzo/7, ,cpp)
                        sub(/:$/, "", clean_peer)     # strip trailing colon if present from "exec on" line
                        clientmode_servers_rollup[clean_peer]++
                    }                } else {
                    active_outcomes[pid] = sprintf("%s%-8.8s%s", failure_clr, "failure", clr_off)
                }
                final_time = (active_duration[pid] != "" ? active_duration[pid] : 0)
                log_str = sprintf("[%s%s%s] [%s%s%s] %s%s%s on %s%s%s (%s%ds%s) [%s]",
                                  data_clr, pid, clr_off,
                                  ts_clr, strftime("%H:%M:%S"), clr_off,
                                  file_clr, active_input_files[pid], clr_off,
                                  host_clr, active_peers[pid], clr_off,
                                  ts_clr, final_time, clr_off,
                                  active_outcomes[pid])
                rotate_history(log_str)
                delete_active_records(pid)
                # declare this pid dead now for the routing reason "exit"
                # to ignore any trailing lines that would otherwise re-initialize it
                dead_pids[pid] = systime() "|exit"

                # DIAGNOSTIC: verify if the arrays actually cleared
                if ((!(pid in active_starts)) && (!(pid in last_contact)) && (!(pid in active_peers))) {
                     print systime() " POST-DELETE SUCCESS: PID " pid " cleared." >> "/tmp/distcc_awk_debug.log"
                } else {
                     print systime() " POST-DELETE FAIL: PID " pid " still exists in tracking arrays!" >> "/tmp/distcc_awk_debug.log"
                }
            }
        }
    }   # end parse_client_line
    ### awk function for SERVER mode ###-------------------------------------------------------------------------------------
    function parse_server_line(    pid, child_pid, ip, parts, path, client_id, pkg, log_str, time_str) {
    # Debug: dump every incoming line to stderr to verify the pipe is alive
#     { print "DEBUG [awk server mode input]: " $0 > "/dev/stderr"; fflush("/dev/stderr") }

        # if it is a real log line, parse the data
        # and ignore (dcc_increment_safeguard) lines that are sqawned child processes that generate only one line
        if ($0 !~ /__HEARTBEAT__/ && $0 !~ /dcc_increment_safeguard/) {
            # extract pid (numeric part of first field; format: "distcc[1234567]"
            match($1, /[0-9]+/)
            pid = substr($1, RSTART, RLENGTH)   # RSTART, RLENGTH are awk built-in tracking regex matched pattern relative to full string
            # guard against a pid declared dead having a follow-on line revive it
#            if (pid in dead_pids) { return 0 } <-- server mode: pid persists over several jobs
            # update last contact for every line received (enable prune if job dies with no exit_sel)
            last_contact[pid] = systime()
            # safe default initialization for fields required by piping and logging (do only on first observation of pid)
            if (!(pid in active_starts)) {
                active_input_files[pid]  = "(null)"
                active_peers[pid]        = "UNKNOWN_0.0.0.0"
                active_ip_addrs[pid]     = "0.0.0.0"
                active_duration[pid]     = "0ms"       # "0ms" matching distccd (server) native time unit output format
                active_starts[pid]       = systime()
            }
            # set start placeholder outcome only on the very first encounter (if empty)
            if (!(pid in active_outcomes)) {
                active_outcomes[pid] = sprintf("%s%-8.8s%s", placeholder_clr, "pending", clr_off) }
            # if line matches selector, save input ip address for this pid (assumes it always has a port number to strip
            #   distccd[96193] "(dcc_check_client)" connection from fd62:6262:6262:0:d9ac:eab7:6d40:2331:40662
            if ($0 ~ ip_sel) {
                ip = $NF
                gsub(/:[0-9]+$/, "", ip)             # strip trailing colon and digits (port number)
                active_ip_addrs[pid] = ip           # assign to array
                # guard - check if the ip exists in pre-loaded list
                if (ip in dns_cache) {
                    active_peers[pid] = dns_cache[ip]
# uncomment to debug
#                    diagnostic_messages["ip_is_in_cache"][systime()] = sprintf("ip address [%s] is in cache with host [%s]", ip, dns_cache[ip])
                } else {
                    # emit signal to shell to trigger call to maybe_get_and_register_hostname
#                    printf "__REGISTER_ME__ %s %s\n", pid, ip
                    active_peers[pid] = "UNKNOWN_" ip  # fallback
                    diagnostic_messages["ip_is_in_not_cache"][systime()] = sprintf("(ip) ip address [%s] is NOT in cache", ip)
                }
            }
            # if line matches selector, save input and output file names for this pid (already short form in log)
            #   distccd[96193] "compile from" gtkactions_interface.cpp to gtkactions_interface.cpp.o
            if ($0 ~ file_sel) {
                active_input_files[pid] = $4
                active_output_files[pid] = $6
            }
            # if line matches selector, save distcc server host_name for this pid
            #   1              2                       3                                     4  5         6
            #   distccd[96193] x86_64-pc-linux-gnu-g++ /var/tmp/portage/kde-plasma/.../work  on localhost "completed ok" --> outcome=$NF
            if ($0 ~ success_sel) {
                # for server mode, the list of packages for multiple ip addresses of clients (should be one per)
                # use array of arrays [client_id][pkg] rather than 2-d array (indexing is independent)
                # store systime to know the age of this package record
                # this split method is agnostic to which field the package name occupies
                # but need to ensure port_prefix is found, else test-compile lines that dont have it will assign " / " as pkg
                if (split($0, parts, port_prefix) > 1) {  # like cut, using port_prefix as delimiter - use parts[2]
                    split(parts[2], path, "/")            # like cut, using "/" as delimiter - concat first two fields with another "/"
                    pkg = path[2] "/" path[3]             # again like cut, so f1 is left of first / - take f2 f3
                } else {
                    pkg = ""                              # assign null pkg to preclude active_packages assignment below
                }
                # server-mode client_id is ip of client
                client_id = active_ip_addrs[pid]
                # if pkg and client_id are both assigned, and if active_packages is not already assigned, do so
                if (pkg != "" && client_id != "" && client_id != "0.0.0.0") {
                    # key on client_id (assigned above) and package name to self-deduplicate, and store systime() so we can prune if aged-out
                    if (active_packages[client_id][pkg] == "") { active_packages[client_id][pkg] = systime() }
                 # removed else block with diagnostic because, in the dcc_job_summary, messages NOT including a portage prefixed path
                 # are almosts certainly just "test compile" cases running for the ebuild and not actual files being compiled for pkg
#                } else {
#                    diagnostic_messages["pkg_index_lacking"][systime()] = sprintf( \
#                        "(success block) array index missing or default - client_id: [%s], pkg: [%s]", client_id, pkg)
                }
                # dont need to annotate history section for success until summary is processed, but do annotate outcome in active section for a blink
                active_outcomes[pid] = sprintf("%s%-8.8s%s", success_clr, $NF, clr_off)
            }
            # if line matches selector, record the outcome for this pid
            #   distccd[1460350] (dcc_readx) ERROR: unexpected eof on fd5
            #   s_failure_selector="ERROR:"  #.................# && /dcc_r/ --> outcome = all after ERROR:
            if (($0 ~ failure_sel) && ($0 ~ /dcc_r/)) {
                split($0, parts, "ERROR: ")
                active_outcomes[pid] = sprintf("%s%-8.8s%s", failure_clr, parts[2], clr_off)
                log_str = sprintf("[%s%s%s] [%s%s%s] %s%s%s on %s%s%s (%s%ds%s) [%s]",
                                  data_clr, pid, clr_off,
                                  ts_clr, strftime("%H:%M:%S"), clr_off,
                                  file_clr, active_input_files[pid], clr_off,
                                  host_clr, active_peers[pid], clr_off,
                                  ts_clr, final_time, clr_off,
                                  active_outcomes[pid])
                # update history with record of failure, but dont delete active records as pid will continue on new remote host
                rotate_history(log_str)
            }
            # if line matches selector, record the elapsed time for this pid
            #   distccd[96193] (dcc_job_summary) client: fd62:6262:6262:0:d9ac:eab7:6d40:2331:40662 COMPILE_OK exit:0 \
            #                ... sig:0 core:0 ret:0 time:21251ms x86_64-pc-linux-gnu-g++  \
            #                ... /var/tmp/portage/kde-plasma/plasma-workspace-6.6.5-r1/work/plasma-workspace-6.6.5_build/gmenu-dbusmenu-proxy/gtkactions_interface.cpp
            if ($0 ~ summary_sel) {
                # assess success/falure - note both get exit: 0 status, so use COMPILE_OK vs OTHER in $5
                if ($5 == "COMPILE_OK") {
                    active_outcomes[pid] = sprintf("%s%-8.8s%s", success_clr, "success", clr_off)
                } else {
                    active_outcomes[pid] = sprintf("%s%-8.8s%s", failure_clr, "failure", clr_off)
                }
                # if ip or host_name is empty, try to fill it
                if (active_ip_addrs[pid] =="" || active_ip_addrs[pid] == "0.0.0.0") {
                    ip = $4
                    gsub(/:[0-9]+$/, "", ip)             # strip trailing colon and digits (port number)
                    active_ip_addrs[pid] = ip           # assign to array
                    # guard - check if the ip exists in pre-loaded list
                    if (ip in dns_cache) {
                        active_peers[pid] = dns_cache[ip]
                    } else {
                        # emit signal to shell to trigger call to maybe_get_and_register_hostname
#                        printf "__REGISTER_ME__ %s %s\n", pid, ip
                        active_peers[pid] = "UNKNOWN_" ip  # fallback
                        diagnostic_messages["ip_is_in_not_cache"][systime()] = sprintf("(summary) ip address [%s] is NOT in cache", ip)
                    }
                }
                # if job is complete and we have a ip address, increment the server mode rollup
                if ($5 == "COMPILE_OK" && active_ip_addrs[pid] != "") {
                    servermode_clients_rollup[active_ip_addrs[pid]]++
                }                # if package is empty, try to fill it
                # this split method is agnostic to which field the package name occupies
                # but need to ensure port_prefix is found, else test-compile lines that dont have it will assign " / " as pkg
                if (split($0, parts, port_prefix) > 1) {  # like cut, using port_prefix as delimiter - use parts[2]
                    n = split(parts[2], path, "/")            # like cut, using "/" as delimiter - concat first two fields with another "/"
                    pkg = path[2] "/" path[3]             # again like cut, so f1 is left of first / - take f2 f3
                } else {
                    pkg = ""                              # assign null pkg to preclude active_packages assignment below
                }
                # server-mode client_id is ip of client
                client_id = active_ip_addrs[pid]
                # if pkg and client_id are both assigned, and if active_packages is not already assigned, do so
                if (pkg != "" && client_id != "" && client_id != "0.0.0.0") {
                    # key on client_id (assigned above) and package name to self-deduplicate, and store systime() so we can prune if aged-out
                    if (active_packages[client_id][pkg] == "") { active_packages[client_id][pkg] = systime() }
                 # removed else block with diagnostic because, in the dcc_job_summary, messages NOT including a portage prefixed path
                 # are almosts certainly just "test compile" cases running for the ebuild and not actual files being compiled for pkg
#                } else {
#                    diagnostic_messages["pkg_index_lacking"][systime()] = sprintf( \
#                        "(summary block) array index missing or default - client_id: [%s], pkg: [%s]", client_id, pkg)
                }
                # if infile is still empty, fill it with last element of path
                if (!(pid in active_input_files)) {active_input_files[pid] = path[n] }
                # record elapsed time
                split($0, parts, "time:")    #...# format: " ... time:21576ms ..." cut from line using "time:" as delimiter
                split(parts[2], time_str, " ")   # cut from remaining line using " " as delimiter
                active_duration[pid] = time_str[1]
                final_time = (active_duration[pid] != "" ? active_duration[pid] : "0ms")
                log_str = sprintf("[%s%s%s] [%s%s%s] %s%s%s for %s%s%s (%s%s%s) [%s]",
                                  data_clr, pid, clr_off,
                                  ts_clr, strftime("%H:%M:%S"), clr_off,
                                  file_clr, active_input_files[pid], clr_off,
                                  host_clr, active_peers[pid], clr_off,
                                  ts_clr, final_time, clr_off,
                                  active_outcomes[pid])
                rotate_history(log_str)
                delete_active_records(pid)
                # do NOT declare this pid dead now - pid persists in server mode as long as the compiler slot stays open
                # likely for the duration of the package.  We actually NEED trailing lines (for new jobs under this pid)
                # to re-initialize the active records associated with pid and get new filename, etc.
            }
        }
    }   # end parse_server_line
    #-----[ main block of awk script ]-------------------------------------------------------------------------
    {
        # Debug: dump every incoming line to stderr to verify the pipe is alive
#        { print "DEBUG [dns cache input]: " $0 > "/dev/stderr"; fflush("/dev/stderr") }
        # structure is four logically orthogonal blocks for three kinds of
        # streaming data uniquely identified by the beginning of each line
        # __DNS_UPDATE__ and __HEARTBEAT__ come from the parent bash shell itself
        # distcc[ and distccd[ come from log data tailed to awk by the parent bash shell
        if (match($0, "^__DNS_UPDATE__" W1)) {
            # bash is injecting a dns update (or initialization) for the dns_cache; consume it
            # dont trust the field sepation enumeration $2, $3, etc...
            # strip the tag and following whitespace (W1 is posix one+ whitespace) - leaving ip first in remainder
            # extract everything after the tag and its spaces
            payload = substr($0, RSTART + RLENGTH)
            split(payload, data_parts)
            ip = data_parts[1]
            host = data_parts[2]
            dns_cache[ip] = host
            # check ingested values and log diagnostic report (for debugging)
            if (ip != "") {
                diagnostic_messages["dns_ip_diagnostic"][systime()] = sprintf( \
                    "Ingested ip: [%s] from line [%s]", ip, $0 )
            } else {
                diagnostic_messages["dns_ip_diagnostic"][systime()] = sprintf( \
                    "Failed to ingest ip from line [%s]", $0 )
            }
            # check ingested values and log diagnostic report (for debugging)
            if (host != "") {
                diagnostic_messages["dns_host_diagnostic"][systime()] = sprintf( \
                     "Ingested host: [%s] from line [%s]", host, $0 )
            } else {
                diagnostic_messages["dns_host_diagnostic"][systime()] = sprintf( \
                      "Failed to ingest host from line [%s]", $0 )
            }
            # check ingested values and log diagnostic report (for debugging)
            if (ip in dns_cache) {
                diagnostic_messages["dns_cache_diagnostic"][systime()] = sprintf( \
                    "Ingested dns_cache[%s] content: [%s] from line [%s]", ip, dns_cache[ip], $0 )
            } else {
                diagnostic_messages["dns_cache_diagnostic"][systime()] = sprintf( \
                    "Failed to ingest dns_cache[%s] content from line [%s]", ip, $0 )
            }
        } else if ($0 ~ /^__HEARTBEAT__/) {
            # heartbeat carries field(s) that enable dynamic interaction with awk
            # e.g. update terminal width dynamically
            width = $2
            # update ui assets using dynamic width
            dashline = sprintf("%s%s%s", line_clr, repeat("-", width), clr_off)
            dubdashline = sprintf("%s%s%s", line_clr, repeat("=", width), clr_off)
            separator = sprintf("%s%s%s", line_clr, "|", clr_off)
            # prune expired data
            prune_expired_packages()
            prune_expired_jobs()
            # todo - code the if client into prune_dead_pids (find a different way/timeout for server pids)
#            if (mode == "client") prune_dead_pids()
            prune_dead_pids()
            # redraw the frame with dynamic width every cycle
            draw_heading()
            draw_packages()
            # reset timer, count, elapsed; render active jobs
            now = systime()
            count = 0
            draw_active()
            draw_recent_history()
            if (mode == "server") { draw_servermode_rollup() }
            if (mode == "client") { draw_clientmode_rollup() }
            if (verbosity > 5 || DEBUG == "True") { draw_diagnostics() }
        } else if ($0 ~ /^distcc\[/) {
            # this is client-mode log data coming from tail -F of distcc-client.log
            # let the parsing function extract pid locally rathern than make it global
            if (mode == "server") {
                diagnostic_messages["mode_mismatch"][systime()] = "Ingested client data while in server mode"
            }
            parse_client_line()
        } else if ($0 ~ /^distccd\[/) {
            # this is server-mode log data coming from tail -F of distccd.log
            # let the parsing function extract pid locally rathern than make it global
            if (mode == "client") {
                diagnostic_messages["mode_mismatch"][systime()] = "Ingested server data while in client mode"
            }
            parse_server_line()
        } else {
                diagnostic_messages["unexpected_data"][systime()] = sprintf("Ingested unexpected or malformed data [%s]", $0)
        }
        # force output to terminal immediately
        fflush()
    }   # main block
        # the output of awk text processing is piped into a signal handler in real time
    ' | consume_tui_output          # this \' char is the end of awk itself
}   # end run_tui_engine bash function

