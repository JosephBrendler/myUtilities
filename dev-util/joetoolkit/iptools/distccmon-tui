    function parse_server_line(pid) {
        # if it is a real log line, parse the data
        if ($0 !~ /^HEARTBEAT/) {
            # extract pid (numeric part of first field; format: "distcc[1234567]"
            match($1, /[0-9]+/)
            pid = substr($1, RSTART, RLENGTH)   # RSTART, RLENGTH are awk built-in tracking regex matched pattern relative to full string
            active_outcomes[pid] = sprintf("%spending...%s", placeholder_clr, clr_off)
            # if line matches selector, save input ip address for this pid (assumes it always has a port number to strip
            #   distccd[96193] "(dcc_check_client)" connection from fd62:6262:6262:0:d9ac:eab7:6d40:2331:40662
            if ($0 ~ ip_sel) {
                ip = $NF
                gsub(/:[0-9]+$/, "", ip)             # strip trailing colon and digits (port number)
                active_ip_addrs[pid] = ip           # assign to array
                active_starts[pid] = systime()      # start time for elapsed calculation
                # GUARD CLAUSE: Check if the IP exists in your pre-loaded list
                if (ip in dns_cache) {
                    active_peers[pid] = dns_cache[ip]
                } else {
                    # emit signal to shell to trigger call to maybe_get_and_register_hostname
                    printf "__REGISTER_ME__ %s %s\n", pid, ip
                    active_peers[pid] = "UNKNOWN_" ip  # Fallback so your logs stay readable
                }
            }
            # if line matches selector, save input and output file names for this pid (already short form in log)
            #   distccd[96193] "compile from" gtkactions_interface.cpp to gtkactions_interface.cpp.o
            if ($0 ~ file_sel) {
                active_input_files[pid] = $4
                active_output_files[pid] = $6
            }

            # if line matches selector, save distcc server host_name for this pid
            #   1              2                       3                                     4  5         6
            #   distccd[96193] x86_64-pc-linux-gnu-g++ /var/tmp/portage/kde-plasma/.../work  on localhost "completed ok"
            if ($0 ~ success_sel) {
                pkg = $3
                sub("^" port_prefix "/", "", pkg)
                split(pkg, path, "/")
                active_packages[pid] = path[1] "/" path[2]
            }
            # if line matches selector, record the outcome for this pid
            #   distccd[1460350] (dcc_readx) ERROR: unexpected eof on fd5
            #   s_failure_selector="ERROR:"  #.................# && /dcc_r/ --> outcome = all after ERROR:
            if (($0 ~ failure_sel) && ($0 ~ /dcc_r/)) {
                split($0, parts, "ERROR: ")
                active_outcomes[pid] = sprintf("%s%s%s", failure_clr, parts[2], clr_off)
                log_str = sprintf("[%s%s%s] [%s%s%s] %s%s%s on %s%s%s (%s%ds%s) [%s]",
                                  pid_clr, pid, clr_off,
                                  ts_clr, strftime("%H:%M:%S"), clr_off,
                                  file_clr, active_input_files[pid], clr_off,
                                  host_clr, active_peers[pid], clr_off,
                                  ts_clr, final_time, clr_off,
                                  active_outcomes[pid])
                # update history with record of failure, but dont delete active records as pid will continue on new remote host
                rotate_history(log_str)
            }
            # if line matches selector, record the elapsed time for this pid
            #   distccd[96193] (dcc_job_summary) client: fd62:6262:6262:0:d9ac:eab7:6d40:2331:40662 COMPILE_OK exit:0 \
            #                ... sig:0 core:0 ret:0 time:21251ms x86_64-pc-linux-gnu-g++  \
            #                ... /var/tmp/portage/kde-plasma/plasma-workspace-6.6.5-r1/work/plasma-workspace-6.6.5_build/gmenu-dbusmenu-proxy/gtkactions_interface.cpp
            if ($0 ~ summary_sel) {
                match($10, /[0-9]+/)
                milliseconds = int(substr($10, RSTART, RLENGTH))
                active_duration[pid] = int(milliseconds / 1000)
                # assess success/falure - note both get exit: 0 status, so use COMPILE_OK vs OTHER in $5
                if ($5 == "COMPILE_OK") {
                    active_outcomes[pid] = sprintf("%ssuccess%s", success_clr, clr_off)
                } else {
                    active_outcomes[pid] = sprintf("%sfailure%s", failure_clr, clr_off)
                }
                # record elapsed time
                final_time = (active_duration[pid] != "" ? active_duration[pid] : 0)
                log_str = sprintf("[%s%s%s] [%s%s%s] %s%s%s for %s%s%s (%s%ds%s) [%s]",
                                  pid_clr, pid, clr_off,
                                  ts_clr, strftime("%H:%M:%S"), clr_off,
                                  file_clr, active_input_files[pid], clr_off,
                                  host_clr, active_peers[pid], clr_off,
                                  ts_clr, final_time, clr_off,
                                  active_outcomes[pid])
                rotate_history(log_str)
                delete_active_records(pid)
            }
        }


    }
    #-----[ main awk script ]-------------------------------------------------------------------------
    # first update the dns_cache (runs once at "boot" time)
    # NR == FNR is a standard awk idiom. NR is the total number of records processed, and FNR is the record number of the current file.
    # While reading the first stream (the SSH command output of dns hosts files), they are equal.
    # The moment awk shifts over to the second stream (tail -F), NR keeps rising but FNR resets to 1,
    # causing awk to cleanly jump down to the log parsing block in each subsequent pass (log line, or heartbeat)
    NR == FNR {
        ip = $1; host = $2
        if (ip == "" || ip ~ /^#/) next
        dns_cache[ip] = host      # populated associative array of hostnames keyed on ip addresses (RAM cache)
        next
    }
    # second, consume log stream (runs endlessly at sub-millisecond RAM speed)
    {
#    # Debug: dump every incoming line to stderr to verify the pipe is alive
#    { print "DEBUG [awk input]: " $0 > "/dev/stderr"; fflush("/dev/stderr") }
## Debug: Check if variables are populated
#    if (length(clr) == 0) { print "DEBUG [HEARTBEAT]: 'clr' is null" > "/dev/stderr" }
#    if (length(cup) == 0) { print "DEBUG [HEARTBEAT]: 'cup' is null" > "/dev/stderr" }
#    if (length(width) == 0) { print "DEBUG [HEARTBEAT]: 'width' is null" > "/dev/stderr" }
#    # Force a flush to see this immediately
#    fflush("/dev/stderr")            # this is the heartbeat line injected rythmically by bash shell
        # structure is four logically orthogonal blocks for three kinds of
        # streaming data uniquely identified by the beginning of each line
        # __DYNAMIC_UPDATE__ and HEARTBEAT come from the parent bash shell itself
        # distcc[ and distccd[ come from log data tailed to awk by the parent bash shell
        if ($0 ~ /^__DYNAMIC_UPDATE__/) {
            # bash is injecting a dynamic update for the dns_cache; consume it
            dns_cache[$2] = $3    # live updates injected into running memory (triggered by server function above)
            next
        } else if ($0 ~ /^HEARTBEAT/) {
            # it carries field(s) that enable dynamic interaction with awk
            # e.g. update terminal width dynamically
            width = $2
            # update ui assets using dynamic width
            dashline = sprintf("%s%s%s", line_clr, repeat("-", width), clr_off)
            dubdashline = sprintf("%s%s%s", line_clr, repeat("=", width), clr_off)
            separator = sprintf("%s%s%s", line_clr, "|", clr_off)
            # redraw the frame with dynamic width every cycle
            draw_heading(mode)
            # reset timer, count, elapsed; render active jobs
            now = systime()
            count = 0
            draw_active(mode)
            draw_recent_history(mode)
            if (verbosity > 5 || DEBUG == "True") { draw_diagnostics(mode) }
        } else if ($0 ~ /^distcc\[/) {
            # this is client-mode log data coming from tail -F of distcc-client.log
            # (re)set pid globally, so mode parsing can set it and then draw_ actions can use it
            pid=""
            if (mode == "server") {
                # create multi-dimensional array element diagnostic_errors["mode_mismatch", systime()]
                # stored internally by awk as a single key value concatenated using subript separator (SUBSEP)
                # result: diagnostic_errors["mode_mismatch\0341784294220"] = "Ingested server data while in client mode"
                # (where \034 is ascii FS (File/Field Separator)
                diagnostic_errors["mode_mismatch", systime()] = "Ingested client data while in server mode"
            }
            parse_client_line(pid)
        } else if ($0 ~ /^distccd\[/) {
            # this is server-mode log data coming from tail -F of distccd.log
            # (re)set pid globally, so mode parsing can set it and then draw_ actions can use it
            pid=""
            if (mode == "client") {
                diagnostic_errors["mode_mismatch", systime()] = "Ingested server data while in client mode"
            }
            parse_server_line(pid)
        } else {
                diagnostic_errors["unexpected_data", systime()] = "Ingested unexpected or malformed data"
        }
        # force output to terminal immediately
        fflush()

       # below feeds two process substitutions into the awk script
       # - the first is short-diration initial ingest of dns hosts files
       # - the second runs "forever" until interrupted, first background tail -F to generate a stream of log data
       #   and injecting HEARTBEAT once a second to force a screen-refresh at least that often
       #   - that stream is filtered by grep, to manage what lines awk must process
       # - and the output of awk text processing is piped into a signal handler in real time
    }' <( stream_dns_hostfiles ) <( stream_log_data ) | consume_tui_output

}   # end run_tui_engine bash function

