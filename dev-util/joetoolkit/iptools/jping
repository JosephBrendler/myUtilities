_do_arping() {
  j_msg "-${debug}" -p "in ${FUNCNAME[0]}"
  # Note: the logic in this function is basically lifted from _do_ssh(); for detailed
  # comments explaining how the parallel and serialized branches work see that function
    # timeout notes:
  # arping use of GNU timeout would be redundant; use -W ${waittime}                   | Layer 2; exits after response
  local _ups=0 _downs=0 _arping_wait
  local _count=0  # concurrency control variable for manually paralleled processes
  local -a _arping_opts=()
  # integerize waittime for arping
  if ! isint "$waittime"; then
    # try to round a decimal up to integer value, but don't round 1 or 1.0 up to 2
    if [ "${waittime##*.}" -gt 0 ] && [[ "$waittime" == *"."* ]]; then
      _arping_wait=$(( ${waittime%.*} + 1 ))
    else
      _arping_wait="${waittime%.*}"
    fi
    waittime="$_arping_wait"
    # now add that to args
    _arping_opts+=("-c" "1" "-w" "$_arping_wait" "-f")
  else
    _arping_opts+=("-c" "1" "-w" "$waittime" "-f")
  fi
  j_msg "-${info}" -m "command:  arping ${_arping_opts[*]} \"\$target\" &>/dev/null"
  # arping options:
  # -c 1 (one packet), -W $waittime (wait for response)
  # -f (exit immediately after first reply)
  # Note: arping usually requires an interface (-I); defaulting to eth0 or similar may be needed
  # arping only supports ipv4
  for x in "${targets[@]}"; do case $x in "${joetoo_ip4_prefix}"*) targets_4+=("$x");; esac; done
  targets=("${targets_4[@]}")
  if [ "$PARALLEL" ]; then
    while read -r line; do
      j_msg "-${notice}" -p "$line"
      clean_line=$( printf '%s\n' "$line" | strip_ansi )
      case "$clean_line" in
        *is\ Up)   (( _ups++ )) ;;
        *is\ Down) (( _downs++ )) ;;
      esac
    done < <(
      { for target in "${targets[@]}"; do (
          { arping "${_arping_opts[@]}" "$target" &>/dev/null && \
            printf '%s\n' "${Mon}${target}${Boff} is ${BGon}Up${Boff}" || \
            printf '%s\n' "${Mon}${target}${Boff} is ${BRon}Down${Boff}" ;
          } 2>/dev/null &
        )
        if (( ++_count % "$jobs" == 0 )); then wait; fi
        done; wait
      } | sed "/^${W0}$/d"
    )
  else # serialize
    for target in "${targets[@]}"; do
      j_msg "-${notice}" -p -n "${Mon}${target}${Boff} is "
      arping "${_arping_opts[@]}" "$target" &>/dev/null
      result=$?
      if handle_result $result "Up" "Down" "${notice}"; then (( _ups++ )); else (( _downs++ )); fi
    done
  fi

  msg="complete. ${BBon}[${BMon}$_ups${BBon}] ${BGon}up${Boff} |"
  msg+=" ${BBon}[${BMon}$_downs${BBon}] ${BRon}down${Boff}"
  j_msg "-${notice}" -M "$idx_face_beam" "$msg"
}

