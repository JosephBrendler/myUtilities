  if ! isint "$waittime"; then
    # try to round a decimal up to integer value, but don't round 1 or 1.0 up to 2
    if [ "${waittime##*.}" -gt 0 ] && [[ "$waittime" == *"."* ]]; then
      _ssh_wait=$(( ${waittime%.*} + 1 ))
    else
       _ssh_wait="${waittime%.*}"
    fi
    _msg="${BYon}(warning)${Boff} ssh -o ConnectTimeout=\"\${waittime}\" must be integer, waittime [$waittime] rounded to [$_ssh_wait]"
    j_msg "-${warn}" "$_msg"
    waittime="$_ssh_wait"
    # now add that to args
    ssh_opts+=("-o" "ConnectTimeout=${_ssh_wait}")
  fi

  # handle user-directed RESOLVE choice
  # if [ ! "$RESOLVE" ] ; then ... NA for ssh; fi
  # for associateive array ${!var[@]} lists all keys (i.e. ips in this case)
  [ "$ASSOCIATIVE" ] && targets=("${!a_targets[@]}")

  j_msg "-${debug}" -p "checking [${#targets[@]}] targets"
  j_msg "-${notice}" -m "${BWon}(notice)${Boff} command: timeout $timeout ssh \${fam} ${ssh_opts[*]} \"\$target\" true 2>&1"

  # form the "unloaded" command as a function taking ${target} as its arg, to be evaluated at load/run time
  _ssh_cmd() {
    # j_msg "-${debug}" -p "in ${FUNCNAME[0]} with arg(s) [$*]";
    local _target="$1" fam=""
    case "$_target" in
      *[!0-9a-fA-F.:]* ) : ;; # possible hostname - continue
      *:*              ) fam="-6";;
      *.*              ) fam="-4";;
    esac
    if timeout "$timeout" ssh "${fam}" "${ssh_opts[@]}" "$_target" true 2>&1 ; then
      printf '%s\n' "${BGon}Up${Boff} - port ${port} is ${BGon}Open${Boff}"; return 0
    else
      printf '%s\n' "${BRon}Down${Boff} - port ${port} is ${BRon}Closed${Boff}" ; return 1
    fi
  }

  if [ "$PARALLEL" ]; then
    _jping_parallel_core "_ssh_cmd"
  else # serialize
    _jping_serial_core "_ssh_cmd"
  fi

  msg="complete. ${BBon}[${BMon}$ups${BBon}] ${BGon}up${Boff} |"
  msg+=" ${BBon}[${BMon}$downs${BBon}] ${BRon}down${Boff}"
  j_msg "-${notice}" -M "$idx_face_beam" "$msg"
  j_msg "-${warn}" -p "ssh checks only port state; host status is implied"
  j_msg "-${warn}" -p "False negatives are possible if timeout/wait times are too short"
  j_msg "-${warn}" -m "To be more certain, use this or another tool again, with a longer timeout and check more ports/services"
}

_do_ping() {
  # ping -h 2>&1 | grep '\-[cHnwW46qt]'
  #  -c <count>         stop after <count> replies
  #  -H                 force reverse DNS name resolution (useful for numeric
  #                     destinations or for -f), override -n
  #  -n                 no reverse DNS name resolution, override -H
  #  -q                 quiet output
  #  -t <ttl>           define time to live
  #  -w <deadline>      reply wait <deadline> in seconds
  #  -W <timeout>       time to wait for response
  #  -4                 use IPv4
  #  -6                 use IPv6
  j_msg "-${debug}" -p "in ${FUNCNAME[0]} with arg(s) [$*]"
  # Note: the logic in this function is basically lifted from _do_ssh(); for detailed
  # comments explaining how the parallel and serialized branches work see that function
  # timout notes:
  #   for ip addresses, ping use of GNU timeout is redundant - -W ${waittime} | Exits after count/wait reached
  #   for hostnames though, it limits time-wait for dns-lookup
  # ping uses -W for seconds (standard iputils-ping)
  # -c 1 ensures it sends only one packet
  # -n turns off reverse DNS name resolution because I'm manually doing that in core functions (so ping doesnt need to wait for it)
  local _ping_opts=("-c" "1" "-W" "$waittime" "-n")

  # handle user-directed RESOLVE choice
  # if [ ! "$RESOLVE" ] ; then ... NA for _ping_opts in this use case (see above); fi
  # for associateive array ${!var[@]} lists all keys (i.e. ips in this case)
  [ "$ASSOCIATIVE" ] && targets=("${!a_targets[@]}")

  j_msg "-${notice}" -m "${BWon}(notice)${Boff} command: timeout $timeout ping ${_ping_opts[@]} \$target &>/dev/null"
  j_msg "-${debug}" -m "${BYon}(debug)${Boff} mode: [$mode]"

  # form the "unloaded" command as a function taking ${target} as its arg, to be evaluated at load/run time
  _ping_cmd() {
    # j_msg "-${debug}" -p "in ${FUNCNAME[0]} with arg(s) [$*]";
    local _target="$1" fam=""
    case "$_target" in
      *[!0-9a-fA-F.:]* ) : ;; # possible hostname - continue
      *:*              ) fam="-6";;
      *.*              ) fam="-4";;
    esac
    # use GNU timeout to protect against long delays in dead field case (many non-existent targets)
    # ping does not have an "enriched" mode, so just provide the appropriate output
    if timeout "$timeout" ping "$fam" "${_ping_opts[@]}" "$_target" &>/dev/null ; then
      printf '%s\n' "${BGon}Up${Boff}"; return 0
    else
      printf '%s\n' "${BRon}Down${Boff}" ; return 1
    fi
  }

  if [ "$PARALLEL" ]; then
    _jping_parallel_core "_ping_cmd"
  else # serialize
    _jping_serial_core "_ping_cmd"
  fi

  msg="complete. ${BBon}[${BMon}$ups${BBon}] ${BGon}up${Boff} |"
  msg+=" ${BBon}[${BMon}$downs${BBon}] ${BRon}down${Boff}"
  j_msg "-${notice}" -M "$idx_face_beam" "$msg"
}

_do_socat() {
  # socat -h | grep -E '\-[tTu0]| add| GOPEN| TCP'
  #  -t<timeout>    wait seconds before closing second channel // use 0 to immediately close when /dev/null sends EOF
  #  -T<timeout>    total inactivity timeout in seconds        // use GNU timeout $timeout instead
  #  -u             unidirectional mode (left to right)        // ensure no time wasted on second direction
  #  -0             do not prefer an IP version                // should be default but specify to ensure both ipv4/6 work
  #     address-head:
  #       GOPEN:<filename>                          groups=FD,FIFO,CHR,BLK,REG,SOCKET,NAMED,OPEN,TERMIOS,UNIX
  #       TCP[-CONNECT]:<host>:<port>                 groups=FD,SOCKET,CHILD,RETRY,IP4,IP6,TCP
  # man socat
  #     connect-timeout=<seconds>   Abort the connection attempt after <seconds> [timeval] with error status.
  #
  # socat is a powerful "data plumber" -- its primary purpose is to weld two pipes together
  #   and keep the water flowing until one side breaks or the pipe runs dry
  # In my opinion, using it for a port check works well, but it is like
  #   "driving the Winnebago around the corner to see if the store is open"
  # method: use /dev/null for one pipe and host:port for the other, with a timeout
  #   and read the exit status (works b/c /dev/null provides an immediate EOF when read)
  # *** note: host spec is different for ipv4/6 - 6 requres [${_target}] (square brackets)
  #
  # timeout notes:
  # socat - recommended to use GNU timeout "$timeout" and connect-timeout=${waittime}
  #   to protect vs protocol/banner hang
  #
  j_msg "-${debug}" -p "in ${FUNCNAME[0]} with arg(s) [$*]"
  local _msg=""
  local _socat_opts=("-0" "-t0" "-u" "GOPEN:/dev/null")
  # guard against empty timeout (should be defaulted)
  if [ -z "$timeout" ]; then
    if [ -n "$waittime" ]; then
      timeout="$waittime"
      j_msg "-${warn}" -p "substituted waittime [$waittime] for null timeout"
    else
      timeout=1
      j_msg "-${warn}" -p "assiigned timeout=1 because it and waittime were both empty"
    fi
  fi

  # handle user-directed RESOLVE choice
  # if [ ! "$RESOLVE" ] ; then ... NA for _ping_opts in this use case (see above); fi
  # for associateive array ${!var[@]} lists all keys (i.e. ips in this case)
  [ "$ASSOCIATIVE" ] && targets=("${!a_targets[@]}")

  # formulate _socat_opts array
  _msg="command:  timeout $timeout socat ${_socat_opts[@]}"
  _msg+=" TCP:\"\${target}\":${port},connect-timeout=${waittime} 2>/dev/null"
  j_msg "-${notice}" -m "${BWon}(notice)${Boff} $_msg"

  # form the "unloaded" command as a function taking ${target} as its arg, to be evaluated at load/run time
  _socat_cmd() {
    local _exit_status=0
    # j_msg "-${debug}" -p "in ${FUNCNAME[0]} with arg(s) [$*]";
    local _target="$1"

    case "$_target" in
      *:*) _target="[${_target}]"  # socat requires ipv6 address to be wrapped in []
    esac
    # use GNU timeout to protect against long delays in dead field case (many non-existent targets)
    local _cmd=("timeout" "$timeout" "socat" "${_socat_opts[@]}")
    _cmd+=("TCP:${_target}:${port},connect-timeout=${waittime}" "2>&1")
    _out=$(timeout "$timeout" socat "${_socat_opts[@]}" \
      TCP:"${_target}":"${port}",connect-timeout="${waittime}" 2>&1)
    _exit_status=$?
    # determine provide output format (FAST or ENRICHED) based on the global mode variable --
    # _core functions compose the preliminary message <target> (<hostname/address>) is " <-- ending space is space
    # _core functions then append the output of this _<tool>_cmd function with content as follows
    # FAST: <color><Up/Down><collor_off>
    # ENRICHED: <color><Up/Down><collor_off> <and/but> port <color><port><color_off> is <color><port_state><color_off>
    case "${mode:0:1}" in
      F )
        if [ "$_exit_status" -eq 0 ]; then
          printf '%s\n' "${BGon}Up${Boff}"
          return 0
        else
          printf '%s\n' "${BRon}Down${Boff}"
          return 0
        fi
        ;;
      E )
        # Return rich states
        if [ "$_exit_status" -eq 0 ]; then
          printf '%s and port %s is %s\n' "${BGon}Up${Boff}" "${BMon}${port}${Boff}" "${BGon}Open${Boff}"
          return 0
        elif printf '%s\n' "$_out" | grep -qE "refused"; then
          printf '%s but port %s is %s\n' "${BGon}Up${Boff}" "${BMon}${port}${Boff}" "${BYon}Closed${Boff}"
          return 0
        elif printf '%s\n' "$_out" | grep -qE "not known"; then
          # nmap got an explicit TCP RST, host is up but port is closed
          printf '%s and port %s is %s\n' "${BGon}Down${Boff}" "${BMon}${port}${Boff}" "${BRon}Unverified${Boff}"
          return 1
        else
          printf '%s and port %s is %s\n' "${BRon}Down${Boff}" "${BMon}${port}${Boff}" "${BRon}Timedout${Boff}"
          return 1
        fi
        ;;
      * ) j_msg "-${err}" -m "${BRon}(error)${Boff} invalid mode in ${FUNCNAME[0]}"; my_usage; exit 1 ;;
    esac
  }

  if [ "$PARALLEL" ]; then
    _jping_parallel_core "_socat_cmd"
  else # serialize
    _jping_serial_core "_socat_cmd"
  fi

  case "${mode:0:1}" in
    F )
      msg="complete. ${BBon}[${BMon}$ups${BBon}] ${BGon}up${Boff} |"
      msg+=" ${BBon}[${BMon}$downs${BBon}] ${BRon}down${Boff}"
      j_msg "-${notice}" -M "$idx_face_beam" "$msg"
      ;;
    E )
      msg="${BWon}complete${Boff}"
      j_msg "-${notice}" -M "$idx_face_beam" "$msg"
      msg=" ${BBon}[${BMon}$ups${BBon}] ${BGon}up${Boff} |"
      msg+=" ${BBon}[${BMon}$downs${BBon}] ${BRon}down${Boff} |"
      msg+=" ${BBon}[${BMon}$opened${BBon}] ${BGon}opened${Boff} |"
      msg+=" ${BBon}[${BMon}$closed${BBon}] ${BRon}closed${Boff} |"
      msg+=" ${BBon}[${BMon}$filtered${BBon}] ${BYon}filtered${Boff} |"
      msg+=" ${BBon}[${BMon}$unverified${BBon}] ${BOon}unverified${Boff} |"
      msg+=" ${BBon}[${BMon}$timeouts${BBon}] ${BRon}timeouts${Boff}"
      j_msg "-${notice}" -M "$idx_face_beam" "$msg"
      j_msg "-${warn}" -p "Timedout count can include false negatives due to short waits or firewalled ports"
      j_msg "-${warn}" -m "To be more certain, use this or another tool again, with a longer timeout and check more ports/services"
      ;;
    * ) j_msg "-${err}" -m "${BRon}(error)${Boff} invalid mode in ${FUNCNAME[0]}"; my_usage; exit 1 ;;
  esac

}

_do_arping() {
  #  arping -h 2>&1 | grep '\-[fqcwi]'
  #  -f            quit on first reply
  #  -q            be quiet
  #  -c <count>    how many packets to send
  #  -w <timeout>  how long to wait for a reply
  #  -i <interval> set interval between packets (default: 1 second)
  #
  j_msg "-${debug}" -p "in ${FUNCNAME[0]} with arg(s) [$*]"
  # Note: the logic in this function is basically lifted from _do_ssh(); for detailed
  # comments explaining how the parallel and serialized branches work see that function
    # timeout notes:
  # arping use of GNU timeout would be redundant; use -W ${waittime}                   | Layer 2; exits after response
  local _arping_wait _msg
  local -a _arping_opts=("-c" "1" "-f" "-q")
  local -a _my_subnets_4=()
  local _my_subnet_4=""
  local _my_interface=""
  local _my_ips_4=""
  local -a targets_4=()

  # determine local subnets (to use in _arping_cmd)
  readarray -t _my_subnets_4 < <(ip route show scope link | awk '{print $1}' | sort -u)
  # determine local addresses (to use in _arping_cmd)
  _my_ips_4=$(ip -o -4 addr show scope global  | awk '{print $4}' | cut -d'/' -f1| tr '\n' ' ')

  # integerize waittime for arping
  if ! isint "$waittime"; then
    # try to round a decimal up to integer value, but don't round 1 or 1.0 up to 2
    if [ "${waittime##*.}" -gt 0 ] && [[ "$waittime" == *"."* ]]; then
      _arping_wait=$(( ${waittime%.*} + 1 ))
    else
      _arping_wait="${waittime%.*}"
    fi
    waittime="$_arping_wait"
    # now add that to args
    _arping_opts+=("-w" "$_arping_wait")
  else
    _arping_opts+=("-w" "$waittime")
  fi
  # arping options:
  # -c 1 (one packet), -W $waittime (wait for response)
  # -f (exit immediately after first reply)
  # Note: arping usually requires an interface (-I); defaulting to eth0 or similar may be needed

  # handle user-directed RESOLVE choice
  # if [ ! "$RESOLVE" ] ; then ... NA for _arping_opts in this use case (see above); fi
  # for associateive array ${!var[@]} lists all keys (i.e. ips in this case)
  [ "$ASSOCIATIVE" ] && targets=("${!a_targets[@]}")

  # arping only supports ipv4 - targets can be hostnames or ip addresses; so exclude ipv6 addresses
  for x in "${targets[@]}"; do
    case "$x" in
      *:*) : ;; # ..............# ipv6 address; do nothing with it
      *  ) targets_4+=("$x");;  # hostname or ipv4 address - add to new list
    esac
  done
  # warn user if targetlist was down-selected to ipv4 only
  if [ ${#targets_4[@]} -lt ${#targets[@]} ]; then
    j_msg "-${warn}" -p "${BYon}(Warning)${Boff} arping supports only ipv4, targetlist downselected"
  fi
  j_msg "-${notice}" -p "checking [${#targets_4[@]}] targets"
  # reload targets array with new list
  targets=("${targets_4[@]}")
  # note that this list may include hostnames that may be resolved by _core functions
  # to ipv6 addresses or foreign subnets; so _arping_cmd will need to furnter filter each final _target

  _msg="${BWon}(notice)${Boff} command: [timeout $timeout arping ${_arping_opts[@]} -I \"\$_my_interface\" \"\$_target\" &>/dev/null]"

  j_msg "-${notice}" -m "$_msg"

  # form the "unloaded" command as a function taking ${target} as its arg, to be evaluated at load/run time
  _arping_cmd() {
    # j_msg "-${debug}" -p "in ${FUNCNAME[0]} with arg(s) [$*]";
    local _target="$1"
    # filter local addresses
    case "$_my_ips_4" in
      *"${_target}"*) printf '%s\n' "local address - not ARPable ${BRon}Unreachable${Boff}" ; return 1 ;;
    esac
    # filter ipv6 addresses resolved for hostname by _core function
    case "$_target" in
      *:* ) printf '%s\n' "wrong family ${BRon}Unreachable${Boff}" ; return 1 ;;
    esac
    # filter foreign subnets, or identify interface and scan for _target on local subnet
    for _my_subnet_4 in "${_my_subnets_4[@]}"; do
      _my_cidr_4=${_my_subnet_4##*/}
      _target_subnet_4=$(ipcalc --network "${_target}/${_my_cidr_4}" | cut -d'=' -f2)
      # filter foreign subnets
      case "${_my_subnet_4}" in
        *"${_target_subnet_4}"*)
           _my_interface=$(ip route show scope link | grep "$_target_subnet_4" | awk '{print $3}' | head -n1)
           break # match - stop checking and exit for loop
           ;;
      esac
    done
    # if no matching subnet was found, reject this _target
    if [ -z "$_my_interface" ] ; then
      printf '%s\n' "wrong subnet ${BRon}Unreachable${Boff}"
      return 1
    fi
    # use GNU timeout to protect against long delays in dead field case (many non-existent targets)
    timeout "$timeout" arping "${_arping_opts[@]}" -I "$_my_interface" "$_target" &>/dev/null
    case $? in
      0   ) printf '%s\n' "${BGon}Up${Boff}" ;;
      1   ) printf '%s\n' "${BRon}Down${Boff}" ;;
      2   ) printf '%s\n' "${BRon}Unreachable${Boff}" ;;
      124 ) printf '%s\n' "${BRon}Timedout${Boff}" ;;
      *   ) printf '%s\n' "${BRon}Timedout${Boff}" ;;
    esac
  }

  if [ "$PARALLEL" ]; then
    _jping_parallel_core "_arping_cmd"
  else # serialize
    _jping_serial_core "_arping_cmd"
  fi

  msg="complete. ${BBon}[${BMon}$ups${BBon}] ${BGon}up${Boff} |"
  msg+=" ${BBon}[${BMon}$downs${BBon}] ${BRon}down${Boff}"
  j_msg "-${notice}" -M "$idx_face_beam" "$msg"

}

_do_ndisc6() {
  # ndisc6 -h | grep '\-[1nqrw]'
  #  -1, --single     display first response and exit
  #  -d, --no-solicit don't send any solicitation messages
  #  -n, --numeric    don't resolve host names
  #  -q, --quiet      only print the link-layer address (mainly for scripts)
  #  -r, --retry      maximum number of attempts (default: 3)
  #  -w, --wait       how long to wait for a response [ms] (default: 1000)
  j_msg "-${debug}" -p "in ${FUNCNAME[0]} with arg(s) [$*]"
  # Note: the logic in this function is basically lifted from _do_arping(); for detailed
  # comments explaining how the parallel and serialized branches work see that function
  local _ndisc6_wait _msg
  local -a _ndisc6_opts=("-1" "-r" "1" "-q")
  local -a _my_subnets_6=()
  local _my_ips_6=""
  local _my_interface=""
  local -a targets_6=()

  # determine local subnets (to use in _arping_cmd)
  readarray -t _my_subnets_6 < <(ip -6 route | grep -v 'fe80' | awk '{print $1}' | sort -u | \
     grep -v '^::1' | grep -v '^2600:')   # filter loopback address and internet uplink (dont scan that!!)

  # determine local addresses (to use in _arping_cmd)
  _my_ips_6=$(ip -o -6 addr show scope global  | awk '{print $4}' | cut -d'/' -f1| tr '\n' ' ')

  # determine the prefered local interface to use with ndisc6
  _my_interface=$(ip addr show scope global | head -n1 | awk '{print $2}' | sed 's|:||')

  # convert waittime to milliseconds
  if [ "${waittime##*.}" -gt 0 ] && [[ "$waittime" == *"."* ]]; then
    [ -z "${waittime#*.}" ] && waittime="${waittime}0"
    [ -z "${waittime%.*}" ] && waittime="0${waittime}"
    _ndisc6_wait=$(( ( ${waittime%.*} * 1000 ) + ( ${waittime#*.} * 100 ) ))
  else
    _ndisc6_wait=$(( ${waittime} * 1000 ))
  fi
  # now add that to args
  _ndisc6_opts+=("-w" "$_ndisc6_wait")

  # handle user-directed RESOLVE choice
  # if [ ! "$RESOLVE" ] ; then ... NA for _ndisc6_opts in this use case (see above); fi
  # for associateive array ${!var[@]} lists all keys (i.e. ips in this case)
  [ "$ASSOCIATIVE" ] && targets=("${!a_targets[@]}")

  # ndisc6 only supports ipv6 - targets can be hostnames or ip addresses; so exclude ipv4 addresses
  for x in "${targets[@]}"; do
    case "$x" in
      *[0-9].[0-9]*) : ;; # ..............# ipv6 address; do nothing with it
      *  ) targets_6+=("$x");;  # hostname or ipv6 address - add to new list
    esac
  done
  # warn user if targetlist was down-selected to ipv4 only
  if [ ${#targets_6[@]} -lt ${#targets[@]} ]; then
    j_msg "-${warn}" -p "${BYon}(Warning)${Boff} ndisc6 supports only ipv6, targetlist downselected"
  fi
  j_msg "-${notice}" -p "checking [${#targets_6[@]}] targets"
  # reload targets array with new list
  targets=("${targets_6[@]}")
  # note that this list may include hostnames that may be resolved by _core functions
  # to ipv6 addresses or foreign subnets; so _arping_cmd will need to furnter filter each final _target

  _msg="${BWon}(notice)${Boff} command: [timeout $timeout ndisc6 ${_ndisc6_opts[@]} \"\$_target\" \"\$_my_interface\" &>/dev/null]"

  j_msg "-${notice}" -m "$_msg"

  # form the "unloaded" command as a function taking ${target} as its arg, to be evaluated at load/run time
  _ndisc6_cmd() {
    # j_msg "-${debug}" -p "in ${FUNCNAME[0]} with arg(s) [$*]";
    local _target="$1"
    # filter local addresses - dont have to filter for ndisc6
    case "$_my_ips_6" in
      *"${_target}"*) printf '%s\n' "local address - not ndisc6-able ${BRon}Unreachable${Boff}" ; return 1 ;;
    esac
    # filter ipv6 addresses resolved for hostname by _core function
    case "$_target" in
      *[0-9].[0-9]* ) printf '%s\n' "wrong family ${BRon}Unreachable${Boff}" ; return 1 ;;
    esac
    # filter foreign subnets, or identify interface and scan for _target on local subnet
    _my_interface=""  # (re) initialize
    for _my_subnet_6 in "${_my_subnets_6[@]}"; do
      _my_cidr_6=${_my_subnet_6##*/}
      _target_subnet_6=$(ipcalc --network "${_target}/${_my_cidr_6}" | cut -d'=' -f2)
      # filter foreign subnets
      case "${_my_subnet_6}" in
        *"${_target_subnet_6}"*)
           # select the first (preferred) interface matching target/my subnet (field 3 is interface)
           # Format: fd62:6262:6262::/64 dev eth0 proto ra metric 2 expires 86391sec pref medium
           _my_interface=$(ip -6 route show | grep -v 'fe80' | grep "$_target_subnet_6" | awk '{print $3}' | head -n1)
           break # match - stop checking and exit for loop
           ;;
      esac
    done
    # if no matching subnet was found, reject this _target
    if [ -z "$_my_interface" ] ; then
      printf '%s\n' "wrong subnet ${BRon}Unreachable${Boff}"
      return 1
    fi
    # use GNU timeout to protect against long delays in dead field case (many non-existent targets)
    timeout "$timeout" ndisc6 "${_ndisc6_opts[@]}" "$_target" "$_my_interface" &>/dev/null
    _exit_status=$?
#echo "_exit_status: [$_exit_status]"
    case "$_exit_status" in
      0   ) printf '%s\n' "${BGon}Up${Boff}" ;;
      1   ) printf '%s\n' "${BRon}Down${Boff}" ;;
      2   ) printf '%s\n' "${BRon}Unreachable${Boff}" ;;
      124 ) printf '%s\n' "${BRon}Timedout${Boff}" ;;
      *   ) printf '%s\n' "${BRon}Timedout${Boff}" ;;
    esac
  }

  if [ "$PARALLEL" ]; then
    _jping_parallel_core "_ndisc6_cmd"
  else # serialize
    _jping_serial_core "_ndisc6_cmd"
  fi

  msg="complete. ${BBon}[${BMon}$ups${BBon}] ${BGon}up${Boff} |"
  msg+=" ${BBon}[${BMon}$downs${BBon}] ${BRon}down${Boff}"
  j_msg "-${notice}" -M "$idx_face_beam" "$msg"

}


#-----[ notes ]---------------------------------------------------------------------------------
# Notes:
# Some tools require or benefit from the use of an external timeout (e.g. GNU timeout)
#   to manage (and prevent hangs in) their total execution
# (1) Mandatory for tools built for interactive use -
#   + /dev/tcp - without an outer timeout, a dropped packet will await system TCP timeout (60+ sec)
#   + ssh - has ConnectTimeout, but can hang in key exchange or banner grab
#     (if the port is open but the service is broken)
# (2) Recommended for tools where it provides a safety net vs hangs in kernel space if network state is wierd
#   + nc (netcat) - has -w but version dependent may only apply to connection
#   + socat - has -t/connect-timeout (channel handshake) and -T (inactivity),
#       (but socat just sits there if it connects but hangs on a protocol string)
# (3) NOT needed/redundant for tools that are built for scanning and have internal "hard" timeouts
#   + nmap: use --host-timeout - reliable and handles the entire lifecycle of the probe
#   + fping: use -t (per-target timeout). It’s designed for high-speed parallel work and won't hang
#   + ping/arping: use -W (wait) and -c (count) - designed to exit after packet exchange/wait time
# command   | GNU timeout n       | tool connection timeout   |
# tool      | (jping $timeout -t) | (jping W="$waittime" -W)  | Logic/Notes
# ----------|---------------------|---------------------------|---------------------------------
# /dev/tcp  | timeout "$timeout"  | (N/A)                     | No internal timeout; needs GNU t
# ssh       | timeout "$timeout"  | -o ConnectTimeout=${W}    | Protects vs protocol/banner hang
# socat     | timeout "$timeout"  | connect-timeout=${W}      | Protects vs protocol/banner hang
# nc        | timeout "$timeout"  | -w ${W}                   | Version-proofs the exit status
# nmap      | Redundant           | --host-timeout ${W}       | Internal timer covers lifecycle
# fping     | Redundant           | -t ${W_ms}                | Native parallel; very reliable
# ping      | Redundant           | -W ${W}                   | Exits after count/wait reached
# arping    | Redundant           | -W ${W}                   | Layer 2; exits after response


