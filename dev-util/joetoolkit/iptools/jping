}

_do_netcat() {
  #  -n                      numeric-only IP addresses, no DNS
  #  -v                      verbose [use twice to be more verbose]
  #  -w secs                 timeout for connects and final net reads
  #  -z                      zero-I/O mode [used for scanning]

  j_msg "-${debug}" -p "in ${FUNCNAME[0]} with arg(s) [$*]"
  # timeout notes:
  # nc - recommended to use GNU timeout "$timeout" AND jping waittime (-w ${waittime})
  #      to fortify and version-proof the exit status
  local ups=0 downs=0
  local _count=0  # concurrency control variable for manually paralleled processes
  local -a _nc_opts=("-zv")
  if [ -z "$timeout" ]; then
    if [ -n "$waittime" ]; then
      timeout="$waittime"
      j_msg "-${warn}" -p "substituted waittime [$waittime] for null timeout"
    else
      timeout=1
      j_msg "-${warn}" -p "assiigned timeout=1 because it and waittime were both empty"
    fi
  fi
  if ! isint "$waittime"; then
    # try to round a decimal up to integer value, but don't round 1 or 1.0 up to 2
    if [ "${waittime##*.}" -gt 0 ] && [[ "$waittime" == *"."* ]]; then
      _nc_wait=$(( ${waittime%.*} + 1 ))
    else
       _nc_wait="${waittime%.*}"
    fi
    j_msg "-${warn}" "${BYon}(warning)${Boff} nc -w must be integer, waittime [$waittime] rounded to [$_nc_wait]"
    waittime="$_nc_wait"
  fi
  _nc_opts+=("-w" "$waittime")

  # handle user-directed RESOLVE choice
  if [ ! "$RESOLVE" ] ; then _nc_opts+=("-n"); fi
  # for associateive array ${!var[@]} lists all keys (i.e. ips in this case)
  [ "$ASSOCIATIVE" ] && targets=("${!a_targets[@]}")

  j_msg "-${debug}" -p "_nc_opts: [${_nc_opts[@]}]"
  j_msg "-${info}" -m "${BWon}(info)${Boff} command: timeout $timeout nc ${_nc_opts[@]} \${fam} \$target $port"


  # form the "unloaded" command as a function taking ${target} as its arg, to be evaluated at load/run time
  _netcat_cmd() {
    # j_msg "-${debug}" -p "in ${FUNCNAME[0]} with arg(s) [$*]";
    local _target="$1" fam=""
    case "$_target" in
      *[!0-9a-fA-F.:]* ) : ;; # possible hostname - continue
      *:*              ) fam="-6";;
      *.*              ) fam="-4";;
    esac
    timeout "$timeout" nc "${_nc_opts[@]}" "${fam}" "$target" "$port" &>/dev/null
  }

  if [ "$PARALLEL" ]; then
    _jping_parallel_core "_netcat_cmd"
  else # serialize
    _jping_serial_core "_netcat_cmd"
  fi
  msg="complete. ${BBon}[${BMon}$ups${BBon}] ${BGon}up${Boff} |"
  msg+=" ${BBon}[${BMon}$downs${BBon}] ${BRon}down${Boff}"
  j_msg "-${notice}" -M "$idx_face_beam" "$msg"
}

