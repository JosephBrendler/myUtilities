  local msg="${BRon}usage${Boff}: ${_func_color}$PN${Boff} [\"<target_list>\"]"
  msg+=" [-c|--command <cmd>] [-p port]"

  j_msg "-${notice}" -p "$msg"
    msg="               [-P|--parallel] -j|--jobs jobs] [-s|--serial]"
  j_msg "-${notice}" -mp "$msg"
    msg="               [-W|--wait n] [-t|--timeout n] [-h|--help]"
  j_msg "-${notice}" -mp "$msg"
  msg="${BYon}Options --${Boff}"
  j_msg "-${notice}" -p "$msg"
  msg="${BMon}  -c|--command${Boff}${Con} .........: one of [d[evtcp]|n[etcat]|nm[ap]|ss[h]|a[rping]|p[ing]|f[ping]|so[cat]"
  j_msg "-${notice}" -m "$msg"
  msg="${BMon}  -p|--port${Boff}${Con} ............: user-specified port to check"
  j_msg "-${notice}" -m "$msg"
  msg="${BMon}  -P|--parallel${Boff}${Con} ........: parallel processing (${Won}default${Con})"
  j_msg "-${notice}" -m "$msg"
  msg="${BMon}  -j|--jobs [n]${Boff}${Con} ........: job count (${Won}default:${Con} \$(nproc))"
  j_msg "-${notice}" -m "$msg"
  msg="${BMon}  -S|--serial${Boff}${Con} ..........: disable parallel processing"
  j_msg "-${notice}" -m "$msg"
  msg="${BMon}  -I|--interactive${Boff}${Con} .....: show config and confirm before executing command"
  j_msg "-${notice}" -m "$msg"
  msg="${BMon}  -N|--noninteractive${Boff}${Con} ..: execute immediately (${Won}default${Con})"
  j_msg "-${notice}" -m "$msg"
  msg="${BMon}  -W|--wait [n]${Boff}${Con} ........: response-wait timeout (n seconds)(${Won}default${Con} 0.5)(if applicable)"
  j_msg "-${notice}" -m "$msg"
  msg="${BMon}  -t|--timeout [n]${Boff}${Con} .....: job timeout (n seconds)(${Won}default${Con} 0.5)(if applicable)"
  j_msg "-${notice}" -m "$msg"
  msg="${BMon}  -n|--noresolve${Boff}${Con} .......: never resolve (and display) hostnames for addresses"
  j_msg "-${notice}" -m "$msg"
  msg="${BMon}  -R|--resolve${Boff}${Con} .........: always resolve (and display) hostnames for addresses (${Won}default${Con})"
  j_msg "-${notice}" -m "$msg"
