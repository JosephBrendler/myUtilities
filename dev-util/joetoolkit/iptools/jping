    # try to round a decimal up to integer value, but don't round 1 or 1.0 up to 2
    if [ "${waittime##*.}" -gt 0 ] && [[ "$waittime" == *"."* ]]; then
      _nc_wait=$(( ${waittime%.*} + 1 ))
    else
       _nc_wait="${waittime%.*}"
    fi
    j_msg "-${warn}" "${BYon}(warning)${Boff} nc -w must be integer, waittime [$waittime] rounded to [$_nc_wait]"
    waittime="$_nc_wait"
  fi
  j_msg "-${info}" -m "command:  timeout $timeout nc $nc_opts -\${fam} -w $waittime \"\$target\" $port"

  if [ "$PARALLEL" ]; then
