#!/bin/bash

# shellcheck source=/usr/sbin/script_header_joetoo
# shellcheck source=/usr/sbin/script_header_joetoo_extended
# shellcheck source=/usr/sbin/script_header_joetoo_unicode
source /usr/sbin/script_header_joetoo


PN=${0##*/}   # basename
if [ -f /etc/joetoolkit/BUILD ]; then . /etc/joetoolkit/BUILD; else BUILD="0.0.1"; fi

# Tool			Protocol	Parallelism			Advantage												Disadvantage
# /dev/tcp	TCP only	Manual (&)			Built into Bash; no binary req.	TCP only; syntax is clunky
# nc -zv		TCP/UDP		Manual (xargs)	Standard on most systems				Versions vary (OpenBSD vs GNU)
# ping			ICMP only	Manual (xargs)	Universal; low overhead 				Blocked by many firewalls
# socat			Any				Manual (&)			Extremely flexible; power tool 	Complex syntax; heavy binary
# fping			ICMP only	Native					High-speed parallel scanning 		Must be installed separately
# ping      ICMP only Manual (&)      Standard on most systems        Often filtered by firewall
# ssh       ssh       Manual (&)      Runs on most and answers quick  Requires SSH daemon

# arping    arp       Manual (&)      Bypass Firewalls								local ipv4 subnet only
# ndisc6    ndp       Manual (&)      Bypass Firewalls								local ipv6 subnet only


#-----[ variables ]----------------------------------------------
varlist="PN BUILD user logFile rlv.config_dir verbosity loglevel bool.LOGGING"
varlist+=" bool.INTERACTIVE bool.QUIET bool.DEBUG bool.UNICODE_CAPABLE bool.UNICODE_DISABLE"
varlist+=" BREAK bool.RESOLVE bool.ASSOCIATIVE mode command port bool.FILE bool.PARALLEL jobs waittime timeout"
varlist+=" rlv.target_list rlv.targets_str"
initialize_vars

default_target_list="192.168.62.{1..254}"  # a default

TAB=$(printf '\t')   # pre-cooked literal tab character
CR=$(printf '\r')    # pre-cooked literal carriage return character
NLx="$(printf '\nx')" # pre-cooked literal newline character followed by x to prevent shell stripping \n
NL="${NLx%x}"         # strip the x, leaving just the pre-cooked literal newline character

mode="FAST"          # default (fast) will be set otherwise if -m flag is used with arg
command="devtcp"     # default (fast)
port=22              # default to ssh port num
PARALLEL="$TRUE"     # will be set false if cmdline has -s flag
FILE="$FALSE"        # will be set true if cmdline has -f flag
INTERACTIVE="$FALSE" # will be set true if cmdline has -I flag
ASSOCIATIVE="$FALSE" # will be set true if cmdline has -A flag
RESOLVE="$TRUE"      # will be set true if cmdline has -R flag; false if -n flag
jobs=$(nproc)        # default parallel jobs to the number of cores
waittime="0.5"       # e.g. ping -W0.5 hostname (some tools e.g. nc don't allow fractions// use with timeout)
timeout="0.5"        # e.g. timeout 0.5 nc -vz $target 22
ups=0                # count of host-status "Up" targets
downs=0              # count of host-status "Down" targets
opened=0             # count of port-state "Open" targets
closed=0             # count of port-state "Closed" targets
filtered=0           # count of port-state "Filtered" targets
unverified=0         # count of port-state "Unverified" targets
timeouts=0           # count of port-state "Timeout" targets (may be down or up with port firewalled)

logFile="/var/log/${PN}.log"
joetoo_ip4_prefix=
declare -a targets=()    # check these
declare -A a_targets=()  # (if -A flag) use an associative array (hostnames keyed on ip addr); hold both values in one array


#-----[ functions ]----------------------------------------------
# define here improved (and POSIX) rather than source script_header_joetoo_extended's RBG_FG function
# to define truecolor (24 bit) Orange to add to status coloring
# ToDo: convert to RGB_FG to posix, move to script_header_joetoo, and define BOon and others there
# note BOLD is defined in script_header_joetoo already
RGB_FG()    # echo esc seq color as RGB. (OK in Konsole/Gnome term, but not lxterminal)
{ local _FG="38;2"; _R=$1; _G=$2; _B=$3;
  printf '%s%s;%s;%s;%sm' "${CSI}" "${_FG}" "${_R}" "${_G}" "${_B}" ; }
RGB_BG()    # echo esc seq color as RGB. (OK in Konsole/Gnome term, but not lxterminal)
{ local _BG="48;2"; _R=$1; _G=$2; _B=$3;
  printf '%s%s;%s;%s;%sm' "${CSI}" "${_BG}" "${_R}" "${_G}" "${_B}" ; }
B_RGB_FG()    # echo esc seq color as RGB. (OK in Konsole/Gnome term, but not lxterminal)
{ local _FG="38;2"; _R=$1; _G=$2; _B=$3;
  printf '%s%s;%s;%s;%s;%sm' "${CSI}" "${_FG}" "${_R}" "${_G}" "${_B}" "${BOLD}"; }
Oon=$(RGB_FG 255 165 0)
BOon=$(B_RGB_FG 255 165 0)
BOonBB=${BOon}$(RGB_BG 0 0 255)

_jping_terminal_sanity() {
  # restore standard character echoing and carriage return to the TTY device
  stty echo icrnl 2>/dev/null
  # use script_header_joetoo's SCU to explicitly unhide the hardware terminal cursor
  SCU
  # ensure CTRL-C will work when trapped here, by explicitly running exit 130 (not return)
  exit 130
}

my_usage() {
  j_msg "-${debug}" -p "in ${FUNCNAME[0]}"
  local msg="${BRon}usage${Boff}: ${_func_color}$PN${Boff} [\"<target_list>\"]"
  msg+=" [-c|--command <cmd>] [-p port]"

  j_msg "-${notice}" -p "$msg"
    msg="               [-P|--parallel] -j|--jobs jobs] [-s|--serial]"
  j_msg "-${notice}" -mp "$msg"
    msg="               [-W|--wait n] [-t|--timeout n] [-h|--help]"
  j_msg "-${notice}" -mp "$msg"
  msg="${BYon}Options --${Boff}"
  j_msg "-${notice}" -p "$msg"
  msg="${BMon}  -m|--mode${Boff}${Con} ............: one of [F[AST]*|E[NRICHED] (TBD:D[ISCOVERY]|M[APPING] (*: ${Won}default${Con})${Boff}"
  j_msg "-${notice}" -m "$msg"
  msg="${BMon}  -c|--command${Boff}${Con} .........: one of [d[evtcp]*|n[etcat]|nm[ap]|ss[h]|a[rping]nd[isc6]|p[ing]|f[ping]|so[cat] (*: ${Won}default${Con})${Boff}"
  j_msg "-${notice}" -m "$msg"
  msg="${BMon}  -p|--port${Boff}${Con} ............: user-specified port to check${Boff}"
  j_msg "-${notice}" -m "$msg"
  msg="${BMon}  -P|--parallel${Boff}${Con} ........: parallel processing (${Won}default${Con})${Boff}"
  j_msg "-${notice}" -m "$msg"
  msg="${BMon}  -j|--jobs [n]${Boff}${Con} ........: job count (${Won}default:${Con} \$(nproc))${Boff}"
  j_msg "-${notice}" -m "$msg"
  msg="${BMon}  -S|--serial${Boff}${Con} ..........: disable parallel processing${Boff}"
  j_msg "-${notice}" -m "$msg"
  msg="${BMon}  -I|--interactive${Boff}${Con} .....: show config and confirm before executing command${Boff}"
  j_msg "-${notice}" -m "$msg"
