  j_msg "-${notice}" -m "$msg"
  msg="${BMon}  -A|--associative${Boff}${Con} .....: from file, form an associve array of ip addrs keyed on hostnames"
  j_msg "-${notice}" -m "$msg"
  msg="${BMon}  -h|--help${Boff}${Con} ............: print this message"
  j_msg "-${notice}" -m "$msg"
  msg="${BYon}Arguments --${Boff}"
  j_msg "-${notice}" -p "$msg"
  msg="${BCon}  <target_list>${Boff}${Con} .......: (optional) ${Won}default:${Con} ${default_target_list}"
  j_msg "-${notice}" -m "$msg"
  msg="${BYon}Notes --"
  j_msg "-${notice}" -p "$msg"
  msg="${BCon}  (1) $PN default is command: /dev/tcp port 22"
  j_msg "-${notice}" -m "$msg"
  msg="${BCon}  (2) ping command is slower and icmp rather than explicit port, but lower false positive rate"
  j_msg "-${notice}" -m "$msg"
  msg="${BCon}  (3) parallel processing is on by default (disable with -s), and -j jobs defaults to \$(nproc)"
  j_msg "-${notice}" -m "$msg"
  msg="${BCon}  (4) general command choice rationale --"
  j_msg "-${notice}" -m "$msg"
  j_msg "-${notice}" -mp "${BWon}         Tool        Protocol    Parallelism      Advantage          Disadvantage${Boff}${Boff}"
  j_msg "-${notice}" -mp "${BWon}         --------    ---------   --------------   -----------------  -------------------------${Boff}"
  j_msg "-${notice}" -mp "${Con}         /dev/tcp    TCP only    Manual (&)       Built-in (Bash)    No UDP; syntax clunky${Boff}"
  j_msg "-${notice}" -mp "${Con}         nc -zv      TCP/UDP     Manual (xargs)   Standard/Readable  Versions vary widely${Boff}"
  j_msg "-${notice}" -mp "${Con}         nmap        Any         Native           Deep inspection    Heavy binary; slow${Boff}"
  j_msg "-${notice}" -mp "${Con}         ssh         TCP (22)    Manual (&)       Verifies Service   Requires SSH daemon${Boff}"
  j_msg "-${notice}" -mp "${Con}         arping      Layer 2     Manual (&)       Bypass Firewalls   Local subnet only${Boff}"
  j_msg "-${notice}" -mp "${Con}         ping        ICMP only   Manual (xargs)   Universal/Light    Often blocked; no ports${Boff}"
  j_msg "-${notice}" -mp "${Con}         fping       ICMP only   Native           Fastest scanning   Requires separate install${Boff}"
  j_msg "-${notice}" -mp "${Con}         socat       Any         Manual (&)       Hyper-flexible     Complex; high overhead${Boff}"
  msg="${BCon}  (5) ${BMon}<target_list> ${BCon}can be any of the following forms --${Boff}"
  j_msg "-${notice}" -m "$msg"
  j_msg "-${notice}" -mp "${Con}         Quoted list.......: ${Boff}\"10.0.0.1 10.0.0.2\" or \"slim2 elrond\" or \"\$host_list\" or \"\${hosts[*]}\""
  j_msg "-${notice}" -mp "${Con}         Brace Expansion...: ${Boff}\"192.168.1.{1..254}\""
  j_msg "-${notice}" -mp "${Con}         IPv4 CIDR Subnet..: ${Boff}192.168.62.0/24 ${BCon}(Max /22)${Boff}"
  j_msg "-${notice}" -mp "${Con}         IPv6 CIDR Subnet..: ${Boff}fd62:6262::/118 ${BCon}(Max /118)${Boff}"
  j_msg "-${notice}" -mp "${Con}         Flat File (-f)....: ${Boff}/path/to/targetlist.txt"

  j_msg "-${notice}" -p "${BYon}Examples --${Boff}"
  j_msg "-${notice}" -mp "${Con}  Standard Scan...: ${_func_color}$PN${Boff} ${_quote_color}\"192.168.1.{1..50}\"${Boff}"
  msg="${Con}  Custom Command..: ${_func_color}$PN${Boff} ${_data_color}-c${Boff}"
  msg+=" ${_cmd_color}nc${Boff} ${_data_color}-p 80${Boff} ${_cmt_color}10.0.0.0/24${Boff}"
  j_msg "-${notice}" -mp "$msg"
  msg="${Con}  File Input......: ${_func_color}$PN${Boff} ${_data_color}-f -c${Boff} ${_cmd_color}ping${Boff}"
  msg+=" ${_cmt_color}my_hosts.txt${Boff}"
  j_msg "-${notice}" -mp "$msg"

  j_msg "-${notice}" -p "${BRon}Safety Limits --${Boff}"
  j_msg "-${notice}" -mp "${Con}  To prevent system instability, CIDR expansion is capped at${Boff}"
  j_msg "-${notice}" -mp "${Con}  ${BMon}1024 addresses${Boff} per call. Use larger subnets with caution${Boff}"
}

fractip2dec() { # (POSIX) convert reasonably small fraction of ip address to decimal value
  local _addr="$1"  # ip address
  local _c _d       # octets in ipv4
  local _last       # hextet in ipv6
  local _rem        # remnant in parsing positional parameter by expansion
  local _dec        # calculated decimal value
  case "$_addr" in
    *:*) fam=6; case "$1" in *[!0-9a-fA-F:]*) j_msg "-${err}" "invalid characters in ipv6 addr"; return 1 ;; esac ;;
    *.*) fam=4; case "$1" in *[!0-9.]*) j_msg "-${err}" "invalid characters in ipv4 addr"; return 1 ;; esac ;;
  esac

  case "$fam" in
    4)   # ipv4 address - reasonable range is /22 subnet, so ignore first two octets and convert the rest to decimal
      _d=${_addr##*.}  # strip longest match for '*.' from prefix - leaving 4th octet d
      _rem=${_addr%.*} # strip shortest match for '.*' from suffix - leaving a.b.c
      _c=${_rem##*.}   # strip longest match for '*.' from prefix - leaving 3rd octet c
      _dec=$(( _d + ( _c * 256 ) ))
      ;;
    6)   # ipv4 address - reasonable range is /118 subnet, so ignore all but last hextet abd convert that to decimal
      _last=${_addr##*:}    # strip longest match for '*:' from prefix - leaving last hextet
      _dec=$(h2d "$_last")  # use script_header_joetoo hex to decimal conversion
      ;;
    *)  j_msg "-${err}" "invalid fam in ip2dec function"; return 1 ;;
  esac
  printf '%s\n' "${_dec:-0}"   # convert null (like last hextet zero) to explicit zero
  return 0
}

getpartip() { # (POSIX) return fraction of ip address above reasonably small range
  local _addr="$1"  # ip address
  local _c _d       # octets in ipv4
  local _last       # hextet in ipv6
  local _rem        # remnant in parsing positional parameter by expansion
  local _dec        # calculated decimal value
  case "$_addr" in
    *:*) fam=6; case "$1" in *[!0-9a-fA-F:]*) j_msg "-${err}" "invalid characters in ipv6 addr"; return 1 ;; esac ;;
    *.*) fam=4; case "$1" in *[!0-9.]*) j_msg "-${err}" "invalid characters in ipv4 addr"; return 1 ;; esac ;;
  esac

  case "$fam" in
    4)   # ipv4 address - reasonable range is /22 subnet, so ignore first two octets and convert the rest to decimal
      _d=${_addr##*.}  # strip longest match for '*.' from prefix - leaving 4th octet d
      _rem=${_addr%.*} # strip shortest match for '.*' from suffix - leaving a.b.c
      _c=${_rem##*.}   # strip longest match for '*.' from prefix - leaving 3rd octet c
      _rem=${_addr%.*} # strip shortest match for '.*' from suffix - leaving a.b
      ;;
    6)   # ipv4 address - reasonable range is /118 subnet, so ignore all but last hextet abd convert that to decimal
      _rem=${_addr%:*} # strip shortes match for ":*" from suffix - leaving all but last hextet
      ;;
    *)  j_msg "-${err}" "invalid fam in ip2dec function"; return 1 ;;
  esac
  printf '%s\n' "$_rem"
  return 0
}

validate_target_list() {
  local -a accumulated_list=() # accumulated indexed array of target addresses
  local _vt_file=""            # pathname of file named by target_list
  local _vt_partcount          # number of space-delimited parts in target_list
  local -a part_targets        # array of targets expanded from a target-list part
  local _vt_cidr _vt_net _vt_prefix  # components fo cidr subnet expansion
  local _vt_start _vt_end _vt_diff   # components for range expansion
  local _vt_start_dec _vt_end_dec    # components for range expansion
  local _c _d       # octets in ipv4
  local _last       # hextet in ipv6
  local _rem        # remnant in parsing positional parameter by expansion
  # target list can be any of a number of forms requiring different handling here -
  #  - shorthand (e.g. 192.168.62.{1..254}, default) --> expand to a list
  #  - a cidr formatted subnet - expand to a list but apply reasonable-size guards
  #  - a quoted list - of ipv4 and/or ipv6 addresses
  #  - a quoted list - of hostnames and/or fully qualified domain names
  #  - the pathname to a file containing a list of addresses, hostnames, or both
  #    - if both, and if -A|--associative (ASSOCIATIVE pBool) is set,
  #      then build an associative target_list array of addresses key'd on names
  # parse initial target_list variable, and assign final target_list array

  # strategy: parse to identify use case -
  #  - FILE and ASSOCIATIVE - return associative array
  #  - FILE but not ASSOCIATIVE - populate array with lines from file and continue validation of these parts
  #  - if not file - validate each part
  #  - for each part -
  #    is n.n.n.n/nn cidr subnet? - expand/append to accumulated_list array (with reasonable limits)
  #    is n.n.n.{n..nn} brace shorthand - expand/append to accumulated_list array
  #    is a.a.a.a-b.b.b.b or a:a:a::-b:b:b:: - expand/append to accumulated_list array (with reasonable limits)
  #    is a hostname or single address - append to accumulated_list

  # if -f|--file ($FILE pBool) indicates $target_list is a file pathname,
  # replace the pathname with the contents of the file and continue validation
  if [ "$FILE" ] ; then
    _vt_file="$target_list"
    if [ -f "$_vt_file" ] ; then
       # if the -A|--associative (ASSOCIATIVE pBool) is set, then build associative array,
       #   otherwise, build an indexed address array from potentially hybrid parts
       if [ "$ASSOCIATIVE" ] ; then
         local -a lines
         readarray -t lines < <(cat "$_vt_file")
         # iterate through all lines of the hosts files
         j_msg "-${debug}" -p "reading associative array a_targets"
         for line in "${lines[@]}"; do
           # read the whole line, assign ip and host; ignore iface and timestamp
           read -r ip host _ <<<"$line"
           # Skip empty/comments
           [[ -z "$ip" || "$ip" == \#* ]] && continue
           # reject malformed hosts file (column 1, 2 must be valid ip address, hostname
           case "$ip" in
             *:*|*.* ) : ;; # ip address is ok - do nothing
             *       )
               j_msg "-${err}" "invalid ip address [$ip] while ingesting associative array from file [$_vt_file]"
               my_usage; exit 1 ;;
           esac
           case "$host" in
             *[!0-9a-zA-Z.-]* ) j_msg "-${err}" "invalid; illegal chars" ; my_usage; exit 1 ;;
             -*|*-            ) j_msg "-${err}" "invalid: starts/ends w hyphen" ; my_usage; exit 1 ;;
             *.-*|*-.*        ) j_msg "-${err}" "invalid: fqdn part starts/ends w hyphen" ; my_usage; exit 1 ;;
             *..*             ) j_msg "-${err}" "invalid: consecutive dots" ; my_usage; exit 1 ;;
             .*               ) j_msg "-${err}" "invalid: starts w dot" ; my_usage; exit 1 ;;
             *                ) : ;;   # valid hostname/fqdn - do nothing
           esac
           [ ${#host} -gt 253 ] && { j_msg "-${err}" "invalid fqdn; exceeds 253 characters"; my_usage; exit 1 ; }
#           j_msg "-${debug}" -m -n "assigning"
           a_targets["$ip"]="$host"
#           handle_result $? "ip: [$ip] host: [$host]" "" "$debug"
         done
         j_msg "-${info}" -m "ingested associative array with [${#a_targets[@]}] a_targets"
         j_msg "-${debug}" -p "a_targets [${#a_targets[@]}] a_targets"
         targets_str="${a_targets[*]}"    # string for show_config
         return 0  # if -f|--file and -A|--associateve, then return with a_targets now
       else
         # transfer file content to target_list (space-delimited string) for common validation and assignment
         # (filter comments and blank lines)
         target_list=$(cat "$_vt_file" | grep -v "^${W0}#" | sed 's|^$||')
         _vt_partcount=$(printf '%s' "$target_list" | wc -w)
         j_msg "-${info}" -p "${BWon}(info}${Boff} ingested file [$_vt_file] as new target_list with [$_vt_partcount] parts"
       fi  # ASSOCIATIVE
    else
       j_msg "-${err}" "${BRon}(error)${Boff}: -f flag is set but file [$target_list] not found"; my_usage; exit 1
    fi
  else
    _vt_partcount=$(printf '%s' "$target_list" | wc -w)
    j_msg "-${info}" -p "${BWon}(info}${Boff} validating original target_list with [$_vt_partcount] parts"
  fi

  # parse target_list with posix pipe to translate any comma, semicolon, pipe, CR, TAB, NL delimiters to spaces
  target_list=$(printf '%s' "$target_list" | tr ",;|${TAB}${CR}${NL}" ' ')
  _vt_partcount=$(printf '%s' "$target_list" | wc -w)
  j_msg "-${info}" -p "${BWon}(info}${Boff} after delimiter translation, validating target_list with [$_vt_partcount] parts"

  ### Note: at this point, regardless of its origin target_list is a single space-delimited string with
  #    with any combination of allowable parts, but no 

  # validate each part of target_list; id type, expand, and append to an accumulation of expanded parts
  # strategy --
  #   - only cidr subnet contains a / so look for that first and validate or reject
  #   - if not cidr, then only brace shorthand will contain {}
  for list_part in $target_list; do   # unquoted to split list into parts
    case "$list_part" in

      */*      )  # cidr subnet - e.g. "fd62:6262:6260::/118"
        # assign cidr and net with parameter expansion
        _vt_cidr="${list_part##*/}"    # strip longest match for '*/' from the left - leaving cidr
        _vt_net="${list_part%/*}"      # strip shortest match for '/*' from the right - leaving network
        # validate net with ipcalc
        if ! ipcalc -c "$_vt_net"; then
          j_msg "-${err}" "${BRon}error${Boff}: network [$_vt_net] rejected by ipcalc"; my_usage; exit 1;
        fi
        # detect family ipv4 or ipv6 and validate reasonably sized address range
        # set prefix to be used by ipcalc to split the subnet into addresses (/31 or /128 for individual ips)
        case "$_vt_net" in
          *:*) fam=6; _vt_prefix=128; [[ "$_vt_cidr" -lt 118 ]] && \
            { j_msg "-${err}" "${BRon}error${Boff}: IPv6 subnet out of range (max /118)"; my_usage; exit 1 ; } ;;
          *.*) fam=4; _vt_prefix=32; [[ "$_vt_cidr" -lt 22 ]] && \
            { j_msg "-${err}" "${BRon}error${Boff}: IPv4 subnet out of range (max /22)"; my_usage; exit 1 ; } ;;
          *  ) j_msg "-${err}" "${BRon}error${Boff}: invalid network specified [$_vt_net]"; my_usage; exit 1 ;;
        esac
        # hydrate address range using ipcalc-ng
        # -S splits into prefix sized subnets /32 (ipv4) or /128 (ipv6) for individual ips
        # --no-decorate is clean | cut drops the cidr
        readarray -t part_targets < <(ipcalc -S "$_vt_prefix" "$list_part" --no-decorate | cut -d'/' -f1)
        # append this to array of accumulated targets
        accumulated_list+=("${part_targets[@]}")
        j_msg "-${debug}" -p "${BYon}(debug)${Boff} accumulated list contains [${#accumulated_list[@]}] individual targets"
        continue   # this was cidr subnet, so skip other-case logic below, get next part
        ;;  # */* - cidr subnet

      *"{"*|*"}"*  )  # brace shorthand - e.g. "192.168.62.{1..254}" (note: arrays expand on command line, way before here)
        # reject if contains other invalid chars
        case "$list_part" in
          *[!0-9a-zA-Z.:{}]*) j_msg "-${err}" "invalid characters in brace-shorthand list_part [$list_part]"; my_usage; exit 1 ;;
          *)  j_msg "-${debug}" "all characters in brace-shorthand list_part [$list_part] are valid" ;;
        esac
        # now vetted, expand safely with eval and use readarray's -O option to *append to accumulated targets
        # readarray -d '' -t -O "${#accumulated_list[@]}" accumulated_list < <( eval "printf '%s\0' $list_part" )
        # use the safer 2-step approach - first eval to expand into intermediate array
        readarray -d '' -t part_targets < <( eval "printf '%s\0' $list_part" )
        # append this to array of accumulated targets
        accumulated_list+=("${part_targets[@]}")
        j_msg "-${debug}" -p "${BYon}(debug)${Boff} accumulated list contains [${#accumulated_list[@]}] individual targets"
        continue   # this was brace shorthand part, so skip other-case logic below, get next part
        ;;  # *{*|*}* - brace shorthand

      *-*      )  # hyphen-separated start-end range or hyphenated host-name
        # reject if contains other invalid chars
        case "$list_part" in
          *[!0-9a-fA-F.:-]*)
            # cannot be range but could be hyphenated host-hame (check vs hostname template -
            # hostname allows letters, digits, hyphens, periods separating domain parts
            # domain parts must be max 63 char and fqdn including .s must be max 253 char
            case "$list_part" in
              *[!0-9a-zA-Z.-]*) j_msg "-${err}" "invalid characters in hyphenated list_part [$list_part]"; my_usage; exit 1 ;;
              *)  # append as possible (vetted) hostname
                accumulated_list+=("$list_part")
                j_msg "-${debug}" -p "${BYon}(debug)${Boff} accumulated list contains [${#accumulated_list[@]}] individual targets"
                continue  # skip other-case logic below; get next part
                ::
            esac
            ;;
          *)  j_msg "-${debug}" "all characters in range list_part [$list_part] are valid" ;;
        esac
        # validate both start and end to determine family, re-hydration prefix and reject if contains invalid other chars
        _vt_start=$(printf '%s\n' "$list_part" | cut -d '-' -f 1)
        _vt_end=$(printf '%s\n' "$list_part" | cut -d '-' -f 2)
        case "$_vt_start" in
          *:*) fam=6; _vt_prefix=128; case "$_vt_end" in *[!0-9a-fA-F:]*)
                 j_msg "-${err}" "invalid characters in ipv6 range list_part [$list_part]";
                 my_usage; exit 1; esac
               ;;
          *.*) fam=4; _vt_prefix=32; case "$_vt_end" in *[!0-9.]*)
                 j_msg "-${err}" "invalid characters in ipv4 range list_part [$list_part]";
                 my_usage; exit 1; esac
               ;;
          *  ) j_msg "-${err}" "${BRon}error${Boff}: invalid range start specified [$_vt_start]"; my_usage; exit 1 ;;
        esac
        # if start and end differ in first two octets / any but last hextet, then reject as unreasonably large range
        if [[ "$(getpartip "$_vt_start")" != "$(getpartip "$_vt_end")" ]]; then
          j_msg "-${err}" "leading octet/hextet mismatch; range too big (limit equiv /22 /118 for ipv4/6)";
          my_usage; exit 1
        fi
        # examine decimal difference in lower 2 octests/last hextet to confirm reasonable range
        _vt_start_dec=$(fractip2dec "$_vt_start")
        _vt_end_dec=$(fractip2dec "$_vt_end")
        _vt_diff=$(( _vt_end_dec - _vt_start_dec ))
        if [ "$_vt_diff" -gt 1023 ]; then
          j_msg "-${err}" "calculated range too big (limit 1023 addrs, equiv /22 /118 for ipv4/6)";
          my_usage; exit 1
        fi
        # now safely hydrate the reasonably sized range to part_targets and append to accumulated targets
        readarray -t part_targets < <(
            ipcalc -d "$list_part" --no-decorate | \
                xargs -n 1 ipcalc -S "${_vt_prefix}" --no-decorate | \
                cut -d'/' -f1 )
        # append this to array of accumulated targets
        accumulated_list+=("${part_targets[@]}")
        j_msg "-${debug}" -p "${BYon}(debug)${Boff} accumulated list contains [${#accumulated_list[@]}] individual targets"
        continue   # this was hyphen-separated range expansion, so skip other-case logic below, get next part
        ;;  # *-* - range expansion

     *         )  # expanding cases covered, but list_part could still be an ip addresses or a host names
        # reject if contains other invalid chars
        case "$list_part" in
          *[!0-9a-zA-Z.:\ ]*) j_msg "-${err}" "invalid characters in individual-target list_part [$list_part]"; my_usage; exit 1 ;;
          *)  j_msg "-${debug}" "all characters in individual-target list_part [$list_part] are valid";
            # append individual target to accumulated targets
            accumulated_list+=("$list_part")
            j_msg "-${debug}" -p "${BYon}(debug)${Boff} accumulated list contains [${#accumulated_list[@]}] individual targets"
            continue  # skip any future other-case logic below; get next part
            ;;
        esac
        ::
    esac
  done
  # now build final array
  targets=("${accumulated_list[@]}")  || die "failed to build final targets array"
  j_msg "-${info}" -m "${BWon}(info)${Boff} final target list contains [${#targets[@]}] individual targets"
  # construct targets_str which is used by show_config via rlv.targets_str in varlist
  export targets_str="${targets[*]}"    # string for show_config
  return 0
}

parse_cmdline_and_validate_input() {
  j_msg "-${debug}" -p "in ${FUNCNAME[0]} with arg(s) [$*]"
  local args=()
  local msg
  # early-exit guard max cmdline is - jping <tgtlst> -c d -p 1 -P -j 2 -W 1 -t 1 -f
  if [ $# -gt 13 ] ; then
    j_msg "-${err}" "too many [$#] args [$*]"
    my_usage; exit 1
  fi
  j_msg "-${debug}" -p "${BYon}cmdlind${Boff}: [$*]"
  # parse command line (validate any $2 arg requested by $1 before assigning
  # ($2 must exist, which is not the case if $1 was the last arg,
  #  and $2 must not be an option - must not start with '-' )
  while [ $# -gt 0 ] ; do
    j_msg "-${debug}" -p "${BYon}parsing parameter${Boff}: [$1] of ${BYon}existing cmdline${Boff} [$*]"
    case "$1" in
      --                  ) args+=("$@"); break ;;  # remainder of cmdline is arg(s)

      -c|--command        )  # ...................... #  devtcp(default) or netcat|ping|fping|socat
        if [[ -z "$2" || "$2" == -* ]]; then
          j_msg "-${err}" "Option $1 requires an argument" ; my_usage; exit 1
        else
          command="$2"; shift
          # early-exit guard - command must be one of devtcp|netcat|ping|fping|socat
          case "$command" in
            d* ) command="devtcp" ;;
            ne*) command="netcat" ;;
            nm*) command="nmap"   ;;
            ss*) command="ssh"    ;;
            a* ) command="arping" ;;
            p* ) command="ping"   ;;
            f* ) command="fping"  ;;
            so*) command="socat"  ;;
            *  ) j_msg "-${err}" "${BRon}error${Boff}: invalid command [$command]";
                 my_usage; exit 1 ;;
          esac
          j_msg "-${debug}" -p "${BYon}set${Boff} command: [$command], and shifting 2"
        fi ;;

      -P|--parallel       )  # ...................... # parallel-process iaw -j|--jobs
          PARALLEL="$TRUE"
          j_msg "-${debug}" -p "${BYon}set${Boff} PARALLEL: [$(TrueFalse "$PARALLEL")], shifting 1"
          ;;

      -S|--serial         )  # ...................... # disable parallel-process
          PARALLEL="$FALSE"
          j_msg "-${debug}" -p "${BYon}set${Boff} PARALLEL: [$(TrueFalse "$PARALLEL")], shifting 1"
          ;;

      -I|--interactive    )  # ...................... # number of parallel jobs
        INTERACTIVE="$TRUE"
        j_msg "-${debug}" -p "${BYon}set${Boff} INTERACTIVE: [$(TrueFalse "$FILE")], shifting 1"
        ;;

      -N|--noninteractive )  # ...................... # number of parallel jobs
        INTERACTIVE="$FALSE"
        j_msg "-${debug}" -p "${BYon}set${Boff} INTERACTIVE: [$(TrueFalse "$FILE")], shifting 1"
        ;;

      -p|--port           )  # ...................... # number of parallel jobs
        if [[ -z "$2" || "$2" == -* ]]; then
          j_msg "-${err}" "Option $1 requires an argument" ; my_usage; exit 1
        else
          port="${2:-22}"; shift
          j_msg "-${debug}" -p "${BYon}set${Boff} port: [$port], and shifting 2"
        fi
        # warn if jobs concurrency is potentially unreasonable (2 x nproc)
        _safe_level=$(( $(nproc) * 2 ))
        if [ "$jobs" -gt "$_safe_level" ]; then
          j_msg "-${warn}" -p "${BYon}(warning)${Boff} jobs [$jobs] specified may exceed sensible concurrency levels"
        fi
        ;;

      -j|--jobs           )  # ...................... # number of parallel jobs
        if [[ -z "$2" || "$2" == -* ]]; then
          j_msg "-${err}" "Option $1 requires an argument" ; my_usage; exit 1
        else
          jobs="$2"; shift
          j_msg "-${debug}" -p "${BYon}set${Boff} jobs: [$jobs], and shifting 2"
        fi
        safe_load=$(( $(nproc) * 2 ))
        if [ "$jobs" -gt "$safe_load" ]; then
          j_msg "-${warn}" -p "${BYon}(warning)${Boff} jobs [$jobs] may be in excess of reasonable concurrency levels"
        fi
        ;;

     -w|-W|--wait         )  # ...................... # time to wait for response
        if [[ -z "$2" || "$2" == -* ]]; then
          j_msg "-${err}" "Option $1 requires an argument" ; my_usage; exit 1
        else
          waittime="$2"; shift
          j_msg "-${debug}" -p "${BYon}set${Boff} waittime: [$waittime], and shifted 2"
        fi ;;

      -t|--timeout        )  # ...................... # for timeout command (GNU)
        if [[ -z "$2" || "$2" == -* ]]; then
          j_msg "-${err}" "Option $1 requires an argument" ; my_usage; exit 1
        else
          timeout="$2"; shift
          j_msg "-${debug}" -p "${BYon}set${Boff} timeout: [$timeout], and shifted 2"
        fi ;;

      -n|--noresolve      )  #....................... # never resolve hostnames
        export RESOLVE="$FALSE"
        j_msg "-${debug}" -p "${BYon}set${Boff} RESOLVE: [$(TrueFalse "$RESOLVE")], shifting 1"
        ;;

      -R|--resolve        )  #....................... # always resolve hostnames
        export RESOLVE="$TRUE"
        j_msg "-${debug}" -p "${BYon}set${Boff} RESOLVE: [$(TrueFalse "$RESOLVE")], shifting 1"
        ;;

      -f|--file           )  #........................ # set if target_list is a file path name
        FILE="$TRUE"
        j_msg "-${debug}" -p "${BYon}set${Boff} FILE: [$(TrueFalse "$FILE")], shifting 1"
        ;;

      -A|--associative    )  # ....................... # parallel-process iaw -j|--jobs
          export ASSOCIATIVE="$TRUE"
          j_msg "-${debug}" -p "${BYon}set${Boff} ASSOCIATIVE: [$(TrueFalse "$ASSOCIATIVE")], shifting 1"
          ;;

      -h|--help           ) my_usage; exit 1 ;;

      *                   )  # ...................... # fall-through (either arg or bad flag)
        case "${1:0:1}" in   # if - then this is an invalid flag
          "-") j_msg "-${err}" "${BRon}(error)${Boff}: invalid option flag [$1]"; my_usage; exit 1 ;;
          *  )  # hold to return unhandled arg to positional parameters
            args+=("$1")
            j_msg "-${debug}" -p "${BYon}appended${Boff} \$1 [$1] ${BYon}to args:${Boff} [${args[*]}], shifting 1"
            ;;
        esac
        ;;
    esac
    shift
  done
  j_msg "-${debug}" -p "remaining argument(s): [${args[*]}]"
  # early-exit guard - remainder should be one arg (valid target list)
  [ "${#args[@]}" -gt 1 ] && { j_msg "-${err}" "${BRon}error${Boff}: one target list arg allowed"; my_usage; exit 1 ; }
  set -- "${args[@]}"
  # early-exit guard - validate port
  if isint "$port"; then
    j_msg "-${debug}" -p "${BYon}(debug)${Boff}: validated port [$port]"
  else
    j_msg "-${err}" "${BRon}(error)${Boff}: non-integer port [$port]"
    my_usage; exit 1;
  fi
  # early-exit guard - validate job count (concurrency)
  if isint "$jobs"; then
    j_msg "-${debug}" -p "${BYon}(debug)${Boff}: validated jobs [$jobs]"
  else
    j_msg "-${err}" "${BRon}(error)${Boff}: non-integer jobs [$jobs]"
    my_usage; exit 1
  fi
  # early-exit guard - validate timing parameters (allow decimal - test after stripping .)
  if isint "$(printf '%s' "$waittime" | tr -d '.')"; then
    j_msg "-${debug}" -p "${BYon}(debug)${Boff}: validated waittime [$waittime]"
  else
    j_msg "-${err}" "${BRon}(error)${Boff}: invalid waittime [$waittime]"
    my_usage; exit 1
  fi
  if isint "$(printf '%s' "$timeout" | tr -d '.')"; then
    j_msg "-${debug}" -p "${BYon}(debug)${Boff}: validated timeout [$timeout]"
  else
    j_msg "-${err}" "${BRon}(error)${Boff}: invalid timeout [$timeout]"
    my_usage; exit 1
  fi

  # assign remaining arg|default as target_list
  target_list="${1:-"$default_target_list"}"

  validate_target_list || die "failed to validate_target_list"
  # return status code of assignment by default
}   # end of - parse_cmdline_and_validate_input

sanity_check() {
  j_msg "-${debug}" -p "in ${FUNCNAME[0]}"
  # return non-zero if something doesnt make sense
  if [ "$ASSOCIATIVE" ] && [ ${#a_targets[@]} -eq 0 ] ; then
    j_msg "-${err}" "${BRon}(error)${Boff} ASSOCIATIVE is [$(TrueFalse $ASSOCIATIVE)] but \${#a_targets[@]} = 0"
  fi
  
}

# Notes:
# Some tools require or benefit from the use of an external timeout (e.g. GNU timeout)
#   to manage (and prevent hangs in) their total execution
# (1) Mandatory for tools built for interactive use -
#   + /dev/tcp - without an outer timeout, a dropped packet will await system TCP timeout (60+ sec)
#   + ssh - has ConnectTimeout, but can hang in key exchange or banner grab
#     (if the port is open but the service is broken)
# (2) Recommended for tools where it provides a safety net vs hangs in kernel space if network state is wierd
#   + nc (netcat) - has -w but version dependent may only apply to connection
#   + socat - has -t/connect-timeout (channel handshake) and -T (inactivity),
#       (but socat just sits there if it connects but hangs on a protocol string)
# (3) NOT needed/redundant for tools that are built for scanning and have internal "hard" timeouts
#   + nmap: use --host-timeout - reliable and handles the entire lifecycle of the probe
#   + fping: use -t (per-target timeout). It’s designed for high-speed parallel work and won't hang
#   + ping/arping: use -W (wait) and -c (count) - designed to exit after packet exchange/wait time
# command   | GNU timeout n       | tool connection timeout   |
# tool      | (jping $timeout -t) | (jping W="$waittime" -W)  | Logic/Notes
# ----------|---------------------|---------------------------|----------------------------------
# /dev/tcp  | timeout "$timeout"  | (N/A)                     | No internal timeout; needs GNU t
# ssh       | timeout "$timeout"  | -o ConnectTimeout=${W}    | Protects vs protocol/banner hang
# socat     | timeout "$timeout"  | connect-timeout=${W}      | Protects vs protocol/banner hang
# nc        | timeout "$timeout"  | -w ${W}                   | Version-proofs the exit status
# nmap      | Redundant           | --host-timeout ${W}       | Internal timer covers lifecycle
# fping     | Redundant           | -t ${W_ms}                | Native parallel; very reliable
# ping      | Redundant           | -W ${W}                   | Exits after count/wait reached
# arping    | Redundant           | -W ${W}                   | Layer 2; exits after response


#-----[ native-parallel tools ]-----------------------------------------------------
_do_fping() {
#                 ### to to - love the -nA gets both name and address, but make it an option ###
#                       default to using whichever is provided in the targets array
#
    j_msg "-${debug}" -p "in ${FUNCNAME[0]} with arg(s) [$*]"
  # fping -h | grep  '\-[artqc],'
  #  -c, --count=N      count mode: send N pings to each target and report stats
  #  -r, --retry=N      number of retries (default: 3)
  #  -t, --timeout=MSEC individual target initial timeout (default: 500 ms,
  #  -i, --interval=MSEC  interval between sending ping packets (default: 10 ms)
  #  -q, --quiet        quiet (don't show per-target/per-ping results)
  #  -a, --alive        show targets that are alive
  #  -u, --unreach      show targets that are unreachable
  # timeout notes:
  # fping - GNU timeout would be redundant, use -t ${W_ms} | Native parallel; very reliable
  # Notes:
  #  - prints “is alive” or “is unreachable” when *neither* -a nor -u is specified.
  #  - -c causes generation of two blocks of output results and summare statistics
  #  - fping uses -t (ms), so we convert 0.5 to 500 (just do integer math)
  local _fp_opts=("-A")          # always show targets by address
  local _int=${waittime%%.*}   # strip longest match for '.*' from right - leaving int part
  local _frac=${waittime#*.}   # strip shortest match for '*.' from left - leaving frac part
  local _interval=1   # miliseconds scheduled between probes
  local _retries=0    # # of times to try each probe
  if ! isint "$_int" && isint "$_frac"; then
    j_msg "-${err}" "${BRon}(error)${Boff} bad waittime [$waittime = $_wait_ms ms] fping requires integer milliseconds"
  fi
  j_msg "-${debug}" -p "${BYon}(debug)${Boff} _int: [$_int] _frac: [$_frac]"
  local _wait_ms=$(( ( _int * 1000 ) + ( _frac * 100 ) ))
  local ups=0 downs=0 _out=""
  # handle user-directed RESOLVE choice
  if [ "$RESOLVE" ] ; then _fp_opts+=("-n"); fi
  # append timing options to _fp_opts
  _fp_opts+=("-r" "$_retries" "-i" "$_interval" "-t" "$_wait_ms")
  j_msg "-${debug}" -p "${BYon}(debug)${Boff} _fp_opts: [${_fp_opts[@]}]"
  j_msg "-${info}" -m "${BWon}(info)${Boff} command: fping ${_fp_opts[@]} \${targets[@]}"

  # for associateive array ${!var[@]} lists all keys (i.e. ips in this case)
  [ "$ASSOCIATIVE" ] && targets=("${!a_targets[@]}")
  if [ "$PARALLEL" ]; then
    # native parallelism: pass the whole array at once,
    # but colorize output using parameter expansion/substitution
    while IFS= read -r line; do
      case "$line" in
        *Up*|*alive*)
          (( ups++ ))
          line="${Con}${line/(/${BBon}(${BMon}}"
          line="${line/)/${BBon})${Boff}}"
          line="${line/alive/${BGon}Up${Boff}}"
          ;;
        *[uU]nreachable*)
          (( downs++ ))
          line="${Con}${line/(/${BBon}(${BMon}}"
          line="${line/)/${BBon})${Boff}}"
          line="${line/unreachable/${BRon}Unreachable${Boff}}"
          ;;
      esac;
      # buffer the output and print it (faster) after the subshell
      _out+="${line}"$'\n'  # note: append literal newline
    done < <( fping "${_fp_opts[@]}" "${targets[@]}" )
    # now print the buffered output | sort to put down last and the rest in alpha order by name
    printf '%b\n' "$_out" | sort -k4,4r -k1,1
  else # serialize
    j_msg "-${warn}" -p "${command} is natively optimized for parallel; serializing it will be significantly slower"
    for target in "${targets[@]}"; do
#      j_msg "-${notice}" -p -n "${BMon}${target}${Boff} is "
      # run same command as parallel but sed to colorize and strip alive/unreachable and newline
      # to follow w handle_result
      fping "${_fp_opts[@]}" "$target" 2>/dev/null | \
        sed 's| alive||' | \
        sed 's| unreachable||' | \
        tr -d '\n' | \
        sed "s|^|${Con}|" | \
        sed "s|(|${BBon}(${BMon}|" | \
        sed "s|)|${BBon})${Boff}|"
      if handle_result $? "Up" "Down" "${notice}"; then
        (( ups++ ));
      else
        (( downs++ ));
      fi
    done
  fi
  # summarize results
  msg="complete. ${BBon}[${BMon}$ups${BBon}] ${BGon}up${Boff} |"
  msg+=" ${BBon}[${BMon}$downs${BBon}] ${BRon}down${Boff}"
  j_msg "-${notice}" -M "$idx_face_beam" "$msg"
}

_do_nmap() {
  #                 ### to to - love the fast default but also want option for name and address ###
  #                       default to using whichever is provided in the targets array
  # nmap options:
  #  --host-timeout <ms>   abort host scan after this time
  #  --max-retries 0       don't retry unresponsive probes
  #  -p <port>             port selection
  #  -n/-R                 Never/Always do DNS resolution [default: sometimes]
  #  -6                    IPv6 mode (auto-detected)
  #  -Pn                   skip host discovery (treat all as online)
  #  -T4                   faster timing template
  #  -oG -                 grepable output to stdout (-) instead of file
  # Note: -Tn sets rtt, scan-delay, retries - so dont set those (-T4 is optimized for LAN scanning)
  #  * -PO[protocol list]  IP Protocol Ping
  #  * -sO                 IP protocol scan
  #  (*) - possible future integration
  # timeout notes:
  # nmap - GNU timeout would be redundant; use --host-timeout ${_wait_ms}ms | Internal timer covers lifecycle
  #
  j_msg "-${debug}" -p "in ${FUNCNAME[0]} with arg(s) [$*]"
  local _int=${waittime%%.*}
  local _frac=${waittime#*.}
  local _wait_ms=$(( (_int * 1000) + (_frac * 100) ))
  local _port="${port:-22}"   # default port should already be done in validate_input
  local ups=0 downs=0 _filtered=0
  local _out="" _raw_out="" _family=""
  local current_host="" current_status="" current_port_state=""
  local -a targets_4 targets_6 host_names
  local -a _nm_opts=("--max-retries" "0")
  local _count=0  # concurrency control variable for manually paralleled processes

  # handle user-directed RESOLVE choice
  if [ "$RESOLVE" ] ; then _nm_opts+=("-R"); else _nm_opts+=("-n"); fi
  # for associateive array ${!var[@]} lists all keys (i.e. ips in this case)
  [ "$ASSOCIATIVE" ] && targets=("${!a_targets[@]}")

  # start constructing _nm_opts array with "static" values
  _nm_opts+=("-Pn" "-T4")
  # append dynamically constructed timeout, port, greppable output flags to array
  # (flag and value as separate array elements so they parse properly)
  _nm_opts+=("--host-timeout" "${_wait_ms}ms" "-p" "$_port" "-oG" "-")
  j_msg "-${debug}" -p "${BYon}(debug)${Boff} _nm_opts: [${_nm_opts[*]}]"
  j_msg "-${info}" -m "${BWon}(info)${Boff} ipv4 native parallel command: nmap ${_nm_opts[@]} \${targets_4[@]}"
  j_msg "-${info}" -m "${BWon}(info)${Boff} ipv6 manual parallel command: timeout --signal=INT 2 nmap ${_nm_opts[@]} -6 \$target"

  # FUTURE HOOK: add multi-port scanning here
  # _nm_opts+=("-P0[$_proto_list]") or maybe _nm_opts+=("-sO")
  #

  # for parallel, call the function above for each of the now-split target sets
  #   -in order to maintain paralellism, run both in the background, and the only
  #    safe way to do that is to run each in its own subshell
  #   -to facilitate output parsing and buffering, have each subshell write
  #    to a mktemp file in /dev/shm (faster than /tmp), if it is available
  #   _to make a summary count of ups, downs, _filtered, don't have the
  #    subshells to the math (i.e. don't put the math in the helpver function;
  #    instead, have the parent (this function) do the math after concatenating
  #    the temp files for the output buffer
  if [ "$PARALLEL" ]; then
    # nmap only does one of ipv4 or ipv6 in its parallel mode, so split into target list for each family
    for target in "${targets[@]}"; do
      if [[ "$target" =~ : ]]; then targets_6+=("$target")
      elif [[ "$target" =~ ^[0-9.]+$ ]]; then targets_4+=("$target")
      else host_names+=("$target")
      fi
    done
    j_msg "-${notice}" -p "targetlist subdivided to optimize for nmap"
    j_msg "-${notice}" -m "ipv4 target addresses: [${#targets_4[@]}]"
    j_msg "-${debug}" -m  "ipv4 target addresses: [${targets_4[@]}]"
    j_msg "-${notice}" -m "ipv6 target addresses: [${#targets_6[@]}]"
    j_msg "-${debug}" -m  "ipv6 target addresses: [${targets_6[@]}]"
    j_msg "-${notice}" -m "target hostnames ....: [${#host_names[@]}]"
    j_msg "-${debug}" -m  "target hostnames ....: [${host_names[@]}]"

    if [ -d /dev/shm ] && [ -w /dev/shm ]; then
      tmp4=$(mktemp /dev/shm/jping_nmap4.XXXXXX)
      tmp6=$(mktemp /dev/shm/jping_nmap6.XXXXXX)
      tmp_h=$(mktemp /dev/shm/jping_nmap_h.XXXXXX)
    else
      tmp4=$(mktemp /tmp/jping_nmap4.XXXXXX)
      tmp6=$(mktemp /tmp/jping_nmap6.XXXXXX)
      tmp_h=$(mktemp /tmp/jping_nmap_h.XXXXXX)
    fi

    # use nmaps native parallel ability for ipv4, where it works well due to optimized parallel ipv4 rDNS spt
    ( nmap "${_nm_opts[@]}" "${targets_4[@]}" ) > "$tmp4" &
    # Caution: nmap does not have a native/optimized ipv6 reverse dns lookup like it does for ipv4
    #   and its timing/timeout parameters cannot control what it has to pass to the system dns resolver
    # So - DON"T use nmap in native-parallel mode for ipv6 -- I'll do it myself
    #( nmap "${_nm_opts[@]}" -6 "${targets_6[@]}" ) > "$tmp6" &
    for target in "${targets_6[@]}"; do
      # wrap nmap with GNU timeout, append to file, and push to background
      # (SIGTERM default will wipe out nmap's buffer, so use --signal==INT instead, to dump what it has found before dying)
      timeout --signal=INT 2 nmap "${_nm_opts[@]}" -6 "$target" >> "$tmp6" &
      # Dynamically throttled by validated global $jobs
      # (this goes mmediately after backgrounding (&) and outside the closing ')'
      #  for intermediate subshell above so the _count variable will
      #  be available in the current shell's scope), and before the done keyword)
      #  (wait -n waits for a job vs all jobs to finish)
      if (( ++_count % "$jobs" == 0 )); then wait -n; fi
    done;  wait  # crucial to wait for all backgrounded jobs to finish
    # Similary with hostnames - which may fail to resolve, may resolve to ipv6 addresses, etc.
    for target in "${host_names[@]}"; do
      # wrap nmap with GNU timeout, append to file, and push to background
      # (SIGTERM default will wipe out nmap's buffer, so use --signal==INT instead, to dump what it has found before dying)
      timeout --signal=INT 2 nmap "${_nm_opts[@]}" "$target" >> "$tmp_h" &
      # Dynamically throttled by validated global $jobs
      # (this goes mmediately after backgrounding (&) and outside the closing ')'
      #  for intermediate subshell above so the _count variable will
      #  be available in the current shell's scope), and before the done keyword)
      #  (wait -n waits for a job vs all jobs to finish)
      if (( ++_count % "$jobs" == 0 )); then wait -n; fi
    done;  wait  # crucial to wait for all backgrounded jobs to finish

    _raw_out="$(cat "$tmp4" "$tmp6" "$tmp_h")"

    # _finalize_host helper for while loop below
    _finalize_host() {
      # adjust for hosts that have status line but no ports line or vice versa
      if [ -n "$current_status" ] && [ -z "$current_port_state" ]; then
          current_port_state="closed"
      fi
      if [ -z "$current_status" ] && [ -n "$current_port_state" ]; then
          current_status="Down"
      fi
      # colorize custom status output
      case "$current_status" in
          Up)   status_color="${BGon}Up${Boff}" ;;
          Down) status_color="${BRon}Down${Boff}" ;;
          *)    status_color="${BYon}Unk${Boff}" ;;
      esac
      # colorize custom sport state  output
      case "$current_port_state" in
          open)      port_color="${BGon}open${Boff}" ;;
          closed)    port_color="${BRon}closed${Boff}" ;;
          filtered)  port_color="${BYon}filtered${Boff}" ;;
          *)         port_color="${BYon}?${Boff}" ;;
      esac
      # increment counters
      if [ "$current_status" = "Up" ]; then
          (( ups++ ))
      else
          (( downs++ ))
      fi
      if [ "$current_port_state" = "filtered" ]; then (( _filtered++ )); fi

      # finalize previous host - build one-line colorized output (acommodating hostname) from aggregated data
      current_host="${BMon}${current_host// / ${BBon}}"
      current_host="${current_host//\(/\(${Boff}${Con}}"
      current_host="${current_host//\)/${BBon}\)${Boff}}"
      host_line="${BMon}${current_host}${Boff} (${status_color})  port ${_port}: ${port_color}"
      # append to output buffer for fast printf later
      _out+="${host_line}"$'\n'
    }   # end of _finalize_host function

    # iterate through lines of output buffer and count stats by
    # examining the Status and Ports lines for each target
    # initialize the variables in which we aggregate data
    # for the host here, before the loop, but do not reset
    # current_host="" inside the loop - instead, REASSIGN it and
    # reset current_status="" and current_port_state="" when the
    # host is known to have changed
    current_host=""
    current_status=""
    current_port_state=""

    while IFS= read -r line; do
      # example grepable output lines formats (nmap -n; ! $RESOLVE)
      #   Host: 192.168.62.155 () Status: Up
      #   Host: 192.168.62.155 () Ports: 22/open/tcp//ssh///
      # example grepable output lines formats (nmap -R; $RESOLVE)
      #   Host: 192.168.62.155 (g3nuc01.brendler) Status: Up
      #   Host: 192.168.62.155 (g3nuc01.brendler) Ports: 22/open/tcp//ssh///

      [[ "$line" == \# ]] && continue  # ignore comment lines
      [[ -z "$line" ]] && continue     # ignore blank lines

      # count stats and colorize indication in line
      case "$line" in
        Host:\ *Status:\ *)
            # to get here with an empty current_host will only happen at the beginning of the file
            # afterward, this signals transition from the host we can now finish to a new one, do that below
            if [ -n "$current_host" ]; then
                # determine Up/Down based on status + port (variables read in previous "turns"
                local host_line=""
                local status_color=""
                local port_color=""

                # use helper function to finalize the previous host
                _finalize_host

                current_host=""
                current_status=""
                current_port_state=""

            fi  # -n "$current_host"

            # now, start new host - if RESOLVE, include hostname
            if [ "$RESOLVE" ] ; then
                current_host=$(printf '%s\n' "$line" | awk '{print $2 " " $3}')
            else
                current_host=$(printf '%s\n' "$line" | awk '{print $2}')
            fi
            current_status=""; current_port_state=""  # clear these for the new host
            case "$line" in
                *Status:\ Up*)   current_status="Up" ;;
                *Status:\ Down*) current_status="Down" ;;
                *)               current_status="" ;;
            esac
            ;;

        Host:\ *Ports:\ *)
            case "$line" in
                # port status line format ends - "... Ports: 22/open/tcp//ssh///"
                *\/open\/*)      current_port_state="open" ;;
                *\/closed\/*)    current_port_state="closed" ;;
                *\/filtered\/*)  current_port_state="filtered" ;;
            esac
            ;;
      esac
    done <<< "$_raw_out"
    # use helper function to finalize the last host
    # - build one-line output from aggregated data (flush the "buffer")
    _finalize_host

    # print final the buffered output, sorted on port status, then up/down, then address
    printf '%s\n' "$_out" | LC_COLLATE=en_US.UTF-8 sort -k6,6r -k4,4 -k1,1

    rm -f "$tmp4"
    rm -f "$tmp6"
    rm -f "$tmp_h"
  else  # else searialize the jobs
    j_msg "-${warn}" -p "${command} is natively optimized for parallel; serializing it will be slower"
    j_msg "-${debug}" -p "${BYon}(debug)${Boff} _nm_opts: [${_nm_opts[*]}]"
    for target in "${targets[@]}"; do
      # prepaare to pass _family to nmap as an option flag "-4" or "-6"
      _family=""  # reinitialize each iteration
      [[ "$target" == *:* ]] && _family="-6"
      local _result _addr _hostname
      _result=$(nmap "${_nm_opts[@]}" "$_family" "$target" 2>/dev/null)
      # use tail to get the last status line from nmap's greppable output
      # (since with -Pn nmap always first prints a Status: Up line (as -Pn said to assume))
      _addr=$(printf '%s' "$_result" | grep Status | tail -n 1 | awk '{print $2}')
      j_msg "-${notice}" -p -n "${BMon}${_addr}"
      if [ "$RESOLVE" ] ; then
        if [ "$ASSOCIATIVE" ]; then
          _hostname="${a_targets[$target]}"
        else
          _hostname=$(printf '%s' "$_result" | grep Status | tail -n 1 | awk '{print $3}')
        fi
        j_msg "-${notice}" -mp -n " ${BBon}(${Boff}${Con}${_hostname}${BBon})${Boff} is"
      else
        j_msg "-${notice}" -mp -n "${Boff} is"
      fi

      if grep -q "Status: Up" <<< "$_result"; then
        (( ups++ ))
        j_msg "-${notice}" -mp -n " (${BGon}Up${Boff})"
      else
        (( downs++ ))
        j_msg "-${notice}" -mp -n " (${BRon}Down${Boff})"
      fi

      if grep -q "/open/" <<< "$_result"; then
        j_msg "-${notice}" -mp " port ${_port}: ${BGon}open${Boff}"
      elif grep -q "/filtered/" <<< "$_result"; then
        (( _filtered++ ))
        j_msg "-${notice}" -mp " port ${_port}: ${BYon}filtered${Boff}"
      else
        j_msg "-${notice}" -mp " port ${_port}: ${BRon}closed${Boff}"
      fi
    done
  fi

  msg="complete. ${BBon}[${BMon}$ups${BBon}] ${BGon}up${Boff} |"
  msg+=" ${BBon}[${BMon}$downs${BBon}] ${BRon}down${Boff} |"
  msg+=" ${BBon}[${BMon}$_filtered${BBon}] ${BYon}filtered${Boff}"
  j_msg "-${notice}" -p -M "$idx_face_beam" "$msg"

}

#-----[ manual parallel tools ]-----------------------------------------------------

_jping_parallel_core() {
    # common core manual parallelization engine - take T/F command function name as input and
    #   run it in parallel for all targets in the target-appropriate manner
    #   depending on user choices for dns resolution (RESOLVE), use of
    #   associative arrays to obviate lookups (ASSOCIATIVE) - or to just
    #   go fast without lookups if not RESOLVE
    # Provide common standard colorized and sorted output format
    local target    # one memger of the original targets array passed to calling function
    local _hostname # hostname looked up (or provided as target) as appropriate if RESOLVE
    local _tgt_v    # _target vecotr derived from _hostname if original target is a hostname
    local _target   # one _target of _tgt_v new target vector
    local _count=0  # concurrency control variable for manually paralleled processes
    local _status   # up/down
    local line      # one line of raw output of parallelized jobs
    local cleanline # ansi-stripped line to facilitat safer status counting
    local _jp_command # name of tool-specific syntaxed command to call with each target

    # receive the name of the function for core connectivity check
    local _jp_command="$1"

    j_msg "-${debug}" -p "running ${FUNCNAME[0]} with _jp_command: [${_jp_command}]"
    j_msg "-${debug}" -p "global targets array: [${targets[@]}]"

    # feed the grouped output (below) into a while loop in the current shell
    # in order to be able to scan the output and count total ups and downs
    # (cant be done in subshell because that variable is gone when subshell exits)
    while read -r line; do
      # print the colorozed line to stdout (and/or log)
      line="${BMon}${line//\(/${BBon}\(${Boff}${Con}}"
      line="${line//\)/${BBon}\)${Boff}}"
      j_msg "-${notice}" -p "$line"
      # Strip ANSI colors before checking the status
      # (Color codes can interfere with "Up" matching)
      clean_line=$( printf '%s\n' "$line" | strip_ansi )
      case "$clean_line" in
        *is\ Up)   (( ups++ )) ;;
        *is\ Down) (( downs++ )) ;;
      esac
    done < <(  # substitute the process below (actual parallel scan) into the while loop above
    { for target in "${targets[@]}"; do (
        { if [ "$RESOLVE" ]; then
            if "$ASSOCIATIVE" ]; then  # already have hostname
              _hostname="${a_targets[$target]}"
              if "$_jp_command" "$target"; then   # execute RESOLVE and ASSOCIATIVE case
                _status="${BGon}Up${Boff}";
              else
                _status="${BRon}Down${Boff}"
              fi
              printf '%s\n' "${target} (${_hostname}) is $_status"
            else   # Not ASSOCIATIVE - look up hostname in the background
              # if this is a hostname rathern than address, look up the address(es) instead
              case "$target" in
                *[!0-9a-fA-F.:]*)  # target is a hostname (contains characters not allowed in ip address)
                    # j_msg  "-${debug}" -p "target [$target] is hostname"
                   _hostname=${target};
                   # use getent to look up all ip addresses for this _hostname
                   _tgt_v=$(getent ahosts "$target" | awk '{print $1}' | sort -u)
                   for _target in $_tgt_v; do
                     if "$_jp_command" "$_target" ; then  # execute RESOLVE but not ASSOCIATIVE for target hostname
                       _status="${BGon}Up${Boff}"
                     else
                       _status="${BRon}Down${Boff}"
                     fi
                     printf '%s\n' "${_hostname} (${_target}) is $_status"
                   done
                   ;;
                *)   # .......... # target is an ip address (non-ASSOCIATIVE case) - look up hostname with dig
                  _hostname=$(dig -x "$target" +short | sed 's|.$||')
                  if "$_jp_command" "$target"; then   # execute RESOLVE but not ASSOCIATIVE for target ip address
                    _status="${BGon}Up${Boff}"
                  else
                    _status="${BRon}Down${Boff}"
                  fi
                  printf '%s\n' "${target} (${_hostname}) is $_status"
                  ;;
              esac
            fi
          else # not RESOLVE
            if "$_jp_command" "$target" ; then   # execute non-RESOLVE case
              _status="${BGon}Up${Boff}"
            else
              _status="${BRon}Down${Boff}"
            fi
            printf '%s\n' "${target} () is $_status"
          fi
        } 2>/dev/null &
      )
      # Dynamically throttled by validated global $jobs
      # (this goes mmediately after backgrounding (&) and outside the closing ')'
      #  for intermediate subshell above so the _count variable will
      #  be available in the current shell's scope), and before the done keyword)
      # wait -n waits for a job vs all jobs to finish
      if (( ++_count % "$jobs" == 0 )); then wait -n; fi
      done; wait
      # filter empty lines and sort by status and then address
    } | sed "/^${W0}$/d" | sort -t' ' -k4,4r -k2,2
#    } | sed "/^${W0}$/d"  # unsorted for now
  )

}

_jping_serial_core() {
    # common core manual serialization engine - take T/F command function name as input and
    #   run it in serial sequence for all targets in the target-appropriate manner
    #   depending on user choices for dns resolution (RESOLVE), use of
    #   associative arrays to obviate lookups (ASSOCIATIVE) - or to just
    #   go fast without lookups if not RESOLVE
    # Provide common standard colorized and sorted output format
    local target    # one memger of the original targets array passed to calling function
    local _hostname # hostname looked up (or provided as target) as appropriate if RESOLVE
    local _tgt_v    # _target vecotr derived from _hostname if original target is a hostname
    local _target   # one _target of _tgt_v new target vector
    local _count=0  # concurrency control variable for manually paralleled processes
    local _status   # up/down
    local line      # one line of raw output of parallelized jobs
    local cleanline # ansi-stripped line to facilitat safer status counting
    local _js_command # name of tool-specific syntaxed command to call with each target

    # receive the name of the function for core connectivity check
    local _js_command="$1"

    j_msg "-${debug}" -p "running ${FUNCNAME[0]} with _js_command: [${_js_command}]"
    j_msg "-${debug}" -p "global targets array: [${targets[@]}]"

    for target in "${targets[@]}"; do
        if [ "$RESOLVE" ]; then
          if [ "$ASSOCIATIVE" ]; then  # already have hostname
            _hostname="${a_targets[$target]}"
            # use simpler format of j_msg to set up output line prior and handle_result to close after execution because
            #   serialized jobs will assemble output pieces properly - unlike parallel which require atomic writes
            j_msg "-${notice}" -p -n "${BMon}${target}${Boff} ${BBon}(${Boff}${Con}${_hostname}${BBon})${Boff} is"
            "$_js_command" "$target"   # execute RESOLVE and ASSOCIATIVE case
            if handle_result $? "Up" "Down" "${notice}"; then (( ups++ )); else (( downs++ )); fi
          else   # Not ASSOCIATIVE - look up hostname in the background
            # if this is a hostname rathern than address, look up the address(es) instead
            case "$target" in
              *[!0-9a-fA-F.:]*)
                 _hostname=${target};
                 _tgt_v=$(getent ahosts "$target" | awk '{print $1}' | sort -u)
                 for _target in $_tgt_v; do
                   j_msg "-${notice}" -p -n "${BMon}${_hostname}${Boff} ${BBon}(${Boff}${Con}${_target}${BBon})${Boff} is"
                   # j_msg "-${debug}" -p "_js_command: [$_js_command]  _target: [$_target]"
                   "$_js_command" "$_target"   # execute RESOLVE but not ASSOCIATIVE case with target hostname
                   if handle_result $? "Up" "Down" "${notice}"; then (( ups++ )); else (( downs++ )); fi
                 done
                 ;;
              *)   # ip address
                _hostname=$(dig -x "$target" +short | sed 's|.$||')
                j_msg "-${notice}" -p -n "${BMon}${target}${Boff} ${BBon}(${Boff}${Con}${_hostname}${BBon})${Boff} is"
                "$_js_command" "$target"   # execute RESOLVE but not ASSOCIATIVE case with target ip address
                if handle_result $? "Up" "Down" "${notice}"; then (( ups++ )); else (( downs++ )); fi
                ;;
            esac
          fi
        else   # not RESOLVE
          j_msg "-${notice}" -p -n "${BMon}${target}${Boff} ${BBon}(${Boff}${Con}${_hostname}${BBon})${Boff} is"
          "$_js_command" "$target"   # execute non-RESOLVE case
          if handle_result $? "Up" "Down" "${notice}"; then (( ups++ )); else (( downs++ )); fi
        fi
    done

}

_do_devtcp() {
  j_msg "-${debug}" -p "in ${FUNCNAME[0]} with arg(s) [$*]"
  # timeout notes:
  # /dev/tcp - use GNU timeout "$timeout" | No internal timeout; needs GNU t
  local ups=0 downs=0
  local _hostname _target _tgt_v
  local _count=0  # concurrency control variable for manually paralleled processes
  local -a _cmd  # properly constructed command line array, using this tool
  if [ -z "$timeout" ]; then
    if [ -n "$waittime" ]; then
      timeout="$waittime"
      j_msg "-${warn}" -p "substituted waittime [$waittime] for null timeout"
    else
      timeout=1
      j_msg "-${warn}" -p "assiigned timeout=1 because it and waittime were both empty"
    fi
  fi
  j_msg "-${info}" -m "${BWon}(info)${Boff} command: timeout $timeout bash -c \"</dev/tcp/\${target}/22\""

  # handle user-directed RESOLVE choice
#  if [ "$RESOLVE" ] ; then _nm_opts+=("-R"); else _nm_opts+=("-n"); fi
  # for associateive array ${!var[@]} lists all keys (i.e. ips in this case)
  [ "$ASSOCIATIVE" ] && targets=("${!a_targets[@]}")

  j_msg "-${debug}" -p "checking [${#targets[@]}] targets"

  # form the "unloaded" command as a function taking ${target} as its arg, to be evaluated at load/run time
  _devtpc_cmd() {
    # j_msg "-${debug}" -p "in ${FUNCNAME[0]} with arg(s) [$*]";
    local _target="$1";
    timeout "$timeout" "bash" "-c" "</dev/tcp/${_target}/22" &>/dev/null
  }

  if [ "$PARALLEL" ]; then
