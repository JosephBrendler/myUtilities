      clean_line=$( printf '%s\n' "$line" | strip_ansi )
      case "$clean_line" in
        *is\ Up)   (( ups++ )) ;;
        *is\ Down) (( downs++ )) ;;
      esac
    done < <(  # substitute the process below (actual parallel scan) into the while loop above
    { for target in "${targets[@]}"; do (
      case "$target" in *:*) fam="6";; *.*) fam="4";; *) die "bad target in ${FUNCNAME[0]}";; esac
      # -z: scan mode (zero-I/O), -v: verbose (sent to stderr), -w: waittime
        {  timeout "$timeout" nc "$nc_opts" "-${fam}" -w "$waittime" "$target" "$port" &>/dev/null && \
          printf '%s\n' "${Mon}${target}${Boff} is ${BGon}Up${Boff}" || \
          printf '%s\n' "${Mon}${target}${Boff} is ${BRon}Down${Boff}" ;
        } 2>/dev/null &
      )
      # Dynamically throttled by validated global $jobs
      # (this goes mmediately after backgrounding (&) and outside the closing ')'
      #  for intermediate subshell above so the _count variable will
      #  be available in the current shell's scope), and before the done keyword)
      if (( ++_count % "$jobs" == 0 )); then wait; fi
      done; wait;
    } | sed "/^${W0}$/d"
  )
  else # serialize
    for target in "${targets[@]}"; do
      j_msg "-${notice}" -p -n "${Mon}${target}${Boff} is "
      case "$target" in *:*) fam="6";; *.*) fam="4";; *) die "bad target in ${FUNCNAME[0]}";; esac
      timeout "$timeout" nc "$nc_opts" "-${fam}" -w "$waittime" -- "$target" "$port" &>/dev/null; result=$?
      handle_result $result "Up" "Down" "${notice}"
      if [ $? -eq 0 ]; then (( ups++ )); else (( downs++ )); fi
    done
  fi
  msg="complete. ${BBon}[${BMon}$ups${BBon}] ${BGon}up${Boff} |"
  msg+=" ${BBon}[${BMon}$downs${BBon}] ${BRon}down${Boff}"
  j_msg "-${notice}" -M "$idx_face_beam" "$msg"
}

