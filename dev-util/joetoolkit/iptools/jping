#-----[ main script ]----------------------------------------------
checknotroot  # principle of least privilege (root priv not required for this script)

separator "$(hostname)" "${PN}-${BUILD}"
j_msg "-${info}" -M "$idx_rocket" "Starting"

validate_input "$@" || die "failed to validate_input"

show_config

# this is too trivial to need a separate dispatcher function
#   simple handoff to the command-specific function
#   these functions have access to global ${targets[@]} and $PARALLEL
"_do_${command}"
wait  # allow parallel/backgrounded jobs to finish

j_msg "-${info}" -M "$idx_face_grin" "Starting"
