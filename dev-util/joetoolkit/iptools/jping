_do_devtcp() {
  j_msg "-${debug}" -p "in ${FUNCNAME[0]} with arg(s) [$*]"
  # timeout notes:
  # /dev/tcp - use GNU timeout "$timeout" | No internal timeout; needs GNU t
  local _hostname _target _tgt_v
  local -a _cmd  # properly constructed command line array, using this tool

  if [ -z "$timeout" ]; then
    if [ -n "$waittime" ]; then
      timeout="$waittime"
      j_msg "-${warn}" -p "substituted waittime [$waittime] for null timeout"
    else
      timeout=1
      j_msg "-${warn}" -p "assiigned timeout=1 because it and waittime were both empty"
    fi
  fi
  j_msg "-${notice}" -m "${BWon}(notice)${Boff} command: timeout $timeout bash -c \"</dev/tcp/\${target}/22\""

  # handle user-directed RESOLVE choice
#  if [ "$RESOLVE" ] ; then _nm_opts+=("-R"); else _nm_opts+=("-n"); fi
  # for associateive array ${!var[@]} lists all keys (i.e. ips in this case)
  [ "$ASSOCIATIVE" ] && targets=("${!a_targets[@]}")

  j_msg "-${debug}" -p "checking [${#targets[@]}] targets"

  # form the "unloaded" command as a function taking ${target} as its arg, to be evaluated at load/run time
  _devtcp_cmd() {
    # j_msg "-${debug}" -p "in ${FUNCNAME[0]} with arg(s) [$*]";
    local _target="$1";
    if timeout "$timeout" "bash" "-c" "</dev/tcp/${_target}/${port}" &>/dev/null ; then
      printf '%s\n' "${BGon}Up${Boff} - port ${port} is ${BGon}Open${Boff}"; return 0
    else
      printf '%s\n' "${BRon}Down${Boff} - port ${port} is ${BRon}Closed${Boff}" ; return 1
    fi

  }

  if [ "$PARALLEL" ]; then
    _jping_parallel_core "_devtcp_cmd"
  else # serialize
    _jping_serial_core "_devtcp_cmd"
  fi

  msg="complete. ${BBon}[${BMon}$ups${BBon}] ${BGon}up${Boff} |"
  msg+=" ${BBon}[${BMon}$downs${BBon}] ${BRon}down${Boff}"
  j_msg "-${notice}" -M "$idx_face_beam" "$msg"
  j_msg "-${warn}" -p "/dev/tcp checks only port state; host status is implied"
  j_msg "-${warn}" -p "False negatives are possible if timeout/wait times are too short"
  j_msg "-${warn}" -m "To be more certain, use this or another tool again, with a longer timeout and check more ports/services"

}

_do_netcat() {
  # nc -h 2>&1 | grep '\-[nvwzpu]'
  #  -n                      numeric-only IP addresses, no DNS
  #  -p port                 local port number
  #  -u                      UDP mode
  #  -v                      verbose [use twice to be more verbose]
  #  -w secs                 timeout for connects and final net reads
  #  -z                      zero-I/O mode [used for scanning]
  #
  j_msg "-${debug}" -p "in ${FUNCNAME[0]} with arg(s) [$*]"
  # timeout notes:
  # nc - recommended to use GNU timeout "$timeout" AND jping waittime (-w ${waittime})
  #      to fortify and version-proof the exit status
  local -a _nc_opts=("-zv")

  if [ -z "$timeout" ]; then
    if [ -n "$waittime" ]; then
      timeout="$waittime"
      j_msg "-${warn}" -p "substituted waittime [$waittime] for null timeout"
    else
      timeout=1
      j_msg "-${warn}" -p "assiigned timeout=1 because it and waittime were both empty"
    fi
  fi
  if ! isint "$waittime"; then
    # try to round a decimal up to integer value, but don't round 1 or 1.0 up to 2
    if [ "${waittime##*.}" -gt 0 ] && [[ "$waittime" == *"."* ]]; then
      _nc_wait=$(( ${waittime%.*} + 1 ))
    else
       _nc_wait="${waittime%.*}"
    fi
    j_msg "-${warn}" "${BYon}(warning)${Boff} nc -w must be integer, waittime [$waittime] rounded to [$_nc_wait]"
    waittime="$_nc_wait"
  fi
  _nc_opts+=("-w" "$waittime")

  # handle user-directed RESOLVE choice
  if [ ! "$RESOLVE" ] ; then _nc_opts+=("-n"); fi
  # for associateive array ${!var[@]} lists all keys (i.e. ips in this case)
  [ "$ASSOCIATIVE" ] && targets=("${!a_targets[@]}")

  j_msg "-${debug}" -p "_nc_opts: [${_nc_opts[@]}]"
  j_msg "-${notice}" -m "${BWon}(notice)${Boff} command: timeout $timeout nc ${_nc_opts[@]} \${fam} \$target $port"


  # form the "unloaded" command as a function taking ${target} as its arg, to be evaluated at load/run time
  _netcat_cmd() {
    # j_msg "-${debug}" -p "in ${FUNCNAME[0]} with arg(s) [$*]";
    local _target="$1" fam=""
    case "$_target" in
      *[!0-9a-fA-F.:]* ) : ;; # possible hostname - continue
      *:*              ) fam="-6";;
      *.*              ) fam="-4";;
    esac
    # to capture output from stderr, recirect it to stdout
    _out=$(timeout "$timeout" nc "${fam}" "${_nc_opts[@]}" "$_target" "$port" 2>&1)

    # determine richness based on the global mode variable
    case "${mode:0:1}" in
      F )
        if printf '%s\n' "$_out" | grep -qE "open"; then
          printf '%s\n' "${BGon}Up${Boff}"
          return 0
        else
          printf '%s\n' "${BRon}Down${Boff}"
          return 1
        fi
        ;;
      E )
        # Return rich states
        if printf '%s\n' "$_out" | grep -qE "open"; then
          printf '%s and port %s is %s\n' "${BGon}Up${Boff}" "${BMon}${port}${Boff}" "${BGon}Open${Boff}"
          return 0
        elif printf '%s\n' "$_out" | grep -qE "refused"; then
          printf '%s but port %s is %s\n' "${BGon}Up${Boff}" "${BMon}${port}${Boff}" "${BYon}Filtered${Boff}"
          return 0
        else
          printf '%s and port %s is %s\n' "${BRon}Down${Boff}" "${BMon}${port}${Boff}" "${BRon}Closed${Boff}"
          return 1
        fi
        ;;
      * ) j_msg "-${err}" -m "${BRon}(error)${Boff} invalid mode in ${FUNCNAME[0]}"; my_usage; exit 1 ;;
    esac
  }

  if [ "$PARALLEL" ]; then
    _jping_parallel_core "_netcat_cmd"
  else # serialize
    _jping_serial_core "_netcat_cmd"
  fi

  case "${mode:0:1}" in
    F )
      msg="complete. ${BBon}[${BMon}$ups${BBon}] ${BGon}up${Boff} |"
      msg+=" ${BBon}[${BMon}$downs${BBon}] ${BRon}down${Boff}"
      j_msg "-${notice}" -M "$idx_face_beam" "$msg"
      ;;
    E )
      msg="complete."
      msg+=" ${BBon}[${BMon}$ups${BBon}] ${BGon}up${Boff} |"
      msg+=" ${BBon}[${BMon}$downs${BBon}] ${BRon}down${Boff} |"
      msg+=" ${BBon}[${BMon}$opened${BBon}] ${BGon}opened${Boff} |"
      msg+=" ${BBon}[${BMon}$closed${BBon}] ${BRon}closed${Boff} |"
      msg+=" ${BBon}[${BMon}$filtered${BBon}] ${BYon}filtered${Boff} |"
      msg+=" ${BBon}[${BMon}$unverified${BBon}] ${BOon}unverified${Boff} |"
      msg+=" ${BBon}[${BMon}$timeouts${BBon}] ${BRon}timeouts${Boff}"
      j_msg "-${notice}" -M "$idx_face_beam" "$msg"
      j_msg "-${warn}" -p "Timedout count can include false negatives due to short waits or firewalled ports"
      j_msg "-${warn}" -m "To be more certain, use this or another tool again, with a longer timeout and check more ports/services"
      ;;
      * ) j_msg "-${err}" -m "${BRon}(error)${Boff} invalid mode in ${FUNCNAME[0]}"; my_usage; exit 1 ;;
  esac
}

