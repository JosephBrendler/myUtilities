_do_nmap() {
  #                 ### to to - love the fast default but also want option for name and address ###
  #                       default to using whichever is provided in the targets array
  # nmap options:
  #  --host-timeout <ms>   abort host scan after this time
  #  --max-retries 0       don't retry unresponsive probes
  #  -p <port>             port selection
  #  -n/-R                 Never/Always do DNS resolution [default: sometimes]
  #  -6                    IPv6 mode (auto-detected)
  #  -Pn                   skip host discovery (treat all as online)
  #  -T4                   faster timing template
  #  -oG -                 grepable output to stdout (-) instead of file
  # Note: -Tn sets rtt, scan-delay, retries - so dont set those (-T4 is optimized for LAN scanning)
  #  * -PO[protocol list]  IP Protocol Ping
  #  * -sO                 IP protocol scan
  #  (*) - possible future integration
  # timeout notes:
  # nmap - GNU timeout would be redundant; use --host-timeout ${_wait_ms}ms | Internal timer covers lifecycle
  #
  j_msg "-${debug}" -p "in ${FUNCNAME[0]} with arg(s) [$*]"
  local _int=${waittime%%.*}
  local _frac=${waittime#*.}
  local _wait_ms=$(( (_int * 1000) + (_frac * 100) ))
  local _port="${port:-22}"   # default port should already be done in validate_input
  local _out=""
  local -a targets_4 targets_6 host_names
  local -a _nm_opts=("--max-retries" "0")

  # handle user-directed RESOLVE choice
  if [ "$RESOLVE" ] ; then _nm_opts+=("-R"); else _nm_opts+=("-n"); fi
  # for associateive array ${!var[@]} lists all keys (i.e. ips in this case)
  [ "$ASSOCIATIVE" ] && targets=("${!a_targets[@]}")

  # start constructing _nm_opts array with "static" values
  _nm_opts+=("-Pn" "-T4")
  # append dynamically constructed timeout, port, greppable output flags to array
  # (flag and value as separate array elements so they parse properly)
  _nm_opts+=("--host-timeout" "${_wait_ms}ms" "-p" "$_port" "-oG" "-")
  j_msg "-${debug}" -p "${BYon}(debug)${Boff} _nm_opts: [${_nm_opts[*]}]"
  j_msg "-${notice}" -m "${BWon}(notice)${Boff} ipv4 native parallel command: nmap ${_nm_opts[@]} \${targets_4[@]}"
  j_msg "-${notice}" -m "${BWon}(notice)${Boff} ipv6 manual parallel command: timeout --signal=INT 2 nmap ${_nm_opts[@]} -6 \$target"
  j_msg "-${debug}" -p "${BYon}(debug)${Boff} mode: [$mode]"

  # FUTURE HOOK: add multi-port scanning here
  # _nm_opts+=("-P0[$_proto_list]") or maybe _nm_opts+=("-sO")
  #

  # form the "unloaded" command as a function taking ${target} as its arg, to be evaluated at load/run time
  _nmap_cmd() {
    local _target="$1"
    local _out
    local fam=""

    case "$_target" in *:* ) fam=("-6") ;; esac

    _out=$(timeout "$timeout" nmap "$fam" "${_nm_opts[@]}" "$_target" 2>&1)

    # determine provide output format (FAST or ENRICHED) based on the global mode variable --
    # _core functions compose the preliminary message <target> (<hostname/address>) is " <-- ending space is space
    # _core functions then append the output of this _<tool>_cmd function with content as follows
    # FAST: <color><Up/Down><collor_off>
    # ENRICHED: <color><Up/Down><collor_off> <and/but> port <color><port><color_off> is <color><port_state><color_off>
    case "${mode:0:1}" in
      F )
        if printf '%s\n' "$_out" | grep -qE "open"; then
          printf '%s\n' "${BGon}Up${Boff}"
          return 0
        else
          printf '%s\n' "${BRon}Down${Boff}"
          return 1
        fi
        ;;
      E )
        # Return rich states
        if printf '%s\n' "$_out" | grep -qE "open"; then
          printf '%s and port %s is %s\n' "${BGon}Up${Boff}" "${BMon}${port}${Boff}" "${BGon}Open${Boff}"
          return 0
        elif printf '%s\n' "$_out" | grep -qE "filtered"; then
          printf '%s but port %s is %s\n' "${BGon}Up${Boff}" "${BMon}${port}${Boff}" "${BYon}Timedout${Boff}"
          return 0
        elif printf '%s\n' "$_out" | grep -qE "closed"; then
          # nmap got an explicit TCP RST, host is up but port is closed
          printf '%s but port %s is %s\n' "${BGon}Up${Boff}" "${BMon}${port}${Boff}" "${BRon}Closed${Boff}"
          return 0
        else
          printf '%s and port %s is %s\n' "${BRon}Down${Boff}" "${BMon}${port}${Boff}" "${BRon}Timedout${Boff}"
          return 1
        fi
        ;;
      * ) j_msg "-${err}" -m "${BRon}(error)${Boff} invalid mode in ${FUNCNAME[0]}"; my_usage; exit 1 ;;
    esac
  }

  if [ "$PARALLEL" ]; then
    _jping_parallel_core "_nmap_cmd"
  else # serialize
    _jping_serial_core "_nmap_cmd"
  fi

  case "${mode:0:1}" in
    F )
      msg="complete. ${BBon}[${BMon}$ups${BBon}] ${BGon}up${Boff} |"
      msg+=" ${BBon}[${BMon}$downs${BBon}] ${BRon}down${Boff}"
      j_msg "-${notice}" -M "$idx_face_beam" "$msg"
      ;;
    E )
      msg="${BWon}complete${Boff}"
      j_msg "-${notice}" -M "$idx_face_beam" "$msg"
      msg=" ${BBon}[${BMon}$ups${BBon}] ${BGon}up${Boff} |"
      msg+=" ${BBon}[${BMon}$downs${BBon}] ${BRon}down${Boff} |"
      msg+=" ${BBon}[${BMon}$opened${BBon}] ${BGon}opened${Boff} |"
      msg+=" ${BBon}[${BMon}$closed${BBon}] ${BRon}closed${Boff} |"
      msg+=" ${BBon}[${BMon}$filtered${BBon}] ${BYon}filtered${Boff} |"
      msg+=" ${BBon}[${BMon}$unverified${BBon}] ${BOon}unverified${Boff} |"
      msg+=" ${BBon}[${BMon}$timeouts${BBon}] ${BRon}timeouts${Boff}"
      j_msg "-${notice}" -M "$idx_face_beam" "$msg"
      j_msg "-${warn}" -p "Timedout count can include false negatives due to short waits or firewalled ports"
      j_msg "-${warn}" -m "To be more certain, use this or another tool again, with a longer timeout and check more ports/services"
      ;;
    * ) j_msg "-${err}" -m "${BRon}(error)${Boff} invalid mode in ${FUNCNAME[0]}"; my_usage; exit 1 ;;
  esac

}

