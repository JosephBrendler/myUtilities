  j_msg "-${notice}" -m "$msg"
  msg="${BMon}  -n|--noresolve${Boff}${Con} .......: never resolve (and display) hostnames for addresses${Boff}"
  j_msg "-${notice}" -m "$msg"
  msg="${BMon}  -R|--resolve${Boff}${Con} .........: always resolve (and display) hostnames for addresses (${Won}default${Con})${Boff}"
  j_msg "-${notice}" -m "$msg"
  msg="${BMon}  -f|--file${Boff}${Con} ............: indicates target_list is /path/to/target_list file${Boff}"
  j_msg "-${notice}" -m "$msg"
  msg="${BMon}  -A|--associative${Boff}${Con} .....: from file, form an associve array of ip addrs keyed on hostnames${Boff}"
  j_msg "-${notice}" -m "$msg"
  msg="${BMon}  -v|--louder${Boff}${Con} ..........: Increase verbosity (may repeat)${Boff}"
  j_msg "-${notice}" -m "$msg"
  msg="${BMon}  -q|--quieter${Boff}${Con} .........: Fecrease verbosity (may repeat)${Boff}"
  j_msg "-${notice}" -m "$msg"
  msg="${BMon}  -Q|--quiet${Boff}${Con} ...........: Silence most output (script_header_joetoo quiet mode)${Boff}"
  j_msg "-${notice}" -m "$msg"
  msg="${BMon}  -D|--debug${Boff}${Con} ...........: Enable debug output${Boff}"
  j_msg "-${notice}" -m "$msg"
