    done
  fi

  msg="complete. ${BBon}[${BMon}$ups${BBon}] ${BGon}up${Boff} |"
  msg+=" ${BBon}[${BMon}$downs${BBon}] ${BRon}down${Boff}"
  j_msg "-${notice}" -M "$idx_face_beam" "$msg"
}

_do_socat() {
  # socat is a powerful "data plumber" -- its primary purpose is to weld two pipes together
  #   and keep the water flowing until one side breaks or the pipe runs dry
  # using it for a port check is like "driving the Winnebago around the corner to see"
  #   "if the store is open" - but it works well
  # method: use /dev/null for one pipe and host:port for the other, with a timeout
  #   and read the exit status (works b/c /dev/null provides an immediate EOF when read)
  # note: host spec is different for ipv4/6 - 6 requres [${_target}] (square brackets)
  #
  # timeout notes:
  # socat - recommended to use GNU timeout "$timeout" and connect-timeout=${waittime}
  #   to protect vs protocol/banner hang
  #
  j_msg "-${debug}" -p "in ${FUNCNAME[0]}"
  local _open=0 _closed=0 _msg=""
  local _count=0  # concurrency control variable for manually paralleled processes
  # guard against empty timeout (should be defaulted)
  if [ -z "$timeout" ]; then
    if [ -n "$waittime" ]; then
      timeout="$waittime"
      j_msg "-${warn}" -p "substituted waittime [$waittime] for null timeout"
    else
      timeout=1
      j_msg "-${warn}" -p "assiigned timeout=1 because it and waittime were both empty"
    fi
  fi
  _msg="command:  timeout $timeout socat GOPEN:/dev/null"
  _msg+=" TCP:\"\${target}\":${port},connect-timeout=${waittime} 2>/dev/null"
  j_msg "-${info}" -m "$_msg"

  if [ "$PARALLEL" ]; then
    # use process substitution rather than a pipe to feed the grouped output (below)
    #  into a while loop in the current shell
    # in order to be able to scan the output and count total ups and downs
    # (cant be done in subshell because that variable is gone when subshell exits)
    while read -r line; do
      [ -z "$line" ] && continue   # ignore blank lines
      # print the line to stdout (and/or log)
      j_msg "-${notice}" -p "$line"
      # Strip ANSI colors before checking the status
      # (Color codes can interfere with matching)
      clean_line=$( printf '%s\n' "$line" | strip_ansi )
      case "$clean_line" in
        *is\ Open)   (( _open++ ));  ;;
        *is\ Closed) (( _closed++ )) ;;
      esac
    done < <(  # substitute the process below (actual parallel scan) into the while loop ab>
      {  for target in "${targets[@]}"; do
        (
          # Handle the bracket logic inside the subshell
          case "$target" in *:*) target="[$target]"; esac
          timeout "$timeout" socat GOPEN:/dev/null TCP:"${target}":"${port}",connect-timeout="${waittime}" 2>/dev/null
          res=$?
          # generate formatted output
          local _status_msg="${Con}$target${Boff} port ${Mon}$port${Boff} is "
          case "$res" in
            0) _status_msg+="${BGon}Open${Boff}";;
            *) _status_msg+="${BRon}Closed${Boff}";;
          esac
          printf '%s\n' "$_status_msg"
          # Note: cant count them with if block here; subshell vars not avail to parent
        ) &
        # Dynamically throttled by validated global $jobs
        # (this goes mmediately after backgrounding (&) and outside the closing ')'
        #  for intermediate subshell above so the _count variable will
        #  be available in the current shell's scope), and before the done keyword)
        if (( ++_count % "$jobs" == 0 )); then wait; fi
        done
        wait
      }
    )
  else
    _open=0; _closed=0
    for target in "${targets[@]}"; do
      j_msg -p -n "${Con}$target${Boff} port ${Mon}$port${Boff} is";
      case "$target" in *:*) target="[${target}]";; esac;
      timeout "$timeout" socat GOPEN:/dev/null TCP:"${target}":"${port}",connect-timeout=0.4 2>/dev/null;
      if handle_result $? "Open" "Closed"; then (( _open++ )); else (( _closed++ )); fi;
    done
  fi
  _msg="${BGon}open${Boff}: [${BMon}$_open${Boff}]"
  _msg+=" ${BRon}closed${Boff}: [${BMon}$_closed${Boff}]"
  j_msg -p "$_msg"

}

#-----[ main script ]----------------------------------------------
checknotroot  # principle of least privilege (root priv not required for this script)

separator "$(hostname)" "${PN}-${BUILD}"
j_msg "-${info}" -M "$idx_rocket" "Starting"

parse_cmdline_and_validate_input "$@" || die "failed to parse_cmdline_and_validate_input"

if [ $INTERACTIVE ] ; then
  show_config
  confirm_continue_or_exit
fi

# handoff to the tool-specific function
# (these functions have access to global ${targets[@]}, $PARALLEL, $port, $waittime, $timeout, etc)
time "_do_${command}"
wait  # allow parallel/backgrounded jobs to finish (in case I forgot to have them do this internally)

j_msg "-${info}" -M "$idx_face_grin" "Complete"
