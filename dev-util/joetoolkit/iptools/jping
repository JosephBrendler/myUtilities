  j_msg "-${notice}" -m "$msg"
  msg="${BYon}Arguments --${Boff}"
  j_msg "-${notice}" -p "$msg"
  msg="${BCon}  <target_list>${Boff}${Con} .......: (optional) ${Won}default:${Con} ${default_target_list}${Boff}"
  j_msg "-${notice}" -m "$msg"
  msg="${BYon}Notes --${Boff}"
  j_msg "-${notice}" -p "$msg"
  msg="${BCon}  (1) $PN default is command: /dev/tcp port 22${Boff}"
