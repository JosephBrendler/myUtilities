#!/bin/bash
# wifi debug watch loop - tailor as needed

source /usr/sbin/script_header_joetoo

logFile=/var/log/x402_wifi_debug.log
LOGGING=$TRUE
validate_logfile

while true; do
  clear;
  separator "$(hostname)" "wifi_debug";
  output=$(
    date;
    iw dev wlan0 link;
    iw dev wlan0 station dump | egrep 'signal|tx retries|tx failed|beacon loss|inactive time|connected time|bitrate';
    echo;
    grep . /sys/module/rtw89*/parameters/* 2>/dev/null;
    dmesg | tl
  ) ;
  j_msg "-${notice}" -p "$output";
  sleep 30;
done
