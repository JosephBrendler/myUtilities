beacon_filter() {
    $grep_cmd -h '' "$logfile" \
    | grep -E "${ZONE_REGEX}.*ACCEPT" \
    | grep -E "DPT=(${SUSPECT_PORTS})" \
    | grep -vE "DST=(${GOOD_DNS_REGEX})" \
    | grep -vE 'DST=(127\.|10\.|192\.168\.|172\.(1[6-9]|2[0-9]|3[0-1])\.)' \
    | grep -vE 'DST=(fd|fc)[0-9a-fA-F]:' \
    | awk '{
        for(i=1;i<=NF;i++)
            if ($i ~ /^DST=/) {
                ip=substr($i,5)
                print ip
            }
    }'
}


old_beacon_filter() {
    $grep_cmd -h '' "$logfile" \
    | grep -E "DPT=(${SUSPECT_PORTS})" \
    | awk '{for(i=1;i<=NF;i++) if($i ~ /^DST=/) print substr($i,5)}'
}

#-----[ main script ]--------------------------------------------------------------------
#checkroot
separator "${PN}-${BUILD}"

# outbound ACCEPTs (zone - net)
j_msg -${info} -m "Outbound ACCEPTs (zone - net)"
j_msg -${info} -m "$($grep_cmd -E "${ZONE_REGEX}.*ACCEPT" "$logfile")"

# policy ACCEPTs (~ chains [supplemental created by shorewall for policy-matches])
j_msg -${info} -m "Policy ACCEPTs (~ chains)"
j_msg -${info} -m "$($grep_cmd -E "${ZONE_REGEX}~.*ACCEPT" "$logfile")"

# small packets (LEN=40 - 120)
j_msg -${info} -m "Small packets (LEN=40 - 120)"
j_msg -${info} -m "$($grep_cmd -E "${SMALL_LEN}" "$logfile" | grep -E "${ZONE_REGEX}")"

# suspicious destination ports
j_msg -${info} -m "Suspicious destination ports"
j_msg -${info} -m "$($grep_cmd -E "DPT=${SUSPECT_PORTS}" "$logfile" | grep -E "${ZONE_REGEX}")"

# DNS anomalies (UDP - port 53)
j_msg -${info} -m "DNS anomalies (UDP - port 53)"
j_msg -${info} -m "$($grep_cmd -E 'PROTO=UDP.*DPT=53' "$logfile" | grep -E "${ZONE_REGEX}")"

# repeated DST IPs (excluding known-good resolvers)
j_msg -${notice} -p "Top repeated DST IPs (potential beacon endpoints)"
ingest_ip_array beacon_filter
identify_ip_hits
