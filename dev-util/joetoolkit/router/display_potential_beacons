#!/usr/bin/env bash

logfile="${1:-"${default_logfile}"}"

# Internal-origin zones
ZONES=(loc dmz vpn)

# known-good DNS/DoT/DoH resolvers to ignore
GOOD_DNS=(
  9.9.9.9
  149.112.112.112
  2620:fe::fe
  2620:fe::9
  1.1.1.1
  1.0.0.1
  2606:4700:4700::1111
  2606:4700:4700::1001
  8.8.8.8
  8.8.4.4
)

# build regexes
ZONE_REGEX="$(printf '%s-net|' "${ZONES[@]}")"
ZONE_REGEX="${ZONE_REGEX%|}"

GOOD_DNS_REGEX="$(printf '%s|' "${GOOD_DNS[@]}")"
GOOD_DNS_REGEX="${GOOD_DNS_REGEX%|}"

# suspicious ports (common C2)
# (note: in [3-6][0-9]{4}, {4} means "4 of the preceding token", so 30000-69999
SUSPECT_PORTS='(53|80|123|443|8080|8443|[3-6][0-9]{4})'

# beacon-like packet sizes (40 - 120)
SMALL_LEN='LEN=([4-9][0-9]|1[01][0-9]|120)\b'

