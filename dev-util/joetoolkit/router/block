# Rev. 11 October 2012; updated 10 April 2026
# Tested with ipset 6.13

# ToDo - update and further harden firewall/clients against malicious IPv6 traffic, using one/some of these
#  reputable alternatives that support IPv6 --
# pamhaus Exploits Blocklist (XBL)
#    Focus: Compromised devices and hijacked IPs.
#    Format: Distributed via DNSBL, but they provide data for IPv6 addresses exhibiting signs of compromise.
# FireHOL IP Lists:
#    Focus: Aggregating multiple sources.
#    Usage: IPSet collections on GitHub, which often categorize lists by "abuse," "proxies," or "attacks."
# Blocklist.de:
#    Focus: SSH, Mail, and Web server attacks.
#    Format: variety of exports; data includes IPv6 addresses reported by their sensors for brute-force attempts

# Purpose: Load DShield.org Recommended Block List into an ipset in a running
# firewall.  That list contains the networks from which the most malicious
# traffic is being reported by DShield participants.

# Notes: Call this from crontab. Feed updated every 15 minutes.
# netmask=24: dshield's list is all class C networks
# hashsize=64: default is 1024 but 64 is more than needed here

target="http://feeds.dshield.org/block.txt"
ipset_params="hash:ip --netmask 24 --hashsize 64"

filename=${target##*/}                  # basename idiom ("block.txt")
firewall_ipset=${filename%.*}           # ipset will be filename minus ext ("block")
data_dir="/var/tmp/${firewall_ipset}"   # data directory will be same ("/var/tmp/block")
data_file="${data_dir}/${filename}"     # ("/var/tmp/block/block.txt")

# if data directory does not exist, create it
mkdir -pm 0750 "${data_dir}"

# function to get modification time of the file in log-friendly format
# stderr redirected in case file is not present
get_timestamp() {
    date -r $1 +%m/%d' '%R
}

# file modification time on server is preserved during wget download
[ -w "$data_file" ] && old_timestamp=$(get_timestamp "${data_file}")

# fetch file only if newer than the version we already have
# (-q: quiet; -N: timestamping (get if newer); -P: prefix (save to data_dir)
wget -qNP "${data_dir}" "${target}"

if [ "$?" -ne "0" ]; then
    logger -p cron.err "IPSet: ${firewall_ipset} wget failed."
    exit 1
fi

timestamp=$(get_timestamp "${data_file}")

# compare timestamps because wget returns success even if no newer file
if [ "${timestamp}" != "${old_timestamp}" ]; then

    temp_ipset="${firewall_ipset}_temp"
    ipset create "${temp_ipset}" "${ipset_params}"

    # extract ipv4 addresses from data_file and store in $networks
    # ^ ................: anchor to BOL (^)
    # ([0-9]{1,3}\.){3} :  group of 1 to 3 digits followed by a dot, repeated exactly 3 times (e.g., 192.168.1.)
    # [0-9]{1,3} .......:         matches the 4th octet (1 to 3 digits)
    # .*$ ...: matches any char followed by anything, i.e. everything else, anchored to EOL ($)
    # \1 ....:  backreference (replace entire line with content found inside 1st parentheses
    # p......: print
    # net effect : strip /24 and comments from "192.168.1.0/24 # hello"; store "192.168.1.0"
#    networks=$(sed -rn 's/(^([0-9]{1,3}\.){3}[0-9]{1,3}).*$/\1/p' "${data_file}")
    readarray -t networks < <(sed -rn 's/(^([0-9]{1,3}\.){3}[0-9]{1,3}).*$/\1/p' "${data_file}")

    for net in "$networks[@]}"; do
        ipset add "${temp_ipset}" "${net}/24"
    done

    # if ipset does not exist, create it
    ipset create -exist "${firewall_ipset}" "${ipset_params}"

    # swap the temp ipset for the live one
    ipset swap "${temp_ipset}" "${firewall_ipset}"
    ipset destroy "${temp_ipset}"

    # log the file modification time for use in minimizing lag in cron schedule
    logger -p cron.notice "IPSet: ${firewall_ipset} updated (as of: ${timestamp})."

fi
