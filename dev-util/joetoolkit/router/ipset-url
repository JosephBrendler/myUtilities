#!/bin/bash

# ipset-url Joe Brendler 1 November 2015 (updated 10 April 2026)

# look up ips for url and then find them in ipsets
[ $# -eq 0 ] && echo "Enter a url to test" && exit -1

for ip in $(dig +short "$1")  $(dig AAAA +short "$1")
do
  echo "--------[ $ip ]---------------"
  ipset-find $ip | grep 'IS'
done
