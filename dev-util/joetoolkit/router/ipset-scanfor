#!/bin/bash
#
# scan ipsets for filter arg
#
source /usr/sbin/script_header_joetoo
[ $# -eq 0 ] && { j_msg -${err} "${BRon}usage${Boff}: $PN <scan_target>"; exit 1; }
target="$1"
checkroot

PN=${0##*/}
if [ -f /etc/joetoolkit/BUILD ]; then . /etc/joetoolkit/BUILD; else BUILD="0.1.2_20260410"; fi

separator "$(hostname)" "${PN}-${BUILD}"

j_msg -${info} -m -n "aggregating array of ipsets"
# allow_set and block_sets are ipsets of type list:set (sets of sets), so don't include them
readarray -t setlist < <(ipset list -n | grep -v set)
handle_result $? "recorded ${#setlist[@]} sets" "" ${info} || die "failed to aggregating array of ipsets"

j_msg -${info} -m "Scanning ipsets for target [$target]"
for name in "${setlist[@]}"
do
  separator "${PN}-${BUILD}" "(scanning ${name})"
  ipset list "$name" | grep "$target"
done

j_msg -${notice} -p "done"
