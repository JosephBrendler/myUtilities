#!/bin/bash
# determine which ipset(s) match search criteria
# Joe Brendler, 2 Nov 14

source /usr/sbin/script_header_joetoo


PN=${0##*/}   #  like =$(basename $0) but w/o subshell and function call

if [ -f /etc/joetoolkit/BUILD ]; then . /etc/joetoolkit/BUILD; else BUILD="0.0.1"; fi

[ -z $verbosity ] && verbosity=${notice}  # assign default if null; allow calling program to dictate

ip_found_color="${BGon}"
ip_not_found_color="${BRon}"
search_term=""

## ToDo - add "parseOptions()" function, inlcuding increment verbosity per "v" in -vv, etc

parseCommandLine()
{
j_msg -${notice} -p "parsing commandline [ $@ ]"
while [[ $# -gt 0 ]]
do
  # if it starts with "-" then treat as option, else treat as ip address
  if [ "${1:0:1}" == "-" ]
  then
    j_msg -${info} -m "about to process argument(s): [ $* ]"
    j_msg -${debug} -p "1: [ $1 ], 2: [ $2 ]"
    # process command line argument (must be one of the following)
    [ ! -z "$1" ] && case "$1" in
      "-b" | "--bogus"         ) BOGUS_VARIABLE="yes" ;;
      "-h" | "--help"          ) useage ; exit 0 ;;
      "-v" | "--verbose"       ) let "verbosity+=1" ;;
      *                        ) process_compound_arg $1 ;;
    esac
  else
    [ ! -z "$1" ] && search_term="$1" || ( useage && exit 1 )
  fi
  shift
done
}

process_compound_arg()
{
# must begin with a single dash
[ ! "${1:0:1}" == "-" ] && E_message "${E_BAD_ARGS}" && useage && exit 1
# must not begin with two dashes (ToDo - pick up in process_argument)
[ "${1:0:2}" == "--" ] && E_message "${E_BAD_ARGS}" && useage && exit 1
# strip leading dash(es)
myargs=${1##-}
# handle remaining characters in sequence
while [ -n "${myargs}" ]
do
    #handle first char
    case ${myargs:0:1} in
        "b") BOGUS_VARIABLE="yes" ;;
        "v") let "verbosity+=1" ;;
        *  ) E_message "${E_BAD_ARGS}" && useage && exit 1
esac
    #strip first char from myargs (i.e. "shift")
    myargs=${myargs:1}
done
}

useage()
{
  j_msg -${notice} -p "${BGon}Useage:  ${Boff}ipset-find [-v[v[v[...]]]|-b] <search_criterion>"
  j_msg -${notice} -mp " Command line options:"
  j_msg -${notice} -mp "    "$BBon"[-h | --help]"$Boff".............print this text"
  j_msg -${notice} -mp "    "$BBon"[-v | --verbose]"$Boff"..........increase verbosity"
  j_msg -${notice} -mp ""
  j_msg -${notice} -mp "${BBon}Example: ${Boff}ipset-find '^192.'"
}

#---[ main script ]-------------------------------
checkroot

separator "$(hostname)" "${PN}-${BUILD}"

# $* and $@ are not the same; $* is a string and $@ is an actual array
parseCommandLine "$@"

if [[ ! -z ${search_term} ]]
then
  j_msg -${notice} -p "Searching ipsets for: [ ${BYon}${search_term}${Boff} ]"
  # ipsets named "ipdeny" and "*_set" are of type list:set (ignore these)
  for i in $(ipset list -n | grep -v "_set" | grep -v "ipdeny" )
  do
    if ipset test $i ${search_term} 2>1 ; then
      j_msg -${notice} -p "${search_term} ${ip_found_color}IS${Boff} in set ${ip_found_color}${i}${Boff}"
    else
      j_msg -${debug} -p "${search_term} is ${ip_not_found_color}NOT${Boff} in set ${i}"
    fi
  done
else
  useage
fi
