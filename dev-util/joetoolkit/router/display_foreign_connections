#-----[ variables ]---------------------------------------------------------------------

PN=${0##*/}   # basename

#BUILD="0.1.1 20170116"

if [ -f /etc/joetoolkit/BUILD ]; . /etc/joetoolkit/BUILD; else BUILD="0.1.2 20260315"; fi

tempfile="/home/joe/tempfile"
#default_logfile="/var/log/firewall.log"
