#                print ip          # print that
#            }                     # end of if {...}
#    }'                            # end of awk script

#-----[ main script ]---------------------------------------------------------------------
separator "${PN}-${BUILD}"

# repeated DST IPs (excluding known-good resolvers)
j_msg -${notice} -p "foreign connections"
ingest_ip_array fc_filter
identify_foreign_ip_hits
