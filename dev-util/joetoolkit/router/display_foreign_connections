#default_logfile="/var/log/syslog"
#wayback_logfile="/var/log/old_logs/syslog*"
default_logfile="/var/log/shorewall-run.log"
wayback_logfile="/var/log/old_logs/shorewall-run.logs*"

if [[ -z $1 ]]
then
  logfile=$default_logfile
  grep_cmd="grep"
else
  logfile=$wayback_logfile
  grep_cmd="zgrep"
fi
j_msg -${notice} -p "Using logfile $logfile"

#-----[ functions ]---------------------------------------------------------------------


# build foreign_connection filter
fc_filter() {
  # only look at records for accepted connections to or from the 'net' zone
  #   otherwise you'll see "false positives" from loc2fw or vpn2fw ACCEPTs of nat
  #   traffic corresponding to REJECTED fw2net traffic, etc
  $grep_cmd -h ACCEPT $logfile | \
    grep '\-net' | \
    grep -v 'MAC= ' | \
    grep -v 'SPT=53' | \
    awk '{
      for(i=1;i<=NF;i++)
        if ($i ~ /^DST=/) {
          ip=substr($i,5)
          print ip
        }
    }'
}
