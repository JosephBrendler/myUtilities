#!/bin/bash
source /usr/sbin/script_header_joetoo

PN=${0##*/}   # basename

[ -z "$verbosity" ] && verbosity=$notice

PRETEND=$TRUE
FLAGGED=$FALSE

varlist="PN BPN BUILD user logFile cmdseq_statusfile verbosity loglevel"
varlist="${varlist} num_cmds starting_step stopping_step BREAK"
varlist+=" configfile target_folder rlv.target_line_text insert_file before_after BREAK rlv.target_file_list"
varlist="${varlist} bool.INTERACTIVE bool.RESUME bool.LOGGING bool.QUIET bool.DEBUG bool.PRETEND"
varlist="${varlist} bool.UNICODE_CAPABLE bool.UNICODE_DISABLE"
varlist="${varlist} bool.handle_local_arg_EXISTS bool.handle_local_compound_arg_EXISTS"
varlist="${varlist} bool.handle_local_usage_EXISTS"
varlist="${varlist} rlv.local_cmdline_arg_handler"
varlist+=" BREAK user group"


command_sequence=(
'batch_edit_target_files'
)

msg1_sequence=(
'batch edit target files'
)

num_cmds=${#command_sequence[@]}
#-----[ functions ]-----------------------------------------------------
re_initialize_variables() {
    j_msg "-${notice}" -p "re-initializing variables"
#    myPRETEND=$PRETEND

    #reinitialize and verbosity as above
    FLAGGED=$FALSE
    j_msg "-${info}" -p -n "assigning PN = $(basename $0) "
    export PN=${0##*/}
    right_status $? "${info}" || FLAGGED=$TRUE

    j_msg "-${info}" -p -n "sourcing BUILD"
    source "/etc/${PN}/BUILD"
    right_status $? "${info}" || FLAGGED=$TRUE

    j_msg "-${info}" -p -n "sourcing BPN"
    source "/etc/${PN}/BPN"
    right_status $? "${info}" || FLAGGED=$TRUE

    j_msg "-${info}" -p -n "sourcing script_header_joetoo_extended"
    source "/usr/sbin/script_header_joetoo_extended"
    right_status $? "${info}" || FLAGGED=$TRUE

    j_msg "-${info}" -p -n "re-initializing PRETEND ..."
    export PRETEND=$myPRETEND
    right_status $? "${info}" || FLAGGED=$TRUE
    d_do 'echo -en " $(status_color ${PRETEND})$(TrueFalse ${PRETEND})${Boff}"' "${info}"

    j_msg "-${info}" -p -n "re-initializing num_cmds = ${#command_sequence[@]} ..."
    export num_cmds=${#command_sequence[@]}
    right_status $? "${info}" || FLAGGED=$TRUE

    j_msg "-${info}" -p -n "re-initializing starting_step = 0 ..."
    export starting_step=0
    right_status $? "${info}" || FLAGGED=$TRUE

    j_msg "-${info}" -p -n "re-initializing stopping_step = $((${#command_sequence[@]} - 1)) ..."
    export stopping_step=$(( num_cmds - 1))
    right_status $? "${info}" || FLAGGED=$TRUE

    j_msg "-${info}" -p -n "assigning configfile ..."
    export configfile="/etc/${PN}/${PN}.conf"
    right_status $? "${info}" || FLAGGED=$TRUE

    j_msg "-${info}" -p -n "assigning cmdseq_statusfile = ${PN}_statusfile ..."
    export cmdseq_statusfile="${PN}_statusfile"
    right_status $? "${info}" || FLAGGED=$TRUE

    j_msg "-${info}" -p -n "initializing bash array for output ..."
    export output=()
    right_status $? "${info}" || FLAGGED=$TRUE

    [ $FLAGGED ] && return 1 || return 0
}

read_config() {
    echo
    j_msg "-${debug}" -m "configfile: $configfile"
    j_msg "-${info}" -m -n "Reading config ..."
    if [ -e "${configfile}" ] ; then
        j_msg "-${info}" -mp -n " [ ${configfile} ]"
        source "${configfile}" || die "failed to source ${configfile}"
        right_status $TRUE "${info}"
    else
        j_msg "-${info}" -mp -n " (${BRon}not found${Boff})"
        right_status 1 "${info}"
        usage
    fi
    return 0
}

display_config() {
  echo
  j_msg "-${notice}" -p "${BYon}Current Configuration --${Boff}"
  longest=$(get_longest ${varlist})
  display_vars ${longest} ${varlist}
  echo
  separator "${BYon}Content of insert_file [${insert_file}]" "(below)"
  cat "${insert_file}"
  separator "${BYon}Content of insert_file [${insert_file}]" "(above)"
  echo
  return 0
}

do_insert() {
    j_msg "-${debug}" -p " running do_insert with input from [ ${insert_file} ]"
    insert_file="${1}"
    while read linein
    do
#      if [ ! -z "${linein}" ] ; then
        j_msg "-${debug}" -p "  inserting [ ${linein} ]"
        output+=("${linein}")
#      fi
    done < "${insert_file}"
    return 0
}

read_input_and_edit_output() {
    # read input from file specified in arg1
    in_file="$1"
    while read line
    do
        # if line is not null and it matches tartet text, then insert before/after
        if [ ! -z "${line}" ] && [ "${line}" == "${target_line_text}" ] ; then
            j_msg "-${debug}" -p "this is target target line; inserting ${before_after}"
            case "${before_after}" in
                "before" )
                    j_msg "-${debug}" -p "adding insert to output array"
                    do_insert "${insert_file}"
                    j_msg "-${debug}" -p "adding original line [ ${line} ] to output array"
                    output+=("$(echo "${line}")")
                  ;;
                "after"  )
                    j_msg "-${debug}" -p "adding original line [ ${line} ] to output array"
                    output+=("$(echo "${line}")")
                    j_msg "-${debug}" -p "adding insert to output array"
                    do_insert "${insert_file}"
                  ;;
                *        ) j_msg "-${err}" "invalid before_after [ ${before_after}]"; usage;;
            esac
        else
            # this is not the target line, so just add it back into the output array
            j_msg "-${debug}" -p "adding line [ ${line} ] to output array"
            output+=("$(echo "${line}")")
        fi
    done < "${in_file}"
    return 0
}

sanity_check() {
    # sanity check explanations
    [ $# -gt 1 ] && j_msg "-${err}" "too many arguments [$#]" && usage
    [ ${#user} -eq 0 ] && j_msg "-${err}" "user: [ ${user} ] null" && usage
    [ ${#group} -eq 0 ] && j_msg "-${err}" "group: [ ${group} ] null" && usage
    [ ${#user} -gt 0 ] && [[ ! $(grep ${user} /etc/shadow) ]] && j_msg "-${err}" "user: [ ${user} ] not found" && usage
    [ ${#group} -gt 0 ] && [[ ! $(grep ${group} /etc/gshadow) ]] && j_msg "-${err}" "group: [ ${group} ] not found" && usage
    [ ! -e "${target_folder}" ] && j_msg "-${err}" "target_folder [ ${target_folder} ] does not exist" && usage
    [ ! -e "${insert_file}" ] && j_msg "-${err}" "insert_file [ ${insert_file} ] does not exist" && usage
    [ ${#target_file_list} -eq 0 ] && j_msg "-${err}" "target_file_list [ ${target_file_list} ] null" && usage
    [ ${#target_line_text} -eq 0 ] && j_msg "-${err}" "target_line_text [ ${target_line_text} ] null" && usage
    [ ! -L "/etc/${PN}/${PN}.conf" ] && j_msg "-${err}" "${PN}.conf symlink does not exist. Run eselect ${PN} list/set" && usage
    return 0
}

dump_output() {
    for ((i=0; i<${#output[@]}; i++)) ; do
        echo "$i: ${output[$i]}"
    done
    return 0
}

write_output() {
    out_file="${1}"
    j_msg "-${info}" -p -n "writing output to ${out_file} ..."
    echo "" > "${out_file}"
    for ((i=0; i<=${#output[@]}; i++))
    do
        echo "${output[i]}" >> "${out_file}"
    done ; right_status $? "${info}"
    j_msg "-${info}" -p -n "setting ownership with chown ${user}:${group} ${out_file} ..."
    chown "${user}:${group}" "${out_file}" ; right_status $? "${info}"
}

batch_edit_target_files() {
    for filename in $(find "${target_folder%/}/" -name "${target_file_list}") ; do
        # reinitialize output array
        output=()
        separator "${PN}-${BUILD}" "(${FUNCNAME[0]})"
        target_file="${filename}"
        j_msg "-${info}" -p "target_file: [ ${target_file} ]"
        read_input_and_edit_output "${target_file}"
        d_do dump_output "${info}"
        if [ ! ${PRETEND} ] ; then
            # do it for real
            write_output "${target_file}"
            # if the first line is now blank, remove it
            while [ -z "$(head -n 1 $target_file)" ]; do sed -i '1{/^$/d}' "$target_file" ; done
            # if the last line is now blank, remove it
            while [ -z "$(tail -n 1 $filename)" ]; do sed -i '${/^[[:space:]]*$/d;}' "$filename" ; done
        else
            j_msg "-${notice}" -p "${BRon}PRETEND${Boff} -- ${BYon}did not write output${Boff}"
        fi
    done
}

#-----[ main script ]--------------------------------------------------
echo
separator "$(hostname)" "${PN}"
checkroot
j_msg "-${notice}" -p "calling app_configure"
app_configure || die "failed to app_configure"
j_msg "-${notice}" -p "calling re_initialize_variables"
re_initialize_variables || die "failed re_initialize_variables"
separator "$(hostname)" "${PN}-${BUILD}"
validate_file "${cmdseq_statusfile}" || die "failed validate_status_file"
read_config || die "failed read_config"

# call script_header_joetoo's process command line to override config
process_cmdline $@

sanity_check || die "failed sanity_check"
display_config || die "failed display_config"
confirm_continue_or_exit

# ok - use script_header_joetoo_extended's run_array now actually do it
run_array "${cmdseq_statusfile}" '' '' || die "failed run_sequence"
j_msg "-${notice}" -p "${BMon}${PN}${BGon} completed successfully${Boff}"
echo
exit 0
