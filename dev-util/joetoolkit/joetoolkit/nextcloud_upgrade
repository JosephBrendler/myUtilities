#!/bin/bash
# nextcloud_upgrade
# joe brendler 6 August 2023
#
source /usr/sbin/script_header_joetoo
new_version=""
myCloud_dir="/var/www/localhost/htdocs/myCloud/"
old_dir=$PWD

#BUILD=0.1.3
if [ -f /etc/joetoolkit/BUILD ]; then . /etc/joetoolkit/BUILD; else BUILD=0.1.4; fi

#-----[ variables ]-------------------
result=""     # result of version check
answer=""     # answer to yns_prompt
new_ver=""     # new version requested
cur_ver=""     # currently installed version (to be determined analytically)
WEBAPP_UP=$FALSE
OCC_UP=$FALSE

#-----[ functions ]-------------------

version_check()     # check the new ($1) and currently installed versions and set external result
{
  new_ver="$1"
  j_msg -${notice} -p "${BYon}Checing current version${Boff}"
  filename=$(find ${myCloud_dir} -maxdepth 1 -iname '*nextcloud*')
  cur_ver=${filename##*-}  # strip longest match for *- from the left - leaving version installed by webapp
  # start output comparison line with new version info
  j_msg -${notice} -p -n "Requested Version: ${new_ver}"
  vercomp ${new_ver} ${cur_ver}; result=$?
  # print comparison indicator (< = >)
  j_msg -${notice} -mp -n " $(show_result $result)"
  # finish output line with comparison target info
  j_msg -${notice} -p " ${cur_ver} (currently installed)"
  j_msg -${notice} -p "result: $result"
}

webappconfig_upgrade()
{
  new_ver="$1"
  j_msg -${notice} -p "${BWon}About to upgrade with command:  [ ${BGon}webapp-config -d $(basename ${myCloud_dir}) -U nextcloud ${new_version} ${BWon}] ${BRon}CTRL-C to abort${Boff}"
  sh_countdown 4
  webapp-config -d $(basename ${myCloud_dir}) -U nextcloud ${new_ver}
}

occ_upgrade()
{
  cd ${myCloud_dir}
  j_msg -${notice} -p "switched from ${old_dir} to $PWD"
  j_msg -${notice} -p "do not forget to switch back to ${old_dir} when complete"
  echo
  j_msg -${notice} -p "${BWon}About to upgrade with command:  [ ${BGon}sudo -u apache php ./occ upgrade ${BWon}] ${BRon}CTRL-C to abort${Boff}"
  sh_countdown 5
  sudo -u apache php ./occ upgrade
  cd ${old_dir}
}

double_check()
{
  j_msg -${notice} -p "${BYon}Currently configured as follows${Boff}"
  j_msg -${notice} -m "${LBon} Currently installed nextcloud version.............: ${BWon}${cur_ver}${Boff}"
  j_msg -${notice} -m "${LBon} Requested new nextcloud version...................: ${BWon}${new_ver}${Boff}"
  j_msg -${notice} -m "${LBon} WEBAPP_UP (upgrade nextcloud with webapp-config)...: $(status_color ${WEBAPP_UP})$(TrueFalse ${WEBAPP_UP})${Boff}"
  j_msg -${notice} -m "${LBon} OCC_UP (upgrade installed app with occ)............: $(status_color ${OCC_UP})$(TrueFalse ${OCC_UP})${Boff}"
  yns_prompt "${BMon}Continue?${Boff}"
}

#-----[ main script ]-----------------
separator "nextcloud_upgrade-${BUILD}"
checkroot
[ $# -gt 1 -o $# -eq 0 ] && echo "please provide exactly one argument (new version #)" && exit 1
new_version="$1"
version_check ${new_version}

# configure logical flags, to proceed as directed
case ${result} in
  0) # =
    answer=""
    yns_prompt "Requested version is already installed by webapp-config. Continue or skip to occ upgrade?"
    case ${answer} in
      [yY]*) j_msg -${notice} -p "Proceeding with reinstall..."; WEBAPP_UP=$TRUE; OCC_UP=$TRUE ;;
      [nN]*) j_msg -${notice} -p "Exiting..."; WEBAPP_UP=$FALSE; OCC_UP=$FALSE ;;
      [sS]*) j_msg -${notice} -p "Skipping webapp upgrade; continuing to occ upgrade..."; WEBAPP_UP=$FALSE; OCC_UP=$TRUE  ;;
      *    ) j_msg -${err} "Invalid answer to prompt [${answer}]; exiting..."; exit 1 ;;
    esac
    ;;
  1) # >
    j_msg -${notice} -p "Proceeding with both webapp-config and occ upgrades..."
    WEBAPP_UP=$TRUE; OCC_UP=$TRUE
    ;;
  2) # <
    answer=""
    yns_prompt "Are you sure you want to downgrade?"
    case ${answer} in
      [yY]*) j_msg -${notice} -p "Proceeding with downgrade..."; WEBAPP_UP=$TRUE; OCC_UP=$TRUE ;;
      [nN]*) j_msg -${notice} -p "Exiting..."; WEBAPP_UP=$FALSE; OCC_UP=$FALSE ;;
      [sS]*) j_msg -${notice} -p "Skipping webapp upgrade; continuing to occ upgrade..."; WEBAPP_UP=$FALSE; OCC_UP=$TRUE  ;;
      *    ) j_msg -${err} "Invalid answer to prompt [${answer}]; exiting..."; exit 1 ;;
    esac
    ;;
  *) # <
    j_msg -${err} "Invalid result from version_check() [${result}]; exiting"
    exit 1
    ;;
esac

# double-check user comittment to contiue as directed
answer=""
double_check
case ${answer} in
  [yY]*) j_msg -${notice} -p "Proceeding..." ;;
  [nNsS]*) j_msg -${notice} -p "Aborting at user's request..."; WEBAPP_UP=$FALSE; OCC_UP=$FALSE ;;
  *    ) j_msg -${err} "Invalid answer to prompt [${answer}]; exiting..."; exit 1 ;;
esac

# execute the selected upgrade/downgrade steps
[[ ${WEBAPP_UP} ]] && webappconfig_upgrade ${new_version}
[[ ${OCC_UP} ]] && occ_upgrade

j_msg -${notice} -p "All done"
exit 0
