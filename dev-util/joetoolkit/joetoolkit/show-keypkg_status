#!/bin/bash
#
# show-keypkg_status - FAST - ho header, no bells/whistles, yet nicely colored by eix itself
#
eix-update >/dev/null 2>&1

key_packages=(
 'sys-libs/glibc'
 'sys-devel/binutils'
 'dev-build/libtool'
 'sys-devel/gcc'
 'sys-kernel/linux-headers'
 'sys-devel/gcc-config'
 )
printf '\n%s\n' "-----[ gcc toolchain ]-------------------------------"
for x in ${key_packages[@]}; do eix -ec $x; done

key_packages=(
 'llvm-core/llvm'
 'llvm-core/clang'
 )
printf '\n%s\n' "-----[ llvm toolchain ]-------------------------------"
for x in ${key_packages[@]}; do eix -ec $x; done
