#!/bin/bash

source /usr/sbin/script_header_joetoo

# show most recent elogs in /var/log/portage/elog/

# Author: Joe Brendler 23 Jan 2011
#  rev 20 Mar 11 -- added latest & today options
#      01 Oct 12 -- added paged output option
#      17 Aug 14 -- bugfix: tmp_elog_summary constrained to ELOG_DIR
#      17 Mar 26 -- refactor for j_msg, etc

# set default option flags
LATEST="$FALSE"
TODAY="$FALSE"
PAGED="$FALSE"

# change if you store elogs elsewhere; must end in /
ELOG_DIR="/var/log/portage/elog/"

# function blocks
usage()
{
   j_msg -${notice} -p "${BGon}usage: show-elog [option]${Boff}"
   j_msg -${notice} -m "  Option -h  | --help     display this text"
   j_msg -${notice} -m "         -l  | --latest   display elogs for latest emerge operations only"
   j_msg -${notice} -m "         -t  | --today    display elogs for today's emerge operations only"
   j_msg -${notice} -m "         -p  | --paged    display elogs with paged (less) output"
   j_msg -${notice} -m
   j_msg -${notice} -m "  Note: User will be shown dates of emerge operations for which elog files exist"
   j_msg -${notice} -m "      and be prompted for input.  Response can be any string filter.  Resulting"
   j_msg -${notice} -m "      output will be the names and contents of all matching filenames. Default"
   j_msg -${notice} -m "      is the most recent date found."
   j_msg -${notice} -m
   j_msg -${notice} -m "  Example:"
   j_msg -${notice} -p "${BGon}  Enter date ["20110123"]:${Boff} 2009<enter>"
   j_msg -${notice} -m "      will generate output of names and contents of all files with filename"
   j_msg -${notice} -m '      matching "2009"'
   j_msg -${notice} -m
   j_msg -${notice} -m "  Note: You can use show-elogs in a non-interactive fashion by piping it the"
   j_msg -${notice} -m "      input for its filter prompt.  You can also generate a paged display of"
   j_msg -${notice} -m "      its output by piping it to less.  For example:"
   j_msg -${notice} -m "         # echo 'portage' | show-elogs | less"
   j_msg -${notice} -m "      to generate a paged display of elogs pertaining to the portage package."
}

find_elog_dates ()
{
# display dates for emerge operations for which elog files exist
# options: -v verbose (default) | -q silent
# returns: latest date found in format +%Y%m%d as found in filenames
[ ! "$1" = "-q" ] && j_msg -${notice} -p "${BYon}Note: elogs exist for emerge operations run on the following dates (oldest first):${Boff}"
[ ! "$1" = "-q" ] && j_msg -${notice} -mp -n "${Con}"  # turn on this color for all date selectors
j=1
for x in $(find "$ELOG_DIR" -maxdepth 1 -mindepth 1 -type f -not -iname 'summary*' | grep -v 'keep' | cut -d":" -f 3 | cut -d"-" -f 1 | sort -nu); do
   [ ! "$1" = "-q" ] && j_msg -${notice} -mp -n "   "$x
   let "rem = $(expr $j % 7)"
   [ $rem -eq  0 ] && [ ! "$1" = "-q" ] && printf '\n'
   let "j = $j + 1"
done
[ ! "$1" = "-q" ] && j_msg -${notice} -mp "${Boff}"
answer="$x"  # returns latest date found for variable assignment
}

#------------------------------------------------------------------------
# start main script

# process command line argument (must be one of the following)
[ ! -z "$1" ] && case $1 in
    "-h" | "--help"    ) usage ; exit 0  ;;
    "-l" | "--latest"  ) LATEST="$TRUE" ;;
    "-t" | "--today"   ) TODAY="$TRUE" ;;
    "-p" | "--paged"   ) PAGED="$TRUE" ;;
    *                  ) usage; exit 1 ;;
esac

answer=""
if [ "$TODAY" ]
then
    answer="$(date -u +%Y%m%d)"
elif [ "$LATEST" ]
then
    find_elog_dates -q  # quietly sets answer to latest date
else
    # prompt user to select date; default to latest
    find_elog_dates -v  # verbosely lists all elog dates
    printf '\n'
    j_msg -${notice} -p -n "${BGon}Enter date ["$answer"]:"
    read reply
    [ ! -z $reply ] && answer=$reply
fi
# create output file and display selected elogs
tmp_elog_summary_file="${ELOG_DIR%/}/tmp_elog_summary"
[ -e "$tmp_elog_summary_file" ] && rm "$tmp_elog_summary_file"
printf '%s' "${BGon} * " > "$tmp_elog_summary_file"
printf '%s' "${BYon}Found the following elogs for filter: ${BRon}$answer" >> "${ELOG_DIR%?}/tmp_elog_summary"
printf '\n' >> "$tmp_elog_summary_file"

for i in $(find $ELOG_DIR -maxdepth 1 -mindepth 1 -type f -iname "*${answer}*" -printf '%f\n'); do

   printf '%s'  "${BGon} * ${BYon} ${i%%$answer*}${BRon}${answer}${BYon}${i##*$answer} ${Boff}" >> "$tmp_elog_summary_file"
   printf '\n' >> "$tmp_elog_summary_file"
   cat "${ELOG_DIR%/}/${i}" >> "$tmp_elog_summary_file"
done

if [ "$PAGED" ]
then
   less "$tmp_elog_summary_file"
else
   cat "$tmp_elog_summary_file" | sed 's|^|   |'
fi

# clean up
[ -e "$tmp_elog_summary_file" ] && rm "$tmp_elog_summary_file"
exit 0

