#!/bin/bash
source /usr/sbin/script_header_joetoo

PN=${0##*/}

if [ -v /etc/joetoolkit/BUILD ]; then . /etc/joetoolkit/BUILD; else BUILD=0; fi

separator "$(hostname)" "${PN}-${BUILD}"
cronlog="/var/log/cron.log"
#cronlog="/var/log/syslog"
#cronlog="/var/log/messages"

filterlist=(CROND cron hourly binhost)

j_msg -${notice} -p "filtering cronlog [$cronlog] ..."

j_msg -${info} -m "Starting with scripted filterlist=[${filterlist[@]}]"

count=${#filterlist[@]}

while [[ $# -gt 0 ]]
do
  filterlist[count]="$1"
  j_msg -${info} -m "Added [$1] from command line to filterlist, which now has ${#filterlist[@]} elements"
  let "count+=1"
  shift
done
command=("/bin/grep -v '${filterlist[0]}' $cronlog")
for ((i=1; i<${#filterlist[@]}; i++))
do
  command+=(" | grep -v '${filterlist[i]}'")
done
j_msg -${notice} -p "${BYon}about to issue command \"${BWon}${command}${BWon}\"${Boff}"
eval "${command[@]}"
