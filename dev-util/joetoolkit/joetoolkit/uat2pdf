#!/bin/bash
# uat2pdf - (c) joe brendler 2025-2055
# convert text to pdf while preserving ansi color sequences and multi-byte unicode characters
#
source /usr/sbin/script_header_joetoo

PN=${0##*/}   #  like =$(basename $0) but w/o subshell and function call

if [ -f /etc/joetoolkit/BUILD ]; then . /etc/joetoolkit/BUILD; else BUILD="0.0.1"; fi

[ -z $verbosity ] && verbosity=${notice}  # assign default if null; allow calling program to dictate

user="joe"

#-----[ variables ]--------------------------------------------------

old_dir=$(pwd)

#-----[ functions ]--------------------------------------------------
usage() {  j_msg -${err} "${BRon}usage: ${BGon}${PN} <INPUT_TEXT_FILE>${Boff}"; exit 1 ; }

convert_ansi_to_html() {
    # --light-background --scheme solarized (use a light theme and matching colors)
    ansi2html --light-background --scheme solarized < "$input_file" > "$tmp_html"
    return $?
}

convert_html_to_pdf() {
    # htmldoc (alternative: simpler, but HTML subset)
#    htmldoc --webpage -f "$output_file" "$tmp_html"
# there will be some warnings generated by weasyprint processing of ansi2html-gennerated css (font-size: normal)
# (which will be overridden by my build_css anyway) and because original input may contain non-printable chars
#  such as BEL, VT, SO/SI, or unicode zero-idth characters. These are harmless and will be silenced by the use
#  of the -q option flag (remove -q for further debugging)
    # weasyprint (full CSS, best fidelity)
    weasyprint -q --full-fonts --srgb "$tmp_html" "$output_file" --stylesheet "$tmp_css" 2>/dev/null
    return $?
}

build_css() {
cat > "$tmp_css" <<'EOF'
body {
    font-family: "DejaVu Sans Mono", "Noto Sans Mono", "Noto Color Emoji", monospace;
    font-size: 10pt;
    white-space: pre-wrap;
}
EOF

}
#-----[ main script ]------------------------------------------------

[ $# -eq 0 ] && {  j_msg -${err} "input file not specified" ; usage ; }
[ $# -gt 2 ] && {  j_msg -${err} "invalid arguments" ; usage ; }
input_file="$1"
output_file="${2:-${input_file}.pdf}"
tmp_html="$(mktemp --suffix=.html /tmp/${PN}.XXXXXX)"
tmp_css="$(mktemp --suffix=.css  /tmp/${PN}.XXXXXX)"

separator "$(hostname)" "${PN}-${BUILD}"

j_msg -${debug} -p "input_file: $input_file"
j_msg -${debug} -p "output_file: $output_file"
j_msg -${debug} -p "tmp_html: $tmp_html"
j_msg -${debug} -p "tmp_css: $tmp_css"

j_msg -${notice} -M $idx_screwdriver -p -n "Constructing css file to control conversion"
# there shouldn't be stderr ouput but redirect for full control (remove redirect for debugging)
build_css 2>/dev/null
handle_result $? '' '' $notice || die "failed to build_css"

j_msg -${notice} -M $idx_hammer -p -n "Converting input via ansi2html"
# there shouldn't be stderr ouput but redirect for full control (remove redirect for debugging)
convert_ansi_to_html 2>/dev/null
handle_result $? '' '' $notice || die "failed to convert_ansi_to_html"

j_msg -${notice} -M $idx_wrench -p -n "Further converting html to pdf via weasyprint"
# there shouldn't be stderr ouput but redirect for full control (remove redirect for debugging)
convert_html_to_pdf 2>/dev/null
handle_result $? '' '' $notice || die "failed to convert_ansi_to_html"

j_msg -${notice} -M $idx_trophy -p "${BGon}Done${Boff}"

#debug_marker

