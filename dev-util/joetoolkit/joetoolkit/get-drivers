#!/bin/bash
source /usr/sbin/script_header_joetoo
PN=${0##*/}

#BUILD="0.0"
if [ -f /etc/joetoolkit/BUILD ]; then . /etc/joetoolkit/BUILD; else BUILD="0.0.1"; fi

driverlist=()
combinedlist=()

separator "$(hostname)" "${PN}-${BUILD}"
j_msg -${notice} -p "Finding drivers identified by lspci ...\n"
for x in $( lspci -k | grep -i kernel | sort -u | awk -F': ' '{ print $2 }' ); do driverlist+=($x); done

j_msg -${notice} -p "Finding drivers identified by lshw ...\n"
for x in $( lshw | grep -i driver | awk -F'=' '{ print $2 }' | sed 's/latency//' | sort -u ); do driverlist+=($x); done

j_msg -${notice} -p "Here are the sorted combined results ...\n"
for y in $( for x in "${driverlist[@]}"; do echo "$x"; done | sort -u ); do combinedlist+=($y); done

echo
for (( i=0; i<=${#combinedlist[@]}; i++ )); do echo -e "\t$i: ${combinedlist[i]}"; done
echo
