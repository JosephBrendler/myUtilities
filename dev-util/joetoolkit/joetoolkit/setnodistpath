#!/bin/bash
# setnodistpath - modify PATH to eliminate distcc masquerades
#
# NOTE:  must *source* this script to make the export assignment active in calling shell
#
# fallback: if not already defined by a parent script, define a dummy logger
# (cmd &> redirects both stdout and stderr)
type j_msg -${debug} -mp &>/dev/null || j_msg() { :; }

_old_path=() _new_path=()

IFS=':' read -r -a _old_path <<<"$PATH"

for x in "${_old_path[@]}"; do
  if [[ "$x" != *"distcc"* && "$x" != *"ccache"* ]]
  then
    _new_path+=("$x")
  else
    j_msg -${debug} -mp "dropping old path element --> $x"
  fi
done
j_msg -${debug} -mp "new path has ${#_new_path[@]} elements"
j_msg -${debug} -mp "new path: ${_new_path[@]}"

export PATH=$(IFS=:; echo "${_new_path[*]}")

for ((i=0; i<${#_new_path[@]}; i++ )); do j_msg -${debug} -mp "$i: ${_new_path[i]}"; done
j_msg -${debug} -mp "PATH = ${PATH}"
