#!/bin/bash
# user-script specific commandline argument module (to extend process_compound_arguments)
# ** will be sourced by using script **
# ( MUST end " * )  j_msg -${err} "${E_BAD_ARGS}" && usage ;;"
# Note: options i, n, s, r, v, q are already used by the default cmdline processor
# from usage:
#
case ${myargs:0:1} in
    [pP] )
      # example 1
      export PRETEND=${TRUE}
      j_msg -${info} -m "${BYon}set PRETEND = $(status_color ${PRETEND})$(TrueFalse ${PRETEND}) ${Boff}"
      ;;
    [wW] )
      # example 2
      export PRETEND=${FALSE}
      j_msg -${info} -m "${BYon}set PRETEND = $(status_color ${PRETEND})$(TrueFalse ${PRETEND}) ${Boff}"
      ;;
     *   ) j_msg -${err} "${E_BAD_ARGS}" && usage ;;
esac
