#!/bin/bash
#
# collect_distcc_hosts_support_data_sysbench - joe brendler nov 2025 (c) 2025-7789 
#
source /usr/sbin/script_header_joetoo

#-----[ variables ]-------------------------------------------------------------

PN=${0##*/}   #  like =$(basename $0) but w/o subshell and function call

if [ -f /etc/joetoolkit/BUILD ]; then . /etc/joetoolkit/BUILD; else BUILD="0.0.1"; fi

[ -z $verbosity ] && verbosity=${notice}  # assign default if null; allow calling program to dictate

total_remote_limit=0
declare -a host_benchmarks


#-----[ functions ]-------------------------------------------------------------

# calculate the job limit for a single host
# (algorithm: determine dominant constraint
#  cpu core count (at 1 core per job)
#  or RAM size (at 2G per job)
#  return the lesser)
calculate_job_limit() {
  local cores="$1"
  local ram_gb="$2"
  local ram_jobs=$((ram_gb / 2))

  if [[ "$cores" -lt "$ram_jobs" ]]; then
    echo "$cores"
  else
    echo "$ram_jobs"
  fi
}

#-----[ main script ]-------------------------------------------------------------
checknotroot  # needs to run as user for ssh remote collection; /etc/distcc/hosts is world readable (644)
separator "$(hostname)" "${PN}-${BUILD}"

# define a format string for three columns
# %-15s: left-aligned string, 15 characters wide
# %-10s: left-aligned string, 10 characters wide
# %-10s: left-aligned string, 10 characters wide
format="%s %-15s %-10s %-10s %s\n"

j_msg -${notice} -mp "\n" # double newline
j_msg -${notice} -p "${BYon}Collecting data for distcc server farm ...${Boff}\n"
printf "$format" "${BCon}${RVon}" "hostname" "sysbench" "joblimit" "${Boff}"
printf "$format" "${Con}" "--------" "--------" "--------" "${Boff}"

# define the command to be run both locally and remotely - combined for more efficient subshell
CMD='nproc && free -g | awk "/Mem:/{print \$2}" && '
CMD+='sysbench --threads=1 cpu run | grep "events per second" | awk "{print \$4}"'


# process localhost ---
local_output=$(bash -c "$CMD")
# load all lines into a local array
readarray -t _tmp_data <<< "$local_output"
# validate
[ "${#_tmp_data[@]}" -eq 3 ] || die "failed local data acquisition"
# ssign from array (0-indexed)
local_cores="${_tmp_data[0]}"
local_ram_gb="${_tmp_data[1]}"
local_benchmark="${_tmp_data[2]}"
unset _tmp_data
local_job_limit=$(calculate_job_limit "$local_cores" "$local_ram_gb")

# print the formatted output for localhost
printf "$format" "${Bon}" "localhost" "$local_benchmark" "$local_job_limit" "${Boff}"

# process /etc/distcc/hosts file
_this_host=$(hostname)
# grep -Ev "^#|^${W0}$" strips comments and blank lines
# sed -E "s/^${W0}//; l-trims leading whitespace
# sed -E s/,lzo.*//;  r-trims from ,lzo. to the right
# sed -E s/\/(.*)//   r-trims from / to the right (e.g. 192.168.1.5/4 (jobs indicator))
# also pre-filter out "localhost/loopback" entries
host_list=$(grep -Ev "^#|^${W0}$" /etc/distcc/hosts | \
            sed -E "s/^${W0}//; s/,lzo.*//; s/\/(.*)//" | \
            grep -Ev "^(localhost|127\.0\.0\.1|::1|${_this_host})$")
readarray -t hosts <<< "$host_list"

if [[ "${#hosts[@]}" -eq 0 ]]; then
  echo "No distcc hosts found in /etc/distcc/hosts (excluding localhost)."
else
  _count=0
  for host in "${hosts[@]}"; do
    [ -z "$host" ] && continue

    remote_output=$(ssh -o BatchMode=yes -o ConnectTimeout=5 "$host" "$CMD" 2>/dev/null)

    if [[ -n "$remote_output" ]]; then

      # load all lines into a local array
      _tmp_data=()
      readarray -t _tmp_data <<< "$remote_output"
      # validate
      if [ ! "${#_tmp_data[@]}" -eq 3 ]; then
        j_msg -${err} "failed data acquisition from [$host]"
        continue  # skip to next host
      fi
      # assign from array (0-indexed)
      remote_cores="${_tmp_data[0]}"
      remote_ram_gb="${_tmp_data[1]}"
      remote_benchmark="${_tmp_data[2]}"
      job_limit=$(calculate_job_limit "$remote_cores" "$remote_ram_gb")
      host_benchmarks+=("$host:$remote_benchmark:$job_limit")
      # print the formatted output for remote hosts - alternate reverse video
      if (( _count % 2 == 0 )); then
        printf "$format" "${Bon}${RVon}" "$host" "$remote_benchmark" "$job_limit" "${Boff}"
      else
        printf "$format" "${Bon}" "$host" "$remote_benchmark" "$job_limit" "${Boff}"
      fi
      total_remote_limit=$((total_remote_limit + job_limit))
    else
      echo "  failed to retrieve info from $host; check SSH access or sysbench installation."
    fi  # remote output not null
    _count=$((_count + 1))
  done
  unset _tmp_data
fi  #  hosts -gt 0

printf "$format" "${Con}" "--------" "--------" "--------" "${Boff}"
j_msg -${notice} -mp ""
j_msg -${notice} -p "Final remote resource limit (R): $total_remote_limit\n"
j_msg -${notice} -p "Recommended /etc/distcc/hosts order (descending power):"

# sort with key on col 2 (sysbench)
sorted_hosts=($(printf "%s\n" "${host_benchmarks[@]}" | sort -t: -k2 -nr))

for entry in "${sorted_hosts[@]}"; do
  host=$(echo "$entry" | cut -d: -f1)
  limit=$(echo "$entry" | cut -d: -f3)
  j_msg -${notice} -mp "$host,lzo/${limit}"
done

separator "$(hostname)" "${PN}-${BUILD}"
j_msg -${notice} -mp ""
j_msg -${notice} -p "Done"
