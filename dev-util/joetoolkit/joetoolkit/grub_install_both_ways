#!/bin/bash
# see news grub2 article - recommends install both with and w/o --removable
# syntax here taken from https://wiki.gentoo.org/wiki/Handbook:AMD64/Installation/Bootloader
#
efi_dir=$(grep '/efi' /etc/fstab | awk '{print $2}')
[ ! -d "$efi_dir" ] && { printf '%s\n' "valid efi dir not found"; exit 1; }
grub-install --efi-directory="${efi_dir}" --target=x86_64-efi
grub-install --efi-directory="${efi_dir}" --target=x86_64-efi --removable
