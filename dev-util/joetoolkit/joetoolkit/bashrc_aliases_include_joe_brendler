# converting alias gcsm to a function for clarity; still built to treat gpg failure as a warning rather than a blocker
gcsm() # (BASH) submit signed commit (follow with gpom to push)
{   local _gcsm_msg="${1:-}"
    echo 'test' > ~/cachetest  #.............................# create a dummy file to sign
    gpg --clearsign ~/cachetest > /dev/null 2>&1 || true  #..# sign file w pinentry, cache the key, ignore pcscd error msg
    [ -f ~/cachetest.asc ] || return 1   #...................# verify the file signature (.asc) was created
    rm ~/cachetest.asc  #....................................# remove the signature to reset
    git commit -s -m "${_gcsm_msg}"  #.......................# sign the commit
}
