# use new approach, below

#-----[ portage environment cache ]--------------------------------------------------
_load_portage_env() {
    # source the file natively once so shell handles ROOT and path nesting for all variables
    if [ -f /etc/portage/make.conf ]; then
        . /etc/portage/make.conf 2>/dev/null
    fi

    # export variables globally, applying Gentoo's standard fallback defaults
    export PORTDIR="${PORTDIR:-/var/db/repos/gentoo}"
    export PKGDIR="${PKGDIR:-/var/cache/binpkgs}"
    export DISTDIR="${DISTDIR:-/var/cache/distfiles}"
    export PORTAGE_TMPDIR="${PORTAGE_TMPDIR:-/var/tmp}"
    export PORTAGE_LOGDIR="${PORTAGE_LOGDIR:-/var/log/portage}"
}
_load_portage_env
unset -f _load_portage_env  # clean up the function namespace immediately

export DISTCC_DIR="${PORTAGE_TMPDIR%/}/portage/.distcc/"

alias distmon='DISTCC_DIR="${DISTCC_DIR}" distccmon-text 2'
