#!/bin/sh
_pw_len=${1:-16}
_alphabet='ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789!@#$%^&*()_+-=[]{};:,.<>/?'
_alen=${#_alphabet}

_pw=""
_i=0
while [ $_i -lt "$_pw_len" ]; do
    _byte=$(od -An -N1 -tu1 /dev/urandom)
    _idx=$(( _byte % _alen ))
    _pw="${_pw}${_alphabet:$_idx:1}"
    _i=$((_i+1))
done

printf '%s\n' "$_pw"
