#!/bin/bash
# source user-script specific usage-module which should be built in the same format
# this file must contain legitimate bash assignments and commands
# it will be sourced by the script_header_joetoo_extended usage() function
# Note: options i, n, s, r, v, q are already used by the default cmdline processor
j_msg -${notice} -p "${BYon}  Note: -n (unsuperviced) and -r (resume) functionality is disabled for ${PN}${Boff}"
j_msg -${notice} -m "  -p | --pretend ..........: do not write output to file(default)"
j_msg -${notice} -m "  -w | --write ............: do write output to file"
j_msg -${notice} -m ""
j_msg -${notice} -p "${BYon}No other arguments are allowed - specify configuration${Boff}"
j_msg -${notice} -p "  ${BYon}in confg file /etc/${PN}/${PN}.conf${Boff}"
j_msg -${notice} -m "    target_folder......: path to folder containing target(s)"
j_msg -${notice} -m "    target_file_list...: name of target file(s). e.g. *.conf"
j_msg -${notice} -m "    target_line_text...: text of line before/after which to insert"
j_msg -${notice} -m "    insert_file........: pathname of file with content to insert"
j_msg -${notice} -m "    before_after.......: \"before\" or \"after\" (default=after)"
j_msg -${notice} -m "    owner..............: target file owner. e.g. \"joe\""
j_msg -${notice} -m "    group..............: target file group. e.g. \"joe\""
j_msg -${notice} -m "    VERBOSE............: provide verbose output (boolean)"
j_msg -${notice} -m "    verbosity..........: (0-6) how verbose"
j_msg -${notice} -m ""
j_msg -${notice} -p "  ${Mon}Note:${Boff}"
j_msg -${notice} -m "    ${Mon} user and group must exist${Boff}"
j_msg -${notice} -m "    ${Mon} target_folder and insert_file must exist${Boff}"
j_msg -${notice} -m "    ${Mon} target_file_list and target_line_text cannot be null${Boff}"
