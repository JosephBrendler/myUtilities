#
# script_header_joetoo_unicode - raw hex codepoint definitions for the superset of
#   unicode characters used in script_header_joetoo

#-----[ raw hex Unicode/Emojis ]--------------------------------------------------------------

# factors determining which emoji to display in context
#
# The emoji must directly relate to the subject matter of the section. This is the **primary** consideration.
#
# 1. Content/Topic Relevance    puzzle
#
# Purpose               My Variable Name
# Steps/Process         gear
# New Ideas/Concepts    light_bulb
# Fixes/Tools           hammer_and_wrench
# Errors/Warnings       no_entry
# Rejection/Failure     cross_mark
# Success/Validation    check_mark_button
#
# 2. Tone and Intent    (blue side-face indicates "heading)

# The emoji must align with the intended tone of the response
# (e.g., helpful, cautionary, or encouraging).

# Purpose               My Variable Name
# Debugging/Analysis    lady_bug
# Search/Investigation  magnifying_glass_left
# Repair/Correction     wrench
# Formal/Technical      book
# Conceptual/Thinking   face_thinking
# Celebratory           confetti
#
# 3. Consistency and Visual Hierarchy (ladder)

# Use a distinct, contextually consistent emoji for the main topic headings
# within a single response, avoiding overuse to maintain clarity
#
# 4. Example of Usage   (hammer)
#
# variables like `${hammer}` and `${cross_mark}` to indicate status or actions
#
#  specialized functions using these are found later in layou/UI and messaging sections
# variable value assignments follow
#
# Action/Execution      u_message ${hammer} "hello, world" Indicates a WORK process is running or starting
# Error/Termination     uE_message ${cross_mark} "testing uE_error_message"` Clearly signals a failure, stop, or invalid state

# prefix ALL emoji defintions with "\\U" to ensure emit_utf8_from_hex will interpret them properly

# VS16 (Variation Selector-16, code point U+FE0F) is an invisible control character used to specify
#   that the preceding character should be displayed with an emoji rather than a monochrome text
#   (this is needed for some older emojis (like heart_red)

# zero-width characters
VS16="\\UFE0F"         # variation selector 16 (use colorized version)
VS15="\\UFE0E"         # variation selector 15 (use text version [use monochrome is deprecated])
ZWJ="\\U200D"          # zero width joiner (e.g. man + ZWJ + staff_of_asclepius becomes a "doctor"
ZWNJ="\\U200C"         # zw non-joiner; glues two characters w/o "merging" them
ZWS="\\U200B"          # zw space (soft space -used in watermarkign and steganography)
WJ="\\U2060"           # zw word joiner (glue words together - do not break/separate)
SHY="\\U00AD"          # zw soft hyphen (displays only if at EOL, good place to split a word)
CGJ="\\U034F"          # zw combined grapheme joiner - sort combined not separately

# bi-directional controls
LRO="\\U202D"          # zw left-to-right override
RLO="\\U202E"          # zw right-to-left override
LRE="\\U202A"          # zw left-to-right embedding (older)
RLE="\\U202B"          # zw right-to-left embedding (older)
PDF="\\U202C"          # zw pop directional format (terminate LRE/RLE/LRO/RLO)(older)
LRI="\\U2066"          # zw left-to-right isolate (newer)
RLI="\\U2067"          # zw right-to-left isolate (newer)
FSI="\\U2068"          # zw first strong isolate (newer)
PDI="\\U2069"          # zw pop directional isolate (terminate LRI/RLI/FSI)(newer)


