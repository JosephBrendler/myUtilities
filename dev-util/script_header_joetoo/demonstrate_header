# shellcheck disable=SC2329  # function invoked by run_sequence()
_dh_demo_foundation() # (POSIX) demonstrate bool truth validation and unicode registry
{ demo_foundation_ret=0
  _dh_FAILED=$FALSE

  separator "demonstrate_header-${BUILD}" "(foundation)"
    # shellcheck disable=SC2086  # severity level integers as part of option flag should not be quoted
    j_msg -${notice} -p "${BWon}Foundation${Boff}"
    j_msg -${notice} -p "${Con}While highlightinging ${BGon}truth testing${Boff}${Con} for several types of values, this module will demonstrate:${Boff}"
    printf "   "; j_msg -${notice} -m "TrueFalse() - a simple utility to translate types of \"truth\" to a True/False string"
    printf "   "; j_msg -${notice} -m "status_color() - a simple utility to generate G/Y/R/W coloring according to input \"truth\"status"
    printf "   "; j_msg -${notice} -m "j_msg -n and right_status as agents in the announce/act/report-results idiom"
    j_msg -${notice} -p "${Con}While highlighting ${BGon}unicode character registry${Boff}${Con} content and capability, this module will demonstrate:${Boff}"
    printf "   "; j_msg -${notice} -m "separator() for layout, output separation"
    printf "   "; j_msg -${notice} -m "get_longest() and repeat() as agents in fixed width column layout"
    printf "   "; j_msg -${notice} -m "emoji_safe() for dynamic emoji generation and \$bin_emojiname (precooked)"
    printf "   "; j_msg -${notice} -m "ACTIVE_ZERO_WIDTH_- _EMOJI_- and _I_BOX_REGISTRY content"
    printf "   "; j_msg -${notice} -m "use of | od -An -t x1 idiom for unicode binary (hex) byte verification"
    printf "   "; j_msg -${notice} -m "auto-setting of emoji and ascii prefix for j_msg, according to severity"
    printf "   "; j_msg -${notice} -m "use of DEBUG environment variable on cmdline, to override severity for j_msg"
    printf '\n'

  #-----[ section 1 truth testing ]-----------------------------------------------------
  # data format: label|value|expectation (0=True, 1=False, 2=unset)
  _dh_tests="\$TRUE|$TRUE|0 \$FALSE|$FALSE|1 y|y|0 Y|Y|0"
  _dh_tests="${_dh_tests} n|n|1 N|N|1 t|t|0 T|T|0 f|f|1 F|F|1"
  _dh_tests="${_dh_tests}  up|up|0 down|down|1 0|0|0 1|1|2 z|z|2 ''|''|1"

  # preview the command syntax for each of the commands to be run (4 lines, like this)
  # line 1 part 1 - for _dh_t in
  _dh_cmd="${_ctl_color}  for${_Boff} _dh_t${_Boff} ${_ctl_color}in${_Boff} "
  # line 1 part 2 - ${_dh_tests}; do
  _dh_cmd="${_dh_cmd}${_var_color}\${_dh_tests}${_Boff}${_op_color};${_Boff} ${_ctl_color}do${_Boff}"
  printf "\n"; j_msg -${notice} -p "${BYon}About to run:${Boff}\n${_dh_cmd}"
  # line 2 -   _dh_val=$(printf '%s' "${_dh_t}" | cut -d'|' -f2)
  _dh_cmd="       _dh_val${_ctl_color}=\$(${_cmd_color}printf ${_data_color}'%s' "
  _dh_cmd="${_dh_cmd}${_quote_color}\"${_var_color}\${_dh_t}${_quote_color}\"${_op_color}"
  _dh_cmd="${_dh_cmd} | ${_cmd_color}cut ${_data_color}-d${_quote_color}'|'${_data_color}"
  _dh_cmd="${_dh_cmd} -f2${_Boff}${_ctl_color}) ${_Boff}"
  j_msg -${notice} -mp "${_dh_cmd}"
  # line 3 -   _dh_out=$(TrueFalse "${_dh_val}")
  _dh_cmd="       _dh_out${_ctl_color}=\$(${_func_color}TrueFalse ${_quote_color}\""
  _dh_cmd="${_dh_cmd}${_var_color}\${_dh_val}${_quote_color}\"${_Boff}${_ctl_color})${_Boff}"
  j_msg -${notice} -mp "${_dh_cmd}"
  # line 4 -   _dh_status=$?
  _dh_cmd="       _dh_status${_op_color}=${_var_color}\$?${_Boff}"
  j_msg -${notice} -mp "${_dh_cmd}"
  # line 5 -     j_msg -${notice} -np "    ${BWon}testing: [${BCon}${_dh_label}${Boff}${BWon}] is $(status_color "${_dh_val}")${_dh_out}${Boff}"
  _dh_cmd="       ${_func_color}j_msg ${_data_color} -${notice} -np${_quote_color}\"    \${BWon}testing:"
  _dh_cmd="${_dh_cmd} [\${BCon}\${_dh_label}\${Boff}\${BWon}] is "
  _dh_cmd="${_dh_cmd}\$(status_color \"\${_dh_val}\")\${_dh_out}\${Boff}${_quote_color}\"${_Boff}"
  j_msg -${notice} -mp "${_dh_cmd}"
  # line 6 -  [ "$_dh_status" -eq "$_dh_exp" ] ;  right_status $? ||  _dh_FAILED=$TRUE
  _dh_cmd="       ${_op_color}[ ${_quote_color}\"\$_dh_status\"${_Boff}${_data_color}"
  _dh_cmd="${_dh_cmd} -eq ${_quote_color}\"\$_dh_exp\"${_Boff}${_op_color} ] ; ${Boff}"
  _dh_cmd="${_dh_cmd} ${_func_color}right_status ${_var_color}\$?${_Boff}${_op_color}"
  _dh_cmd="${_dh_cmd} || ${_Boff}_dh_FAILED${_op_color}=${_quote_color}\"\$TRUE\"${_Boff}"
  j_msg -${notice} -mp "${_dh_cmd}"
  # line 7 - done
  _dh_cmd="${_ctl_color}    done${_Boff}"
  j_msg -${notice} -mp "${_dh_cmd}"
  printf "\n"

  j_msg -${notice} -m " ${BYon}Summary of T/F tests with ${BGon}status_color${Boff}() and ${BGon}TrueFalse${Boff}() --"

  # logic execution
  for _dh_t in ${_dh_tests}; do
    _dh_label=$(printf '%s' "${_dh_t}" | cut -d'|' -f1)
    _dh_val=$(printf '%s' "${_dh_t}" | cut -d'|' -f2)
    _dh_exp=$(printf '%s' "${_dh_t}" | cut -d'|' -f3)

    # explicit translation of the literal '' placeholder to a true null value
    [ "${_dh_val}" = "''" ] && _dh_val=""
    # get the formatted output
    _dh_out=$(TrueFalse "${_dh_val}")
    # get the exit status from TrueFalse
    _dh_status=$?

    j_msg -${notice} -npm "    ${BWon}testing: [${BCon}${_dh_label}${Boff}${BWon}] is $(status_color "${_dh_val}")${_dh_out}${Boff}"

    # validate that the exit status matches our expectation for this value
    [ "$_dh_status" -eq "$_dh_exp" ] ; right_status $? ${notice} || _dh_FAILED=$TRUE
  done
    # now use demo_foundation_ret as overall bitmask status for this module
    [ "$_dh_FAILED" ] && demo_foundation_ret=1   # bit 0 = truth testing demo failed

  printf "\n"
  j_msg -${notice} -nm ""
  smart_wrap_n 3 3 3 "" "Note: most shells evaluate null ('') as ${BRon}FALSE${Boff} and non-null as ${BGon}TRUE${Boff}"
  printf "\n\n"

  #-----[ section 2 registry examiner ]-----------------------------------------------------
  _dh_FAILED=$FALSE  # reset for section 2
  # preview the command syntax for each of the commands to be run (4 lines, like this)
  # line 1 part 1 - separator "_dh_demo_foundation" "(ACTIVE_ZERO_WIDTH_REGISTRY)"
  _dh_cmd="${_func_color}    separator ${_quote_color}\"_dh_demo_foundation\""
  _dh_cmd="${_dh_cmd} \"(ACTIVE_ZERO_WIDTH_REGISTRY)\"${_Boff}"
  printf "\n"; j_msg -${notice} -p "${BYon}About to run:${Boff}\n${_dh_cmd}"
  # line 2 - _examine_registry "$ACTIVE_ZERO_WIDTH_REGISTRY"
  _dh_cmd="${_func_color}    _examine_registry ${_quote_color}\"ACTIVE_ZERO_WIDTH_REGISTRY\"${_Boff}"
  j_msg -${notice} -mp "${_dh_cmd}"
  # line 3 -  handle_result $? || _dh_FAILED=$TRUE
  _dh_cmd="${_func_color}    handle_result ${_var_color}\$?${_Boff}${_op_color}"
  _dh_cmd="${_dh_cmd} || ${_Boff}_dh_FAILED${_op_color}=${_quote_color}\"\$TRUE\"${_Boff}"
  j_msg -${notice} -mp "${_dh_cmd}"
  # line 4 - separator "_dh_demo_foundation" "(ACTIVE_EMOJI_REGISTRY)"
  _dh_cmd="${_func_color}    separator ${_quote_color}\"_dh_demo_foundation\""
  _dh_cmd="${_dh_cmd} \"(ACTIVE_EMOJI_REGISTRY)\"${_Boff}"
  j_msg -${notice} -mp "${_dh_cmd}"
  # line 5 - _examine_registry "$ACTIVE_EMOJI_REGISTRY"
  _dh_cmd="${_func_color}    _examine_registry ${_quote_color}\"ACTIVE_EMOJI_REGISTRY\"${_Boff}"
  j_msg -${notice} -mp "${_dh_cmd}"
  # line 6 -  handle_result $? || _dh_FAILED=$TRUE
  _dh_cmd="${_func_color}    handle_result ${_var_color}\$?${_Boff}${_op_color}"
  _dh_cmd="${_dh_cmd} || ${_Boff}_dh_FAILED${_op_color}=${_quote_color}\"\$TRUE\"${_Boff}"
  j_msg -${notice} -mp "${_dh_cmd}"
  # line 7 - separator "_dh_demo_foundation" "(ACTIVE_UI_BOX_REGISTRY)"
  _dh_cmd="${_func_color}    separator ${_quote_color}\"_dh_demo_foundation\""
  _dh_cmd="${_dh_cmd} \"(ACTIVE_UI_BOX_REGISTRY)\"${_Boff}"
  j_msg -${notice} -mp "${_dh_cmd}"
  # line 8 - _examine_registry "$ACTIVE_UI_BOX_REGISTRY"
  _dh_cmd="${_func_color}    _examine_registry ${_quote_color}\"ACTIVE_UI_BOX_REGISTRY\"${_Boff}"
  j_msg -${notice} -mp "${_dh_cmd}"
  # line 9 -  handle_result $? || _dh_FAILED=$TRUE
  _dh_cmd="${_func_color}    handle_result ${_var_color}\$?${_Boff}${_op_color}"
  _dh_cmd="${_dh_cmd} || ${_Boff}_dh_FAILED${_op_color}=${_quote_color}\"\$TRUE\"${_Boff}"
  j_msg -${notice} -mp "${_dh_cmd}\n"

  printf " $bin_uSNOW "; j_msg -mp "Starging registry examination ..."
  separator "_dh_demo_foundation" "(ACTIVE_ZERO_WIDTH_REGISTRY)"
  _examine_registry "$ACTIVE_ZERO_WIDTH_REGISTRY"
  j_msg -${notice} -nmp  "done; result: "
  handle_result $? || _dh_FAILED=$TRUE
  separator "_dh_demo_foundation" "(ACTIVE_EMOJI_REGISTRY)"
  _examine_registry "$ACTIVE_EMOJI_REGISTRY"
  j_msg -${notice} -nmp  "done; result: "
  handle_result $? || _dh_FAILED=$TRUE
  separator "_dh_demo_foundation" "(ACTIVE_UI_BOX_REGISTRY)"
  _examine_registry "$ACTIVE_UI_BOX_REGISTRY"
  j_msg -${notice} -nmp  "done; result: "
  handle_result $? || _dh_FAILED=$TRUE

  _dh_cmt="${BYon}Note: ${_Boff}use e.g. ${_cmd_color}printf ${_quote_color}\""
  _dh_cmt="${_dh_cmt}\$bin_hammer\" ${_Boff}to print a precooked emoji\n"
  _dh_cmt="${_dh_cmt}in either case, pipe output to ${_Boff}"
  _dh_cmt="${_dh_cmt}${_op_color}| ${_cmd_color}od ${_data_color}"
  _dh_cmt="${_dh_cmt}-An -t x1 ${_Boff} to see its hex bytes"
  j_msg -${notice} -mp "${_dh_cmt}"

  # update overall status for this module
  [ "$_dh_FAILED" ] && demo_foundation_ret=$((demo_foundation_ret | 2 ))   # bit 1 = registry demo failed

  separator "$PN" "(severity levels)"
  #-----[ section 2b  ]-----------------------------------------------------
  _dh_FAILED=$FALSE  # reset for section 2b
  # preview the command syntax for each of the commands to be run (4 lines, like this)
  # line 1 - for _SEVERITY in $(seq 0 7); do
  _dh_cmd="${_ctl_color}for${_Boff} _SEVERITY ${_ctl_color}in ${_op_color}\$("
  _dh_cmd="${_dh_cmd}${_cmd_color}seq ${_data_color}0 7${_Boff}${_op_color});"
  _dh_cmd="${_dh_cmd} ${_ctl_color}do${_Boff}"
  printf "\n"; j_msg -${notice} -p "${BYon}About to run:${Boff}\n${_dh_cmd}"
  # line 2 - case "$_SEVERITY" in
  _dh_cmd="${_ctl_color}    case${_Boff} _SEVERITY ${_ctl_color}in${_Boff}"
  j_msg -${notice} -mp "${_dh_cmd}"
  # line 3 - 0|1)   premoji_idx="$idx_severity_01_emoji" ;;  # Emerg, Alert ,...... cross_mark
  _dh_cmd="        0${_op_color}|${_Boff}1${_ctl_color}) ${_Boff}premoji_idx"
  _dh_cmd="${_dh_cmd}${_ctl_color}=${_quote_color}\"${_var_color}"
  _dh_cmd="${_dh_cmd}\$idx_severity_01_emoji${_quote_color}\" ${_ctl_color};;"
