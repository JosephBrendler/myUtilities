initialize_command_sequence() # (POSIX) initialize command sequence for joetoo cli framework
{ ics_ret=0
  _ics_FLAGGED=$FALSE
  j_msg -${info} -n -m "creating tempfile for command sequnce"
  cmd_seq_file=$(mktemp /tmp/${PN}.XXXXXX)
  handle_result $? "$cmd_seq_file" '' "$info" || _ics_FLAGGED=$TRUE

  j_msg -${info} -n -p "setting trap to remove tempfile on EXIT"
  trap 'rm -f "$cmd_seq_file"' EXIT
  handle_result $? "trap set" '' "$info" || _ics_FLAGGED=$TRUE

  j_msg -n -p "initializing command sequence"
  num_cmds=0   # global variable holding the length of the sequence
# heredoc needs to be on the left edge; no leading whitespace
# initialize/clear the command sequence file
# format for each line of heredoc content is:
#   command_string${US}description_string
#   where: command_string is POSIX executable
#   and:   ${US} is teletype era unit separator char \037 pre-cooked with printf
#   and:   description_string is a human-readable description of the command
while IFS= read -r _ics_entry; do
      [ -z "$_ics_entry" ] && continue
      # write directly to the file instead of using  ' set -- "$@" '
      printf '%s\n' "$_ics_entry" >> "$cmd_seq_file"
      num_cmds=$(( num_cmds + 1 ))
done <<EOF
_dh_show_capabilities || dh_final_status=$(( dh_final_status | ( 1 << 0 ) ))${US}show capabilities
_dh_demo_foundation   || dh_final_status=$(( dh_final_status | ( 1 << 1 ) ))${US}demonstrate the foundation
_dh_demo_corelogic    || dh_final_status=$(( dh_final_status | ( 1 << 2 ) ))${US}demonstrate the core logic functions
_dh_demo_ui_layout    || dh_final_status=$(( dh_final_status | ( 1 << 3 ) ))${US}demonstrate UI / Layout
_dh_demo_msg_log      || dh_final_status=$(( dh_final_status | ( 1 << 4 ) ))${US}demonstrate messaging / logging
_dh_demo_cli          || dh_final_status=$(( dh_final_status | ( 1 << 5 ) ))${US}demonstrate the command line interface
summarize_results${US}summarize results
EOF
  handle_result $? "num_cmds: $num_cmds" '' || _ics_FLAGGED=$TRUE

  j_msg -${info} -n -m "initailizing starting_step"
  starting_step=1
  handle_result $? "$starting_step" '' $info || _ics_FLAGGED=$TRUE

  j_msg -${info} -n -m "initializing stopping step"
  stopping_step="$num_cmds"
  handle_result $? "$stopping_step" '' $info || _ics_FLAGGED=$TRUE

  [ "$_ics_FLAGGED" ] && ics_ret=1
  export num_cmds
  export cmd_seq_file
  unset -v _ics_entry _ics_FLAGGED _ics_result
  return $ics_ret
}
