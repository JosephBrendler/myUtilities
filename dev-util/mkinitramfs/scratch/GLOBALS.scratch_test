#!/bin/sh
# assign Global variables
# Note: does not (yet) support cross-compile
# BUILD is now generated by make_sources.sh using KERNEL_VERSION made available here
#
# verify that kernel sources are installed at /usr/src/linux -- and get KERNEL_VERSION
kernel_sources_dir=/usr/src/linux
if [ -L "${kernel_sources_dir}" ] || [ -d "${kernel_sources_dir}" ]; then
  # get kernel version number w/o leaving current directory
  # (silence possible complaint from dist-kernel about - make should not be run manually here)
  KERNEL_VERSION=$(make -s -C "${kernel_sources_dir}" kernelversion 2>/dev/null)
else
  # cannot use E_message yet - script_header_joetoo cannot load until located by assignments below
  die "Could not find kernel sources. Did you emerge (e.g.) sys-kernel/gentoo-kernel ?"
fi
# fall back to reading Makefile with sed, if make fails
if [ -z "${KERNEL_VERSION}" ]; then
  if [ -f "${kernel_sources_dir}/Makefile" ]; then
    KERNEL_VERSION=$(
      # use sed substitution to pull parts for version string from Makefile
      #  -n : only print lines that match
      #  -E : use extended regex for grouping () and OR w | w/o \ escapes
      # s/ starts the subtitution. pattern is ^ BOL followed by first capture group (version parts)
      #   followed by space = space
      #   followed by second capture group ( any char followed by anything )
      # /\2/ (the substitution) means keep only capture group 2
      # p tells sed to print the result only if a successful substitution happened
      # the result will be newline separated output like 6<NL>18<NL>18<NL>
      sed -n -E 's/^(VERSION|PATCHLEVEL|SUBLEVEL|EXTRAVERSION) = (.*)/\2/p' \
        "${kernel_sources_dir}/Makefile" |
      # pipe that output to this command grouping to read, assemble, and render on stdout
      { read -r _v; read -r _p; read -r _s; read -r _e
          # assemble the string -- VERSION.PATCHLEVEL.SUBLEVEL + EXTRAVERSION
          # note: EXTRAVERSION usually includes a leading hyphen (e.g., -gentoo)
          printf '%s.%s.%s%s\n' "$_v" "$_p" "$_s" "$_e"
      }
    )
  else
    die "KERNEL_VERSION is empty and ${kernel_sources_dir}/Makefile is missing"
  fi   # Makefile exists?
fi  # KERNEL_VERSION still empty?

# Now assign the rest of the global variables
DATE_STAMP="$(date +%Y%m%d%H%M)"
#SOURCES_DIR="/usr/src/initramfs"
SOURCES_DIR="/home/joe/myUtilities/dev-util/mkinitramfs/scratch/initramfs"
SCRIPT_HEADER_DIR="/usr/sbin"
#MAKE_DIR=$(pwd)
MAKE_DIR="/home/joe/myUtilities/dev-util/mkinitramfs"
